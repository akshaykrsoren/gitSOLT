</style>
<link href="https://fonts.googleapis.com/css2?family=Mulish:ital,wght@0,200..1000;1,200..1000&display=swap" rel="stylesheet">

<div class="modal fade" id="ServiceType_Add_Modal" tabindex="-1" role="dialog" aria-labelledby="myModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-sm" style="margin-top: 10%;">
        <div class="modal-content custompopupModal">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                <h4 class="modal-title" id="gridSystemModalLabel">Add New Service Type</h4>
            </div>

            <div class="modal-body">
                <div class="form-group">
                    <label class="popuplabel">Speciality Type Name</label>
                    <span style="color:red;">*</span>
                    @Html.TextBoxFor(model => model.ServiceName, new { @type = "text", @maxlength = "100", @placeholder = "Enter Speciality Type", @class = "form-control" })
                    @Html.ValidationMessageFor(model => model.ServiceName)
                </div>
                <div class="form-group">
                    <label class="popuplabel">Description (Optional)</label>
                    @Html.TextBoxFor(model => model.Description, new { @type = "text", @maxlength = "200", @class = "form-control", style = "height: 60px;border-radius:5px" })

                </div>

                <div class="d-flex gap-2" style="float:right;margin-top:30px">
                    <button class="btn btn-outline-dark BatchSchudelbtn" style="margin-right: 10px;" onclick="Closepopup()">Cancel</button>
                    <button type="button" onclick="AddServices('Add')" class="btn  btn-primary " style="border-radius:5px;padding: 6px 20px 6px 22px;">Save</button>
                </div>
                @*<button type="submit" class="btn btn-sm btn-primary pull-right" style="text-transform: capitalize">Save</button>*@

                <div class="clearfix"></div>
            </div>

        </div>
    </div>
</div>

