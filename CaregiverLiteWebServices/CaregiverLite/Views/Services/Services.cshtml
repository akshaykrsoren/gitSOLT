        font-size: 14px;
    }

    thead th {
        position: sticky;
        top: 0;
        z-index: 2;
        color: #1B4066;
        font-family: Mulish;
        font-size: 14px;
        font-style: normal;
        font-weight: 700;
        background-color: #f3f9ff !important;
    }

    tbody tr:nth-child(odd) {
        background-color: #F8F8F8; /* Odd rows */
