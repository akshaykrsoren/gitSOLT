    .HDR {
        color: #1B1B1C;
        font-family: Mulish;
        font-size: 18px;
        font-style: normal;
        font-weight: 800;
        line-height: normal;
    }

    .BatchSchudelbtn {
        background-color: white;
        color: #092C44;
        border: 1px solid #1F305B;
        border-radius: 6px;
        font-size: 14px;
        font-weight: 600;
        line-height: 25px;
        right: 0px;
    }

    .popuplabel {
        font-family: Mulish;
        font-size: 13px;
        font-style: normal;
        font-weight: 600;
        line-height: normal;
    }

    input {
        border-radius: 5px !important;
    }

    .custompopupModal {
        width: 360px !important;
        height: 328px;
    }

    .confirmbtn {
        background-color: #FFDEDE;
        color: #E24B4B;
        border: 1px solid;
        border-radius: 4px;
        height: 40px;
        font-weight: bold;
    }

        .confirmbtn:hover {
            background-color: #ebd2d2;
        }

    .cancelbtn {
        background-color: #D4FFE8;
        color: #239450;
        border: 1px solid;
        border-radius: 4px;
        height: 40px;
        font-weight: bold;
