    }

    .table-container {
        /*height: 300px;
        overflow-y: auto;
        border: 1px solid #ddd;*/
    }

    table {
        width: 100%;
        border-collapse: collapse; /* Ensures proper border alignment */
    }

    th {
        padding: 12px 0px 12px 12px;
        border: 1px solid #D4E9FF; /* This adds a border between columns */
        text-align: left;
    }

    td {
        padding: 20px 0px 20px 30px !important;
        border-left: 1px solid #D4E9FF; /* Left border */
        border-right: 1px solid #D4E9FF; /* Right border */
