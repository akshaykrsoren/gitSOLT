<script>
    $(document).ready(function () {
        $('#specialityTypeDiv').css("display", "block");
        $('#visitTypeDiv').css("display", "none");

        $('#tab1234 li').click(function () {
            $('#tab1234 li').removeClass("activeDiv");

            var clickedId = $(this).attr("id");

            debugger;
            if (clickedId == "visitType") {
                $('#visitTypeDiv').css("display", "block");
                $('#specialityTypeDiv').css("display", "none")
            } else {
                $('#visitTypeDiv').css("display", "none");
                $('#specialityTypeDiv').css("display", "block")
            }
            $(this).addClass("activeDiv")
        })
    });


    function OpenService_AddPopup(ServiceId, ServiceName) {
        $('#loading').show();
        $('#ServiceType_Add_Modal').modal('show');
        $('#loading').hide();
    }
    function OpenEdit_ServicePopup(ServiceId, ServiceName,Description) {
        debugger;
        $('#loading').show();
        $("#hdntxtServiceId").val(ServiceId);
        $("#txtEditServiceName").val(ServiceName);
        $("#ServiceName").val(ServiceName);
        $("#txtServiceDescription").val(Description);

        $('#ServiceType_Edit_Modal').modal('show');
        $('#loading').hide();
    }

    function OpenVisitTypeAddPopup(ServiceId, ServiceName) {
        $('#loading').show();
        $('#VisitType_Add_Modal').modal('show');
        $('#loading').hide();
    }
    function OpenEdit_VisitPopup(VisitTypeId, VisitTypeName,Description) {
        $('#loading').show();
        $("#hdntxtVisitTypeId").val(VisitTypeId);
        $("#txtVisitTypeName").val(VisitTypeName);
        $("#VisitTypeName").val(VisitTypeName);

        $("#txtEditVisitDescription").val(Description);
        $('#VisitType_Edit_Modal').modal('show');
        $('#loading').hide();
    }
    function Closepopup()
    {
        $('#ServiceType_Add_Modal').modal('hide');
        $('#ServiceType_Edit_Modal').modal('hide');
        $('#VisitType_Add_Modal').modal('hide');
        $('#VisitType_Edit_Modal').modal('hide');
    }

    function AddServices(txtlabel) {
        debugger;

        var ServiceNameValue = $("#ServiceName").val();
        var ServiceDescription = $("#Description").val();
        var ServiceId = $("#hdntxtServiceId").val();
        if (ServiceId) {
            ServiceNameValue = $("#txtEditServiceName").val();
            ServiceDescription = $("#txtServiceDescription").val();

        } else {
            ServiceId = 0;
        }
        if (ServiceNameValue == "") {
            toastr.error('Please enter service type');
            $('#loading').hide();
            return false;
        } else {
            $('#loading').show();
            $.ajax({
                url: INITURL + "/Services/UpdateService",
                data: { ServiceId: ServiceId, ServiceName: ServiceNameValue, Description: ServiceDescription },
                cache: false,
                type: "POST",
                success: function (data, result) {

                    if (result === 'success') {

                        if (txtlabel=="Add")
                        {
                            toastr.success(ServiceNameValue + " added successfully");
                           // alert(ServiceNameValue + " added successfully");
                        } else {
                            toastr.success(ServiceNameValue + " updated successfully");
                           // alert(ServiceNameValue + " updated successfully");
                       }
					     $('#ServiceType_Add_Modal').modal('hide');
                          $('#ServiceType_Edit_Modal').modal('hide');
                        setTimeout(function () {
                            window.location = INITURL + "Services/Services"
                        }, 2000);
                        $('#loading').hide();
                    } else {
                        $('#loading').hide();
                    }
                },
                error: function (reponse) {
                    $('#loading').hide();
                }
            });
        }
    }



    $('.cancelbtn').click(function () {

        debugger
        $('#Delete_Modal').modal('hide');
        // $('#ConfirmationModel').modal('hide');  // Hide the confirmation modal
    });

    $('.confirmbtn').click(function () {
        $('#Delete_Modal').modal('hide');
        debugger
        if (tempServiceId) {
            if (ServiceType == "Service") {
                DeleteService(tempServiceId, tempServiceName);
            } else {
                DeleteVisitService(tempServiceId, tempServiceName);

            }
        }

    });

    var tempServiceId = "";
    var tempServiceName = "";
    var ServiceType = "";

    function ConfirmDelete(id, ServiceName, ptype) {
        debugger
        tempServiceId = id;
        tempServiceName = ServiceName;
        ServiceType = ptype;
        if (ptype == "Service") {
            $('#DeleteLabel').text('Are you sure you want to delete this Speciality Type ?');
        } else {
            $('#DeleteLabel').text('Are you sure you want to delete this Visit Type ?');
        }

        $('#Delete_Modal').modal('show');
    }
    function DeleteService(id, ServiceName) {
        //if (confirm("Are you sure you want to delete " + ServiceName + "?"))
        //{
            $('#loading').show();
            $.ajax({
                url: INITURL + "/Services/DeleteService",
                data: { ServiceId: id },
                cache: false,
                type: "POST",
                success: function (data) {

                    if (data == "1") {
                        toastr.success(ServiceName + " deleted successfully");
                       // alert(ServiceName + " deleted successfully");

                        setTimeout(function () {
                            window.location = INITURL + "Services/Services"
                        }, 3000);
                    }
                    else {
                        toastr.error(ServiceName + " is in other use. You can not delete it.")
                    }
                    $('#loading').hide();
                },
                error: function (reponse) {
                    $('#loading').hide();
                }
            });
       // }
    }


    function AddVisitType(txtlabel) {

        debugger;
        var VisitDescription = $("#txtAddVisitTypeDescription").val();
        var VisitTypeNameValue = $("#VisitTypeName").val();
        var VisitTypeId = $("#hdntxtVisitTypeId").val();
        if (VisitTypeId) {

            VisitTypeNameValue = $("#txtVisitTypeName").val();
            VisitDescription = $("#txtEditVisitDescription").val();

        } else {
            VisitTypeId = 0;
        }
        if (VisitTypeNameValue == "") {
            debugger;
            toastr.error('Please enter Visit type');
            $('#loading').hide();
            return false;
        } else {
            $('#loading').show();
            $.ajax({
                url: INITURL + "/VisitType/UpdateVisitType",
                data: { VisitTypeName: VisitTypeNameValue },
                data: { VisitTypeId: VisitTypeId, VisitTypeName: VisitTypeNameValue, Description: VisitDescription },
                cache: false,
                type: "POST",
                success: function (data, result) {

