<script type="text/javascript">


    var tempMsg = '';
    if (tempMsg != "") {
        toastr.success(tempMsg);
    }






    // Exporting data from database in Excel

    function ExportTable() {
        $(".loading").show();
        var url = 'http://ec2-52-38-33-252.us-west-2.compute.amazonaws.com/CaregiverLiteWebDemo/AttendanceManagement/ExportDataSetToExcel';
        $.ajax({
            url: url,
            type: "POST",
            // data: { strOfficeId: $("#ddFilterOffice").val() },

            success: function (res) {
                $(".loading").hide();
                //alert(res);
                if (res) {
                    var filename = res;
                    var iframe = document.createElement("iframe");
                    iframe.src = filename;
                    iframe.style.display = 'none';
                    document.body.appendChild(iframe);
                    toastr.success("successfully export.");

                }
                else {
                    toastr.warning("Not Exported Try again");
                }
            },
            error: function (reponse) {
                //alert("error : " + JSON.stringify(reponse));
                $(".loading").hide();
            }
        });
    }


    // Print Function

    function printDiv() {
        var printContents = document.getElementById("myDataTable_wrapper").innerHTML;
        var originalContents = document.body.innerHTML;
        document.body.innerHTML = printContents;

        window.print();
        document.body.innerHTML = originalContents;
    }


    var interval;

    //View Checkin-checkout caregiver Start
    function ViewOnMap(Latitude, Longitude, DrivingStopLatitude, DrivingStopLongitude, PatientRequestId) {
        interval = setInterval(function () {
            //ViewOnMap1(Latitude, Longitude, DrivingStopLatitude, DrivingStopLongitude);
            LoadTrackLocationMap(PatientRequestId)
        }, 10000);


    }

    function LoadTrackLocationMap(PatientRequestId) {
        $('#myModalCheckInCheckOutLocation').modal('show');

        $.ajax({
            url: "@Url.Action("TrackLocationByPatientRequestId", "AttendanceManagement")",
            data: { PatientRequestId: PatientRequestId },
            cache: false,
            dataType: 'json',
            type: 'POST',
            success: function (data, response) {

                //   if(data == )
                if (data.Result.length > 0) {
                    //console.log(JSON.stringify(data));

                    //var TotalMiles = data.Result[0].TotalMiles;
                    //  $('#tmiles').val(TotalMiles);
                    // $('#tmiles').html(TotalMiles).show();
                    var trackedLocations = data.Result;
                    TrackLocationMap(trackedLocations);
                    //marker.setVisible(false);
                }
                else {

                    //$('#nolocation').html('No Location Available').show();
                }

            },

            error: function (xhr, response) {
                console.log(xhr, response);

                $('#loading').hide();
            }

        });


        $("#loading").hide();

    }


    function TrackLocationMap(trackedLocations) {
        setTimeout(function () {
            var gm = google.maps;
            var infowindow;
            var iw = new gm.InfoWindow();

            //console.log(trackedLocations);
            if (trackedLocations != null && trackedLocations.length > 0) {

                var icon = 'https://scheduler.paseva.com/image/Red_50x50.png';

                var img = new Image();
                //img.bluepin = "https://scheduler.paseva.com/CaregiverLiteMobileService/Images/CareGiverProfileImages/blue-dot.png";
                //img.greenpin = "https://scheduler.paseva.com/CaregiverLiteMobileService/Images/CareGiverProfileImages/green-dot.png";
                // img.redpin = "https://scheduler.paseva.com/CaregiverLiteMobileService/Images/CareGiverProfileImages/red-dot.png";
                var bounds = new google.maps.LatLngBounds();
                var mapCenter = {
                    lat: parseFloat(trackedLocations[0].LocationLatitude),
                    lng: parseFloat(trackedLocations[0].LocationLongitude)
                }

                var map = new google.maps.Map(document.getElementById('mapLocation'),
                 {
                     center: mapCenter,
                     zoom: 16,
                     mapTypeId: google.maps.MapTypeId.ROADMAP
                 });

                // when only one marker
                if (trackedLocations.length == 1) {


                    var centerinfowindow = new google.maps.InfoWindow();
                    var centermarker = new google.maps.Marker({
                        position: mapCenter,                       
                        map: map

                    });
                    //centermarker.setIcon(img.redpin)


                    var centercontent =
                        '<div><strong>Date: </strong>' +
                            trackedLocations[0].LocationDateTime +
                            '</div>' +
                            '<div><strong>Latitude: </strong>' +
                            trackedLocations[0].LocationLatitude.substr(0, trackedLocations[0].LocationLatitude.indexOf(".") + 7) +
                            '</div>' +
                            '<div><strong>Longitude: </strong>' +
                            trackedLocations[0].LocationLongitude.substr(0, trackedLocations[0].LocationLongitude.indexOf(".") + 7) +
                            '</div>' +
                            '<div><strong>Status: </strong>' +
                            trackedLocations[0].Status +
                            '</div>' +
                                '<div>' +
                                    '<a class="btn btn-xs btn-primary" style="margin-top:5px;" href="javascript:;" onclick="seeAddress(this,' + trackedLocations[0].LocationLatitude + ',' + trackedLocations[0].LocationLongitude + ')">See Address</a>'
                    '</div>';



                    google.maps.event.addListener(centermarker,
                        'click',
                        (function (centermarker, centercontent, centerinfowindow) {
                            return function () {
                                centerinfowindow.setContent(centercontent);
                                centerinfowindow.open(map, centermarker);
                            }; 
                        })(centermarker, centercontent, centerinfowindow));
                    
                }
                for (var i = 0; i < trackedLocations.length - 1; i++) {
                    if ((i + 1) < trackedLocations.length - 1) {

                        var service = new google.maps.DirectionsService();
                        var directionsDisplay = new google.maps.DirectionsRenderer();

                        //   var bounds = new google.maps.LatLngBounds();

                        var src = new google.maps.LatLng(
                            parseFloat(trackedLocations[i].LocationLatitude),
                            parseFloat(trackedLocations[i].LocationLongitude)
                        );
                        var des = new google.maps.LatLng(
                            parseFloat(trackedLocations[i + 1].LocationLatitude),
                            parseFloat(trackedLocations[i + 1].LocationLongitude)
                        );




                        var polyLine = new google.maps.Polyline({
                            path: [src, des],
                            strokeColor: '#0000FF',
                            strokeOpacity: 1.0,
                            strokeWeight: 5,
                            map: map
                        });

                        var content =
                            '<div><strong>Date: </strong>' +
                                trackedLocations[i].LocationDateTime +
                                '</div>' +
                                '<div><strong>Latitude: </strong>' +
                                trackedLocations[i].LocationLatitude.substr(0, trackedLocations[i].LocationLatitude.indexOf(".") + 7) +
                                '</div>' +
                                '<div><strong>Longitude: </strong>' +
                                trackedLocations[i].LocationLongitude.substr(0, trackedLocations[i].LocationLongitude.indexOf(".") + 7) +
                                '</div>' +
                                '<div><strong>Status: </strong>' +
                                trackedLocations[i].Status +
                                '</div>' +
                                '<div>' +
                                    '<a class="btn btn-xs btn-primary" style="margin-top:5px;" href="javascript:;" onclick="seeAddress(this,' + trackedLocations[i].LocationLatitude + ',' + trackedLocations[i].LocationLongitude + ')">See Address</a>'
                        '</div>';

                        var infowindow = new google.maps.InfoWindow();

                        var marker = new google.maps.Marker({
                            position: src,
                            label: { text: 'S', color: 'white' },
                            map: map
                        });
                        bounds.extend(marker.position);

                        google.maps.event.addListener(marker,
                            'click',
                            (function (marker, content, infowindow) {
                                return function () {
                                    infowindow.setContent(content);
                                    infowindow.open(map, marker);                                    
                                };                               
                            })(marker, content, infowindow));

                        // marker.setIcon(img.redpin)
                        marker.setVisible(false);


                        map.fitBounds(bounds);


                        if (i === 0) {
                            marker.setIcon(img.bluepin)
                            // marker.setAnimation(google.maps.Animation.BOUNCE);
                            marker.setVisible(true);
                        }

                        //set marker for last location
                        if ((i + 2) === trackedLocations.length - 1) {
                            var infowindowDes = new google.maps.InfoWindow();

                            var markerDes = new google.maps.Marker({
                                position: des,
                                //label: { text: 'E', color: 'white' },                                
                                //strokeColor: "green",
                                icon: icon,
                                map: map                                
                               // labelClass: "labels", // the CSS class for the label
                               // labelInBackground: false,


                            });
                            
                            //markerDes.setAnimation(google.maps.Animation.BOUNCE);
                            markerDes.setIcon(icon)

                            // markerDes.setIcon(img.redpin)


                            bounds.extend(markerDes.position);
                            var contentDes =
                                '<div><strong>Date: </strong>' +
                                    trackedLocations[i + 1].LocationDateTime +
                                    '</div>' +
                                    '<div><strong>Latitude: </strong>' +
                                    trackedLocations[i + 1].LocationLatitude.substr(0, trackedLocations[i + 1].LocationLatitude.indexOf(".") + 7) +
                                    '</div>' +
                                    '<div><strong>Longitude: </strong>' +
                                    trackedLocations[i + 1].LocationLongitude.substr(0, trackedLocations[i + 1].LocationLongitude.indexOf(".") + 7) +
                                    '</div>' +
                                    '<div><strong>Status: </strong>' +
                                    trackedLocations[i + 1].Status +
                                    '</div>' +
                                '<div>' +
                                    '<a class="btn btn-xs btn-primary" style="margin-top:5px;" href="javascript:;" onclick="seeAddress(this,' + trackedLocations[i + 1].LocationLatitude + ',' + trackedLocations[i + 1].LocationLongitude + ')">See Address</a>'
                            '</div>';

                            google.maps.event.addListener(markerDes,
                                'click',
                                (function (markerDes, contentDes, infowindowDes) {
                                    return function () {
                                        infowindowDes.setContent(contentDes);
                                        infowindowDes.open(map, markerDes);
                                        //markerDes.setVisible(false);
                                    }; //markerDes.setVisible(false);
                                })(markerDes, contentDes, infowindowDes));
                            // markerDes.setVisible(false);

                            map.fitBounds(bounds);
                        }

                    }
                }



            }
        }, 500);
    }



    // See Address

    function seeAddress(that, lat, long) {
        $.ajax({
            url: "https://maps.googleapis.com/maps/api/geocode/json?latlng= " + lat + "," + long + "&sensor=true",
            type: "GET",
            async: false,
            success: function (data) {
                $(that).parent().html("<strong>Address: </strong>" + data.results[0].formatted_address);
            },
            error: function (xhr, ajaxOptions, thrownError) {
                console.log(xhr.status);
            }
        });
    }








    function clearMapCheckInOut() {
        document.getElementById("mapLocation").innerHTML = "";
        clearInterval(interval);


    }
    //View Checkin-checkout caregiver End



</script>