<script>
    $(document).ready(function () {
        $('#myDataTable').dataTable({
            "order": [[2, 'desc']]
        });
    });
    function EditAdmin(PatientRequestID) {
        $("#loading").show();
        $('#EditPanel').load(INITURL + '/AttendanceManagement/AttendanceDetail/?PatientRequestID=' + PatientRequestID, function () {
            sessionStorage.setItem("PartialView", "1");
            $('#myModal2').modal('show');
            $("#loading").hide();
        });
    }

</script>
