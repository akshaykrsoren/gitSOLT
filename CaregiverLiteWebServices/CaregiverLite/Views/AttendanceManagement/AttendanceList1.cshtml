                    <div id="myDataTable_wrapper" class="dataTables_wrapper form-inline no-footer">
                        <div id="myDataTable_processing" class="dataTables_processing" style="display: none;">
                            <div class="loading" id="loading" style="display: block;">
                            </div>
                        </div>
                        @if (Model != null)
                        {
                            if (Model.AttendanceManagementInfo.Count > 0)
                            {
                                <table id="myDataTable" class="table table-striped table-bordered table-hover dataTables-example dataTable no-footer dtr-column" role="grid" aria-describedby="myDataTable_info" style="width: 1035px;">
                                    <thead>
                                        <tr role="row">
                                            <th class="sorting" tabindex="0" aria-controls="myDataTable" rowspan="1" colspan="1" aria-label="Last Name: activate to sort column ascending" style="width: 122px;">Nurse</th>
                                            <th class="sorting" tabindex="0" aria-controls="myDataTable" rowspan="1" colspan="1" aria-label="Start Date: activate to sort column ascending" style="width: 162px;">Patient</th>
                                            <th class="sorting" tabindex="0" aria-controls="myDataTable" rowspan="1" colspan="1" aria-label="Last Name: activate to sort column ascending" style="width: 122px;">Date</th>
                                            <th class="sorting" tabindex="0" aria-controls="myDataTable" rowspan="1" colspan="1" aria-label="Start Date: activate to sort column ascending" style="width: 162px;">Start Time</th>
                                            <th class="sorting" tabindex="0" aria-controls="myDataTable" rowspan="1" colspan="1" aria-label="End Date: activate to sort column ascending" style="width: 162px;">End Time</th>
                                            <th class="sorting" tabindex="0" aria-controls="myDataTable" rowspan="1" colspan="1" aria-label="End Date: activate to sort column ascending" style="width: 162px;">Requested Duration</th>
                                            <th class="sorting" tabindex="0" aria-controls="myDataTable" rowspan="1" colspan="1" aria-label="End Date: activate to sort column ascending" style="width: 162px;">Actual Duration</th>
                                            <th style="width: 99px;" class="sorting_disabled" rowspan="1" colspan="1" aria-label="Action">Action</th>
                                            @*<th>Nurse Current Location</th>*@
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var item in Model.AttendanceManagementInfo)
                                        {
                                            <tr role="row" class="odd">
                                                <td>@item.Name</td>
                                                <td>@item.PatientName</td>
                                                <td>@(String.Format("{0:d/MMM/yyyy}", item.Date))</td>
                                                <td>@(Convert.ToDateTime(item.FromTime).ToString("hh:mm tt"))</td>
                                                <td>@(Convert.ToDateTime(item.ToTime).ToString("hh:mm tt"))</td>
                                                <td>@(Convert.ToDateTime((Convert.ToDateTime(item.ToTime) - Convert.ToDateTime(item.FromTime)).ToString()).ToString("hh")) hrs @(Convert.ToDateTime((Convert.ToDateTime(item.ToTime) - Convert.ToDateTime(item.FromTime)).ToString()).ToString("mm")) mins</td>
                                                <td>
                                                    @{
                                                        string CheckInTotalTimeFinal = string.Empty;

                                                        if (item.CheckInTotalTime != "")
                                                        {
                                                            string[] CheckInTotalTimeSplit = item.CheckInTotalTime.Split(':');
                                                            if (CheckInTotalTimeSplit[0] != "00")
                                                            {
                                                                CheckInTotalTimeFinal = CheckInTotalTimeFinal + CheckInTotalTimeSplit[0] + " hrs ";
                                                            }

                                                            if (CheckInTotalTimeSplit[1] != "")
                                                            {
                                                                CheckInTotalTimeFinal = CheckInTotalTimeFinal + CheckInTotalTimeSplit[1] + " mins";
                                                            }

                                                        }
                                                        else if (item.CheckInTotalTime == "")
                                                        {
                                                            CheckInTotalTimeFinal = "NA";
                                                        }

                                                        @(CheckInTotalTimeFinal)
                                                    }
                                                </td>
                                                <td>
                                                    <a href="javascript:;" class="btn btn-xs btn-primary" style="margin-top:5px; width:100%; border-radius: 11px;" onclick="EditAdmin('@item.PatientRequestId');">Detail</a>
                                                </td>
                                                 @*<td>
                                                    <a id="" class="btn btn-xs btn-primary" style="margin-top:5px; width:97%; border-radius: 11px;" onclick="ViewOnMap('@item.Latitude','@item.Longitude','@item.DrivingStopLatitude','@item.DrivingStopLongitude', '@item.PatientRequestId');">Test Client Map</a>
                                                </td>*@
                                            </tr>
                                                        }

                                    </tbody>
                                </table>
                                                        }
                                                        else
                                                        {
                                                            <b>No Details Found.</b>
                                                            }
                                                        }
                    </div>




                    <!-- Caregiver Check-In And Check-Out Location On Map START -->
                    <div class="modal fade" id="myModalCheckInCheckOutLocation" tabindex="-1" role="dialog" aria-labelledby="myModalLabel" aria-hidden="true">
                        <div class="modal-dialog modal-lg">
