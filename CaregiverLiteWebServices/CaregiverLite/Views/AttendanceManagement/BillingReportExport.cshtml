</style>


<script>
    $(function () {
        var dateFormat = "mm/dd/yy",
          from = $("#FromDate")
            .datepicker({
                defaultDate: "+1w",
                changeMonth: true,
                numberOfMonths: 1,
                maxDate: new Date()

            })
            .on("change", function () {
                //toMinDate.setDate(toMinDate.getDate() - 365);
                to.datepicker("option", "minDate", getDate(this));
            }),
          to = $("#ToDate").datepicker({
              defaultDate: "+1w",
              changeMonth: true,
              numberOfMonths: 1,
              maxDate: new Date(),
              minDate: $("#FromDate").val()

          })
          .on("change", function () {
              // var fromMaxDate = $("#FromDate").val();
              //fromMaxDate.setDate(fromMaxDate.getDate() - 1);
              to.datepicker("option", "minDate", getDate(this));
          });

        function getDate(element) {
            var date;
            try {
                date = $.datepicker.parseDate(dateFormat, element.value);
            } catch (error) {
                date = null;
            }

            return date;
        }

        //$(function () {
        //var ddlCustomers = $("#ddlOffices");
        //ddlCustomers.empty().append('<option selected="selected" value="0" disabled = "disabled">Loading.....</option>');
        var optionsContainer = $("#optionsContainer");
        optionsContainer.append(`<label><input type="checkbox" value="0" /> All </label>`);
        $.ajax({
            type: "POST",
            url: "/AttendanceManagement/ListOffices",
            data: '{}',
            contentType: "application/json; charset=utf-8",
            dataType: "json",
            success: function (response) {
                optionsContainer.empty(); // Clear loading

                // ✅ Append "All" checkbox first
                optionsContainer.append(`
            <label>
                <input type="checkbox" value="0" onchange="toggleAll(this)" /> All
            </label>
        `);

                $.each(response, function () {
                    var value = this['Value'];
                    var text = this['Text'];

                    var checkbox = `
                <label>
                    <input type="checkbox" value="${value}" onchange="updateHeader()"> ${text}
                </label>
            `;
                    optionsContainer.append(checkbox);
                });
                //ddlCustomers.empty().append('<option selected="selected" value="0">All</option>');
                //$.each(response, function () {
                //    ddlCustomers.append($("<option></option>").val(this['Value']).html(this['Text']));
                //});
            },
            failure: function (response) {
                alert(response.responseText);
            },
            error: function (response) {
                alert(response.responseText);
                optionsContainer.html('<div style="padding: 10px;">Failed to load options</div>');
            }
        });
    //});





    });


</script>

