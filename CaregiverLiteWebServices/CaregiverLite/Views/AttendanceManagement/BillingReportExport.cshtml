<script>
  function toggleDropdown() {
    document.getElementById("dropdownList").classList.toggle("show");
  }

  function updateHeader() {
    const checkboxes = document.querySelectorAll('#dropdownList input[type="checkbox"]');
    const selected = Array.from(checkboxes)
      .filter(cb => cb.checked)
      .map(cb => cb.parentElement.textContent.trim());

    const header = document.getElementById("dropdownHeader");

    if (selected.length === 0) {
      header.textContent = "Select Options";
    } else if (selected.length <= 5) {
      header.textContent = selected.join(', ');
    } else {
      const shown = selected.slice(0, 5).join(', ');
      const moreCount = selected.length - 5;
      header.textContent = `${shown}, +${moreCount}`;
    }
  }

  function GetSelectedOfficeValue() {
    const allCheckbox = document.querySelector('#optionsContainer input[type="checkbox"][value="0"]');
    if (allCheckbox && allCheckbox.checked) {
      return '0'; // Return only '0' if "All" is selected
    }

    const checkboxes = document.querySelectorAll('#dropdownList input[type="checkbox"]:not([value="0"])');
    const selected = Array.from(checkboxes)
      .filter(cb => cb.checked)
      .map(cb => cb.value);

    return selected.length > 0 ? selected.join(',') : 'None';
  }

  function toggleAll(allCheckbox) {
    const isChecked = allCheckbox.checked;

    // Toggle all other checkboxes
    document.querySelectorAll('#optionsContainer input[type="checkbox"]:not([value="0"])')
      .forEach(cb => cb.checked = isChecked);

    updateHeader();
  }

  // Uncheck "All" if any individual checkbox is unchecked
  document.addEventListener('change', function (e) {
    if (e.target.matches('#optionsContainer input[type="checkbox"]:not([value="0"])')) {
      const allCheckbox = document.querySelector('#optionsContainer input[type="checkbox"][value="0"]');

      if (!e.target.checked && allCheckbox.checked) {
        allCheckbox.checked = false;
      }

      // Optionally re-check "All" if all individual checkboxes are now selected
      const otherCheckboxes = document.querySelectorAll('#optionsContainer input[type="checkbox"]:not([value="0"])');
      const allChecked = Array.from(otherCheckboxes).every(cb => cb.checked);
      if (allChecked) {
        allCheckbox.checked = true;
      }

      updateHeader();
    }
  });

  // Close dropdown if clicking outside
  window.addEventListener("click", function (e) {
    const dropdown = document.getElementById("multiDropdown");
    if (!dropdown.contains(e.target)) {
      document.getElementById("dropdownList").classList.remove("show");
    }
  });
</script>
