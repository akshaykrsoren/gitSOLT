            });
        }
        else {
            $('#EditPanel').load(INITURL + '/AttendanceManagement/AttendanceDetail/?PatientRequestID=' + PatientRequestID, function () {
                sessionStorage.setItem("PartialView", "1");
                $('#myModal2').modal({ backdrop: 'static', keyboard: false });
                $('#myModal2').modal('show');
                $("#loading").hide();
            });
        }
