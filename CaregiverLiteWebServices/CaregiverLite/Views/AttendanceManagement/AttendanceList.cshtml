<script>
    var attendanceTable;
    var oTable;
    $(document).ready(function () {
        oTable = $('#myDataTable').DataTable({
            "order": [[9, "desc"]],
            responsive: true,
            "dom": 'lfrtip',

            "bPaginate": true,
            "bServerSide": true,

            "bSortable": true,
            "sPaginationType": "full_numbers",
            "oLanguage": {
                "sProcessing": "<div class=\"loading\" id=\"loading\" style=\"display: block;\"></div>"
            },
            "processing": true,

            "sAjaxSource": "getAttendanceList",
            "fnServerData": function (sSource, aoData, fnCallback) {
                $.getJSON(sSource, aoData, function (json) {
                    fnCallback(json);
                    debugger;
                }).fail(function (jqxhr, textStatus, error) {
                    window.location.reload();
                });
            },

            "fnDrawCallback": function (oSettings) {
                //Navigation validation
                var rowsPerPage = this.fnSettings()._iDisplayLength;
                var rowsToShow = this.fnSettings().fnRecordsDisplay();
                var table = $('#myDataTable').DataTable();
                   // Sorting by first column (index 0) in ascending order
                $('#myDataTable thead th').css({
                    "background-color": "white" // Your desired color
                    // Text color
                });
                
                var info = table.page.info();
                var currentPageNo = info.page + 1;
                $("#loading").hide();
                $("#AttendanceListHeader").text("");
                $("#AttendanceListHeader").text("Attendance  (" + rowsToShow + ")");
                $('#myDataTable_filter input ').css({ 'border-radius': '5px', 'height': '36px' });
              
                $('#myDataTable_filter input ').css({ 'border-radius': '5px', 'height': '36px' });
                $('#myDataTable_wrapper select ').css({ 'margin-top': '10px', 'border-radius': '5px', 'margin-bottom': '10px' });
                $('#myDataTable_filter label').contents().filter(function () {
                    return this.nodeType === 3; // This checks for text nodes
                }).remove();

                var searchInput = $('#myDataTable_filter input');
                searchInput.wrap('<div class="search-container" style="position: relative; display: inline-block; width: 100%;"></div>'); // Wrap the search input
                searchInput.css({
                    'padding-right': '30px' // Add padding to the right to make space for the icon
                });
                searchInput.after('<img src="http://ec2-52-38-33-252.us-west-2.compute.amazonaws.com/Content/image/SearchIcon.png" class="search-icon" id="SearchIcon" alt="Search Icon" style="position: absolute; right: 10px; top: 50%; transform: translateY(-50%); cursor: pointer;">');

                 
            },
            "responsive": {
                "details": {
                    "type": 'column'
                }
            },
            "aoColumns": [

                            {
                                "sName": "Nurse",
                                "mRender": function (oObj) {

                                    if (oObj["IsMaual"] == 1) {

                                        return '<span title="This is a manually entered"> <img style="margin-right:10px;" src="http://ec2-52-38-33-252.us-west-2.compute.amazonaws.com/image/manual.svg">' + oObj["Name"] + '</span>';
                                    }

                                    if (oObj["IsForceCheckIn"] == 1) {

                                        return '<span title="This is completed out side radius"> <img style="margin-right:20px;" src="http://ec2-52-38-33-252.us-west-2.compute.amazonaws.com/image/forceCheckIn.png"  style="max-width: 12%; height: auto;"> ' + oObj["Name"] + '</span>';
                                    }


                                    return '<span>' + oObj["Name"] + '</span>';
                                }
                            },
                            {
                                "sName": "Patient",
                                "mRender": function (oObj) {
                                    return oObj["PatientName"];
                                }
                            },
                            {
                                "sName": "Date",
                                "mRender": function (oObj) {
                                    var NewDate = oObj["Date"];
                                    var NewDate1 = NewDate.split(" ");
                                   // alert();
                                    return NewDate1[0];
                                }
                            },
                            {
                                "sName": "Start Time",
                                "mRender": function (oObj) {
                                    return oObj["FromTime"];
                                }
                            },
                            {
                                "sName": "End Time",
                                "mRender": function (oObj) {
                                    return oObj["ToTime"];
                                }
                            },
                           {
                                 "sName": "Requested duration",
                                 "bSortable": false,
                                 "mRender": function (oObj) {

                                     return oObj["RequestedDuration"];
                                 }
                             },
                              {
                                  "sName": "Checkin Duration",
                                  "bSortable": false,
                                  "mRender": function (oObj) {
                                      return oObj["CheckInTotalTime"];
                                  }
                              },
                              {
                                  "sName": "Travel Time",
                                  "mRender": function (oObj) {


                                      if (oObj["TotalTravelTime"].split(':')[1] == undefined)
                                      {
                                          return oObj["TotalTravelTime"].split(':')[0];
                                      }

                                      return oObj["TotalTravelTime"].split(':')[0] + ':' + oObj["TotalTravelTime"].split(':')[1] + ':' + oObj["TotalTravelTime"].split(':')[2]
                                      //return oObj["TotalTravelTime"];
                                  }
                              },
                            {
                                "sName": "Action",
                                "bSortable": false,
                                "mRender": function (oObj) {
                                    var actionhtml = '';

                                    //actionhtml += '<a href="javascript:;" class="btn btn-xs btn-primary" style="margin-top:5px; width:100%;" onclick="EditAdmin(\'' + oObj["PatientRequestId"] + '\');">Detail</a>'

                                    if (oObj["IsMaual"] == 1)
                                    {
                                        actionhtml += '<a href="javascript:;" class="btn btn-xs btn-primary" style="margin-top:5px; width:100%; border-radius:4px;text-transform: none;" onclick="EditAdmin(\'' + oObj["PatientRequestId"] + '\',\'' + oObj["IsMaual"] + '\');">Detail</a>'
                                    }
                                    else
                                    {
                                        actionhtml += '<a href="javascript:;" class="btn btn-xs btn-primary" style="margin-top:5px; width:100%;border-radius:4px;text-transform: none;" onclick="EditAdmin(\'' + oObj["PatientRequestId"] + '\',\'' + oObj["IsMaual"] + '\');">Detail</a>'

                                    }

                                    return actionhtml;
                                }
                            },
                            {
                                "sName": "Action",
                                "bSortable": false,
                                "mRender": function (oObj) {
                                    var actionhtml = '';
                                    if (oObj["IsEdited"] == 1) {
                                        return actionhtml += '<a>Edited</a>'
                                    }
                                    else {
                                        // actionhtml += '<a href="javascript:;" class="btn btn-xs btn-primary" style="margin-top:5px; width:100%;" onclick="EditAdmin(\'' + oObj["PatientRequestId"] + '\',\'' + oObj["IsMaual"] + '\');">Detail</a>'
                                        return actionhtml;
                                    }
                                    return actionhtml;
                                }
                            },



            ]
        });

        $('#myDataTable_filter input').unbind(); //Unbind direct search on each keypress
        $('#myDataTable_filter input').bind('keyup', function (e) { //Bind Keyup event that filter data only on "Enter" key.

            if (e.keyCode == 13) {
                oTable.search(this.value).draw();
            }
        });
        /* Init DataTables */
        $('.carousel').carousel({
            interval: false
        });

        var config = {
            '.chosen-select': {},
            '.chosen-select-deselect': { allow_single_deselect: true },
            '.chosen-select-no-single': { disable_search_threshold: 10 },
            '.chosen-select-no-results': { no_results_text: 'Oops, nothing found!' },
            '.chosen-select-width': { width: "95%" }
        }
        for (var selector in config) {
            $(selector).chosen(config[selector]);
        }

        $("#loading").hide();

    });

