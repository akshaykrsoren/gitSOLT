</style>

<style>
    .multi-select-dropdown {
        position: relative;
        width: 300px;
    }

    .dropdown-header {
        padding: 10px 12px;
        border: 1px solid #ccc;
        background-color: white;
        cursor: pointer;
        border-radius: 4px;
    }

        .dropdown-header::after {
            content: '▼';
            float: right;
            margin-left: 10px;
            font-size: 12px;
            color: #888;
        }

    .dropdown-list {
        position: absolute;
        top: 100%;
        left: 0;
        right: 0;
        background: white;
        border: 1px solid #ccc;
        border-top: none;
        max-height: 250px;
        overflow-y: auto;
        z-index: 1000;
        display: none;
        border-radius: 0 0 4px 4px;
    }

        .dropdown-list.show {
            display: block;
        }

        .dropdown-list label {
            display: block;
            padding: 8px 12px;
            cursor: pointer;
        }

            .dropdown-list label:hover {
                background-color: #f1f1f1;
            }

        .dropdown-list input[type="checkbox"] {
            margin-right: 8px;
        }

