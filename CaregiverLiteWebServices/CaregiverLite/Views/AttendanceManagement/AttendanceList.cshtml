    function EditAdmin(PatientRequestID, IsManual) {
        debugger;
        $("#loading").show();

        if (IsManual == '1') {

            $('#EditPanel').load(INITURL + '/AttendanceManagement/AttendanceDetailsManaul/?PatientRequestID=' + PatientRequestID, function () {
                sessionStorage.setItem("PartialView", "1");
                $('#myModal2').modal({ backdrop: 'static', keyboard: false });
                $('#myModal2').modal('show');
