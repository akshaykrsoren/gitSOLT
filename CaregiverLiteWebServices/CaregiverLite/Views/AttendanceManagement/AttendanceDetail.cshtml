	function TrackLocationMapWithWayPoint(trackedLocations) {
    setTimeout(function () {
        if (!trackedLocations || trackedLocations.length === 0) return;

        const gm = google.maps;
        const bounds = new gm.LatLngBounds();

        const map = new gm.Map(document.getElementById('divmap'), {
            center: {
                lat: parseFloat(trackedLocations[0].LocationLatitude),
                lng: parseFloat(trackedLocations[0].LocationLongitude)
            },
            zoom: 16,
            mapTypeId: gm.MapTypeId.ROADMAP
        });

        // ✅ Shared InfoWindow for all markers
        const infoWindow = new gm.InfoWindow();

        // ✅ Close InfoWindow when clicking outside
        map.addListener("click", () => infoWindow.close());

        const createInfoContent = (data) => `
            <div style="position: relative; max-width: 260px;">
                <a href="#" class="close-info-btn"
                   style="position: absolute; top: 0; right: 5px; font-weight: bold; color: red; text-decoration: none;">X</a>
                <div><strong>Date: </strong>${data.LocationDateTime}</div>
                <div><strong>Latitude: </strong>${parseFloat(data.LocationLatitude).toFixed(6)}</div>
                <div><strong>Longitude: </strong>${parseFloat(data.LocationLongitude).toFixed(6)}</div>
                <div><strong>Status: </strong>${data.Status}</div>
                <div>
                    <a class="btn btn-xs btn-primary" style="margin-top:5px;" href="javascript:;" onclick="seeAddress(this, ${data.LocationLatitude}, ${data.LocationLongitude})">See Address</a>
                </div>
            </div>`;

        const bindInfoWindow = (marker, content) => {
            gm.event.addListener(marker, 'click', () => {
                infoWindow.setContent(content);
                infoWindow.open(map, marker);

                gm.event.addListenerOnce(infoWindow, 'domready', () => {
                    const closeBtn = document.querySelector('.close-info-btn');
                    if (closeBtn) {
                        closeBtn.addEventListener('click', function (e) {
                            e.preventDefault();
                            infoWindow.close();
                        });
                    }
                });
            });
        };

        const createMarker = (latlng, status, map) => {
            const iconDefault = 'https://scheduler.paseva.com/image/Red_50x50.png';
            const CheckedInIcon = 'https://scheduler.paseva.com/image/check_in_icon.png';
            const CheckedOutIcon = 'https://scheduler.paseva.com/image/check_out_icon.png';

            let markerOptions = { position: latlng, map: map };

            switch (status) {
                case 'StartDriving':
                    markerOptions.label = { text: 'S', color: 'white' };
                    break;
                case 'PauseDriving':
                    markerOptions.label = { text: 'P', color: 'white' };
                    break;
                case 'ResumeDriving':
                    markerOptions.label = { text: 'R', color: 'white' };
                    break;
                case 'Checked-in':
                    markerOptions.icon = {
                        url: CheckedInIcon,
                        scaledSize: new google.maps.Size(60, 60)
                    };
                    break;
                case 'Checked-Out':
                    markerOptions.icon = {
                        url: CheckedOutIcon,
                        scaledSize: new google.maps.Size(60, 60)
                    };
                    break;
                case 'StopDriving':
                case 'ForceStopDriving':
                    markerOptions.icon = iconDefault;
                    break;
                default:
                    markerOptions.icon = "https://scheduler.paseva.com/CaregiverLiteMobileService/Images/CareGiverProfileImages/blue-dot.png";
                    break;
            }

            return new google.maps.Marker(markerOptions);
        };

        for (let i = 0; i < trackedLocations.length; i++) {
            const curr = trackedLocations[i];
            const pos = new gm.LatLng(parseFloat(curr.LocationLatitude), parseFloat(curr.LocationLongitude));
            bounds.extend(pos);

            const marker = createMarker(pos, curr.Status, map);
            marker.setVisible(true);
            bindInfoWindow(marker, createInfoContent(curr));

            // draw polyline to next
            if (i < trackedLocations.length - 1) {
                const next = trackedLocations[i + 1];
                const nextPos = new gm.LatLng(parseFloat(next.LocationLatitude), parseFloat(next.LocationLongitude));
                const isPause = curr.Status === 'PauseDriving';

                new gm.Polyline({
                    path: [pos, nextPos],
                    strokeColor: isPause ? '#ffffff' : '#0000FF',
                    strokeOpacity: isPause ? 0.0 : 1.0,
                    strokeWeight: 5,
                    map: map
                });
            }
        }

        map.fitBounds(bounds);
    }, 500);
}

















