    function calculateAndDisplayRoute(directionsService, directionsDisplay, src, des) {
        directionsService.route({
            origin: src,
            destination: des,
            travelMode: 'DRIVING'
        }, function (response, status) {
            if (status === 'OK') {
                directionsDisplay.setDirections(response);
            }
            //else {
            //    window.alert('Directions request failed due to ' + status);
            //}


            else if (status == google.maps.GeocoderStatus.OVER_QUERY_LIMIT) {
                wait = true;
                setTimeout("wait = true", 2000);
                calculateAndDisplayRoute(directionsService, directionsDisplay, src, des);
                //alert("OQL: " + status);


            }



        });
    }







