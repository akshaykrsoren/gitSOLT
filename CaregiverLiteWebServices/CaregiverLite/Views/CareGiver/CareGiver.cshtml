    function OpenVideoPopup(URL) {
        $('.loading').show();
        $("#popupvideoid").attr("src", URL);
        $("#myModalVideo").modal('show');
        $('.loading').hide();
    }

    function DeleteNurse(nurseid,username) {
        if (confirm('@CaregiverLite.Views.Resources.CareGiver.MsgDeleteConfirmation')) {
            $("#loading").show();
            var url = INITURL + '/CareGiver/DeleteNurse';

            $.ajax({
                url: url,
                data: { NurseId: nurseid, Username:username },
                cache: false,
                type: 'POST',
                async: false,
                success: function (data) {
                    if (data == "Success") {
                        window.location = INITURL + '/CareGiver/CareGiver';
                    }
                    $("#loading").hide();
                },
                error: function (reponse) {
                    alert("error : " + reponse);
                    $("#loading").hide();
                }
            });
        }
    }

    function ViewCareGiverProfile(id) {
        $("#loading").show();
        $('#ViewPanel').load(INITURL + '/CareGiver/ViewCareGiver/' + id, function () {
            $('#myModal1').modal('show');
            sessionStorage.setItem("PartialView", "1");
        });
    }

    function ViewClockInClockoutDetails(pNurseid) {
        $('#ClockInClockout_ViewPanel').load(INITURL + '/CareGiver/NurseClockInAttendance/?NurseId=' + pNurseid, function () {
            $('#ClockInClockout_Model').modal('show');
            //sessionStorage.setItem("PartialView", "1");
        });

    }

    function OpenAddNew() {
        $("#loading").show();
        $('#AddCareGiver').load(INITURL + 'CareGiver/AddCareGiver', function () {
            sessionStorage.setItem("PartialView", "1");
            $('#modalAddCareGiver').modal('show');
        });
    }

    function RejectApprovedNurse(nurseid, OfficeId, UserId, QuickBloxId) {

        if (confirm("Are you sure you wants to reject.?")) {
            $("#loading").show();
            var url = INITURL + '/CareGiver/SendApproval';
            var objCareGiver = { NurseId: nurseid, IsApproved: 0, UserId: UserId,OfficeId:OfficeId, QuickBloxId: QuickBloxId }

            $.ajax({
                url: url,
                data: JSON.stringify({ 'CareGiver': objCareGiver }),
                cache: false,
                contentType: 'application/json; charset=utf-8',
                dataType: 'json',
                type: 'POST',
                success: function (data) {
                    if (data.Result == "Success") {
                        window.location = INITURL + "/CareGiver/CareGiver";
                    }
                    else {
                        alert('@CaregiverLite.Views.Resources.CareGiver.MsgError');
                        $("#loading").hide();
                    }
                },
                error: function (reponse) {
                    alert("error : " + reponse);
                    $("#loading").hide();
                }
            });
        }
    }

    function OpenApprovedPopup(username, email, password, nurseid, userid,officeId,quckbloxid, hourrate) {
        $("#loading").show();
        $('#SendApprovePanel').load(INITURL + '/CareGiver/SendApproval', function () {
            sessionStorage.setItem("PartialView", "1");
            $("#apEmail").val(email);
            $("#hdnapNurseId").val(nurseid);
            $("#IsApproved").val(1);
            $("#hdnapUserid").val(userid);
            $("#apHourRate").val(hourrate)
            $("#apHourRate").val(hourrate)
            $("#apHourRate").val(hourrate)

            $("#hdnOfficeId").val(officeId);
            $("#hdnQuickbloxId").val(quckbloxid);
            if (email != username) {
                $("#apUsername").val(username);
                $("#apUsername").attr('readonly', true);
                $("#apPassword").val(password);
                $("#apPassword").attr('readonly', true);
                $("#btnApprove").text('Approve');
            }
            else {
                $("#apUsername").val("");
                $("#apUsername").attr('readonly', false);
                $("#apPassword").attr('readonly', false);
                $("#apPassword").val("");
            }
            $('#modelApproveCareGiver').modal('show');
            $("#loading").hide();
        });
    }



    function NurseTrackLocation(nurseid) {
        var tempdate1 = moment(new Date()).format('MM-DD-YYYY');
        $("#loading").show();
        $('#myModalTrackLocationNurse').modal('show');
        localStorage.setItem("NurseId", nurseid);

        //$("#Date").datepicker({
        //    // minDate: 0,
        //    dateFormat: 'mm-dd-yy',
        //    onSelect: function () {
        //        $(this).change();
        //    }
        //});

        $("#Date").datepicker("destroy").datepicker({
            dateFormat: 'mm-dd-yy',
            minDate: -29,  // 29 days before today (last 30 days including today)
            maxDate: +365,     // today
            onSelect: function () {
                $(this).change();
            }
        });

        $("#Date").val(tempdate1);
        $("#dvmap").hide();
        $("#loading").hide();
        viewmap();
    }

    function viewmap() {
        debugger;
        $("#loading").show();
        var Date = $("#Date").val();
        var NurseID = localStorage.getItem("NurseId");

        //   var d = new Date();
        //    var n = d.getTimezoneOffset();
        //     console.log(n);
        //var offset = new Date().getTimezoneOffset();
        //console.log(offset);

        if (Date == "") {
            toastr.error('Please Select Date');
            $('#loading').hide();
            return false;
        }
        console.log(Date);
        console.log(NurseID);

        $.ajax({
            url: "@Url.Action("TrackLocationByNurseId", "CareGiver")",
            data: { NurseId: NurseID, date: Date },
        cache: false,
        dataType: 'json',
        type: 'POST',
        success: function (data, response) {
            console.log(JSON.stringify(data));
            if (data.Result.length > 0) {
                var trackedLocations = data.Result;
                TrackLocationMap(trackedLocations)
            }
            else {
                toastr.warning('No Location Available on this Date');
                // $('#msg').html('No Location Available on this Date').show();
            }
            //  BindMap(NurseList)

        },
        error: function (xhr, response) {
            console.log(xhr, response);

            $('#loading').hide();
        }
    });
    $("#loading").hide();
    }
    $('#ViewOnMap').click(function () {
        viewmap();
