    #table-scroll {
        height: 300px;
        overflow: auto;
        margin-top: 20px;
        width: 760px;
    }

    table#myDataTable {
        width: auto !important;
    }

    .btn-round {
        border-radius: 50%; /* Make the button round */
        padding: 10px;
        background-color: #f1f1f1; /* Button background */
        border: none;
        width: 37px;
        height: 37px;
        display: flex;
        align-items: center;
        justify-content: center;
    }


    .toggle-container {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-top: -27px;
    }

    /*.switch {
        position: relative;
        display: inline-block;
        width: 48px;
        height: 24px;
        margin-left: 70%;
    }*/

    .switch {
        position: relative;
        display: inline-block;
        width: 48px; /* reduced width */
        height: 24px; /* reduced height */
        margin-top: -8px;
        margin-left: 5px;
    }

        .switch input {
            display: none;
        }

    .slider {
        position: absolute;
        cursor: pointer;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background-color: #ccc;
        transition: 0.4s;
        border-radius: 28px; /* adjusted to match new height */
    }

        .slider:before {
            position: absolute;
            content: "";
            height: 18px; /* adjusted height */
            width: 18px; /* adjusted width */
            left: 4px; /* adjusted position */
            bottom: 3px;
            background-color: white;
            transition: 0.4s;
            border-radius: 50%;
        }

    input:checked + .slider {
        background-color: #4CAF50;
    }

        input:checked + .slider:before {
            transform: translateX(22px); /* adjusted translation */
        }

    #toggleText {
        font-weight: bold;
        margin-top: -7px;
        margin-left: 6px;
    }

    #toggleText1 {
        font-weight: bold;
        margin-top: -7px;
        margin-left: 216px;
        ;
    }

    .confirmbtn {
        background-color: #e6f4ea;
        color: #1d9b6c;
        border: 1px solid;
        border-radius: 4px;
        height: 40px;
        font-weight: bold;
    }

        .confirmbtn:hover {
            background-color: #d1ecd9;
        }

    .cancelbtn {
        background-color: #f4e6e6;
        color: #d93025;
        border: 1px solid;
        border-radius: 4px;
        height: 40px;
        font-weight: bold;
