@model CaregiverLite.Models.CareGiverModel

<div class="modal fade" id="myModalCaregiverProfileVideo" tabindex="-1" role="dialog" aria-labelledby="myModalLabel" style="z-index: 10001;">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-body">
                <button type="button" class="close" onclick="CloseProfileVideoModal()" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                <iframe src="" id="popupCaregiverProfilevideoid" height="360" width="100%" frameborder="0" scrolling="yes" allowfullscreen></iframe>
            </div>
        </div><!-- /.modal-content -->
    </div><!-- /.modal-dialog -->
</div>

<div class="col-md-6">
    <img src="@Model.ProfileImage" id="imgProfileImage" class="img-responsive" style="width: 270px; height: 210px;">
    @if (!string.IsNullOrEmpty(Model.ProfileVideo))
    {
        <br />
        <a href="javascript:void(0);" onclick="OpenVideoCaregiverProfilePopup()">Click here to see video</a>
    }

</div>

