    }

    function showPassword() {
        $("#hidePass").hide();
        $("#ShowPass").show();
    }
    function hidePassword() {
        $("#ShowPass").hide();
        $("#hidePass").show();
    }



    // Function to debounce the API call
    function debounce(func, delay) {
        let debounceTimer;
        return function () {
            const context = this;
            const args = arguments;
            clearTimeout(debounceTimer);
            debounceTimer = setTimeout(() => func.apply(context, args), delay);
        };
    }

    // Function to handle the API call (debounced version)
    const debouncedActiveDeactiveCustomer = debounce(ActiveDeactiveCustomer, 300); // 300ms delay

    // Function to handle the API call for activation/deactivation
    function handleToggleSwitchChange() {
        debugger;
        if (toggleSwitch.checked) {
        /*if (VarActive) {*/
            //toggleText.innerText = "Active";
            //debouncedActiveDeactiveCustomer(true);
            $('#ConfirmationModelActive').modal('show');
            // Activate the patient, debounced
        } else {
            $('#ConfirmationModel').modal('show');  // Show confirmation for Inactive
        }
    }

    // Attach the event listener for toggle switch
    function attachToggleListener() {
        debugger;
        // First, detach any previous listeners to avoid duplication
        $(toggleSwitch).off('change');

        // Now, re-attach the listener
        $(toggleSwitch).on('change', handleToggleSwitchChange);
    }

    // Initial event listener attachment
   // attachToggleListener();

    // Confirmation modal actions
    $('.confirmbtn').off('click').on('click', function () {
        debugger;

        // If "Yes, Inactive" is clicked
        toggleSwitch.checked = false; // Set the toggle to inactive
        toggleText.innerText = "Inactive";  // Update the label text
        debouncedActiveDeactiveCustomer(false); // Deactivate the patient, debounced
        $('#ConfirmationModel').modal('hide');  // Hide the confirmation modal
    });


    $('.confirmbtnActive').off('click').on('click', function () {
        debugger;

        // If "Yes, Inactive" is clicked
        toggleSwitch.checked = true; // Set the toggle to inactive
        toggleText.innerText = "active";  // Update the label text
        debouncedActiveDeactiveCustomer(true); // Deactivate the patient, debounced
        $('#ConfirmationModelActive').modal('hide');  // Hide the confirmation modal
    });

    // Cancel button inside the confirmation modal
    $('.cancelbtn').click(function () {
        debugger;

        // If "No, Go Back" is clicked
        toggleSwitch.checked = true; // Keep the toggle as active
        toggleText.innerText = "Active";  // Keep the label as "Active"
        $('#ConfirmationModel').modal('hide');  // Hide the confirmation modal
    });

    $('.cancelbtnActive').click(function () {
        debugger;

        // If "No, Go Back" is clicked
        toggleSwitch.checked = true; // Keep the toggle as active
        toggleText.innerText = "Active";  // Keep the label as "Active"
        $('#ConfirmationModelActive').modal('hide');  // Hide the confirmation modal
    });

    // Detach and re-attach the listener when the modal is hidden or shown
    $('#ConfirmationModel').on('hidden.bs.modal', function () {
        attachToggleListener(); // Re-attach the listener when modal is hidden
    });

    // AJAX call to activate or deactivate the customer (unchanged)
    function ActiveDeactiveCustomer(IsActive) {
        debugger;
        // $("#loading").show();
        var url = INITURL + '/Patients/ActiveDeactiveCustomer';
        //debugger;
        //alert('fsdfds');
     /*   return;*/
        $.ajax({
            url: url,
            data: { id: '@Model.NurseId', PageName: "Nurse", IsActive: IsActive },
            cache: false,
            type: 'POST',
            async: true,  // Allow non-blocking behavior
            success: function (data) {
                debugger;
                if (data == "Success") {
                    if (IsActive) {
                        toastr.success('@Model.Name' + " has been successfully Activated");
                    } else {
                        toastr.success('@Model.Name' + " has been successfully Inactive");
                    }
                } else {
                    toastr.error("Process denied");

                }
                $("#loading").hide();
            },
            error: function (response) {
                toastr.error("Error occurred: " + response);
                $("#loading").hide();
            }
        });
    }



</script>