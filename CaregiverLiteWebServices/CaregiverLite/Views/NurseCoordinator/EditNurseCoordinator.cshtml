                @Html.ValidationMessageFor(model => model.Email)
                @Html.TextBoxFor(model => model.Email, new { @id = "emailid", @type = "email", @maxlength = "100", @placeholder = "Enter Email", @class = "form-control", @readonly = "readonly" })
            </div>

            @*<div class="form-group">
                    <label>Password</label>
                    <span style="color:red;">*</span>
                    @Html.ValidationMessageFor(model => model.Password)
                    @Html.TextBoxFor(model => model.Password, new { @id = "pas", @type = "password", @maxlength = "256", @placeholder = "Enter Password", @class = "form-control", @attr = "txtpassword" })
                </div>*@
            @*<span style="position: absolute; right: 16px;height: 40px;">
                    <i class="fa fa-eye btn btn-link" id="HidePasswordEdit" style="position: relative; top: -42px;display:none" aria-hidden="true"></i>
                    <i class="fa fa-eye-slash btn btn-link" id="showPasswordEdit" style="position: relative; top: -42px;" aria-hidden="true"></i>
                </span>*@

            @*Office*@
            <div class="form-group">
                <label>Office</label>
                <span style="color:red;">*</span>
                @Html.ValidationMessageFor(model => model.OfficeId)
                @Html.DropDownListFor(model => model.OfficeId, Model.OfficeSelectList, "Select...", new { @class = "form-control customdropDown", @style = "background-position-x: 97%" })
            </div>
            @*IsAllowForPatientChatRoom*@

            <div class="form-group">
                <label>Allow For One to One Chat</label>
                <br>
                @Html.CheckBoxFor(model => model.IsAllowOneToOneChat, new { @style = "transform: scale(1.5); margin-left: 10px;" })
            </div>
            <div class="form-group">
                <label>Allow For Patient Chat Room</label>
                <br>

                @Html.CheckBoxFor(model => model.IsAllowForPatientChatRoom, new
           {
               @style = "transform: scale(1.5); margin-left: 10px;"
           })
            </div>

            <div class="form-group">
                <label>Allow For Group Chat</label>
                <br>
                @Html.CheckBoxFor(model => model.IsAllowGroupChat, new { @style = "transform: scale(1.5); margin-left: 10px;" })
            </div>

            <div class="form-group">
                <label>Allow For Create Group Chat</label>
                <br>
                @Html.CheckBoxFor(model => model.IsAllowToCreateGroupChat, new { @style = "transform: scale(1.5); margin-left: 10px;" })
