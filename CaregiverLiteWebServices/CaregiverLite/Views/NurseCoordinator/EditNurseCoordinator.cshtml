                @Html.ValidationMessageFor(model => model.LastName)
                @Html.TextBoxFor(model => model.LastName, new { @id = "ln", @type = "text", @maxlength = "100", @placeholder = "Enter Last name", @class = "form-control" })
            </div>

            <div class="form-group">
                <label>Email</label>
