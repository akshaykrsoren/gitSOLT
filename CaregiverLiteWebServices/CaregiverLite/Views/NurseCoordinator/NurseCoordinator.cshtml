        oTable.search($('#myDataTable').val()).draw();
    }
      $(document).on('click', '#SearchIcon', function (event) {
        event.stopPropagation();  // Prevents the outer div's click event
        var query = $('#myDataTable_filter input').val(); // Get the value from the search input
        $('#myDataTable').DataTable().search(query).draw(); // Trigger the DataTable search

      });
      $('#Clearbtn').mouseover(function () {
          $('#ClearIcon').attr('src', 'http://ec2-52-38-33-252.us-west-2.compute.amazonaws.com/Content/image/ClearBluebtn.png'); // Change to your hover image
      });

      // Revert image on mouseout
      $('#Clearbtn').mouseout(function () {
          $('#ClearIcon').attr('src', 'http://ec2-52-38-33-252.us-west-2.compute.amazonaws.com/Content/image/ClearFilter.png'); // Revert to original image
      });



      $('#CloseModalScroll').click(function () {

          $('body').css("overflow-y", "auto");
      })

</script>
