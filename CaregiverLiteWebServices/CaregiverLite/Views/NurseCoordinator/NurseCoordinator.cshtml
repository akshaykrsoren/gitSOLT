<script type="text/javascript">
    var tempMsg = '@TempData["Message"]';
    if (tempMsg != "")
        toastr.success(tempMsg);

    var oTable;
    $(document).ready(function () {
        //GetUnAssignedNurseCoordinator();

        $("#loading").show();
        var jquey = jQuery.noConflict();
        oTable = $('#myDataTable').DataTable({
            responsive: true,
            "dom": 'lfrtip',
            "bPaginate": true,
            "bServerSide": true,
            "bSortable": true,
            "sPaginationType": "full_numbers",
            "oLanguage": {
                "sProcessing": "<div class=\"loading\" id=\"loading\" style=\"display: block;\"></div>"
            },
            "processing": true,
            "sAjaxSource": "GetNurseCoordinatorList",
            "fnServerData": function (sSource, aoData, fnCallback) {
                $.getJSON(sSource, aoData, function (json) {
                    fnCallback(json);
                }).fail(function (jqxhr, textStatus, error) {
                    window.location.reload();
                });
            },
            "fnServerParams": function (aoData) {
                aoData.push({ "name": "FilterOfficeId", "value": $('#ddFilterOffice option:selected').val() });
                aoData.push({ "name": "FilterActiveStatus", "value": $('#ddFilterActiveInactive option:selected').val() });
            },
            "fnDrawCallback": function (oSettings) {
                //Navigation validation
                var rowsPerPage = this.fnSettings()._iDisplayLength;
                var rowsToShow = this.fnSettings().fnRecordsDisplay();
                var table = $('#myDataTable').DataTable();
                $('#myDataTable thead th').css({
                    "background-color": "white" // Your desired color
                    // Text color
                });
                var info = table.page.info();
                var currentPageNo = info.page + 1;
                $("#loading").hide();
                $("#NCordinatorHeader").text("");
                $("#NCordinatorHeader").text("Office Staff (" + rowsToShow + ")");
                $('#myDataTable_filter input ').css({ 'border-radius': '5px', 'height': '36px' });

                $('#myDataTable_filter input ').css({ 'border-radius': '5px', 'height': '36px' });
                $('#myDataTable_wrapper select ').css({ 'margin-top': '10px', 'border-radius': '5px', 'margin-bottom': '10px' });
                $('#myDataTable_filter label').contents().filter(function () {
                    return this.nodeType === 3; // This checks for text nodes
                }).remove();

                var searchInput = $('#myDataTable_filter input');
                searchInput.wrap('<div class="search-container" style="position: relative; display: inline-block; width: 100%;"></div>'); // Wrap the search input
                searchInput.css({
                    'padding-right': '30px' // Add padding to the right to make space for the icon
                });
                searchInput.after('<img src="http://ec2-52-38-33-252.us-west-2.compute.amazonaws.com/Content/image/SearchIcon.png" class="search-icon" id="SearchIcon" alt="Search Icon" style="position: absolute; right: 10px; top: 50%; transform: translateY(-50%); cursor: pointer;">');

            },
            "responsive": {
                "details": {
                    "type": 'column'
                }
            },
            "aoColumns": [
                            {
                                className: 'control',
                                orderable: false,
                                targets: 0,
                                "mRender": function (oObj) {
                                    return '';
                                }
                            },
                            {
                                "sName": "FirstName",
                                "mRender": function (oObj) {
                                    return '<span>' + oObj["FirstName"] + '</span>';
                                }
                            },
                            {
                                "sName": "LastName",
                                "mRender": function (oObj) {
                                    return oObj["LastName"];
                                }
                            },
                            {
                                "sName": "UserName",
                                "mRender": function (oObj) {
                                    return oObj["UserName"];
                                }
                            },
                            {
                                "sName": "Email",
                                "mRender": function (oObj) {
                                    return oObj["Email"];
                                }
                            },
                                {
                                    "sName": "AllowForChatting",
                                    "mRender": function (oObj) {
                                        var actionhtml = '';
                                        if (oObj["IsAllowOneToOneChat"]) {
                                            actionhtml = "<span style='display: block; text-align: center'><i class='fa fa-check'></i></span>"
                                            return actionhtml;
                                        }
                                        else {
                                            actionhtml = "<span style='display: block; text-align: center'><i class='fa fa-times'></i></span>"
                                            return actionhtml;
                                        }
                                    }
                                },
                             {
                                 "sName": "AllowForPatientChatRoom",
                                 "mRender": function (oObj) {
                                     var actionhtml = '';
                                     if (oObj["IsAllowForPatientChatRoom"])
                                     {
                                         actionhtml = "<span style='display: block; text-align: center'><i class='fa fa-check'></i></span>"
                                         return actionhtml;
                                     }
                                     else
                                     {
                                         actionhtml = "<span style='display: block; text-align: center'><i class='fa fa-times'></i></span>"
                                         return actionhtml;
                                     }
                                 }
                             },
                                      {
                                          "sName": "AllowForGroupChat",
                                          "mRender": function (oObj) {
                                              var actionhtml = '';
                                              if (oObj["IsAllowGroupChat"]) {
                                                  actionhtml = "<span style='display: block; text-align: center'><i class='fa fa-check'></i></span>"
                                                  return actionhtml;
                                              }
                                              else {
                                                  actionhtml = "<span style='display: block; text-align: center'><i class='fa fa-times'></i></span>"
                                                  return actionhtml;
                                              }
                                          }
                                      },
                                            {
                                                "sName": "AllowForCreateGroupChat",
                                                "mRender": function (oObj) {
                                                    var actionhtml = '';
                                                    if (oObj["IsAllowToCreateGroupChat"]) {
                                                        actionhtml = "<span style='display: block; text-align: center'><i class='fa fa-check'></i></span>"
                                                        return actionhtml;
                                                    }
                                                    else {
                                                        actionhtml = "<span style='display: block; text-align: center'><i class='fa fa-times'></i></span>"
                                                        return actionhtml;
                                                    }
                                                }
                                            },
                            {
                                "sName": "OfficeName",
                                "mRender": function (oObj) {
                                    return oObj["OfficeName"];
                                }
                            },
                               {
                                   "sName": "JobTitle",
                                   "mRender": function (oObj) {
                                       return oObj["JobTitle"];
                                   }
                               },
                                 {
                                     "sName": "NurseCoordinatorId",
                                     "bSortable": false,
                                     "mRender": function (oObj) {
                                         var actionhtml = '';
                                         @*actionhtml += '<a href="javascript:;" class="btn btn-xs btn-danger" style="margin-top:5px; width:100%;" onclick="DeleteNurseCoordinator(\'' + oObj["NurseCoordinatorId"] + '\',\'' + oObj["UserName"] + '\');">@CaregiverLite.Views.Resources.CareGiver.ButtonDelete</a>'
                                         actionhtml += '<a href="javascript:;" class="btn btn-xs btn-primary" style="margin-top:5px; width:100%;" onclick="EditNurseCoordinator(\'' + oObj["NurseCoordinatorId"] + '\');">EDIT</a>'*@
                                         actionhtml += '<a href="javascript:;"   style="margin-top:5px;margin-left:17px; width:100%;height: 15px;width: 15px;" onclick="EditNurseCoordinator(\'' + oObj["NurseCoordinatorId"] + '\');"><img src="http://ec2-52-38-33-252.us-west-2.compute.amazonaws.com/Content/image/EditIcon.png" alt="Edir Icon"></a>';
                                         actionhtml += '<a href="javascript:;"   style="margin-top:5px;margin-left:28px; width:100%;height: 15px;width: 15px;" onclick="DeleteNurseCoordinator(\'' + oObj["NurseCoordinatorId"] + '\');"><img src="http://ec2-52-38-33-252.us-west-2.compute.amazonaws.com/Content/image/DeleteIcon.png" alt="Delete Icon"> </a>';

                                         return actionhtml;
                                     }
                                 },
                                 {
                                     "sname": "IsActive",
                                     "bSortable": false,
                                     "mRender": function (oObj) {
                                         if (oObj["IsActive"] != "False") {

                                             return '<span class="items-badge">Active</span>'
                                         }
                                         else {
                                             return '<span class="items-badgeInActive">InActive</span>'
                                         }
                                         //  return oObj["IsActive"];
                                     }
                                 }


            ]
        });

        $('#myDataTable_filter input').unbind(); //Unbind direct search on each keypress
        $('#myDataTable_filter input').bind('keyup', function (e) { //Bind Keyup event that filter data only on "Enter" key.
            if (e.keyCode == 13) {
                oTable.search(this.value).draw();
            }
        });
        /* Init DataTables */
        $('.carousel').carousel({
            interval: false
        });

        var config = {
            '.chosen-select': {},
            '.chosen-select-deselect': { allow_single_deselect: true },
            '.chosen-select-no-single': { disable_search_threshold: 10 },
            '.chosen-select-no-results': { no_results_text: 'Oops, nothing found!' },
            '.chosen-select-width': { width: "95%" }
        }
        for (var selector in config) {
            $(selector).chosen(config[selector]);
        }

        $("#loading").hide();
    });


    //Delete One
    function DeleteNurseCoordinator(NurseCoordinatorId1, username) {
        if (confirm('Are you sure you want to delete Office Staff?')) {
            $("#loading").show();
            var url = INITURL + '/NurseCoordinator/DeleteNurseCoordinator';

            $.ajax({
                url: url,
                data: { NurseCoordinatorId: NurseCoordinatorId1, UserName: username },
                cache: false,
                type: 'POST',
                async: false,
                success: function (data) {
                    if (data == "Success") {
                        window.location = INITURL + '/NurseCoordinator/NurseCoordinator';
                    }
                    $("#loading").hide();
                },
                error: function (reponse) {
                    alert("error : " + reponse);
                    $("#loading").hide();
                }
            });
        }
    }

    //Add new
    function OpenAddNew() {
        $("#loading").show();
        console.log(INITURL);
        // $('#AddScheduler').load(INITURL + 'Schedulers/AddScheduler', function () {
        $('#AddNurseCoordinator').load(INITURL + 'NurseCoordinator/AddNurseCoordinator', function () {
            sessionStorage.setItem("PartialView", "1");
            $('#myModal').modal('show');
            $("#loading").hide();
        });
    }

    //Edit One
    function EditNurseCoordinator(NurseCoordinatorId) {
        $("#loading").show();
        $('#EditNurseCoordinator').load(INITURL + '/NurseCoordinator/EditNurseCoordinator/' + NurseCoordinatorId, function () {
            sessionStorage.setItem("PartialView", "1");
            $('#myModal2').modal('show');
            $("#loading").hide();
        });
    }

