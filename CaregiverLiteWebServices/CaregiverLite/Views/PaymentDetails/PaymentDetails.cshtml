}




<style>
    .bg-success {
        background-color: #19bb8c;
    }

    b, strong {
        font-weight: 700;
        color: white;
    }

    label {
        color: blue;
    }

    element.style {
        width: 79px;
    }

    .btn-danger {
        background-color: #ff0047;
        color: #fff;
        text-transform: uppercase;
        letter-spacing: 1px;
        line-height: 25px;
    }

    .btn-primary {
        background-color: #3cb371;
        color: #fff;
        text-transform: uppercase;
        letter-spacing: 1px;
        line-height: 25px;
    }
</style>






<div>
    <div id="myDataTable_wrapper" class="dataTables_wrapper form-inline no-footer">
        <div id="myDataTable_processing" class="dataTables_processing" style="display: none;">
            <div class="loading" id="loading" style="display: block;">
            </div>
        </div>

        <div class="ibox-content">


            <br />
            <table id="myDataTable" class="table table-striped table-bordered table-hover dataTables-example">

                <thead>
                    <tr role="row">

                        <th>Patient ID</th>
                        <th>Patient Name</th>
                        <th style="width: 105px;">Nuese Name</th>
                        <th style="width: 92px;">Date</th>
                        <th>Transaction ID</th>
                        <th style="width: 59px;">Transaction Amount</th>
                        <th>Payment Mode</th>
                        @*<th>medicalid</th>*@
                        <th>PaymentType</th>
                        <th>Payment Status</th>
                    </tr>
                </thead>

            </table>

        </div>

    </div>




</div>
<script src="~/Scripts/js/jquery.dataTables.js"></script>
<script src="~/Scripts/bootstrap.js"></script>
<link rel="stylesheet" href="https://code.jquery.com/ui/1.12.1/themes/base/jquery-ui.css">
<script src="~/Scripts/js/oms.min.js"></script>



