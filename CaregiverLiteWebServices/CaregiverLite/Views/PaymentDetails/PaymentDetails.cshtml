<script>

    var attendanceTable;
    var oTable;
    $(document).ready(function () {
        debugger;
        oTable = $('#myDataTable').DataTable({

            responsive: true,
            "dom": 'lfrtip',

            "bPaginate": true,
            "bServerSide": true,

            "bSortable": true,
            "sPaginationType": "full_numbers",
            "oLanguage": {
                "sProcessing": "<div class=\"loading\" id=\"loading\" style=\"display: block;\"></div>"
            },
            "processing": true,

            "sAjaxSource": "getAppointmentDetailslist",
            "fnServerData": function (sSource, aoData, fnCallback) {
                $.getJSON(sSource, aoData, function (json) {
                    fnCallback(json);
                }).fail(function (jqxhr, textStatus, error) {
                    window.location.reload();
                });
                //debugger;
            },
            "fnServerParams": function (aoData) {
                //debugger;
                aoData.push({ "name": "FilterNurseId", "value": $('#ddlcaregiver1 option:selected').val() });

                //debugger;
            },
            "fnDrawCallback": function (oSettings) {
                //Navigation validation
                debugger;
                //var rowsPerPage =1;

                var rowsPerPage = this.fnSettings()._iDisplayLength;
                var rowsToShow = this.fnSettings().fnRecordsDisplay();
                var table = $('#myDataTable').DataTable();
                var info = table.page.info();
                var currentPageNo = info.page + 1;
                $("#loading").hide();
                debugger;
            },
            "responsive": {
                "details": {
                    "type": 'column'
                }
            },
            "aoColumns": [

                           {
                               "sName": "PatientRequestId",
                               "mRender": function (oObj) {
                                   return '<span>' + oObj["PatientID"] + '</span>';
                               }
                           },
                            {
                                "sName": "Patient Name",
                                "mRender": function (oObj) {
                                    return '<span>' + oObj["Patientname"] + '</span>';
                                }
                            },
                             {
                                 "sName": "NueseName",
                                 "mRender": function (oObj) {
                                     return '<span>' + oObj["Name"] + '</span>';
                                 }
                             },
                           {
                               "sName": "Date",
                               "mRender": function (oObj) {
                                   return oObj["Date"];
                               }
                           },
                            {
                                "sName": "TransactionID",
                                "mRender": function (oObj) {
                                    return oObj["TransactionID"];
                                }
                            },

                             {
                                 "sName": "TransactionAmount",
                                 "bSortable": false,
                                 "mRender": function (oObj) {
                                     return oObj["TransactionAmount"];
                                 }
                             }, {
                                 "sName": "PaymentMode",
                                 "bSortable": false,
                                 "mRender": function (oObj) {
                                     return oObj["PaymentMode"];
                                 }
                             },
                              //{
                              //    "sName": "Commission",
                              //    "bSortable": false,
                              //    "mRender": function (oObj) {
                              //        return oObj["Commission"];
                              //    }
                              //},
                              {
                                  "sName": "NetAmount",
                                  "mRender": function (oObj) {
                                      return oObj["paymentType"];
                                  }
                              },

               {
                                   "sName": "Payment Status",
                                   "mRender": function (oObj) {

                                       debugger;


                                       //if (oObj.PaymentStatus == "Approved") {
                                       //    return '<span style="color:#3cb371;">' + oObj["PaymentStatus"] + '</span>'
                                       //} else {
                                       //    return '<span style="color:#ff0047;">' + oObj["PaymentStatus"] + '</span>'
                                       //}
                                       var actionhtml = '';

                                       if (oObj["PaymentStatus"] == "Approved") {
                                           actionhtml += '<a href="javascript:;" class="btn btn-xs btn-primary"  style="margin-top:5px; width:100%;" ">Approved</a>'
                                       }
                                       else {
                                           debugger;

                                           actionhtml += '<a href="javascript:;" class="btn btn-xs btn-danger" style="margin-top:5px; width:100%;" ">Pending</a>'
                                       }

                                       return actionhtml;

                                   }
                               },



            ]
        });

        //debugger;
        $('#myDataTable_filter input').unbind(); //Unbind direct search on each keypress
        $('#myDataTable_filter input').bind('keyup', function (e) { //Bind Keyup event that filter data only on "Enter" key.
            if (e.keyCode == 13) {
                oTable.search(this.value).draw();
            }
        });
        /* Init DataTables */
        $('.carousel').carousel({
            interval: false
        });

        var config = {
            '.chosen-select': {},
            '.chosen-select-deselect': { allow_single_deselect: true },
            '.chosen-select-no-single': { disable_search_threshold: 10 },
            '.chosen-select-no-results': { no_results_text: 'Oops, nothing found!' },
            '.chosen-select-width': { width: "95%" }
        }
        for (var selector in config) {
            $(selector).chosen(config[selector]);
        }

        $("#loading").hide(); $('#myDataTable_filter input').unbind(); //Unbind direct search on each keypress
        $('#myDataTable_filter input').bind('keyup', function (e) { //Bind Keyup event that filter data only on "Enter" key.

            if (e.keyCode == 13) {
                oTable.search(this.value).draw();
            }

        });
        /* Init DataTables */
        $('.carousel').carousel({
            interval: false
        });

        var config = {
            '.chosen-select': {},
            '.chosen-select-deselect': { allow_single_deselect: true },
            '.chosen-select-no-single': { disable_search_threshold: 10 },
            '.chosen-select-no-results': { no_results_text: 'Oops, nothing found!' },
            '.chosen-select-width': { width: "95%" }
        }
        for (var selector in config) {
            $(selector).chosen(config[selector]);
        }

        $("#loading").hide();

    });

    //Neer ending with pagination

    debugger;




</script>


