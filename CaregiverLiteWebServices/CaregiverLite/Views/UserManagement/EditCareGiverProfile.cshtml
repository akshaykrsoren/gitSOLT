    <script>
        $(document).ready(function () {

            var form = $("#fmEditCareGiver").closest("form");
            form.removeData('validator');
            form.removeData('unobtrusiveValidation');
            $.validator.unobtrusive.parse(form);

            var selectedValues = new Array();
            selectedValues = '@Model.ObjCaregiverModel.Services'.trim().split(',')
            $("#ddlEditService").val(selectedValues);

            
            var config = {
                '.chosen-select': {},
                '.chosen-select-deselect': { allow_single_deselect: true },
                '.chosen-select-no-single': { disable_search_threshold: 10 },
                '.chosen-select-no-results': { no_results_text: 'Oops, nothing found!' },
                '.chosen-select-width': { width: "95%" }
            }
            for (var selector in config) {
                $(selector).chosen(config[selector]);

            }
            $("#loading").hide();
        });


        function GetFullAddress() {

            var Street = $("#Street").val();
            Street = Street.replace(/,\s*$/, "");
            // alert(Street);

            var City = $("#City").val();

            var State = $("#State").val();

            var FullAddress = Street + ', ' + City + ', ' + State;

            $("#hdnAddress").val(FullAddress);
        }

       
      
        function EditNurse() {
           // $('#loading').show();
            var selectedValues = "";

            $("#ddlEditService :selected").each(function () {
                selectedValues += $(this).val() + ",";
            });

            $("#hdnEditServices").val(selectedValues);
           


            if (!GetLanLat()) {
                $('#loading').hide();
                return false
            }

            var result = CheckUserName();
            if (result == false) {
                $("#dvError2").css("display", "");
                $("#lblError2").html("User Name is already exists");
                $('#loading').hide();
                return false;
            }

            var result1 = CheckEmail();
            if (result1 == false) {
                debugger;
                $("#dvError2").css("display", "");
                $("#lblError2").html("Email is already exists");
                $('#loading').hide();
                return false;
            }
            if ($(".radio-inline").find(":checked").val() == undefined) {
                $("#radiobutton").css("padding", "20px 0px");
            }
            else {
                $("#radiobutton").css("padding", "7px 0px");
            }
            
             

            var Address = $("#hdnAddress").val();
            var Pincode = $("#txtZipCode").val();

            var Street = $("#txtStreet").val();
            Street = Street.replace(/,\s*$/, "");

            var City = $("#txtCity").val();
            City = City.replace(/,\s*$/, "");

            var State = $("#txtState").val();
            State = State.replace(/,\s*$/, "");







            if ($('#fmEditCareGiver').valid()) {

                var data = new FormData();
                debugger;

                
                    var objCareGiverModel = {
                        UserId: $("#UserId").val(),
                        NurseId: $("#NurseId").val(),
                        Username: $("#txtUsername").val(),
                        Name: $("#FirstName").val() + ' ' + $("#LastName").val(),
                        FirstName: $("#FirstName").val(),
                        LastName: $("#LastName").val(),
                        //NurseFullName: $("#NurseFullName").val(),
                        Email: $("#Email").val(),
                        OldEmail: $("#OldEmail").val(),
                        ServiceNames: $("#ServiceNames").val(),
                        Services: $("#Services").val(),                        
                        HoursRate: $("#HoursRate").val(),
                        ServiceRadius: $("#ServiceRadius").val(),
                        Phone: $("#Phone").val(),
                        PayrollId: $("#PayrollId").val(),
                        Address: Address,
                        Street: Street,
                        City: City,
                        State: State,
                        ZipCode: Pincode,
                        ProfileImage: $("#ProfileImage").val(),
                        Latitude: $("#hdnLatitude").val(),
                        Longitude: $("#hdnLongitude").val(),
                        /*Password: $("#Password").val(),*/
                        ChargeToPatient: $("#ChargeToPatient").val(),
                        Education: $("#Education").val(),
                        OfficeId: $("#OfficeId").val(),
                        OldOfficeId: $("#OldOfficeId").val(),
                        QuickBloxId: $("#QuickBloxId").val(),
                        IsAllowOneToOneChat: $("#IsAllowOneToOneChat").prop('checked'),
                        IsAllowPatientChatRoom: $("#IsAllowPatientChatRoom").prop('checked'),
                        IsAllowGroupChat: $("#IsAllowGroupChat").prop('checked'),
                        IsAllowToCreateGroupChat: $("#IsAllowToCreateGroupChat").prop('checked')

                   


                }
                debugger;
                data.append("ObjCareGiver", JSON.stringify({ 'CareGiverModelDetail': objCareGiverModel }));
                var url = INITURL + 'UserManagement/UpdateCareGiverProfile';
                $('#loading').show();
               
                $.ajax({
                    url: url,
                    type: "POST",
                    processData: false,
                    contentType: false,
                    data: data,                    
                    success: function (data) {
                        if (data.Result == "Success") {                          
                          //  $('#ProfilemOdeal').modal('show');
                            $('#EditProfilemOdeal').modal('hide');
                            toastr.success('Changes you have made have been applied successfully');
                            window.location.reload();
                        }
                        else {
                            toastr.error('Data Save Failed');
                        }
                        $('#loading').hide();
                    },
                    error: function (reponse) {
                        $('#loading').hide();
                        toastr.error('Data Save Failed');
                    }
                });

            }
            else {
                $('#loading').hide();
            }

        }


        function GetFullAddress() {

            var Street = $("#Street").val();
            Street = Street.replace(/,\s*$/, "");
            // alert(Street);

            var City = $("#City").val();

            var State = $("#State").val();

            var FullAddress = Street + ', ' + City + ', ' + State;

            $("#hdnAddress").val(FullAddress);
        }

        function GetLanLat() {
            //  var Address = $("#txtAddress").val();

            //debugger;
            //    var Address = $("#Address").val();
            var Street = $("#txtStreet").val();
            Street = Street.replace(/,\s*$/, "");
            //  alert(Street);

            //  var Address =$("#Address").val().replace('&','-');

            var City = $("#txtCity").val();
            City = City.replace(/,\s*$/, "");

            var State = $("#txtState").val();
            State = State.replace(/,\s*$/, "");

            var FullAddress = Street + ', ' + City + ', ' + State;

            $("#hdnAddress").val(FullAddress);

            FullAddress = FullAddress.replace('&', '-');

            var Pincode = $("#txtZipCode").val();
            if (Street !== '') {
                if (City !== '') {
                    if (State !== '') {
                        var flag = true;
                        $.ajax({
                            type: "GET",
                            url: "https://maps.google.com/maps/api/geocode/json",
                            data: "address=" + FullAddress + "&key=AIzaSyCqG0NdAH_5gP1_D8jGhmTGeqNR-9z_afw",
                            async: false,
                            contentType: "text/plain; charset=utf-8",
                            dataType: "json",
                            success: function (result) {
                                if (result["status"] == "OK") {

                                    $("#hdnLatitude").val(result["results"][0]["geometry"]["location"]["lat"]);
                                    $("#hdnLongitude").val(result["results"][0]["geometry"]["location"]["lng"]);
                                    //alert(result["results"][0]["geometry"]["location"]["lat"]);
                                    //alert(result["results"][0]["geometry"]["location"]["lng"]);


                                    //$("#fmEditCareGiver").submit();
                                }
                                else if (result.status === "ZERO_RESULTS") {
                                    Pincode = $("#txtZipCode").val();
                                    //-------------------Only Pincode--------------------
                                    $.ajax({
                                        type: "GET",
                                        url: "https://maps.google.com/maps/api/geocode/json",
                                        data: "address=" + Pincode + "&key=AIzaSyCqG0NdAH_5gP1_D8jGhmTGeqNR-9z_afw",
                                        async: false,
                                        contentType: "text/plain; charset=utf-8",
                                        dataType: "json",
                                        success: function (result) {
                                            if (result["status"] == "OK") {
                                                $("#hdnLatitude").val(result["results"][0]["geometry"]["location"]["lat"]);
                                                $("#hdnLongitude").val(result["results"][0]["geometry"]["location"]["lng"]);

                                                //alert(result["results"][0]["geometry"]["location"]["lat"]);
                                                //alert(result["results"][0]["geometry"]["location"]["lng"]);
                                            }
                                            else {
                                                alert('Address is invalid');
                                                toastr.error('Please enter valid street/city/state with valid zip code');
                                                flag = false;
                                            }

                                            //$("#fmEditCareGiver").submit();
                                        }
                                    });
                                    //----------End Only Pincode-----------------------------
                                }
                            }
                        });

                    } else {
                        toastr.error('Please Enter State');
                    }
                }
                else {
                    toastr.error('Please Enter City');
                }
            } else {
                toastr.error('Please Enter Street');
            }
            //----------End Pincode+Address----------------
            return flag;
        }


        function divClose() {
            $("#dvError2").css("display", "none");
        }

        function CheckUserName() {
            var url = INITURL + '/CareGiver/IsUserNameExists';
            var result;
            $.ajax({
                url: url,
                data: { Username: $("#Username").val(), UserId: $("#UserId").val() },
                cache: false,
                async: false,
                type: 'POST',
                success: function (data) {
                    result = data;
                },
