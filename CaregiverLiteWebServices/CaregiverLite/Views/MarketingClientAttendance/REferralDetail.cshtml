<style>
    .color {
        color: #055175;
    }

    table {
        border-collapse: collapse;
    }

    td {
        padding-top: .5em;
        padding-bottom: .5em;
    }

    #ui-datepicker-div {
        z-index: 10000 !important;
    }

    .form-calender {
        padding: 0 15px;
    }

    .para {
        color: white;
    }

    .container {
        margin-top: 80px;
        width: 800px;
    }

    .content {
        position: relative;
    }

    .icon1 {
        background-image: url(../../Content/css/img/schedule_black_24dp.png);
        background-size: 20px;
        background-repeat: no-repeat;
        background-position: 135px;
    }

    .errordatetime {
        border: 1px solid red;
    }
</style>






<div class="col-md-12">

    <table class="table table-striped table-bordered table-hover dataTables-example dataTable no-footer dtr-column" role="grid" aria-describedby="myDataTable_info">
        <thead>


            <tr>
                <th style="width:auto"><b style="color:#088bca">Pateint Name</b></th>
                <th style="width:auto"><b style="color:#088bca">Mobile Mumber</b></th>
                <th style="width:auto"><b style="color:#088bca">Insurance</b></th>
                <th style="width:auto"><b style="color:#088bca">Patient Admitted</b></th>
                <th style="width:auto"><b style="color:#088bca">Reason</b></th>
            </tr>

        </thead>
        <tbody>







            @foreach (var item in ViewBag.ReferralDetailList)
            {

                <tr>


                    <td>@item.ClientName</td>
                    <td>@item.PhoneNo</td>
                    <td>@item.Insurance</td>
                    <td>@item.AdmissionStatus</td>
                    <td>@item.Reason</td>

                </tr>

            }

        </tbody>
    </table>
</div>









