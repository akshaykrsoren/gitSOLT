<head>
    <title>PaSeva</title>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/bootstrap/3.4.1/css/bootstrap.min.css">
    <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
    <script src="https://maxcdn.bootstrapcdn.com/bootstrap/3.4.1/js/bootstrap.min.js"></script>
    <link rel="icon" type="image/x-icon" href="http://ec2-52-38-33-252.us-west-2.compute.amazonaws.com/Content/image/Title_icon.png">
    <link href='https://fonts.googleapis.com/css?family=Open Sans' rel='stylesheet'>
</head>
 
 
 


<style>
    .form-outline {
        margin-top: 12px;
        padding-bottom: 9px;
    }

    .form-check {
        padding-bottom: 9px;
    }

    .leftdiv {
        text-align: center;
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%,-50%);
        width: 100%;
    }

     

     

     

     
    img {
        max-width: 100%;
        /*object-fit: cover;*/
    }

    @@media(max-width:768px) {
        img {
            width: 100%;
        }
    }
</style>

<div class="container-fluid" style="padding-left:0px">
    <div class="row">
        <div class="col-md-7  col-sm-7 col-xs-7" style="height: 100%;">             
            <div class="leftdiv">
                <img id="pasevalogo" src="http://ec2-52-38-33-252.us-west-2.compute.amazonaws.com/Content/image/ForgetPasswordLeftImage.png" style="height: 130px;" />

            </div>
            
        </div>
        <div class="col-md-5  col-sm-5 col-xs-5" style="color: #1B1B1C">

            <div class="row" style="margin-top:40%">
                @using (Html.BeginForm("ForgotPassword", "Account", FormMethod.Post, new { @id = "fmForgotPassword", @class = "horizontal-form", @enctype = "multipart/form-data" }))
              {
                    @Html.AntiForgeryToken()
                    @Html.ValidationSummary(true)
                   
                        <div class="col-md-12">
                            <img style="text-align: left;height: 30px;" src="http://ec2-52-38-33-252.us-west-2.compute.amazonaws.com/Content/image/ForgetPasswordIcon.png" />
                            <span style="font-weight: bold;  color: #1F305B;font-size:18px"><b>Forget Password</b></span>

                        </div>
                        <div class="col-md-12" style="margin-top:20px">
                            <div class="form-outline mb-4 ">
                                

                                <span class="form-check-label" for="form1Example3" style="color:#777;font-size: 13px;padding-left: 6px;">Enter your registered email address</span>
                                @Html.TextBoxFor(model => model.Email, new { @type = "email", @class = "form-control", @placeholder = @CaregiverLite.Views.Resources.Account.PlaceHolderEmail, @style= "width:60%;margin-top:8px;margin-bottom:8px" })
                                <span id="spError" style="color:red"></span>
                             </div>
                            
                        </div>
                        <div class="col-md-12" style="margin-top:15px">
                         @*   <button type="button" onclick="submitform();" class="btn btn-primary block full-width m-b">@CaregiverLite.Views.Resources.Account.ButtonSubmit</button>*@
                            <button class="btn btn-primary btn-lg btn-block" type="button" style="background-color: #1F305B;border: none;height: 44px; font-size: 15px;width:60%; padding: 0px;" onclick="submitform();">
                                Continue
                            </button>
                        </div>
                        <div class="col-md-12" style="margin-top:15px">
                            <span  style="margin-left: 23%;font-weight: bold; " ><a  style="color: #1F305B;" href="@Url.Action("Login", "Account")">Back to Login</a></span>

                        </div>
                       
                 

                }
            </div>
        </div>
    </div>
</div>
 
<script>
    $(document).ready(function () {
        var tempMsg = '@TempData["message"]';
        if (tempMsg != "") {
                      $("#spError").html(tempMsg);
        }
        else {
            $("#spError").html("");
        }
    });

    function submitform() {
        if ($("#Email").val() != "") {
            $("#fmForgotPassword").submit();
        }
        else {
            debugger;
            $("#spError").html('@CaregiverLite.Views.Resources.Account.RequiredMsgEmail');
            return false;
        }
    }
</script> 
