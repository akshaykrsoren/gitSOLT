@model CaregiverLite.Models.CareGiverModel
<style>
    .file_div {
        height: auto;
    }

    .custom-checkbox {
        width: 20px;
        height: 20px;
        display: inline-block;
        position: relative;
        z-index: 1;
        top: 3px;
        background: url("../image/checkbox.png") no-repeat;
        cursor: pointer;
    }

        .custom-checkbox.selected {
            background: url("../image/checkbox-selected.png") no-repeat;
        }

        .custom-checkbox input[type="checkbox"] {
            margin: 0;
            position: absolute;
            z-index: 2;
            cursor: pointer;
            outline: none;
            opacity: 0;
        }
</style>
@using (Html.BeginForm("EditCareGiver", "CareGiver", FormMethod.Post, new { @id = "fmEditCareGiver", @class = "horizontal-form", @enctype = "multipart/form-data" }))
{
    <div class="ibox-content">
        <div class="row">
            <div class="alert alert-danger alert-dismissable" style="display:none" id="dvError2">
                <button onclick="divClose();" class="close" type="button">×</button>
                <label id="lblError2"></label>
            </div>
            <div class="col-md-6">
                <div class="form-group">
                    <label>@CaregiverLite.Views.Resources.CareGiver.TableHeaderName</label>
                    @Html.ValidationMessageFor(model => model.Name)
                    @Html.TextBoxFor(model => model.Name, new { @type = "text", @maxlength = "256", @placeholder = @CaregiverLite.Views.Resources.CareGiver.PlaceHolderName, @class = "form-control" })
                </div>
                <div class="form-group">

                    @Html.HiddenFor(model => model.NurseId)
                    @Html.HiddenFor(model => model.UserId)
                    <label>@CaregiverLite.Views.Resources.CareGiver.TableHeaderServices</label>
                    @Html.ValidationMessageFor(model => model.ServiceNames)
                    <div class="form-group">
                        @Html.DropDownList("ddlEditService", new MultiSelectList(@ViewBag.ServiceList, "ServiceId", "ServiceName"), new { @multiple = "multiple", @class = "chosen-select" })
                        @Html.HiddenFor(model => model.ServiceNames, new { @id = "hdnEditServices" })
                    </div>
                </div>
                <div class="form-group">
                    <label>@CaregiverLite.Views.Resources.CareGiver.TableHeaderUserName (This cannot be edited)</label>
                    @Html.ValidationMessageFor(model => model.Username)
                    @Html.TextBoxFor(model => model.Username, new { @type = "text", @maxlength = "256", @placeholder = @CaregiverLite.Views.Resources.CareGiver.PlaceHolderUserName, @class = "form-control", @readonly = "readonly" })
                </div>
                <div class="form-group">
                    <label>@CaregiverLite.Views.Resources.CareGiver.TableHeaderEmail (This cannot be edited)</label>
                    @Html.ValidationMessageFor(model => model.Email)
                    @Html.TextBoxFor(model => model.Email, new { @type = "email", @maxlength = "100", @placeholder = @CaregiverLite.Views.Resources.CareGiver.PlaceHolderEmail, @class = "form-control", @readonly = "readonly" })
                </div>
                <div class="form-group">
                    <label>Complete Address (Enter Street, City & State)</label>
                    @Html.ValidationMessageFor(model => model.Address)
                    @Html.TextBoxFor(model => model.Address, new { @type = "text", @placeholder = @CaregiverLite.Views.Resources.CareGiver.PlaceHolderAddress, @class = "form-control" })
                </div>
                <div class="form-group">
                    <label>@CaregiverLite.Views.Resources.CareGiver.TableHeaderZipCode</label>
                    @Html.ValidationMessageFor(model => model.ZipCode)
                    @Html.TextBoxFor(model => model.ZipCode, new { @type = "text", @maxlength = "10", @placeholder = @CaregiverLite.Views.Resources.CareGiver.PlaceHolderAddress, @class = "form-control" })
                </div>
                <div class="form-group">
                    <label>@CaregiverLite.Views.Resources.CareGiver.PlaceHolderEducation</label>
                    @Html.ValidationMessageFor(model => model.Education)
                    @Html.TextBoxFor(model => model.Education, new { @type = "text", @placeholder = @CaregiverLite.Views.Resources.CareGiver.PlaceHolderEducation, @class = "form-control" })
                </div>
            </div>
            <div class="col-md-6">
                <div class="form-group">
                    <label>@CaregiverLite.Views.Resources.CareGiver.TableHeaderHourRate</label>
                    @Html.HiddenFor(model => model.OldHoursRate, new { @Value = @Model.HoursRate })
                    @Html.ValidationMessageFor(model => model.HoursRate)
                    <div class="input-group">
                        <span class="input-group-addon">$</span>
                        @Html.TextBoxFor(model => model.HoursRate, new { @type = "text", @maxlength = "6", @placeholder = @CaregiverLite.Views.Resources.CareGiver.PlaceHolderHourRate, @class = "form-control" })
                    </div>
                </div>
                <div class="form-group">
                    <label>@CaregiverLite.Views.Resources.CareGiver.TableHeaderPhone</label>
                    @Html.ValidationMessageFor(model => model.Phone)
                    @Html.TextBoxFor(model => model.Phone, new { @type = "text", @autocomplete = "off", @maxlength = "100", @onkeypress = "return isNumber(event)", @placeholder = @CaregiverLite.Views.Resources.CareGiver.PlaceHolderPhone, @class = "form-control" })
                </div>
                <div class="form-group">
                    <label for="exampleInputFile">@CaregiverLite.Views.Resources.CareGiver.LabelPhotoUpload</label>
                    @Html.ValidationMessageFor(model => model.ProfileImage)
                    @Html.HiddenFor(model => model.ProfileImage)
                    <img src="@Model.ProfileImage" id="ImgProfileImage" width="100%" style="margin-bottom:10px" />
                    @Html.TextBoxFor(model => model.ProfileImageFile, new { @type = "file", @class = "form-control file_div", @accept = "image/*", @id = "EditProfileImageFile" })
                </div>
                <div class="form-group">
                    <label for="exampleInputFile">Video Upload</label>
                    @Html.ValidationMessageFor(model => model.ProfileVideo)
                    @Html.HiddenFor(model => model.ProfileVideo)
                    @Html.TextBoxFor(model => model.ProfileVideoFile, new { @type = "file", @class = "form-control file_div", @accept = "video/*", @id = "EditProfileImageFile" })
                </div>
                @{var selected = Model.CanAdminEdit == true ? "selected" : "";}
                <div class="form-group">
                    <label></label>
                    <div disabled>
                        <label>
                            <span id="spCanEdit" class="custom-checkbox @selected" style="width:auto">
                                <input onclick="changecheck();" id="chk" type="checkbox">
                                <span style="padding-left:30px">Admin can Edit profile</span>
                            </span>
                        </label>
                    </div>
                    @Html.HiddenFor(model => model.CanAdminEdit)
                    @Html.HiddenFor(model => model.ChargeToPatient)
                </div>

            </div>
            <div class="clearfix"></div>
            <div class="col-md-12">
                <div class="form-group pull-left">
                    @Html.HiddenFor(model => model.Latitude, new { @id = "hdnLatitude" })
                    @Html.HiddenFor(model => model.Longitude, new { @id = "hdnLongitude" })
                    <label class="control-label">@CaregiverLite.Views.Resources.CareGiver.TableHeaderServiceRadius</label>
                    @Html.ValidationMessageFor(model => model.ServiceRadius)

                    @*<label class="radio-inline">
                            @Html.RadioButtonFor(model => model.ServiceRadius, "15", new { @value = "15", @type = "radio", @class = "radio-inline", @name = "inlineCheckbox" }) 15 Miles
                        </label>
                        <label class="radio-inline">
                            @Html.RadioButtonFor(model => model.ServiceRadius, "30", new { @value = "30", @type = "radio", @class = "radio-inline", @name = "inlineCheckbox" }) 30 Miles
                        </label>
                        <label class="radio-inline">
                            @Html.RadioButtonFor(model => model.ServiceRadius, "70", new { @value = "70", @type = "radio", @class = "radio-inline", @name = "inlineCheckbox" }) 70 Miles
                        </label>*@
                    @Html.DropDownListFor(model => model.ServiceRadius, ViewData["Radious"] as List<SelectListItem>, "Select service radius", new { @class = "form-control" })

                </div>
                @Html.HiddenFor(model => model.Latitude, new { @id = "hdnLatitude" })
                @Html.HiddenFor(model => model.Longitude, new { @id = "hdnLongitude" })
                <button type="button" onclick="EditNurse()" class="btn btn-sm btn-primary pull-right">@CaregiverLite.Views.Resources.CareGiver.HeaderEditCareGiver</button>
            </div>
        </div>

        <div class="clearfix"></div>
    </div>
}
<script src="~/Scripts/jquery.unobtrusive-ajax.js"></script>

<script type="text/javascript">


    $(document).ready(function () {


        var selectedValues = new Array();
        selectedValues = '@Model.Services'.trim().split(',')
        $("#ddlEditService").val(selectedValues);


        var config = {
            '.chosen-select': {},
            '.chosen-select-deselect': { allow_single_deselect: true },
            '.chosen-select-no-single': { disable_search_threshold: 10 },
            '.chosen-select-no-results': { no_results_text: 'Oops, nothing found!' },
            '.chosen-select-width': { width: "95%" }
        }
        for (var selector in config) {
            $(selector).chosen(config[selector]);

        }
    });

    $.validator.setDefaults({
        ignore: [],
    });

    function changecheck() {
        $("#spCanEdit").toggleClass('selected');
    }

    function isNumber(evt) {
        evt = (evt) ? evt : window.event;
        var charCode = (evt.which) ? evt.which : evt.keyCode;
        if (charCode > 31 && (charCode < 48 || charCode > 57)) {
            return false;
        }
        return true;
    }




</script>

<script>

    function divClose() {
        $("#dvError2").css("display", "none");
    }

    function CheckUserName() {
        var url = INITURL + '/CareGiver/IsUserNameExists';
        var result;
        $.ajax({
            url: url,
            data: { Username: $("#Username").val(), UserId: $("#UserId").val() },
            cache: false,
            async: false,
            type: 'POST',
            success: function (data) {
                result = data;
            },
            error: function (reponse) {
                alert("error : " + reponse);
            }
        });
        return result;
    }

    function CheckEmail() {
        var url = INITURL + '/CareGiver/IsEmailExists';
        var result;
        $.ajax({
            url: url,
            data: { Email: $("#Email").val(), UserId: $("#UserId").val() },
            cache: false,
            async: false,
            type: 'POST',
            success: function (data) {
                result = data;
            },
            error: function (reponse) {
                alert("error : " + reponse);
            }
        });
        return result;
    }


    function EditNurse() {
        var selectedValues = "";
        $("#loading").show();

        var canedit = $("#spCanEdit").hasClass("selected") == true ? true : false;
        $("#CanAdminEdit").val(canedit);

        var result = CheckUserName();
        if (result == false) {
            $("#dvError2").css("display", "");
            $("#lblError2").html("User Name is already exists");
            $('#loading').hide();
            return false;
        } else {
            $("#dvError3").css("display", "none");
        }

        var result1 = CheckEmail();
        if (result1 == false) {
            $("#dvError2").css("display", "");
            $("#lblError2").html("Email is already exists");
            $('#loading').hide();
            return false;
        } else {
            $("#dvError3").css("display", "none");
        }

        $("#ddlEditService :selected").each(function () {
            selectedValues += $(this).val() + ",";
        });

        $("#hdnEditServices").val(selectedValues);
        if (GetLanLat()) {
            $("#fmEditCareGiver").submit();
        }
        $("#loading").hide();
    }

    var tempMsg = '@TempData["Message"]';
    //  alert(tempMsg);
    if (tempMsg != "")
        toastr.success(tempMsg);

    sessionStorage.setItem("PartialView", "1");


    function GetLanLat() {
        var Address = $("#Address").val();
        var Pincode = $("#ZipCode").val();
        var flag = true;
        $.ajax({
            type: "GET",
            url: "https://maps.google.com/maps/api/geocode/json",
            data: "address=" + Address + "&key=AIzaSyDCQgMe2fLgmaF9GDvxF61wsIXnktEBKhg",
            async: false,
            contentType: "text/plain; charset=utf-8",
            dataType: "json",
            success: function (result) {

                //alert(result.status);
                if (result["status"] == "OK") {

                    $("#hdnLatitude").val(result["results"][0]["geometry"]["location"]["lat"]);
                    $("#hdnLongitude").val(result["results"][0]["geometry"]["location"]["lng"]);
                    //alert(result["results"][0]["geometry"]["location"]["lat"]);
                    //alert(result["results"][0]["geometry"]["location"]["lng"]);

                    //$("#fmEditCareGiver").submit();
                }
                else if (result.status === "ZERO_RESULTS") {
                    Pincode = $("#ZipCode").val();
                    //-------------------Only Pincode--------------------
                    $.ajax({
                        type: "GET",
                        url: "https://maps.google.com/maps/api/geocode/json",
                        data: "address=" + Pincode + "&key=AIzaSyDCQgMe2fLgmaF9GDvxF61wsIXnktEBKhg",
                        async: false,
                        contentType: "text/plain; charset=utf-8",
                        dataType: "json",
                        success: function (result) {

                            //alert(result["status"]);
                            if (result["status"] == "OK") {

                                $("#hdnLatitude").val(result["results"][0]["geometry"]["location"]["lat"]);
                                $("#hdnLongitude").val(result["results"][0]["geometry"]["location"]["lng"]);
                                return true;
                                //alert(result["results"][0]["geometry"]["location"]["lat"]);
                                //alert(result["results"][0]["geometry"]["location"]["lng"]);
                            }
                            else {
                                alert('Address is invalid');
                                $("#loading").hide();
                                flag = false;
                            }

                            //$("#fmEditCareGiver").submit();
                        }
                    });
                    //----------End Only Pincode-----------------------------
                }

            }

        });

        //----------End Pincode+Address----------------
        return flag;
    }
</script>