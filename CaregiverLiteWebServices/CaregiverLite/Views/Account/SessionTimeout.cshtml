@model CaregiverLite.Models.LoginModel
@{
    ViewBag.Title = @CaregiverLite.Views.Resources.Account.TitleLogin;
    Layout = null;
    //"~/Views/shared/_LoginLayout.cshtml";
}
<head>
    <title>PaSeva</title>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/bootstrap/3.4.1/css/bootstrap.min.css">
    <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
    <script src="https://maxcdn.bootstrapcdn.com/bootstrap/3.4.1/js/bootstrap.min.js"></script>
    <link rel="icon" type="image/x-icon" href="http://ec2-52-38-33-252.us-west-2.compute.amazonaws.com/Content/image/Title_icon.png">
</head>

<style>
    span.field-validation-error {
        color: red;
        display: block;
        text-align: right;
        float: none;
    }
</style>

<script>
        $(document).ready(function () {

            debugger;
            localStorage.clear();
            sessionStorage.clear();

            var tempMsg = '@TempData["message_login"]';
            if (tempMsg != "") {
                if ('@TempData["LoginError"]' == "true") {
                    $("#LoginError").html(tempMsg);
                }
                else {
                    $("#spError").html(tempMsg);
                }
            }
            else {
                $("#spError").html("");
            }
        });
</script>



<style>
    .form-outline {
        margin-top: 12px;
        padding-bottom: 9px;
    }

    .form-check {
        padding-bottom: 9px;
    }

    .leftdiv {
        text-align: center;
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%,-50%);
        width: 100%;
    }

    .rightdiv {
        padding: 60px 45px 0px 45px;
    }

    .leftImage {
        height: 100vh;
        background-size: cover;
        background-repeat: no-repeat;
        background-image: url('http://ec2-52-38-33-252.us-west-2.compute.amazonaws.com/Content/image/Group427318954.png');
    }
     .sesssionExpirebox {
    
    position: absolute;
    top: 50%;
    z-index: 20;
    background-color: white;
    width: 26%;
    left: 50%;
    transform: translate(-50%, -50%);
    padding: 30px 30px 30px 30px;
    text-align: center;
    border-radius: 9px;}
    .sessionfontcolor {
        color: #1F305B
    }
</style>

<div class="container-fluid" style="padding-right: 0px;    padding-left: 0px;    margin-right: auto;    margin-left: auto;    overflow: hidden;">
    <div class="row">


        <div class="col-md-12" style="position:relative">
            <img src="http://ec2-52-38-33-252.us-west-2.compute.amazonaws.com/Content/image/SessionsError.png" style="width: 100%;height: 100vh;" />


            <div style="position: absolute;  bottom: 25px;right: -36px;;transform: translate(-50%, 10px);">
                <p style="color: white;text-align: center;"> Copyright © 2025 Care Giver</p>
            </div>
        </div>
        <div class="col-md-5 text-black sesssionExpirebox">
            <div>
                <div>
                    <img style="text-align: left;height: 65px;" src="http://ec2-52-38-33-252.us-west-2.compute.amazonaws.com/Content/image/Paseva_CompleteLogo.png">


                </div>
                <h3><b style="font-size:20px;" class="sessionfontcolor"> Session Expired</b></h3>
                <p style="margin-bottom: 23px; " class="sessionfontcolor">
                    Your session timed out after a long time of inactivity.
                </p>
                <p><b class="sessionfontcolor" style="font-size:13px;"> Please, Login again.</b>  </p>

                <a href="~/Account/Login" class="btn btn-primary btn-lg btn-block" style="width: 100%;background-color: #1F305B;border: none;">Proceed to Login</a>


            </div>
        </div>
    </div>
</div>


