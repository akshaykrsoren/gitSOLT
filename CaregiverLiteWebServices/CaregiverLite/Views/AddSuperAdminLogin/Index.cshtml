
@{
    Layout = null;
}

<!DOCTYPE html>

<html>
<head>
    <title>Assign Super Admin Role To Users</title>

    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <!-- CSS START -->
    <link href="~/Content/css/bootstrap.min.css" rel="stylesheet">
    <link href="~/Content/font-awesome/css/font-awesome.css" rel="stylesheet">
    <link href="~/Content/css/bootstrap-datetimepicker.css" rel="stylesheet">
    <link href="~/Content/css/dataTables.bootstrap.css" rel="stylesheet">
    <link href="~/Content/css/dataTables.responsive.css" rel="stylesheet">
    <link href="~/Content/css/dataTables.tableTools.min.css" rel="stylesheet">
    <link href="~/Content/css/animate.css" rel="stylesheet">
    <link href="~/Content/css/style.css" rel="stylesheet">
    <link href="~/Content/css/chosen.css" rel="stylesheet">
    <link href="~/Content/css/switchery.css" rel="stylesheet">
    <link href="~/Content/css/fullcalendar.css" rel="stylesheet">
    <link href="~/Content/css/toastr.css" rel="stylesheet" />
    <link href="~/Content/css/fullcalendar.print.css" rel='stylesheet' media='print'>
    <style>
        body {
            background-image: url('/Content/image/bg.jpg');
            background-position: bottom center;
            background-repeat: no-repeat;
            background-attachment: fixed;
            background-size: cover;
        }

        span.field-validation-error {
            float: right;
            color: red;
        }
    </style>


</head>
<body class="white-bg">
    <div style="background:rgba(0,0,0,0.5); height:100vh;">
        <div>
            <div class="middle-box text-center loginscreen  animated fadeInDown">
                <div style="background:#f5f5f5;padding:0 10px;border-radius:10px;">
                    <h1 class="logo-name">PaSeva</h1>

                    @using (Html.BeginForm())
                    {
                        <div class="form-group">
                            @Html.TextBox("txtAddSuperAdminLoginUser", null, new { @type = "text", @required = "required", @class = "form-control", @placeholder = "User Name", @autocomplete="Off" })
                        </div>

                        <div class="form-group">
                            @Html.TextBox("txtAddSuperAdminPassword", null, new { @type = "password", @required = "required", @class = "form-control", @placeholder = "Password" })
                        </div>

                            <div class="form-group">
                                <button type="submit" class="btn btn-primary block full-width m-b">
                                    Submit
                                </button>
                            </div>
                    }
                    <p class="m-t" style="padding-bottom:10px;">@CaregiverLite.Views.Resources.Layout.FooterCopyright</p>
                </div>
                <div class="clearfix"></div>
            </div>
        </div>

    </div>
</body>
</html>
