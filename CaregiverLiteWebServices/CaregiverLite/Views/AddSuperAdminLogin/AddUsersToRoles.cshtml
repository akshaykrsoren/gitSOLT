@*@model IEnumerable<CaregiverLite.Models.AddSuperAdminLoginDetails>*@

@model CaregiverLite.Models.AddSuperAdminLoginDetails
@{
    Layout = null;
}

<!DOCTYPE html>

<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Add Users To Other Roles</title>

    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <!-- CSS START -->
    <link href="~/Content/css/bootstrap.min.css" rel="stylesheet">
    <link href="~/Content/font-awesome/css/font-awesome.css" rel="stylesheet">
    <link href="~/Content/css/bootstrap-datetimepicker.css" rel="stylesheet">
    <link href="~/Content/css/dataTables.bootstrap.css" rel="stylesheet">
    <link href="~/Content/css/dataTables.responsive.css" rel="stylesheet">
    <link href="~/Content/css/dataTables.tableTools.min.css" rel="stylesheet">
    <link href="~/Content/css/animate.css" rel="stylesheet">
    <link href="~/Content/css/style.css" rel="stylesheet">
    <link href="~/Content/css/chosen.css" rel="stylesheet">
    <link href="~/Content/css/switchery.css" rel="stylesheet">
    <link href="~/Content/css/fullcalendar.css" rel="stylesheet">
    <link href="~/Content/css/toastr.css" rel="stylesheet" />
    <link href="~/Content/css/fullcalendar.print.css" rel='stylesheet' media='print'>

   <!--  For Pagination  Library--> 
    @*<script src="~/Scripts/js/jquery-2.1.1.js"></script>*@
    <script src="//ajax.googleapis.com/ajax/libs/jquery/1.7.1/jquery.min.js"></script>
    <link rel="stylesheet" href="http://cdn.datatables.net/1.10.2/css/jquery.dataTables.min.css">
    <script type="text/javascript" src="http://cdn.datatables.net/1.10.2/js/jquery.dataTables.min.js"></script>
    <script type="text/javascript" src="http://maxcdn.bootstrapcdn.com/bootstrap/3.2.0/js/bootstrap.min.js"></script>
   <!-- End For Pagination  Library -->

</head>
<body>
    <div class="loading" id="loading" style="display: none;">
    </div>
    <div class="wrapper wrapper-content animated fadeInRight">
        <div class="row">
            <div class="col-lg-12">
                <div class="ibox float-e-margins">
                    <div class="ibox-title">
                        <h5>Assign roles to Users</h5>
                        <div class="ibox-tools">
                            @*<a class="btn btn-xs btn-primary" style="margin-top:-9px;" href="javascript:;" onclick="OpenAddNew()">Add Office Staff</a>*@
                            <div class="clearfix"></div>
                        </div>
                    </div>
                    <div class="ibox-content">
                        <div class="row">
                            <div class="form-group col-md-2 pull-right">                               
                                </br>                               
                            </div>
                        </div>
                        
                        @if (Model != null)
                        {
                            if (Model.AddSuperAdminLoginInfo.Count > 0)
                            {
                                <table id="myDataTable" class="table table-striped table-bordered table-hover dataTables-example">
                                    <thead>
                                        <tr>                                            
                                            @*<th style="background-color: white;">UserId</th>*@
                                            <th style="background-color: white;">Name</th>
                                            <th style="background-color: white;">Email</th>
                                            @*<th style="background-color: white;">User Name</th>*@
                                            <th style="background-color: white; width: 100px;">Action</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var item in Model.AddSuperAdminLoginInfo)
                                        {
                                            <tr>
                                                @*<td>@Html.DisplayFor(modelitem => item.UserId) </td>*@                                                
                                                <td>@Html.DisplayFor(modelitem => item.Name)</td>
                                                <td>@Html.DisplayFor(modelitem => item.Email)</td>
                                                @*<td>@Html.DisplayFor(modelitem => item.UserName)</td>*@
                                                <td>
                                                    @if (item.RoleName == "SuperAdmin")
                                                    {
                                                <a href="javascript:;" class="btn btn-xs btn-danger" style="margin-top:5px; width:100%;" onclick="ReassignRoleToUser('@item.UserId', '@item.Email')">REMOVE ROLE AS SUPER ADMIN</a>
                                                    }
                                                    else if (item.RoleName == "Nurse" || item.RoleName == "Admin" || item.RoleName == "NurseCoordinator")
                                                    {
                                                <a href="javascript:;" class="btn btn-xs btn-primary" style="margin-top:5px; width:100%;" onclick="AssignRoleToUser('@item.UserId');">ASSIGN ROLE AS SUPER ADMIN</a>
                                                    }
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            }
                            else
                            {
                                <b>No Details Found.</b>
                            }
                        }
                </div>
            </div>
        </div>
    </div>
</div>
</body>
</html>

@*<script src="~/Scripts/js/jquery-2.1.1.js"></script>
<script src="~/Scripts/js/jquery.dataTables.js"></script>
<link rel="stylesheet" href="https://code.jquery.com/ui/1.12.1/themes/base/jquery-ui.css">
<script src="~/Scripts/js/oms.min.js"></script>*@

<script>
$(document).ready(function(){
    $('#myDataTable').dataTable();
});
</script>


<script type="text/javascript">

    //Assigning Role to user
    function AssignRoleToUser(UserId) {      
        if (confirm('Are you sure you want assing role?')) {
            $("#loading").show();
            var url = '/AddSuperAdminLogin/AssignRolerToUser';

            $.ajax({
                url: url,
                data: { UserId: UserId },
                cache: false,
                type: 'POST',
                async: false,
                success: function (data) {
                    if (data == "Success") {
                        window.location = '/AddSuperAdminLogin/AddUsersToRoles';
                    }
                    $("#loading").hide();
                },
                error: function (reponse) {
                    alert("error : " + reponse);
                    $("#loading").hide();
                }
            });
        }
    }

    //Reassign Role to User

    function ReassignRoleToUser(UserId, Email) {
        if (confirm('Are you sure you want reassing role?')) {
            $("#loading").show();
            var url = '/AddSuperAdminLogin/ReassignRoleToUser';

            $.ajax({
                url: url,
                data: { UserId: UserId, Email: Email },
                cache: false,
                type: 'POST',
                async: false,
                success: function (data) {
                    if (data == "Success") {
                        window.location = '/AddSuperAdminLogin/AddUsersToRoles';
                    }
                    $("#loading").hide();
                },
                error: function (reponse) {
                    alert("error : " + reponse);
                    $("#loading").hide();
                }
            });
        }
    }


</script>           