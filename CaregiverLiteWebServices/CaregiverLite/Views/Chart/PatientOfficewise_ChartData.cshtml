

<div id="Chart5" style="height: 300px"></div>
<script>


    $(document).ready(function () {

        var NurseList = @Html.Raw(Json.Encode(ViewBag.PatientBasedOnOfficeList_VisitChart));
        var OfficeCountList = @Html.Raw(Json.Encode(ViewBag.PatientBasedOnOfficeCount_VisitChart));
        debugger;
        const sum = OfficeCountList.reduce((partialSum, a) => partialSum + a, 0);


        document.getElementById("TotalPatientId").innerHTML = sum;



        debugger;

        debugger;

        Highcharts.chart('Chart5', {
            tooltip: {
                useHTML: true,
                formatter: function () {
                  //  return '<div> <b style=font-size:18px;>' + this.x +  '</b> <b style=font-size:18px> : ' + this.y + '</b></div>';
                    return '<div>  <b style=font-size:18px> ' + this.y + '</b></div>';
                }
            },

                chart: {
                    lang: {
                        noData: 'Personalized no data message'
                    },
                    type: 'column',
                    events: {
                        load() {
                            const chart = this;
                            chart.showLoading('Fetching data ...');
                            setTimeout(function() {
                                chart.hideLoading();
                                chart.series[0].setData(OfficeCountList)
                            }, 200);
                        }
                    }
                },
                credits: {
                    enabled: false
                },
                title: {
                    text: ''
                },
                plotOptions: {
                    column: {
                        pointPadding: 0.2,
                        borderWidth: 03,

                    },
                    series: {
                        animation: {

                            duration: 1000
                        },
                        borderRadius: {
                            radius: 50,

                        }
                    }
                },
                xAxis: {
                    labels: {
                        style: {
                            fontWeight: 'bold',
                            fontSize: "12px",
                        }
                    },
                    categories:NurseList
                },
                yAxis: {
                    labels: {
                        style: {
                            fontWeight: 'bold',
                            fontSize: "10px",
                        }
                    },
                    title: {
                        text: ''
                    }
                },
                series: [{
                    color: {
                        linearGradient: { x1: 1, y1: 1, x2: 1, y2: 0 },

                        stops: [
                            [0,'#c3dff8'],
                            [1,'rgba(56, 161, 252, 0.83)' ]
                        ]
                    },
                    showInLegend: false,
                    name: 'Patient',
                    maxPointWidth: 20,
                    data: []
                }],
            },
      function(chart) { // on complete
          if(NurseList.length==0)
          {
              chart.renderer.text('No Data Available', 200, 120)
                 .css({
                     color: '#4572A7',
                     fontSize: '16px'
                 })
                 .add();
          }
      });

    });
</script>


