                    }
                },
                title: {
                    text: ''
                }
            },
            series: [
                 {
                name: 'CheckIn Hours',
                data:AutoData
            }]
        }
        
         );

    });

    function dayDiff(d1,d2)
    {
        var diff = d2.getTime() - d1.getTime();
        var daydiff = diff / (1000 * 60 * 60 * 24);
        return  daydiff;
    }

</script>



