                                        $('#drpFromTime option[value!="0"]').remove();
                                        $('#drpToTime option[value!="0"]').remove();
                                        flag = false;
                                    }
                                    else if (result.status === "OVER_QUERY_LIMIT") {
                                        $("#loading").hide();
                                        toastr.error('Please try again later...');
                                        $('#drpFromTime option[value!="0"]').remove();
                                        $('#drpToTime option[value!="0"]').remove();
                                        flag = false;
                                    }
                                    else if (result.status === "REQUEST_DENIED") {
                                        $("#loading").hide();
                                        toastr.error('Please try again later...');
                                        $('#drpFromTime option[value!="0"]').remove();
                                        $('#drpToTime option[value!="0"]').remove();
                                        flag = false;
                                    }
                                    else if (result.status === "INVALID_REQUEST") {
                                        $("#loading").hide();
                                        toastr.error('Please try again later...');
                                        $('#drpFromTime option[value!="0"]').remove();
                                        $('#drpToTime option[value!="0"]').remove();
                                        flag = false;
                                    }
                                    else if (result.status === "UNKNOWN_ERROR") {
                                        $("#loading").hide();
                                        toastr.error('Please try again later...');
                                        $('#drpFromTime option[value!="0"]').remove();
                                        $('#drpToTime option[value!="0"]').remove();
                                        flag = false;
                                    }
                                    else
                                    {
                                        $("#loading").hide();
                                        toastr.error('Please try again later...');
                                        $('#drpFromTime option[value!="0"]').remove();
                                        $('#drpToTime option[value!="0"]').remove();
                                        flag = false;
                                    }
                                }

                            });
                        }
                        else {
                            toastr.error('Please Enter ZipCode');
                            $('#drpFromTime option[value!="0"]').remove();
                            $('#drpToTime option[value!="0"]').remove();
                        }
                    } else {
                        toastr.error('Please Enter State');
                        $('#drpFromTime option[value!="0"]').remove();
                        $('#drpToTime option[value!="0"]').remove();
                    }
                }
                else {
                    toastr.error('Please Enter City');
                    $('#drpFromTime option[value!="0"]').remove();
                    $('#drpToTime option[value!="0"]').remove();
                }
            } else {
                toastr.error('Please Enter Street');
                $('#drpFromTime option[value!="0"]').remove();
                $('#drpToTime option[value!="0"]').remove();
            }
        } else {
            $('#drpFromTime option[value!="0"]').remove();
            $('#drpToTime option[value!="0"]').remove();
        }
    }


    function IsCRNumberExist()
    {

        var tempCRNumber = $("#CRNumber").val();
        if (tempCRNumber == "" || tempCRNumber == undefined) {
            return;
        }
        if (tempCRNumber) {
            var url = INITURL + '/ClientRequest/GetClientDetailByCRNNumber';
            $("#loading").show();
            $.ajax({
                url: url,
                data: { CRNNumber: tempCRNumber },
                //cache: false,
                contentType: 'application/json; charset=utf-8',
                dataType: 'json',
                //traditional: true,
                type: 'GET',
                success: function (data)
                {
                    debugger;
                    debugger;
                    if (data != null && data.ClientId != 0)
                    {
                        $("#ClientName").val(data.ClientName);
                        $("#Address").val(data.Address);
                        $("#Street").val(data.Street);
                        $("#City").val(data.City);
                        $("#State").val(data.State);
                        $("#ZipCode").val(data.ZipCode);
                      //  GetTime(data.ZipCode);

                        $("#OfficeName").val(data.OfficeName);
                        $("#OfficeId").val(data.OfficeId);

                        $('#ddFilterMarketer').empty();




                        $.each(data.marketersSelectList, function () {
                            debugger;
                            var sss = this.id;
                            $("#ddFilterMarketer").append($("<option></option>").val(this.Value).text(this.Text));
                        });


                        $("#MarketersName").val(data.marketersSelectList[0].Text);


                    }
                    else {
                        $("#ClientName").val('');
                        $("#Street").val('');
                        $("#City").val('');
                        $("#State").val('');
                        $("#ZipCode").val('');
                        $("#Description").val('');
                        $("#OfficeName").val('');
                        $("#Office").val('');
                        $("#Date").val('');


                        toastr.error('This CRN number   does not exist. Please enter correct CRN number  of a current client and try again.');
                    }
                    $("#loading").hide();
                },
                error: function (response) {
                    debugger;
                    alert("error : " + response);
                    $("#loading").hide();
                }
            });
        }
    }

