<script language="javascript" type="text/javascript">
    function GetToTimes() {
        $('#drpToTime').showHideDropdownOptions(25, true);
        var id = $('#drpFromTime').children(":selected").attr("id");
        $('#drpToTime').prop('selectedIndex', 0);
        $('#drpToTime').showHideDropdownOptions(id, false);
    }

    $.fn.showHideDropdownOptions = function (value, canShowOption) {
        for (j = value ; j >= 1 ; j--) {
            if (canShowOption) {
                $('#drpToTime').find('option[id="' + j + '"]').attr('disabled', false);
                $('#drpToTime').find('option[id="' + j + '"]').show();
            }
            else {
                $('#drpToTime').find('option[id="' + j + '"]').hide();
                $('#drpToTime').find('option[id="' + j + '"]').attr('disabled', 'disabled');
            }
        }
    }
</script>


