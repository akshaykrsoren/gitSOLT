    <title>Appointment</title>
    <style>
                .common {
                    position: relative;
                    margin-top: -20px;
                    left: -12px;
                    width: 70px;
                    padding: 5px;
                    border-radius: 5px;
                }

                .card p {
                    font-weight: 700;
                    margin-bottom: 0px;
                }

                .bg-1 {
                    background-color: yellow;
                }

                .bg-2 {
                    background-color: yellowgreen;
                }

                .bg-3 {
                    background-color: violet;
                }

                .bg-4 {
                    background-color: turquoise;
                }

                .card {
                    box-shadow: 0 2px 5px 0 rgb(0 0 0 / 20%);
                    transition: 0.3s;
                    border: none;
                    padding: 10px;
                }

                .card2 {
                    box-shadow: 0 2px 5px 0 rgb(0 0 0 / 20%);
                    transition: 0.3s;
                    border: none;
                }

                .viewbtn {
                    border: none;
                    background: #fff;
                    text-align: left;
                }

                .mycommon {
                    text-align: center;
                    padding: 5px;
                    border-radius: 2px 0px 0px 0px;
                }

                .card2 p {
                    font-weight: 700;
                    margin-bottom: 0px;
                    padding: 10px 2px 0px 2px;
                }

                .bg-green {
                    background-color: #19bb8c;
                    height: 100px;
                }

                    .bg-green h2 {
                        line-height: 100px;
                    }

                .sidebg {
                    background-color: #000;
                    /*height: 100vh;*/
                    height: 900px;
                    padding: 0px;
                    position: relative;
                }

                    .sidebg ul {
                        list-style: none;
                        padding: 0;
                        margin-bottom: 0px;
                    }

                .mt-30 {
                    margin-top: 20px;
                }

                .pl-30 {
                    padding: 10px 30px !important;
                    border-bottom: 1px solid #fff;
                }

                .sidebg ul li {
                    background-color: #red;
                    color: #fff;
                    cursor: pointer;
                    height: 40px;
                }

                .commonpadding {
                    padding: 8px 0px 15px 10px;
                    margin: 0px 0px 0px 0px;
                }

                .submenu {
                    padding: 8px 0px 0px 10px;
                    margin: 0px 0px 0px 10px;
                }

                .listborder {
                    border-left: 4px solid #red;
                    font-family: Arial, Helvetica, sans-serif;
                    text-decoration: none;
                    font-size: 14px;
                }

                #submenudrop {
                    display: none;
                }

                .circleicon {
                    height: 30px;
                    width: 30px;
                    border: 1px solid red;
                    border-radius: 50%;
                }

                .active {
                    display: block;
                }

                .hide {
                    display: none;
                }

                .activelink {
                    background-color: #5073fe;
                }

                .activelinkText {
                    background-color: #5073fe;
                }

                #submenudrop a {
                    color: #fff;
                }

                li a {
                    text-decoration: none;
                    color: white;
                    display: block;
                }

                #pasevalogo {
                    height: 90px;
                    padding: 10px 10px 10px 60px;
                }

                #pasevaName {
                    font-family: Arial, Helvetica, sans-serif;
                    padding: 0px 10px 10px 25px;
                    font-size: 20px;
                    color: white;
                }

                a:hover, a:focus, a:active {
                    color: inherit;
                }

                #menuImg {
                    height: 20px;
                    margin-top: -5px;
                }

                #userlogo {
                    height: 50px;
                    width: 50px;
                    background-color: #bbb;
                    border-radius: 50%;
                }

                .sidebg ul {
                    list-style: none;
                    padding: 0px;
                    margin-bottom: 0px;
                }

                .mt-30 {
                    margin-top: 132px;
                }

                element.style {
                    width: 41px;
                }

                select.form-group-sm .form-control, select.input-sm {
                    height: 40px;
                    line-height: 40px;
                }

                element.style {
                    color: blue;
                }

                label {
                    display: inline-block;
                    max-width: 100%;
                    margin-bottom: 5px;
                    color: blue;
                    font-weight: 700;
                }
                /*.loading {
            position: fixed;
            z-index: 1000000;
            top: 0;
            left: 0;
            align-content: center;
            height: 100%;
            width: 100%;
            background: rgba(255,255,255,.8) url(../../image/loading.gif) 50% 50% no-repeat;
        }*/
