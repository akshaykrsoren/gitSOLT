<body>

    <div class="container-fluid" style="background-color:#F5F5F5;">
        <div class="row">
            <div class="col-md-2 sidebg">
                <div style="background-color:#5073fe; padding-bottom:7px;" class="col-md-12">

                    <img id="pasevalogo" src="~/Content/image/PasevaCustomerLogo.svg" />

                    <!--<h3 id="pasevaName" > Paseva Customer</h3>-->
                    <img style="display:block; width:70%; margin:auto; " src="~/Content/image/PaSevaCustomerNameLogo.png" alt="bottle" />



                </div>

                <ul class="mt-30" id="dropmenu">

                    @* <li class="listborder commonpadding"><img id="menuImg" src="~/Content/image/dashboard.svg" alt="bottle" class="thumbnails" /> <span style="padding-left:5px">Dashboard</span> </li>*@

                    <li class="listborder commonpadding dashboardPSC">
                        <a href="~/PasevaCustomerDashBorad/PasevaDashboard" data-tag="one" style="margin-right:5px">
                            <img id="menuImg" src="~/Content/image/dashboardMenu.svg" alt="bottle" class="thumbnails" />
                            <span style="padding-left:5px">Dashboard</span>
                        </a>
                    </li>



                    @*<li class="listborder submenu patients">
                           <a href="~/Appointment/Patients" data-tag="one" style="margin-right:5px">
                             <i class="fa fa-user"></i>
                             <span style="padding-left:5px">Patients</span>
                             </a>
                         </li>
                        <li class="listborder submenu nurse">
                        <a href="~/Appointment/Nurse" data-tag="one" style="margin-right:5px">
                            <i class="fa fa-user-md" style="padding-left:5px"></i>
                            <span style="padding-left:5px">Nurse</span>
                            </a>
                        </li>*@

                    <li class="listborder submenu bookappointment"><a href="~/Appointment/BookAppointment" data-tag="one" style="margin-right:5px"><img id="menuImg" src="~/Content/image/BookAppointmentMenu.svg" alt="bottle" class="thumbnails" /><span style="padding-left:5px">Book Appointment</span></a></li>
                    <li class="listborder submenu awaitingAppointment"><a href="~/Appointment/PendingAppointment" data-tag="one"><img id="menuImg" src="~/Content/image/AwaitingAppointmentMenu.svg" alt="bottle" class="thumbnails" /> <span style="padding-left:5px">Awaiting Appointment </span></a></li>
                    <li class="listborder submenu confirmAppointment"><a href="~/Appointment/ConfirmAppointment" data-tag="one"><img id="menuImg" src="~/Content/image/ConfirmAppointmentMenu.svg" alt="bottle" class="thumbnails" /> <span style="padding-left:5px">Confirm Appointment </span></a></li>
                    <li class="listborder submenu completeAppointment"><a href="~/Appointment/CompleteAppointment" data-tag="one"><img id="menuImg" src="~/Content/image/CompleteAppointmentMenu.svg" alt="bottle" class="thumbnails" /> <span style="padding-left:5px">Complete Appointment </span></a></li>
                    <li class="listborder submenu cancelAppointment"><a href="~/Appointment/CancelAppointment" data-tag="one"><img id="menuImg" src="~/Content/image/CancelledAppointmentMenu.svg" alt="bottle" class="thumbnails" /> <span style="padding-left:5px">Cancel Appointment </span></a></li>
                    <li class="listborder submenu rescheduleAppointment"><a href="~/Appointment/RescheduledAppointment" data-tag="one"><img id="menuImg" src="~/Content/image/RescheduleAppointmentMenu.svg" alt="bottle" class="thumbnails" /> <span style="padding-left:5px">Reschedule Appointment </span></a></li>
                    <li class="listborder submenu paymentAppointment"><a href="~/Appointment/PaymentDetails" data-tag="one"><img id="menuImg" src="~/Content/image/paymentMenu.svg" alt="bottle" class="thumbnails" /> <span style="padding-left:5px">Payment Details </span></a></li>

                    <li class="listborder commonpadding patients">
                        <a href="~/Appointment/Patients" data-tag="one" style="margin-right:5px">
                            <i class="fa fa-user"></i>
                            <span style="padding-left:5px">Patients</span>
                        </a>
                    </li>
                    <li class="listborder commonpadding nurse">
                        <a href="~/Appointment/Nurse" data-tag="one" style="margin-right:5px">
                            <i class="fa fa-user-md"></i>
                            <span style="padding-left:5px">Nurse</span>
                        </a>
                    </li>

                    <li class="listborder commonpadding"><img id="menuImg" src="~/Content/image/logout.svg" alt="bottle" class="thumbnails" /> <span style="padding-left:5px">Logout</span> </li>


                </ul>

            </div>
            <div class="loading" id="loading">
            </div>
            <div class="col-md-10">
                <div class="row">
                    <div class="col-md-12 bg-green" style="height:128px;">
                        <div class="row">
                            <div class="col-md-9">

                                <h2 class="text-white" style="font-size:40px;">@ViewBag.PageName</h2>

                            </div>
                            <div class="col-md-3" style="margin:35px 0px 0px 0px; ">
                                <div class="row">
                                    <div class="col-md-3">
                                        <img id="userlogo" src="/Content/image/neeraj.jpeg" alt="" />
                                    </div>
                                    <div class="col-md-9" style="padding-left:10px;">
                                        <div class="text-white">Neeraj Venu </div>

                                        <div class="text-white" style="font-size:12px">Administrator</div>
                                    </div>
                                </div>


                            </div>
                        </div>
                    </div>
                </div>
                <div id="container">
                    @RenderBody()
                </div>


            </div>
            @*</div>*@

        </div>
    </div>

    <!-- Optional JavaScript; choose one of the two! -->
    <!-- Option 1: Bootstrap Bundle with Popper -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/js/bootstrap.bundle.min.js" integrity="sha384-MrcW6ZMFYlzcLA8Nl+NtUVF0sA7MsXsP1UyJoMp4YLEuNSfAP+JcXn/tWtIaxVXM" crossorigin="anonymous"></script>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js" integrity="sha256-/xUj+3OJU5yExlq6GSYGSHk7tPXikynS7ogEvDej/m4=" crossorigin="anonymous"></script>
    <script>
            var selected = 0;
            $("#dropmenu").click(function () {
                $("#submenudrop").toggle()
            })


            $(".listborder").click(function () {
                $('.listborder').removeClass('activelink');
                $(this).addClass('activelink');
                $(this).addClass('Active');

            })
            $('#loading').show();
            var url = window.location;
            $('.nav').find('.activelink').removeClass('activelink');
            $('.nav li a').each(function () {
                if (this.href == url) {
                    $(this).parent().addClass('activelink');
                }
            });
            $('#loading').hide();


            var PageStatus = "@ViewBag.PageName";


            if (PageStatus == "DashBoard") {
                $(".dashboardPSC").addClass('activelink');
            }
            if (PageStatus == "Book Appointment") {
                $(".bookappointment").addClass('activelink');
            }

            if (PageStatus == "Awaiting Appointment") {
                $(".awaitingAppointment").addClass('activelink');
            }
            if (PageStatus == "Confirm Appointment") {
                $(".confirmAppointment").addClass('activelink');
            }
            if (PageStatus == "Complete Appointment") {
                $(".completeAppointment").addClass('activelink');
            }
            if (PageStatus == "Cancel Appointment") {
                $(".cancelAppointment").addClass('activelink');
            }

            if (PageStatus == "Reschedule Appointment") {
                $(".rescheduleAppointment").addClass('activelink');
            }

            if (PageStatus == "Transaction Details") {
                $(".paymentAppointment").addClass('activelink');
            }

            if (PageStatus == "Patients") {
                $(".patients").addClass('activelink');
            }

            if (PageStatus == "Nurse") {
                $(".nurse").addClass('activelink');
            }





            $('.clickme a').click(function () {
                $('.clickme a').removeClass('activelink');
                $(this).addClass('activelink');
                var tagid = $(this).data('tag');
                $('.list').removeClass('active').addClass('hide');
                $('#' + tagid).addClass('active').removeClass('hide');
            });
    </script>

</body>
</html>