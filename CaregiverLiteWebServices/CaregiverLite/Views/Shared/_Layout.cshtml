    <script>

                                $(document).ready(function(){

                                    $("#ProfileSignout1").click(function () {
                                        debugger;
                                        sessionStorage.setItem("PartialView", "1");
                                        $('#LogoutModel1').modal('show');
                                        /* $("#loading").hide();*/

                                    });
                                    $('.btn-Logout').click(function () {
