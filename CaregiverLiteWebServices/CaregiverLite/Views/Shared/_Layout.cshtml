                    @*<img src="~/Content/image/DefaultProfile.png" alt="User Avatar" class="user-avatar" />*@

                    @if (Session["role"].ToString() == "Nurse")
                    {
                        var roleImagePath = Session["ProfileImage"].ToString();
                        <img src="@roleImagePath" alt="User Avatar" class="user-avatar" />
                    }
                    else
                    {
                        <img src="~/Content/image/DefaultProfile.png" alt="User Avatar" class="user-avatar" />
                    }
                    <span>
                        Welcome @if (Session["Name"] != null)
                        {@Session["Name"].ToString();
                        }
                    </span>
                </div>

            </div>
        </header>

        <div class="row">
            <div class="col-xs-3 col-lg-2" style="margin-right: 0px;">
                @Html.Partial("_LeftMenu");
