                        <input id="Toggle" type="image" src="" alt="" width="25" height="40" style="padding-top: 2px ;cursor:grab" outline="none" alt="Help" class="nav-icon">
                    </div>
                    <!-- <input id="Toggle" type="image" src="" alt="" width="25" height="40" style="padding-top: 20px ;cursor:grab" outline="none"> -->
