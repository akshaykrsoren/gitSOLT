                                        window.location.href = '/Account/Logout';
                                    });



                                    $('.btn-Cancel').click(function () {
                                        debugger;
                                        $('#LogoutModel1').modal('hide'); // Close pop-up without action
                                    });
                                });

                                function OpenProfile() {


                                    $('#UserProfileView').load(INITURL + 'UserManagement/UserProfile/' + UserId, function () {

                                        sessionStorage.setItem("PartialView", "1");
                                        $('#ProfilemOdeal').modal({
                                            backdrop: 'static',
