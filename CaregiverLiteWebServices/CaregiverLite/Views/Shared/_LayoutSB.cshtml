    function ChatPermission() {
        try {
            var url = window.location;
            // $('#loading').show();
            $.ajax({
                url: "@Url.Action("IsAllowForChat", "Account")",
                type: 'POST',
                async: false,
                success: function (data) {
                    result = data;

                    var paramstt = window.location.href.toString().split(window.location.host)[1];
                    paramstt = paramstt.substring(10);

                    if("@Session["IsAllowOneToOneChat"].ToString()" != "True" && paramstt == "OneToOneChat")
                    {
                        window.location.href = "@Url.Action("NoAuthorize", "Chatting")";
                    }
                    else if("@Session["IsAllowForPatientChatRoom"].ToString()" != "True" && paramstt == "PatientChatRoom")
                    {
                        window.location.href = "@Url.Action("NoAuthorize", "Chatting")";
                    }
                    else if("@Session["IsAllowGroupChat"].ToString()" != "True" && paramstt == "GroupChat")
                    {
                        window.location.href = "@Url.Action("NoAuthorize", "Chatting")";
                    }

                },
                error: function (error) {
                    throw error;
                }
            });

        } catch (e) {
            //  $('#loading').hide();
            console.log(e);
        }
