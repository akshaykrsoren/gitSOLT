    // Load Map Location Tracking by PatientRequestId By Vinod Verma

    function LoadTrackLocationMap(PatientRequestId) {
        $('#myModalTrackLocation').css('overflow', 'visible');
        $('#myModalTrackLocation').css('top', '-67%');

        $("#loading").show();

        $.ajax({
            url: "@Url.Action("TrackLocationByPatientRequestId", "AttendanceManagement")",
            data: { PatientRequestId: PatientRequestId },
            cache: false,
            dataType: 'json',
            type: 'POST',
            success: function (data, response) {

                if (data.Result.length > 0) {
                    //console.log(JSON.stringify(data));
                    var TotalMiles = data.Result[0].TotalMiles;
                    $('#tmiles').html(TotalMiles).show();
                    var trackedLocations = data.Result;
                    for (var i = 0; i < trackedLocations.length; i++) {
                        if (trackedLocations[i].Status == "PauseDriving" || trackedLocations[i].Status == "ResumeDriving") {
                            TrackLocationMapWithWayPoint(trackedLocations);
                        }
                        else {
                            TrackLocationMap(trackedLocations);
                        }
                    }


                    //marker.setVisible(true);
                }

                else {
                    $('#nolocation').html('No Location Available').show();
                }
            },

            error: function (xhr, response) {
                console.log(xhr, response);
                $('#loading').hide();
            }

        });
        $("#loading").hide();
    }


    function TrackLocationMap(trackedLocations) {
        MapPoints = trackedLocations;
        directionsDisplay = new google.maps.DirectionsRenderer({
            suppressMarkers: true
        });

        var myOptions = {
            zoom: 4,
            mapTypeId: google.maps.MapTypeId.ROADMAP,
        }

        map = new google.maps.Map(document.getElementById("divmap"), myOptions);
        directionsDisplay.setMap(map);
        calcRoute(trackedLocations);
    }

    function calcRoute(trackedLocations) {

        var waypts = [];
        var incrementalValue;
        // debugger;
        if (trackedLocations.length >= 20) {
            var loopIncrement = Math.ceil(trackedLocations.length / 20);
            for (var i = 0; i < trackedLocations.length; i = i + loopIncrement) {

                waypts.push({
                    location: trackedLocations[i].LocationLatitude + ',' + trackedLocations[i].LocationLongitude,
                    stopover: true
                });
                //alert(trackedLocations[i].LocationLatitude + ',' + trackedLocations[i].LocationLongitude);
            }
        }
        else {
            for (var i = 0; i < trackedLocations.length - 1; i++) {
                waypts.push({
                    location: trackedLocations[i].LocationLatitude + ',' + trackedLocations[i].LocationLongitude,
                    stopover: true
                });
            }
        }

        start = new google.maps.LatLng(trackedLocations[0].LocationLatitude, trackedLocations[0].LocationLongitude);
        end = new google.maps.LatLng(trackedLocations[trackedLocations.length - 1].LocationLatitude, trackedLocations[trackedLocations.length - 1].LocationLongitude);

        startStatus = trackedLocations[0].Status;
        stopStatus = trackedLocations[trackedLocations.length - 1].Status;

        createMarker(start, startStatus);

        for (var j = 0; j < trackedLocations.length; j++) {
            if (trackedLocations[j].Status == "PauseDriving" || trackedLocations[j].Status == "ResumeDriving") {
                pauseMarker = new google.maps.LatLng(trackedLocations[j].LocationLatitude, trackedLocations[j].LocationLongitude);
                pauseStatus = trackedLocations[j].Status;
                createMarker(pauseMarker, pauseStatus);
            }
        }

        createMarker(end, stopStatus);
        var request = {
            origin: start,
            destination: end,
            waypoints: waypts,
            optimizeWaypoints: true,
            travelMode: google.maps.DirectionsTravelMode.DRIVING
        };

        directionsService.route(request, function (response, status) {
            if (status == google.maps.DirectionsStatus.OK) {
                directionsDisplay.setDirections(response);
                var route = response.routes[0];
            }
        });
    }


    function createMarker(latlng, status) {
        var icon = 'https://scheduler.paseva.com/image/Red_50x50.png';

        if (status == "StartDriving") {
            var marker = new google.maps.Marker({
                position: latlng,
                label: { text: 'S', color: 'white' },
                map: map
            });
        }
        else if (status == "PauseDriving") {
            var marker = new google.maps.Marker({
                position: latlng,
                label: { text: 'P', color: 'white' },
                map: map
            });
        }
        else if (status == "ResumeDriving") {
            var marker = new google.maps.Marker({
                position: latlng,
                label: { text: 'R', color: 'white' },
                map: map
            });
        }
        else if (status == "StopDriving") {
            var marker = new google.maps.Marker({
                position: latlng,
                //label: { text: 'E', color: 'white' },
                map: map
            });
            marker.setIcon(icon)
        }
    }


