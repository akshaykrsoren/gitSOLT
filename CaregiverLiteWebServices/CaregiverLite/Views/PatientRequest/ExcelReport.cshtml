@model CaregiverLite.Models.AttendanceManagementDetail


<style>
    #ui-datepicker-div {
        z-index: 10000 !important;
    }

    .form-calender {
        padding: 0 15px;
    }

    .lbl label {
        text-align: left;
        display: block;
    }
    .formtopmargin {
    margin-top: 6px;
    border-radius:5px;
    }
</style>





<script>
    $(document).ready(function () {
        $(function () {

            debugger;
            var dateFormat = "mm/dd/yy",
              from = $("#Fromdt")
                .datepicker({
                    defaultDate: "+1w",
                    changeMonth: true,
                    numberOfMonths: 1,
                    maxDate: new Date()

                })
                .on("change", function () {
                    //toMinDate.setDate(toMinDate.getDate() - 365);
                    to.datepicker("option", "minDate", getDate(this));
                }),
              to = $("#Todt").datepicker({
                  defaultDate: "+1w",
                  changeMonth: true,
                  numberOfMonths: 1,
                  maxDate: new Date(),
                  minDate: $("#FromDate").val()

              })
              .on("change", function () {
                  // var fromMaxDate = $("#FromDate").val();
                  //fromMaxDate.setDate(fromMaxDate.getDate() - 1);
                  to.datepicker("option", "minDate", getDate(this));
              });

            function getDate(element) {
                var date;
                try {

                    date = $.datepicker.parseDate(dateFormat, element.value);

                } catch (error) {
                    date = null;
                }

                return date;
            }

            //$(function () {
            var ddlCustomers = $("#ddlOffices");
            ddlCustomers.empty().append('<option selected="selected" value="0" disabled = "disabled">Loading.....</option>');
            $.ajax({
                type: "POST",
                url: "/AttendanceManagement/ListOffices",
                data: '{}',
                contentType: "application/json; charset=utf-8",
                dataType: "json",
                success: function (response) {
                    ddlCustomers.empty().append('<option selected="selected" value="0">All</option>');
                    $.each(response, function () {
                        ddlCustomers.append($("<option></option>").val(this['Value']).html(this['Text']));
                    });
                },
                failure: function (response) {
                    alert(response.responseText);
                },
                error: function (response) {
                    alert(response.responseText);
                }
            });


        });

    });





</script>

<div id="main_div" class="Edit_div">
    <div class="alert alert-danger alert-dismissable" style="display:none" id="dvError3">
        <button onclick="divClose();" class="close" type="button">×</button>
        <label id="lblError3"></label>
    </div>
    <div class="row form-calender lbl">
        <div class="col-md-6">
            @*Date*@
            <div class="form-group">
                <label>From Date<span style="color:red;">*</span></label>

                <input type="text" id="Fromdt" class="form-control clsDatePicker formtopmargin" placeholder="DD-MM-YYYY" onkeydown="return false">
                @* @Html.TextBoxFor(model => model.FromDate, new { @class = "form-control clsDatePicker", @data_toggle = "dropdown", @placeholder = "DD-MM-YYYY", onkeydown = "return false", autocomplete = "off", @tabindex = "8" })*@
                <label id="lblFromDate"></label>
            </div>
        </div>
        <div class="col-md-6">
            <label>To Date<span style="color:red;">*</span></label>

            <input type="text" id="Todt" class="form-control clsDatePicker formtopmargin" placeholder="DD-MM-YYYY" onkeydown="return false">
            @*@Html.TextBoxFor(model => model.ToDate, new { @class = "form-control clsDatePicker", @data_toggle = "dropdown", @placeholder = "DD-MM-YYYY", onkeydown = "return false", autocomplete = "off", @tabindex = "8" })*@
            <label id="lblToDate"></label>
        </div>
    </div>
    <div class="col-md-2" style="text-align:left">

        <div>
            <label>Offices :</label>
            <select id="ddlOffices" class = "form-control formtopmargin customdropDown"></select>
        </div>
    </div>
    <div class="col-md-12">
        <button type="button" href="javascript:void(0)" onclick="Addnew();" class="btn btn-sm btn-primary pull-right" tabindex="10">GENERATE REPORT</button>
        <div class="clearfix"></div>
    </div>
</div>



<div class="col-md-12">
    <div class="clearfix"></div>
</div>


<script type="text/javascript">
    $(".loading").show();
    function Addnew() {
        debugger;


       $('#loading').show();
       var FromDate = $("#Fromdt").val();
       var ToDate = $("#Todt").val();
        var OfficeId=$("#ddlOffices").val();
        debugger;
        if (FromDate == "" && ToDate == "") {
            toastr.error("Please select required field.");
            $("#loading").hide();
            return false;
        }
        else if (FromDate == "" || FromDate == undefined) {
            toastr.error("Please select from date.");
            $("#loading").hide();
            return false;
        }
        else if (ToDate == "" || ToDate == undefined) {
            toastr.error("Please select to date.");
            $("#loading").hide();
            return false;
        }



        //$(".loading").show();
              var url = '@Url.Action("GenerateReportAction", "PatientRequest")';

      //  var url = "http://localhost:15177/AttendanceManagement/GenerateReportAction";
        $.ajax({
            url: url,
            type: "POST",
            data: { FromDate: FromDate, ToDate: ToDate, OfficeId: OfficeId},
            success: function (res) {
                $(".loading").hide();
                if (res) {


                    var filename = res;
                    var iframe = document.createElement("iframe");
                    iframe.src = filename;

                    iframe.style.display = 'none';
                    document.body.appendChild(iframe);

                    toastr.success("successfully export.");

                }
                else {
                    toastr.warning("No File Exported!");
                }

            },
            error: function (reponse) {
                alert("error : " + JSON.stringify(reponse));
                $(".loading").hide();
            }
        });




    }
</script>