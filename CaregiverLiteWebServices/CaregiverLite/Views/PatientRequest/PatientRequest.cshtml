            return;
        }
        if ($('#AppointmentFromTime').val()==$('#AppointmentToTime').val())
        {
            alert("FromTime should not be equal to ToTime");
            return;
        }

        var IsValidTIME= isValidTime($('#AppointmentFromTime').val(),$('#AppointmentToTime').val());
        if(!IsValidTIME)
        {
            alert("TOTIme should not be less than FromTime");
            return;
        }

        var originalDate = $('#ReScheduleDate').val(); // e.g. "07/01/2025"
        var ReScheduleDate = moment(originalDate, "MM/DD/YYYY").format("YYYY-MM-DD");

