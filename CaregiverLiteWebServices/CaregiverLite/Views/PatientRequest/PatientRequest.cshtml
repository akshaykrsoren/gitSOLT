    function CheckInPatientRequest(PatientRequestId) {

        if (confirm('Are you sure you want to CheckIn.')) {
            debugger;
            //alert(PatientRequestId);
            $("#loading").show();
            var url = INITURL + '/PatientRequest/CheckInPatientRequest';
            $.ajax({
                url: url,
                data: { PatientRequestId: PatientRequestId },
                cache: false,
                type: 'POST',
                async: false,
                success: function (data) {
                    if (data == "Success") {
                        window.location = INITURL + '/PatientRequest/PatientRequest';
                    }
                    $("#loading").hide();
                },
                error: function (reponse) {
                    alert("error : " + reponse);
                    $("#loading").hide();
                }
            });
        }
    }


