            result="N/A"
        }
        var formatted =[];
        formatted = datalist.map(app => ({
            PatientRequestId: app.PatientRequestId,
            CheckInDateTime: formatDateTime(mutlicheckinDateFormat(app.AppointmentDate), app.CheckInDateTime),
            CheckOutDateTime: formatDateTime(mutlicheckinDateFormat(app.AppointmentDate), app.CheckOutDateTime),
            CheckOutFormReason: result
        }));
        debugger;
       // alert(JSON.stringify(formatted, null, 2));

        var url = INITURL + '/PatientRequest/MarkRequestsComplete';
        $.ajax({
            url: url,
            data: { requestList: formatted },
            cache: false,
            type: 'POST',
            async: false,
            success: function (data) {

                if (data == "Success") {
                    toastr.success('This appointment has been completed successfully');
