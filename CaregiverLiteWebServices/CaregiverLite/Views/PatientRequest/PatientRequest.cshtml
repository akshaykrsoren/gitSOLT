    // Function to generate checkboxes dynamically
    function generateCheckboxes(containerId, data) {
        debugger;
        const container = document.getElementById(containerId);
        container.innerHTML = ""; // Clear existing checkboxes

        data.forEach(item => {
            const checkboxHTML = `
                <div class="form-check">
                    <input class="form-check-input child-checkbox" type="checkbox" id="${item.id}" data-group="${containerId}" ${item.checked ? "checked" : ""}>
                    <label class="form-check-label" for="${item.id}">${item.label}</label>
                </div>
            `;
            container.innerHTML += checkboxHTML;
        });

        attachChildCheckboxListeners(containerId);
        updateParentCheckbox(containerId);
    }

    // Attach event listeners to child checkboxes
    function attachChildCheckboxListeners(containerId) {
        document.querySelectorAll(`#${containerId} .child-checkbox`).forEach(checkbox => {
            checkbox.addEventListener("change", function () {
                updateParentCheckbox(containerId);
            });
        });
    }

    // Update parent checkbox based on child checkboxes
    function updateParentCheckbox(containerId) {
        const parentCheckbox = document.querySelector(`.parent-checkbox[data-target="${containerId}"]`);
        const childCheckboxes = document.querySelectorAll(`#${containerId} .child-checkbox`);
        const checkedCheckboxes = document.querySelectorAll(`#${containerId} .child-checkbox:checked`);

        if (checkedCheckboxes.length === 0) {
            parentCheckbox.checked = false;
            parentCheckbox.indeterminate = false;
        } else if (checkedCheckboxes.length === childCheckboxes.length) {
            parentCheckbox.checked = true;
            parentCheckbox.indeterminate = false;
        } else {
            parentCheckbox.checked = false;
            parentCheckbox.indeterminate = true;
        }
    }

    // Parent checkbox event listener (Check/Uncheck All)
    document.querySelectorAll(".parent-checkbox").forEach(parentCheckbox => {
        parentCheckbox.addEventListener("change", function () {
            const targetContainer = this.getAttribute("data-target");
            document.querySelectorAll(`#${targetContainer} .child-checkbox`).forEach(child => {
                child.checked = this.checked;
            });
            updateParentCheckbox(targetContainer);
        });
    });

