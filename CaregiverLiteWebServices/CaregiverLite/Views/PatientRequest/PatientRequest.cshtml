    function parseTime(timeStr) {
        let [hours, minutes, seconds] = timeStr.split(":").map(Number);
        return new Date(1970, 0, 1, hours, minutes, seconds);

    }

    //function calcTimeDifference(start,end)
    //{
    //    let diffMs = end - start; // Difference in milliseconds
    //    let diffMinutes = diffMs / (1000 * 60); // Convert to minutes

    //    let hours = Math.floor(diffMinutes / 60);
    //    let minutes = diffMinutes % 60;

    //    let resultText = hours > 0
    //        ? ` ( ${hours}:${minutes < 10 ? '0' : ''}${minutes} hours )`
    //        : ` ( ${diffMinutes} minutes )`;

    //    return resultText;
    //}
    function calcTimeDifference(start, end) {
        let diffMs = end - start; // Difference in milliseconds
        let diffMinutes = Math.floor(diffMs / (1000 * 60)); // Convert to minutes

        let hours = Math.floor(diffMinutes / 60);
        let minutes = diffMinutes % 60;

        let resultText = hours > 0
            ? ` ( ${hours}:${minutes < 10 ? '0' : ''}${minutes} hours )`
            : ` ( ${diffMinutes} minutes )`;

        return resultText;
    }
    function formatTime(datetime) {
        let parts = datetime.split(" "); // Split date and time
        let time = parts[1]; // Extract time part (16:07)

        let [hours, minutes] = time.split(":").map(Number); // Split hours and minutes

        let period = hours >= 12 ? " PM" : " AM"; // Determine AM/PM
        hours = (hours % 12 || 12).toString().padStart(2, "0"); // Ensure hours are two digits

        minutes = String(minutes).padStart(2, "0"); // Ensure minutes are always two digits

        return `${hours}:${minutes}${period}`; // Format output without space
    }
    function formatDuration(datetime) {
        let match = datetime.match(/^(\d{2}):(\d{2})/);
        let time =match[0]; // Extract time part (16:17)

        let [hours, minutes] = time.split(":").map(Number); // Split hours and minutes

        let period = hours >= 12 ? "PM" : "AM"; // Determine AM/PM
        hours = hours % 12 || 12; // Convert 24-hour to 12-hour format
        if(minutes==0)
        {
            minutes="00";
        }
        if(hours<10)
        {
            hours="0"+hours;
        }

        minutes = String(minutes).padStart(2, "0");

        return `${hours}:${minutes} ${period}`; // Format output
    }
