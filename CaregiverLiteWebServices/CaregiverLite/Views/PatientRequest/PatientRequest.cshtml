    function formatRequestedDateTime(input)
    {
        debugger;
        const [RdatePart, RtimePart, Rmeridian] = input.split(" ");
        // const [Rmonth, Rday, Ryear] = RdatePart.split("/").map(Number);
        const [Rmonth, Rday, Ryear] = RdatePart.split(/[-/]/).map(Number);

        let [Rhour, Rminute, Rsecond] = RtimePart.split(":").map(Number);

        // Convert to 24-hour time
        if (Rmeridian === "PM" && Rhour !== 12) {
            Rhour += 12;
        }
        if (Rmeridian === "AM" && Rhour === 12) {
            Rhour = 0;
        }

        // Create the date object (month is 0-based)
        const date = new Date(Ryear, Rmonth - 1, Rday, Rhour, Rminute, Rsecond);

        // Get parts for formatting
        const dayNum = date.getDate();
        const monthIndex = date.getMonth();
        const yearNum = date.getFullYear();

        // Manual month names to avoid locale issues
        const monthNames = [
          "January", "February", "March", "April", "May", "June",
          "July", "August", "September", "October", "November", "December"
        ];
        const monthName = monthNames[monthIndex];

        // Get 12-hour time format
        let displayHour = date.getHours();
        let displayMinute = date.getMinutes();
        let ampm = displayHour >= 12 ? "PM" : "AM";

        displayHour = displayHour % 12 || 12;
        displayMinute = displayMinute < 10 ? "0" + displayMinute : displayMinute;

        // Final output
        return `${dayNum} ${monthName} ${yearNum} | ${displayHour}:${displayMinute} ${ampm}`;


    }
