    function isValidTime(fromTime, toTime) {
        debugger;
        // Convert time strings (HH:MM) to minutes for easy comparison
        const fromMinutes = convertToMinutes(fromTime);
        const toMinutes = convertToMinutes(toTime);

        return fromMinutes <= toMinutes; // Returns true if fromTime is less than or equal to toTime
    }

    // Helper function: Convert "HH:MM" to total minutes
