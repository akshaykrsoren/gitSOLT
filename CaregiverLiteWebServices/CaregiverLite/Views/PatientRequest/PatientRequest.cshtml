    CustomMarker.prototype = new google.maps.OverlayView();
    function CustomMarker(latlng, map, imageURL, iconImage, innerMarkerText) {
        this.latlng_ = latlng;
        this.setMap(map);
        this.imageURL = imageURL;
        this.iconImage = iconImage;
        this.innerMarkerText = innerMarkerText;
        var iw = new google.maps.InfoWindow({ content: innerMarkerText, pixelOffset: new google.maps.Size(5, 0) });
        google.maps.event.addListener(this,
                              'click',
                              (function (mm, tt) {
                                  return function () {
                                      iw.setContent(tt);
                                      iw.setPosition(latlng);
                                      iw.open(map, mm);
                                      //setTimeout(function () { $(".custom-class").parent().css("overflow", "hidden"); }, 1000);
                                  };
                              })(this, innerMarkerText));



        //google.maps.event.addListener(this, 'click', (function (mm, tt) {
        //    iw.close();
        //    return function () {
        //        iw.setContent(tt);
        //        iw.open(map, mm);
        //    }
        //})(this, innerMarkerText));
    }


    CustomMarker.prototype.draw = function () {
        var me = this;
        var div = this.div_;
        if (!div) {
            div = this.div_ = document.createElement('DIV');
            div.style.border = "none";
            div.style.position = "absolute";
            div.style.paddingLeft = "0px";
            div.style.cursor = 'pointer';
            div.id = "dvmarker";
            //div.style.zoom = '0.9';
            var blueimg = document.createElement("img");
            blueimg.src = this.iconImage;
            //blueimg.style.position = "relative";
            //blueimg.style.width = "70px";
            blueimg.className = 'bluemarkerimage';
            div.appendChild(blueimg);

            var img = document.createElement("img");
            img.src = this.imageURL;
            img.className = 'map-pic';
            div.appendChild(img);

            google.maps.event.addDomListener(div, "click", function (event) {
                google.maps.event.trigger(me, "click");
            });

            google.maps.event.addDomListener(div, "mouseover", function (event) {
                google.maps.event.trigger(me, "mouseover");
            });

            google.maps.event.addDomListener(div, "mouseout", function (event) {
                google.maps.event.trigger(me, "mouseout");
            });


            var panes = this.getPanes();
            panes.overlayImage.appendChild(div);
        }

        // Position the overlay
        var point = this.getProjection().fromLatLngToDivPixel(this.latlng_);
        if (point) {
            div.style.left = point.x - 25 + 'px';
            div.style.top = point.y - 30 + 'px';
        }
    };

