    function DeleteAppointment(){

        debugger;
        var selectedIDs = new Array();
        $('input:checkbox.cs').each(function () {
            if ($(this).prop('checked')) {
                selectedIDs.push($(this).val());
            }
        });
        if (selectedIDs != "") {
            //var r = confirm("Are you sure you want to remove patient appointment?");
            //if (r == true) {

                $("#loading").show();
                var url = INITURL + '/PatientRequest/RemovePatientRequest';
                $.ajax({
                    url: url,
                    data: JSON.stringify({ PatientRequestId: selectedIDs }),
                    cache: false,
                    contentType: 'application/json; charset=utf-8',
                    dataType: 'json',
                    type: 'POST',
                    success: function (data) {

