    function CancelRequest(PatientId) {
        var r = confirm("Are you sure you want to cancel patient request?");
        if (r == true) {

            $("#loading").show();
            var url = INITURL + '/PatientRequest/CancelPatientRequest';

            $.ajax({
                url: url,
                data: JSON.stringify({ patientrequestid: PatientId }),
                cache: false,
                contentType: 'application/json; charset=utf-8',
                dataType: 'json',
                type: 'POST',
                success: function (data) {

                    if (data == "Success") {
                        toastr.success('Patient Request is cancelled successfully');
                        $("#loading").hide();
                        oTable.search('').draw()
                        //oTable.fnFilter('');
                    }
                    else {

                        $("#loading").hide();
                    }
                },
                error: function (xhr) {
                    console.log(xhr, "error");
                }
            });

        }
    }

    function CompletedRequest(name, desc, requestedDate, signature, checkIn, checkOut, miles, fromtime, totime, CheckInLatLong, CheckOutLatLong, CheckInAddress, CheckOutAddress) {
        desc = unescape(desc);

        if (signature != null) {
            $('#signature').attr("src", signature);
            $('#signature').show();
        } else {
            $('#signature').hide();
        }

        if (name != null) {
            $("#PatientNameDiv").show();
            $("#PatinentNameSpan").text(name);
        }
        else {
            $("#PatientNameDiv").hide();
        }

        if (desc != null) {
            $("#PatientDescriptionDiv").show();
            $("#DiscriptionSpan").text(desc);
        }
        else {
            $("#PatientDescriptionDiv").hide();
        }

        if (requestedDate != null) {
            $("#RequestedDateDiv").show();
            $("#RequestedDateSpan").text(requestedDate);
        }
        else {
            $("#RequestedDateDiv").hide();
        }
        if (checkIn != null) {
            $("#checkInDiv").show();
            $("#checkInSpan").text(checkIn);
        }
        else {
            $("#checkInDiv").hide();
        }
        if (checkOut != null) {
            $("#checkOutDiv").show();
            $("#checkOutSpan").text(checkOut);
        }
        else {
            $("#checkOutDiv").hide();
        }
        if (miles != null) {
            $("#milesDiv").show();
            $("#milesSpan").text(miles);
        }
        else {
            $("#milesDiv").hide();
        }
        if (fromtime != null) {
            $("#frmtmDiv").show();
            $("#frmtmSpan").text(fromtime);
        }
        else {
            $("#frmtmDiv").hide();
        }

        if (totime != null) {
            $("#totmDiv").show();
            $("#totmSpan").text(totime);
        }
        else {
            $("#totmDiv").hide();
        }

        //
        if (CheckInLatLong != null) {
            $("#checkInLatLongDiv").show();
            $("#checkInLatLongSpan").text(CheckInLatLong);
        }
        else {
            $("#checkInLatLongDiv").hide();
        }
        if (CheckOutLatLong != null) {
            $("#checkOutLatLongDiv").show();
            $("#checkOutLatLongSpan").text(CheckOutLatLong);
        }
        else {
            $("#checkOutLatLongDiv").hide();
        }

        if (CheckInLatLong != null) {
            $("#checkInAddressDiv").show();
            $("#checkInAddressSpan").text(CheckInAddress);
        }
        else {
            $("#checkInAddressDiv").hide();
        }
        if (CheckOutLatLong != null) {
            $("#checkOutAddressDiv").show();
            $("#checkOutAddressSpan").text(CheckOutAddress);
        }
        else {
            $("#checkOutAddressDiv").hide();
        }
        //


        $('#myCompleteRequest').modal('show');
    }

