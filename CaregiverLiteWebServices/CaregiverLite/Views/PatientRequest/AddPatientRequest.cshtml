    function GetPatientListByFilter(pFilterText, pFilterData) {

        if (pFilterData == null || pFilterData == "") {
            return;
        }
        $('#loading').show();
        recentSearches = [];
        suggestionsList.innerHTML = '';
        var url = INITURL + '/PatientRequest/GetPatientRequestDetailByFilter';
        $.ajax({
            url: url,
            data: { FilterBy: pFilterText, FilterData: pFilterData },
            cache: false,
            contentType: 'application/json; charset=utf-8',
            dataType: 'json',
            traditional: true,
            type: 'GET',
            success: function (data) {
                debugger;
                if (data.Success) {
                    for (var i = 0; i < data.Result.length; i++) {
                        var row = { id: data.Result[i].MedicalId, text: data.Result[i].PatientName };
                        recentSearches.push(row);
                    }

                    recentSearches.forEach(search => {

                        hasResults = true;
                        const suggestionItem = document.createElement('li');
                        suggestionItem.classList.add('dropdown-item');
                        suggestionItem.textContent = search.text;
                        suggestionItem.dataset.id = search.id; // Store
                        suggestionsList.appendChild(suggestionItem);

                    });
                    suggestionsList.classList.add('show');

                } else {
                    toastr.error('No data found.');
                }
                $('#loading').hide();

            },
            error: function (reponse) {
                toastr.error('process failed.');
                $('#loading').hide();
            }
        });
    }
    function debounce(func, delay) {
        let debounceTimer;
        debugger;
        return function () {
            const context = this;
            const args = arguments;
            clearTimeout(debounceTimer);
            debounceTimer = setTimeout(() => func.apply(context, args), delay);
        };
    }

