    function CheckCaregiverAllowedHours(){
        
        var selectedNurse = $('input:checkbox[id^="chk"]:checked').map(function () {
            return this.id;
        }).get();
        var NurseID = selectedNurse[0].replace(/\D/g, "");
        var url= INITURL + 'PatientRequest/CheckCaregiverAllowedHours';
        $.ajax({
            url: url,
            async:false,
            type: 'POST',
            data: { nurseid: NurseID},
            success: function(response) {
                var data = JSON.parse(response);
                if(data.Table[0].Name !="" &&data.Table[0].Email !="" && response!="failed" ){
                    $("#CareGiverEmailD").html(data.Table[0].Email); 
                    $("#Allowedtime").html(data.Table[0].AllowedHours + " hours");
                    $("#Accesstime").html(data.Table[0].TotalHours  + " hours");
                    // $("#myModalPopup").modal('show');
                    NurseName=data.Table[0].Name;
                    AllowedHours=data.Table[0].AllowedHours;
                    TotalHours=data.Table[0].TotalHours;
                    SchedulerEmail=data.Table2[0].SchedulerEmail;
                    OfficeEmail=data.Table3[0].OfficeEmail;// data.Table[3].OfficeEmail;
                    CCMailID=data.Table3[0].OfficeEmail;  //data.Table[0].Email;//
                    $(".myModalPopup").show();

                }
             
            },
            error: function(xhr, status, error) {
                console.log('Error:', error);
                toastr.error("Failed to fetch aregiver working hours.");
                
            }
        });
    }
 
    function sendMailToSchedulerAndOfficeManagers(){

        $.ajax({
            type: "POST",
            url: '/PatientRequest/SendEmail',
            data: {
                SchedulerEmail: SchedulerEmail,
                CCMailID:CCMailID,
                NurseName:NurseName,
                AllowedHours:AllowedHours,
                TotalHours: TotalHours,
                OfficeEmail:OfficeEmail
            },
            success: function (response) {
                if (response.success) {
                   alert(response.message); // Email sent successfully.
                } else {
                    alert("Failed: " + response.message);
                }
            },
            error: function () {
                alert("An error occurred while sending email.");
            }
        });

    }
