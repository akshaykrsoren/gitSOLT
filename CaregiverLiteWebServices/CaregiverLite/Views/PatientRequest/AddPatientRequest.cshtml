    function ChangeformatTime(minutes) {

        var hours = Math.floor(minutes / 60);
        var mins = minutes % 60;
        var ampm = hours >= 12 ? 'PM' : 'AM';
        //var ampm ='';
        //if(hours==12)
        //{
        //    ampm='AM';
        //}else if( hours >= 12)
        //{
        //    var ampm ='PM';
        //}else{
        //    ampm='AM';
        //}
        hours = hours % 12;
        hours = hours ? (hours < 10 ? "0" + hours : hours) : 12;
        mins = mins < 10 ? '0' + mins : mins;
        return hours + ':' + mins + ' ' + ampm;
    }

