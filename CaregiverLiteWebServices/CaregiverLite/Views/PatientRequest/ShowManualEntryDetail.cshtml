<link rel="stylesheet" href="https://code.jquery.com/ui/1.12.1/themes/base/jquery-ui.css">


<script>
    $(document).ready(function()
    {
        var modelDescription = @Html.Raw(Json.Encode(Model.Description));

        if(modelDescription=='Commuting home.')
        {
            $("#lblPatientName").text("My Home");
        }
        if(modelDescription=='Commuting Office.')
        {
            $("#lblPatientName").text("My Office");
        }

        var model = @Html.Raw(Json.Encode(Model.InsertedDateTime));
        var localUTCtime= model.concat(' UTC')

        $("#lcInsertedDateTime").text(dateFormat(localUTCtime, 'MM/dd/yyyy HH:mm'));



    });
    function dateFormat(inputDate, format) {

        const date = new Date(inputDate);

        //extract the parts of the date
        const day = date.getDate();
        const month = date.getMonth() + 1;
        const year = date.getFullYear();
        const hour = date.getHours();
        const minutes = date.getMinutes();

        //replace the month
        format = format.replace("MM", month.toString().padStart(2, "0"));

        //replace the year
        if (format.indexOf("yyyy") > -1) {
            format = format.replace("yyyy", year.toString());

        } else if (format.indexOf("yy") > -1) {
            format = format.replace("yy", year.toString().substr(2, 2));

        }

        //replace the day
        format = format.replace("dd", day.toString().padStart(2, "0"));


        format = format.replace("HH", hour.toString().padStart(2, "0"));
        format = format.replace("mm", minutes.toString().padStart(2, "0"));

        return format;
    }

    function Save(btn) {


        var tempPatientRequestManualEntryId = @ViewBag.PatientRequestManualEntryId;



        var btnStatus = $(btn).attr("name");

        var localComment = $(".Main_detail_div #Comment").val();

        if (localComment == "" || localComment == undefined || localComment == null)
        {
            if (btnStatus == 'A')
            {
                toastr.error("Please write your comment before Approve");

            }
             
            return;
        }

        var tempPatientRequestApproval = {
            PatientRequestManualEntryId: "",
            ApprovalStatus: "",
            Comment: ""
        }


        tempPatientRequestApproval.PatientRequestManualEntryId = tempPatientRequestManualEntryId;
        tempPatientRequestApproval.Comment = localComment;
        tempPatientRequestApproval.ApprovalStatus = btnStatus;

        

    

        


            $("#loading").show();
            var url = INITURL + '/PatientRequest/PatientRequestManualEntryApproval';


            $.ajax({
                url: url,
                data: { PatientRequestApproval: tempPatientRequestApproval },
                cache: false,
                type: 'POST',
                async: false,
                success: function (data)
                {

                    if (data.Success)
                    {

                        $('#myModalEdit').modal('hide');
                        toastr.success(data.Message);
                        $('#Statusddl').css('z-index', '1090');
                        $('#myDataTable').DataTable().ajax.reload();

                    } else
                    {
                        $('#myModalEdit').modal('hide');
                        toastr.error(data.Message);
                        $('#Statusddl').css('z-index', '1090');
                        $('#myDataTable').DataTable().ajax.reload();
                    }
                    $("#loading").hide();
                },
                error: function (reponse)
                { $('#myModalEdit').modal('hide');
                $('#Statusddl').css('z-index', '1090');
                    toastr.error(data.reponse);
                    $("#loading").hide();
                }

            });

        
            


    }
    function RejectionConfirmation(btn) {
           
        var btnStatus = $(btn).attr("name"); 
        var tempComment = $(".Main_detail_div #Comment").val();
        if (tempComment == "" || tempComment == undefined || tempComment == null)
        {
            if (btnStatus == 'R')
            {
                toastr.error("Please write your comment before Reject");
                  
            }  
            return;
        }
        $('#ModalConfirm').modal('show');

             
    }
        
        
    function ConfirmRejection(btn) {
           
        var btnStatus= $(btn).attr('name');
        if(btnStatus=="R")
        {
            Save(btn);
        }
        if(btnStatus="C")
        {
            $('#ModalConfirm').modal('hide');
        }
           
    }

</script>
