@{
    ViewBag.Title = "Patients";
    //Layout = "~/Views/_ViewStart.cshtml";
    Layout = "~/Views/Shared/_LayoutPasevaCustomer.cshtml";

}

<style>
    .modal-Vd {
        top: 100px;
        left: 20%;
        width: 820px;
        position: absolute;
        z-index: 41;
        /* padding: 30px; */
    }

    .popup-content-act {
        width: 500px;
        height: 500px;
        background: gray;
        display: flex;
        justify-content: center;
        align-items: center;
        margin: 0 auto;
        opacity: 0;
    }

    .popup-show {
        opacity: 1;
    }

    .modal {
        z-index: 9999;
    }

    .modal-content {
        margin: -40px 0px 0px 130px;
    }
</style>



<link href="~/Content/css/dataTables.bootstrap.css" rel="stylesheet">
<link href="~/Content/css/dataTables.responsive.css" rel="stylesheet">
<link href="~/Content/css/dataTables.tableTools.min.css" rel="stylesheet">



<div class="modal fade" id="myModal2" tabindex="-1" role="dialog" aria-labelledby="myModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-md modal-Vd" id="modalEditPopup">
        <div class="modal-content">
            <div class="modal-header">
                <h4 class="modal-title" id="gridSystemModalLabel">Complete Appointment Details</h4>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>

            </div>
            <div class="modal-body row" id="EditPanel">

            </div>
        </div>
    </div>
</div>


<div class="wrapper wrapper-content animated fadeInRight">
    <div class="row">
        <div class="col-lg-12">
            <div class="ibox float-e-margins">
                @*<div class="ibox-title">


                    </div>*@
                <div class="ibox-content">
                    <input type="hidden" id="hdnPatientRequestId" />
                    <table id="myDataTable" class="table table-striped table-bordered table-hover dataTables-example">
                        <thead>
                            <tr>
                                <th><strong>Date</strong></th>
                                <th><strong>Id</strong></th>
                                <th><strong>Patient</strong></th>
                                <th><strong>Appointment Address</strong></th>
                                <th><strong>Pin Code</strong></th>
                                <th><strong>Appointment Status</strong></th>
                                <th><strong>Nurse Details</strong></th>
                                <th><strong> Details</strong></th>

                                @*<th style="width: 100px;" class="noExl">@CaregiverLite.Views.Resources.CareGiver.TableHeaderAction</th>*@
                            </tr>
                        </thead>
                        <tbody></tbody>
                    </table>
                </div>
            </div>



        </div>
    </div>
</div>
<!-- LIST OF PATIENT END-->
<script src="~/Scripts/js/jquery.dataTables.js"></script>
<script src="~/Scripts/bootstrap.js"></script>
<link rel="stylesheet" href="https://code.jquery.com/ui/1.12.1/themes/base/jquery-ui.css">
<script src="~/Scripts/js/oms.min.js"></script>

<script type="text/javascript">

  function EditAdmin(ID) {

      $('#EditPanel').load(INITURL + '/Appointment/CompleteAppointmentDetailPartialView/?PatientRequestId=' + ID, function () {
            sessionStorage.setItem("PartialView", "1");
            $('#myModal2').modal({ backdrop: 'static', keyboard: false });
            $('#myModal2').modal('show');
            $("#loading").show();
        });
    }

    var oTable;

    $(document).ready(function () {

        $("#loading").show();
        var jquey = jQuery.noConflict();
        oTable = $('#myDataTable').DataTable({

            responsive: true,
            "dom": 'lfrtip',

            "bPaginate": true,
            "bServerSide": true,

            "bSortable": true,
            "sPaginationType": "full_numbers",
            "oLanguage": {
                "sProcessing": "<div class=\"loading\" id=\"loading\" style=\"display: block;\"></div>"
            },
            "processing": true,

            "sAjaxSource": "GetAllCompletedAppointmentDetails",
            "fnServerData": function (sSource, aoData, fnCallback) {
                $.getJSON(sSource, aoData, function (json) {
                    fnCallback(json);
                }).fail(function (jqxhr, textStatus, error) {
                    window.location.reload();
                });
            },
            "fnServerParams": function (aoData) {
                //aoData.push({ "name": "FilterOfficeId", "value": $('#ddFilterOffice option:selected').val() });
            },
            "fnDrawCallback": function (oSettings) {
                //Navigation validation
                var rowsPerPage = this.fnSettings()._iDisplayLength;
                var rowsToShow = this.fnSettings().fnRecordsDisplay();
                var table = $('#myDataTable').DataTable();
                var info = table.page.info();
                var currentPageNo = info.page + 1;
                $("#loading").hide();
            },
            "responsive": {
                "details": {
                    "type": 'column'
                }
            },
            "aoColumns":[

                             {
                                 "sName": "MedicalId",
                                 "mRender": function (oObj) {
                                     return oObj["Date"];
                                 }
                             }, {
                                 "sName": "PatientId",
                                 "mRender": function (oObj) {
                                     return oObj["PatientRequestId"];
                                 }
                             },
                            {
                                "sName": "Patient",
                                "mRender": function (oObj) {
                                    return '<span>' + oObj["PatientName"] + '</span>';
                                }
                            },
                            {
                                "sName": "Address",
                                "mRender": function (oObj) {
                                    return oObj["Address"];
                                }
                            },
                            {
                                "sName": "ZipCode",
                                "mRender": function (oObj) {
                                    return oObj["ZipCode"];
                                }
                            },
                             {
                                 "sName": "State",
                                 "bSortable": false,
                                 "mRender": function (oObj) {
                                     return oObj["Status"];
                                 }
                             },
                              {
                                  "sName": "NurseName",
                                  "bSortable": false,
                                "mRender": function (oObj) {
                                    return oObj["NurseName"];
                                }
                              },

                            {
                                  "sName": "NurseDetails",
                                  "bSortable": false,
                                  "mRender": function (oObj) {
                                      var actionhtml = '';
                                      actionhtml += '<a href="javascript:;" class="btn btn-xs btn-primary" style="margin-top:5px; width:100%;" onclick="EditAdmin(\'' + oObj["PatientRequestId"] + '\');">Detail</a>'
                                     return actionhtml;

                                  }
                              },


            ]
        });

        $('#myDataTable_filter input').unbind(); //Unbind direct search on each keypress
        $('#myDataTable_filter input').bind('keyup', function (e) { //Bind Keyup event that filter data only on "Enter" key.
            if (e.keyCode == 13) {
                oTable.search(this.value).draw();
            }
        });
        /* Init DataTables */
        $('.carousel').carousel({
            interval: false
        });

        var config = {
            '.chosen-select': {},
            '.chosen-select-deselect': { allow_single_deselect: true },
            '.chosen-select-no-single': { disable_search_threshold: 10 },
            '.chosen-select-no-results': { no_results_text: 'Oops, nothing found!' },
            '.chosen-select-width': { width: "95%" }
        }
        for (var selector in config) {
            $(selector).chosen(config[selector]);
        }

        $("#loading").hide();

        ///Handle File Uploading start



    });



    function Filtration() {

        oTable.search($('#myDataTable').val()).draw();
    }
</script>
