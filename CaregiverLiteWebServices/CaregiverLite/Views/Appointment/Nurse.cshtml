<!-- LIST OF PATIENT START-->
<div class="wrapper wrapper-content animated fadeInRight">
    <div class="row">
        <div class="col-lg-12">
            <div class="ibox float-e-margins">
                @*<div class="ibox-title">


                    </div>*@
                <div class="ibox-content">
                    <input type="hidden" id="hdnPatientRequestId" />
                    <table id="myDataTable" class="table table-striped table-bordered table-hover dataTables-example">
                        <thead>
                            <tr>
                                <th></th>
                                <th>@CaregiverLite.Views.Resources.CareGiver.TableHeaderName</th>
                                <th style="width: 120px;">Image</th>
                                <th style="width: 210px;">@CaregiverLite.Views.Resources.CareGiver.TableHeaderUserName</th>
                                <th>@CaregiverLite.Views.Resources.CareGiver.TableHeaderEmail</th>
                                <th>@CaregiverLite.Views.Resources.CareGiver.TableHeaderPhone</th>
                                <th>@CaregiverLite.Views.Resources.CareGiver.TableHeaderZipCode</th>
                                @* <th>@CaregiverLite.Views.Resources.CareGiver.TableHeaderOffice</th>*@
                                <th>NurseId</th>
                                @*<th>@CaregiverLite.Views.Resources.CareGiver.TableHeaderInsertedOn</th>
                                    <th style="width: 100px;">@CaregiverLite.Views.Resources.CareGiver.TableHeaderAction</th>
                                    <th>@CaregiverLite.Views.Resources.CareGiver.TableHeaderTrackLocation</th>
                                    <th>Assign Patient Chat Room</th>*@
                            </tr>
                        </thead>
                        <tbody></tbody>
                    </table>
                </div>
            </div>



        </div>
    </div>
</div>

<div class="modal fade" id="myModal2" tabindex="-1" role="dialog" aria-labelledby="myModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-Vd" id="modalEditPopup">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                <h4 class="modal-title" id="gridSystemModalLabel"> Details</h4>
            </div>
            <div class="modal-body row" id="EditPanel">

            </div>
        </div>
    </div>
</div>

<!-- LIST OF PATIENT END-->
<script src="~/Scripts/js/jquery.dataTables.js"></script>
<script src="~/Scripts/bootstrap.js"></script>
<link rel="stylesheet" href="https://code.jquery.com/ui/1.12.1/themes/base/jquery-ui.css">
<script src="~/Scripts/js/oms.min.js"></script>

<script type="text/javascript">

    @*var tempMsg = '@TempData["Message"]';
    var tempFlag = '@TempData["error"]';

    if (tempFlag != "True") {
        if (tempMsg != "")
            toastr.success(tempMsg);
    }
    else {
        if (tempMsg != "")
            toastr.error(tempMsg);
    }*@
    function EditAdmin(ID, Patient) {
        debugger;

        $("#loading").show();
        //var gh = (NurseId)
        $('#EditPanel').load(INITURL + '/Appointment/Details/?ID=' + ID + '&Patient=' + Patient, function () {
            sessionStorage.setItem("PartialView", "1");
            $('#myModal2').modal({ backdrop: 'static', keyboard: false });
            $('#myModal2').modal('show');
            $("#loading").hide();
        });
    }
    var oTable;

    $(document).ready(function () {

        $("#loading").show();
        var jquey = jQuery.noConflict();
        oTable = $('#myDataTable').DataTable({

            responsive: true,
            "dom": 'lfrtip',

            "bPaginate": true,
            "bServerSide": true,

            "bSortable": true,
            "sPaginationType": "full_numbers",
            "oLanguage": {
                "sProcessing": "<div class=\"loading\" id=\"loading\" style=\"display: block;\"></div>"
            },
            "processing": true,

            "sAjaxSource": "GetCareGiverList",
            "fnServerData": function (sSource, aoData, fnCallback) {
                $.getJSON(sSource, aoData, function (json) {
                    fnCallback(json);
                }).fail(function (jqxhr, textStatus, error) {
                    window.location.reload();
                });
            },
            "fnServerParams": function (aoData) {
                //aoData.push({ "name": "FilterOfficeId", "value": $('#ddFilterOffice option:selected').val() });
            },
            "fnDrawCallback": function (oSettings) {
                //Navigation validation
                var rowsPerPage = this.fnSettings()._iDisplayLength;
                var rowsToShow = this.fnSettings().fnRecordsDisplay();
                var table = $('#myDataTable').DataTable();
                var info = table.page.info();
                var currentPageNo = info.page + 1;
                $("#loading").hide();
            },
            "responsive": {
                "details": {
                    "type": 'column'
                }
            },
          "aoColumns": [
                            {
                                className: 'control',
                                orderable: false,
                                targets: 0,
                                "mRender": function (oObj) {
                                    return '';
                                }
                            },
                            {
                                "sName": "Name",
                                "mRender": function (oObj) {
                                    return '<span>' + oObj["Name"] + '</span>';
                                }
                            },
                            {
                                "sName": "ProfileImage",
                                "bSortable": false,
                                "mRender": function (oObj) {
                                    if (oObj["ProfileVideo"] != "")
                                        return '<img height="100" width="100" src=\"' + oObj["ProfileImage"] + '\" style=\"margin-left: 19px;\"/>';
                                    else
                                        return '<img height="100" width="100" src=\"' + oObj["ProfileImage"] + '\" style=\"margin-left: 19px;\" />';
                                }
                            },
                            {
                                "sName": "UserName",
                                "mRender": function (oObj) {
                                    return oObj["UserName"];
                                }
                            },
                            {
                                "sName": "Email",
                                "mRender": function (oObj) {
                                    return oObj["Email"];
                                }
                            },
                            {
                                "sName": "Phone",
                                "mRender": function (oObj) {
                                    return oObj["Phone"];
                                }
                            },
                            {
                                "sName": "ZipCode",
                                "mRender": function (oObj) {
                                    return oObj["ZipCode"];
                                }
                            },
                            //{
                            //    "sName": "Office",
                            //    "mRender": function (oObj) {
                            //        return oObj["Office"];
                            //    }
                            //},
                            {
                                "sName": "NurseId",
                                "mRender": function (oObj) {
                                    return oObj["NurseId"];
                                }
                            },
                            @*{
                              "sName": "InsertedOn",
                           //   "sWidth":"110",
                              "mRender": function (oObj) {
                                  return oObj["InsertedOn"];
                              }
                          },
                            {
                                "sName": "NurseId",
                                "bSortable": false,
                                "mRender": function (oObj) {
                                    var actionhtml = '';
                                    if (oObj["IsApprove"] == false) {
                                        @if (ViewContext.Controller.HasRoles("SuperAdmin") || ViewContext.Controller.IsSysAdmin() || ViewContext.Controller.HasRoles("Admin"))
                                        {
                                            @: actionhtml = '<a href="javascript:;" style="width:100%; margin-top:5px;" class="btn btn-xs btn-success" onclick="OpenApprovedPopup(\'' + oObj["UserName"] + '\', \'' + oObj["Email"] + '\', \'' + oObj["Password"] + '\', \'' + oObj["NurseId"] + '\', \'' + oObj["UserId"] + '\', \'' + oObj["OfficeId"] + '\', \'' + oObj["QuickBloxId"] + '\', \'' + parseFloat(oObj["HourlyRate"]).toFixed(2) + '\')">@CaregiverLite.Views.Resources.CareGiver.ButtonApprove</a>'
                                                                                }
                                    }
                                    else {
                                        @if (ViewContext.Controller.HasRoles("SuperAdmin") || ViewContext.Controller.HasRoles("Admin") || ViewContext.Controller.IsSysAdmin())
                                        {
                                            @: actionhtml = '<a href="javascript:;" style="width:100%; margin-top:5px;" class="btn btn-xs btn-warning" onclick="RejectApprovedNurse(\'' + oObj["NurseId"] + '\', \'' + oObj["OfficeId"] + '\', \'' + oObj["UserId"] + '\', \'' + oObj["QuickBloxId"] + '\',0)">@CaregiverLite.Views.Resources.CareGiver.ButtonReject</a>'
                                        }
                                    }

                                    @if (ViewContext.Controller.HasRoles("SuperAdmin") || ViewContext.Controller.HasRoles("Admin") || ViewContext.Controller.IsSysAdmin())
                                    {
                                        @:  actionhtml += '<a href="javascript:;" class="btn btn-xs btn-danger" style="margin-top:5px; width:100%;" onclick="DeleteNurse(\'' + oObj["NurseId"] + '\' , \'' + oObj["UserName"] + '\');">@CaregiverLite.Views.Resources.CareGiver.ButtonDelete</a>'
                                    }
                                    actionhtml += '<a href="javascript:;" class="btn btn-xs btn-primary" onclick="ViewCareGiverProfile(\'' + oObj["NurseId"] + '\');" style="margin-top:5px; width:100%;">@CaregiverLite.Views.Resources.CareGiver.ButtonProfile</a>'
                                    return actionhtml;
                                }
                            },
                            {
                                "sName": "NurseId",
                                "bSortable": false,
                                "mRender": function (oObj) {
                                    var actionhtml = '';
                                    actionhtml += '<a href="javascript:;" class="btn btn-xs btn-primary" style="margin-top:5px; width:100%;" onclick="NurseTrackLocation(\'' + oObj["NurseId"] + '\');">Track Location</a>'
                                    return actionhtml;
                                }
                            },
                            {
                                "sName": "AssignGroup",
                                "bSortable": false,
                                "mRender": function (oObj) {
                                    var actionhtml = '';
                                    if (oObj["IsApprove"] == true && oObj["IsAllowPatientChatRoom"] == true) {
                                    actionhtml += '<a href="javascript:;" class="btn btn-xs btn-primary" style="margin-top:5px; width:100%;" onclick="OpenAssignGroupModal(\'' + oObj["UserId"] + '\' , \'' + oObj["Name"] + '\',\'' + oObj["QuickBloxId"] + '\',\'' + oObj["Email"] + '\');">Assign Patient Chat Room</a>'
                                    }
                                    else
                                    {
                                    actionhtml += '-'
                                    }

                                    return actionhtml;
                                }
                            }*@
            ]
        });

        $('#myDataTable_filter input').unbind(); //Unbind direct search on each keypress
        $('#myDataTable_filter input').bind('keyup', function (e) { //Bind Keyup event that filter data only on "Enter" key.
            if (e.keyCode == 13) {
                oTable.search(this.value).draw();
            }
        });
        /* Init DataTables */
        $('.carousel').carousel({
            interval: false
        });

        var config = {
            '.chosen-select': {},
            '.chosen-select-deselect': { allow_single_deselect: true },
            '.chosen-select-no-single': { disable_search_threshold: 10 },
            '.chosen-select-no-results': { no_results_text: 'Oops, nothing found!' },
            '.chosen-select-width': { width: "95%" }
        }
        for (var selector in config) {
            $(selector).chosen(config[selector]);
        }

        $("#loading").hide();

        ///Handle File Uploading start



    });



    function Filtration() {

        oTable.search($('#myDataTable').val()).draw();
    }
</script>
