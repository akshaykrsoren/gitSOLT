
@model CaregiverLite.Models.PatientDetailsModel

<style>
    .clsDatePicker {
        z-index: 100000;
    }

    #ui-datepicker-div {
        z-index: 1003;
    }

    .field-validation-error {
        color: red;
        float: right;
    }

    .table td {
        text-align: center;
    }

    .form-control {
        margin-top: 4px;
        border-radius: 5px;
    }

    .customdropDown {
        background-position-x: 95% !important;
    }

    #Delete_Modal .modal-backdrop.in {
        opacity: 0 !important;
    }
</style>

<div class="modal fade" id="Delete_Modal" tabindex="-1" role="dialog" aria-labelledby="myModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-sm" id="modalAddPopup">
        <div class="modal-content" id="deleteModal" style="width: 380px;    height: 247px;    border-radius: 8px;    margin-top:80%">
            <p style="padding:23px 59px 0px 40px; margin-left:-22px; font-style: normal; font-size: 17px;"><strong id="DeleteLabel" style="font-weight: 800; color: #1B4066;"></strong></p>
            <p style="padding:4px 59px 0px 40px; margin-left:-22px; color: #444F60;font-family: Mulish;font-size: 14px;font-style: normal;font-weight: 700;line-height: 22px;"> <strong>Note</strong> - Switching the patient office may result in losing some data. Please contact support@paseva.com for more information.</p>
            <button class="cancel_BTN" style="margin-left: 37%;   margin-top: 27px;   padding: 0px 12px 0px 12px;">No, Go Back</button>
            <button class="confirm_BTN" style="margin-left: 14px;   padding: 0px 12px 0px 12px;">Yes, Switch</button>
        </div>
    </div>
</div>
@using (Html.BeginForm("EditPatientDetail", "Patients", FormMethod.Post, new { @id = "fmEditPatientDetails", @class = "horizontal-form", @enctype = "multipart/form-data" }))
{
    <div id="main_div" class="Edit_div">
        @Html.HiddenFor(model => model.OfficeId, new { @id = "hdnOfficeId" })

        @Html.HiddenFor(model => model.OrganisationId, new { @id = "OrganisationId" })

        <div class="alert alert-danger alert-dismissable" style="display:none" id="dvError3">
            <button onclick="divClose();" class="close" type="button">×</button>
            <label id="lblError3"></label>
        </div>
        <div class="col-md-6">
            @*Medical Id*@
            <div class="form-group">
                <label>@CaregiverLite.Views.Resources.PatientRequest.TableHeaderMedicalId</label>
                <span style="color:red;">*</span>
                @Html.ValidationMessageFor(model => model.MedicalId)
                @Html.TextBoxFor(model => model.MedicalId, new { @type = "text", @maxlength = "25", @placeholder = @CaregiverLite.Views.Resources.PatientRequest.PlaceHolderMedicalId, @class = "form-control", @tabindex = "1", @onblur = "", @readonly = true })
            </div>
            @*Patient Name*@


            <div class="form-group">
                <label>FirstName</label>
                <span style="color:red;">*</span>
                @Html.ValidationMessageFor(model => model.FirstName)
                @Html.TextBoxFor(model => model.FirstName, new { @type = "text", @maxlength = "100", @placeholder = @CaregiverLite.Views.Resources.PatientRequest.PlaceHolderPatientName, @class = "form-control", @tabindex = "2" })
            </div>

            <div class="form-group">
                <label>LastName</label>
                <span style="color:red;">*</span>
                @Html.ValidationMessageFor(model => model.LastName)
                @Html.TextBoxFor(model => model.LastName, new { @type = "text", @maxlength = "100", @placeholder = @CaregiverLite.Views.Resources.PatientRequest.PlaceHolderPatientName, @class = "form-control", @tabindex = "2" })
            </div>


            @*PrimaryMD*@
            <div class="form-group">
                <label>PrimaryMD</label>
                <span style="color:red;">*</span>
                @Html.ValidationMessageFor(model => model.PrimaryMD)
                @Html.TextBoxFor(model => model.PrimaryMD, new { @type = "text", @placeholder = "Enter PrimaryMD", @class = "form-control", @tabindex = "3" })
            </div>
            @*PhoneNo*@
            <div class="form-group">
                <label>@CaregiverLite.Views.Resources.Patients.TableHeaderPhoneNo</label>
                <span style="color:red;">*</span>
                @Html.ValidationMessageFor(model => model.PhoneNo)
                @Html.TextBoxFor(model => model.PhoneNo, new { @type = "text", @maxlength = "20", @placeholder = "Enter Phone Number", @class = "form-control", @tabindex = "4" })
            </div>
            @*Office*@
            <div class="form-group">
                <label>Office</label>
                <span style="color:red;">*</span>
                @Html.ValidationMessageFor(model => model.OfficeId)
                @Html.DropDownListFor(model => model.OfficeId, Model.OfficeSelectList, "Select...", new { @class = "form-control customdropDown", @tabindex = "5" })
            </div>


            <div class="form-group">
                <label>Payer Program</label>
                <span style="color:red;">*</span>
                @*@Html.ValidationMessageFor(model => model.PayerProgramIdss)*@
                @*@Html.TextBoxFor(model => model.PayerProgram, new { @type = "text", @maxlength = "100", @placeholder = "PayerProgram", @class = "form-control", @tabindex = "8" })*@
                @Html.DropDownListFor(model => model.PayerProgramIdss, new SelectList(Model.PayerProgramSelectList, "Value", "Text"), htmlAttributes: new { @class = "form-control customdropDown", @id = "PayerProgramIdss" })

            </div>
            @*ProcedureCode*@
            <div class="form-group">
                <label>ProcedureCode</label>
                <span style="color:red;">*</span>
                <br />
                <input type="text" id="procId" class="form-control" value="@ViewBag.ProcID" />        
                @*@Html.ValidationMessageFor(model => model.ProcedureCodeId)*@
                @*@Html.TextBoxFor(model => model.ProcedureCode, new { @type = "text", @maxlength = "100", @placeholder = "ProcedureCode", @class = "form-control", @tabindex = "10" })*@
                @Html.DropDownListFor(model => model.ProcedureCodeId, new MultiSelectList(Model.ProcedureCodeSelectList, "Value", "Text"), htmlAttributes: new { @class = "form-control customdropDown", @id = "ProcedureCodeId", @disabled = "true" })
            </div>


        </div>
        <div class="col-md-6">
            @*Street*@
            <div class="form-group">
                <label>@CaregiverLite.Views.Resources.Patients.TableHeaderStreet</label>
                <span style="color:red;">*</span>
                @Html.ValidationMessageFor(model => model.Street)
                @Html.TextBoxFor(model => model.Street, new { @type = "text", @placeholder = "Enter Street", @class = "form-control", @tabindex = "6", @onblur = "" })
            </div>
            @*City*@
            <div class="form-group">
                <label>@CaregiverLite.Views.Resources.Patients.TableHeaderCity</label>
                <span style="color:red;">*</span>
                @Html.ValidationMessageFor(model => model.City)
                @Html.TextBoxFor(model => model.City, new { @type = "text", @maxlength = "20", @placeholder = "Enter City", @class = "form-control", @tabindex = "7", @onblur = "" })
            </div>
            @*State*@
            <div class="form-group">
                <label>@CaregiverLite.Views.Resources.Patients.TableHeaderState</label>
                <span style="color:red;">*</span>
                @Html.ValidationMessageFor(model => model.State)
                @Html.TextBoxFor(model => model.State, new { @type = "text", @maxlength = "20", @placeholder = "Enter State", @class = "form-control", @tabindex = "8", @onblur = "" })
            </div>

            @*Zipcode*@
            <div class="form-group">
                <label>@CaregiverLite.Views.Resources.PatientRequest.TableHeaderZipCode</label>
                <span style="color:red;">*</span>
                @Html.ValidationMessageFor(model => model.ZipCode)
                @Html.TextBoxFor(model => model.ZipCode, new
                {
                    @type = "text",
                    @maxlength = "10",
                    @placeholder = @CaregiverLite.Views.Resources.PatientRequest.PlaceHolderZipCode,
                    @class = "form-control",@*@onchange = "javascript:GetTime(this.value);",*@ @tabindex = "9"
                })
            </div>

            <div>
                @Html.HiddenFor(model => model.TimezoneOffset, new { @id = "hdnTimezoneOffset" })
                @Html.HiddenFor(model => model.TimezoneId, new { @id = "hdntimeZoneId" })
                @Html.HiddenFor(model => model.TimezonePostfix, new { @id = "hdnTimezonePostfix" })
                @Html.HiddenFor(model => model.Latitude)
                @Html.HiddenFor(model => model.Longitude)
                @Html.HiddenFor(model => model.PatientId)
            </div>

            <div class="form-group">
                <label>Date Of Birth</label>
                <div class="input-group date" id="datetimepicker1">
                    <input type="text" id="EditDateOfBirth" class="form-control" style="margin-top: 0px;border-radius: 5px 0 0 5px;">
                    <span class="input-group-addon">
                        <i class="glyphicon glyphicon-calendar"></i>
                    </span>
                </div>
            </div>


            <div class="form-group">
                <label>PayerId</label>
                <span style="color:red;">*</span>
                @*@Html.ValidationMessageFor(model => model.PayerIDs)*@
                @*@Html.TextBoxFor(model => model.PayerId, new { @type = "text", @maxlength = "100", @placeholder = "PayerId", @class = "form-control customdropDown", @tabindex = "7" })*@



                @(Model.PayerId == "" ?
                                  @Html.DropDownListFor(model => model.PayerIDs, Model.PayerIDSelectList, "Select...", new { @class = "form-control customdropDown", @tabindex = "7" }) :
                                 @Html.DropDownListFor(model => model.PayerIDs, new SelectList(Model.PayerIDSelectList, "Value", "Text"), new { @class = "form-control customdropDown", @tabindex = "7" })
                )

            </div>

            @if (Model.OrganisationId != 3 && Model.JurisdictionEntitiesSelectList != null)
            {
                <div class="form-group">
                    <label>JurisdictionCode</label>
                    <span style="color:red;">*</span>
                    @*@Html.ValidationMessageFor(model => model.JurisdictionCodeId)*@
                    @*@Html.TextBoxFor(model => model.JurisdictionCode, new { @type = "text", @maxlength = "100", @placeholder = "JurisdictionCode", @class = "form-control customdropDown", @tabindex = "9" })*@
                    @Html.DropDownListFor(model => model.JurisdictionCodeId, new SelectList(Model.JurisdictionEntitiesSelectList, "Value", "Text"), htmlAttributes: new { @class = "form-control customdropDown", @id = "JurisdictionCodeId" })

                </div>

            }

        </div>

        <div class="col-md-12">
            <button type="button" onclick="Save()" class="btn btn-sm btn-primary pull-right" tabindex="10">Save</button>
            <div class="clearfix"></div>
        </div>

        <input type="hidden" id="hdndstOffset" />
        <input type="hidden" id="hdnrawOffset" />
        <input type="hidden" id="hdntimeZoneFullName" />
    </div>
}


