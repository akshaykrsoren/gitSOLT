            <button onclick="divClose();" class="close" type="button">×</button>
            <label id="lblError3"></label>
        </div>
        <div class="col-md-6">
            @*Medical Id*@
            <div class="form-group">
                <label>@CaregiverLite.Views.Resources.PatientRequest.TableHeaderMedicalId</label>
                <label class="form-control">@Model.MedicalId </label>
                 
            </div>
            @*Patient Name*@
            <div class="form-group">
                <label>@CaregiverLite.Views.Resources.PatientRequest.TableHeaderPatientName</label>
                <label class="form-control">@Model.PatientName </label>
               
                </div>
            @*PrimaryMD*@
            <div class="form-group">
                <label>PrimaryMD</label>              
                <label class="form-control">@Model.PrimaryMD </label>            
            </div>
            @*PhoneNo*@
            <div class="form-group">
                <label>@CaregiverLite.Views.Resources.Patients.TableHeaderPhoneNo</label>                 
               
                <label class="form-control">@Model.PhoneNo </label>  
            </div>
            @*Office*@
            <div class="form-group">
                <label>Office</label>                
              
                <label class="form-control">@Model.OfficeId </label>  
            </div>

            <div class="form-group">
                <label>Payer Program</label>
                <label class="form-control">@Model.PayerProgramIdss </label>           
               

            </div>
            @*ProcedureCode*@
            <div class="form-group">
                <label>ProcedureCode</label>
                <label class="form-control">@Model.ProcedureCodeId </label>      
                </div>


        </div>
        <div class="col-md-6">
            @*Street*@
            <div class="form-group">
                <label>@CaregiverLite.Views.Resources.Patients.TableHeaderStreet</label>
                <label class="form-control">@Model.Street </label>      
                
            </div>
            @*City*@
            <div class="form-group">
                <label>@CaregiverLite.Views.Resources.Patients.TableHeaderCity</label>
                <label class="form-control">@Model.City </label>      
                 
            </div>
            @*State*@
            <div class="form-group">
                <label>@CaregiverLite.Views.Resources.Patients.TableHeaderState</label>
                <label class="form-control">@Model.State </label>      
               
            </div>

            @*Zipcode*@
            <div class="form-group">
                <label>@CaregiverLite.Views.Resources.PatientRequest.TableHeaderZipCode</label> 
                <label class="form-control">@Model.ZipCode </label>                    
                
            </div>

