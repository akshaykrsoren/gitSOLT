<link rel="stylesheet" href="https://code.jquery.com/ui/1.12.1/themes/base/jquery-ui.css">
<script type="text/javascript">
    var unassignedCaregivers = '';
    $(document).ready(function () {
        var config = {
            '.chosen-select': {},
            '.chosen-select-deselect': { allow_single_deselect: true },
            '.chosen-select-no-single': { disable_search_threshold: 10 },
            '.chosen-select-no-results': { no_results_text: 'Oops, nothing found!' },
            '.chosen-select-width': { width: "95%" }
        }
        for (var selector in config) {
            $(selector).chosen(config[selector]);

        }
    });

    $('#ddlMember').change(function () {
        $('#ddlMember option:selected').each(function () {
            var $value = $(this).attr('qbid');
            if (!$value)
                RegisterNewCaregiverOnQuickBlox($(this).attr('email'), $(this).val());
        });
    });

    function RegisterNewCaregiverOnQuickBlox(Login, UserId1) {
        $("#loading").show();
        var RegisterUser = { 'login': Login, 'password': "Welcome007!", 'tag': "differenzsystem", 'email': Login };
        QB.users.create(RegisterUser, function (err, user1) {
            if (user1) {
                var url = INITURL + '/Chatting/SaveQBId';
                var QBId = user1.id;
                $.ajax({
                    url: url,
                    data: { UserId: UserId1, QuickBloxId: QBId },
                    type: 'POST',
                    async: false,
                    success: function (data) {
                        $("#ddlCaregiver option[value='" + UserId1 + "']").attr('qbid', QBId);
                        //objIndex = unassignedCaregivers.findIndex((obj => obj.UserId == UserId1));
                        //unassignedCaregivers[objIndex].QuickBloxId = QBId;
                        $("#loading").hide();
                    },
                    error: function (reponse) {
                        alert("error : " + reponse);
                        $("#loading").hide();
                        return;
                    }
                });
            } else {
                alert("error : " + err);
                $("#loading").hide();
                return '';
            }
        });
    }

    function AssignNewMember(ChattingGroupId) {
        //debugger;
        var selectedUserIds = '';
        var selectedQBIds = '';
        $('#ddlMember :selected').each(function () {
            selectedUserIds += $(this).attr("value") + ',';
            if ($(this).attr("qbid"))
                selectedQBIds += parseInt($(this).attr("qbid")) + ',';
        });

        selectedUserIds = selectedUserIds.replace(/,\s*$/, "");
        selectedQBIds = selectedQBIds.replace(/,\s*$/, "");

        if (!selectedUserIds) {
            toastr.info("Please select atleast one member");
            $('#ddlMember').focus();
            return;
        }
        $('#loading').show();
        var url = INITURL + '/Chatting/AddMemberIntoGroup_V1';
        $.ajax({
            url: url,
            cache: false,
            type: 'POST',
            data: {
                ChattingGroupId: ChattingGroupId,
                UserIds: selectedUserIds,
                QuickBloxId: selectedQBIds
            },
            async: true,
            success: function (data) {
                $('#loading').hide();
                if (data == "Success") {
                    $('#modalMemberAssignment').modal('hide');
                    toastr.success('Member(s) has been assigned successfully.');
                }
            },
            error: function (reponse) {
                $('#loading').hide();
            }
        });
    }

    function RemoveMember(ChattingGroupId, UserId, QuickBloxId) {
        if (!confirm('Are you sure you want remove this member ?'))
            return false;
        if (ChattingGroupId && UserId) {
            $('#loading').show();
            var url = INITURL + '/Chatting/RemoveParticipantsFromGroupChat';

            $.ajax({
                url: url,
                type: 'GET',
                data: {
                    ChattingGroupId: ChattingGroupId,
                    UserId: UserId,
                    QuickBloxId: QuickBloxId
                },
                async: true,
                success: function (data) {
                    if (data.result == "Success") {
                        $('#' + UserId).remove();
                        loadAssignedMemberSelectList(data.lstMember);
                        $('#loading').hide();
                        toastr.success('Member has been removed successfully.');
                    }
                    else {
                        toastr.error('Something went wrong!');
                        $('#loading').hide();
                    }
                },
                error: function (reponse) {
                    $('#loading').hide();
                }
            });
        }
    }

    function loadAssignedMemberSelectList(lstMember) {
        $('#ddlMember').empty();
        if (lstMember.length > 0) {
            $.each(lstMember, function (key, value) {
                $('#ddlMember').append("<option value=" + value.UserId + " nurseid=" + value.NurseId + " qbid=" + value.QuickBloxId + "email=" + value.Email + ">" + value.Name + "</option>");
            });
        }
        $('#ddlMember').trigger("chosen:updated");
        $('#loading').hide();
    }


    function AssignGroupAdmin(ChattingGroupId) {

        //debugger;
        var selectedUserIds = "";
        // var arr = [];
        $('input.chkbx:checkbox:checked').each(function () {
            // arr.push($(this).val());
            selectedUserIds += $(this).val() + ",";
        });

        selectedUserIds = selectedUserIds.replace(/,\s*$/, "");

        if (!selectedUserIds) {
            toastr.info("Please select atleast one member");
            $('#ddlMember').focus();
            return;
        }

        $('#loading').show();
        var url = INITURL + '/Chatting/AssignGroupAdmin';
        $.ajax({
            url: url,
            cache: false,
            type: 'POST',
            data: {
                ChattingGroupId: ChattingGroupId,
                UserIds: selectedUserIds
            },
            async: true,
            success: function (data) {
                //debugger;
                $('#loading').hide();
                if (data == "Success") {
                    $('#modalMemberAssignment').modal('hide');
                    toastr.success('Member(s) has been assigned as group admin successfully.');
                }
            },
            error: function (reponse) {
                $('#loading').hide();
            }
        });


        //  $("#DayOfWeek").val(SelectedDayOfWeek);

        //console.log(SelectedDayOfWeek);
    }
</script>
