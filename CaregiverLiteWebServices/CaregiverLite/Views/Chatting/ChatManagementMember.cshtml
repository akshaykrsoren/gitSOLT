<div id="main_div">
    <div class="alert alert-danger alert-dismissable" style="display:none" id="dvError3">
        <button onclick="divClose();" class="close" type="button">×</button>
        <label id="lblError3"></label>
    </div>
    <div class="col-md-12">
        <div class="form-group">
            <label>Group : @ViewBag.GroupName </label>
        </div>
        <div class="form-group">
            <div class="col-md-6">
                <label>Member</label>
                <div class="form-group">
                    <Select id="ddlMember" class="form-control" name="ddlMember">
                        <option value="0">Select Member</option>
                        @if (ViewBag.MemberList != null)
                        {
                            foreach (var item in ViewBag.MemberList)
                            {
                                <option value="@item.UserId" nurseid="@item.NurseId" qbid="@item.QuickBloxId" email="@item.Email"> @item.Name </option>
                            }
                        }
                    </Select>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <label>Office</label>
            <div class="form-group">
                @Html.DropDownList("OfficeId", (System.Web.Mvc.SelectList)ViewBag.lstOffice, "Select Office", new { @class = "form-control" })
            </div>
        </div>


        <div class="form-group">
            <div class="col-md-6">
                <div class="form-group">
                    <label>@Html.CheckBox("chkGroup", false) Group</label>
                </div>
            </div>
        </div>

        <div class="form-group">
            <div class="col-md-6">
                <div class="form-group">
                    <label>@Html.CheckBox("chkPatient", false) Patient</label>
                </div>
            </div>
        </div>




    </div>


</div>
<div class="col-md-12">
    <button type="button" onclick="AssignNewMember(@ViewBag.ChattingGroupId)" class="btn btn-sm btn-primary pull-right">ASSIGN</button>
    <div class="clearfix"></div>
</div>
