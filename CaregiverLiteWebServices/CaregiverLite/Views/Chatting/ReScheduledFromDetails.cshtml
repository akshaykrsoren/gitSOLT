<style>
    .btnss {
        background-color: DodgerBlue;
        border: none;
        color: white;
        padding: 12px 30px;
        cursor: pointer;
        font-size: 10px;
    }

        /* Darker background on mouse-over */
        .btnss:hover {
            background-color: RoyalBlue;
        }
</style>


<a href="" id="test" download style="display:none">Download Here</a>


<div id="main_div">
    <div class="col-md-12">
        <div class="form-group">
            <label>ReScheduled Form Details List</label>
            <div class="col-md-06" style="overflow-y:auto;scroll:auto;max-height:300px">
                <table class="table table-striped table-bordered table-hover dataTables-example" id="Table">
                    <thead>
                        <tr>

                            <td style="width:5%"><b>Employee Name</b></td>
                            <td style="width:10%"><b>Create Date</b></td>
                            <td style="width:11%"><b>Group Name</b></td>
                            <td style="width:5%"><b>office Name</b></td>
                            <td style="width:5%"><b>RescheduleForm URL</b></td>
                            <td style="width:55%"><b>RescheduleForm Details</b></td>

                        </tr>
                    </thead>
                    <tbody id="tbbody">
                        @{ 
                            if (ViewBag.RescheduleFormDetailslist != null)
                            {
                                foreach (var item in ViewBag.RescheduleFormDetailslist)
                                {

                                <tr>
                                    <td>@item.EmployeeName</td>
                                    <td>@item.CreatedDate</td>
                                    <td>@item.patientname</td>
                                    <td>@item.OfficeName</td>
                                    <td><button class="btnss" id="testss" style="width:100%" onclick="DownloadSalesForm('@item.ReschedulingFormUrl')"><i class="fa fa-download"></i> Download</button></td>

                                    <td>

                                        <div>
                                            <table cellpadding="0" cellspacing="0" class="ChildGrid table table-striped table-bordered table-hover dataTables-example">
                                                <tr>
                                                    <th>ScheduledDate</th>
                                                    <th>ScheduledTime</th>
                                                    <th>ReScheduledDate</th>
                                                    <th>ReScheduledTime</th>
                                                    <th>Reason</th>
                                                    <th>TypesOfVisit</th>
                                                </tr>

                                                @foreach (var project in item.ReshuduleDataList)
                                                {
                                                    <tr>
                                                        <td>@project.ScheduledDate</td>
                                                        <td>@project.ScheduledTime</td>
                                                        <td>@project.ReScheduledDate</td>
                                                        <td>@project.ReScheduledTime</td>
                                                        <td>@project.Reason</td>
                                                        <td>@project.TypesOfVisit</td>

                                                    </tr>
                                                }
                                            </table>
                                        </div>
                                    </td>

                                    @*<td>@item.ScheduledTime</td>
                                        <td>@item.ReScheduledDate</td>
                                        <td>@item.ReScheduledTime</td>
                                        <td>@item.Reason</td>
                                        <td>@item.TypesOfVisit</td>*@


                                </tr>
                                }
                            }
                           

                            }
                    </tbody>
                    
                </table>
                <span id="spantags"></span>
            </div>
        </div>
    </div>
</div>


