        $('#download-pdf').click(function () {
            var formContainer = document.getElementById('formContainer');

            html2canvas(formContainer, {
                scale: 1,
                onrendered: function (canvas) { // older html2canvas API for synchronous use
                    var imgData = canvas.toDataURL('image/jpeg', 0.8);

                    var doc = new jsPDF('p', 'mm', 'a4');
                    var pageWidth = doc.internal.pageSize.getWidth();
                    var pageHeight = doc.internal.pageSize.getHeight();

                    var imgWidth = pageWidth;
                    var imgHeight = canvas.height * imgWidth / canvas.width;

                    doc.addImage(imgData, 'JPEG', 0, 0, imgWidth, imgHeight);

                    var pdfBlob = doc.output('blob');

                    // Prepare FormData
                    var formData = new FormData();
                    formData.append('file', pdfBlob, 'sample.pdf');
                    formData.append('AuthInsuranceTypeId', '2');

            // Append an additional text parameter
           
        debugger;
        // Send the file via AJAX
        $.ajax({
            url: 'http://localhost:52086/CaregiverLiteMobileServices.svc/SendAuthorizationInsuranceToEmail',  // Replace with your server URL
            type: 'POST',
            data: formData,
            processData: false,  // Don't process the data
            contentType: false,  // Let the browser set the content type for multipart/form-data
            success: function (response) {
                console.log('PDF uploaded successfully!', response);
            },
            error: function (xhr, status, error) {
                console.error('Upload failed!', error);
            }
        });
          }).catch (function (error) {
