                        <tr><td>MSW</td><td><input type="date" class="form-control" name="msw_from" /></td><td><input type="date" class="form-control" name="msw_to" /></td><td><input type="number" class="form-control" name="msw_visits" /></td><td><input type="number" class="form-control" name="msw_frequency" /></td></tr>
                        <tr><td>HHA</td><td><input type="date" class="form-control" name="hha_from" /></td><td><input type="date" class="form-control" name="hha_to" /></td><td><input type="number" class="form-control" name="hha_visits" /></td><td><input type="number" class="form-control" name="hha_frequency" /></td></tr>
