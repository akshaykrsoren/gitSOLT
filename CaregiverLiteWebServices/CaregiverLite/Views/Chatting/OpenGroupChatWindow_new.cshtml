<script type="text/javascript">

    var sFromQBId = '@Session["FromQBId"]';
    //var sToQBId = '@Session["ToQBId"]';

    var sFromQBName = "@Session["Name"]";
    //var sToQBName = "@Session["ToQBUserName"]";

    var strMessage = "";

    var tmpDialogId = "@Session["chatDialogId"]";
    var dialogJid = "...";


    var gSkip=0;
    var GroupMemberList = @Html.Raw(Json.Encode(ViewBag.GroupMemberDetail));
    var strtblMemberDetail="";
    var loaderFlag=0;
    var totalFiles ="";
    var QuickBloxInit = "@System.Web.Configuration.WebConfigurationManager.AppSettings["QuickbloxAPIUrl"]";


    strtblMemberDetail +="<thead><tr>";

    var limit = 100;

    var skip = 0;

    var totalmsgEntries = 0;

    var msgArr = [];

    var IsScrollDown = 1;

    @*if("@ViewBag.GroupTypeId" == "3")
        strtblMemberDetail +=   "<td>  </td>";*@

    strtblMemberDetail +=      "<td> <b>Member Name</b> </td>"+
                        "<td><b> Email-Id </b></td>"+
                        "<td> <b>Role Type</b> </td>"+
                        "</tr></thead><tbody>";

    for(var tb1=0;tb1 <GroupMemberList.length ; tb1++)
    {
        var html = "";



        if(GroupMemberList[tb1].MemberName.length >0){

            if(GroupMemberList[tb1].IsGroupAdmin == true && "@ViewBag.GroupTypeId" == "3")
                html += "<span style='color: #1dca75;'> (Group Admin)</span>"
            //html += "<i class='fa fa-user' style='margin-left:15px;color: #088bca;font-size: medium;'></i>"

            strtblMemberDetail +=   "<tr>"+
                                    //"<td>"+ html +"</td>"+
                                    "<td>"+ GroupMemberList[tb1].MemberName+"</td>"+
                                    "<td><a href='mailto:"+GroupMemberList[tb1].Email+"' >"+GroupMemberList[tb1].Email+"</a></td>"+
                                    "<td>" + (GroupMemberList[tb1].Type =="NurseCoordinator" ? "Office Staff" :  GroupMemberList[tb1].Type)+ html +"</td>"+
                                    "</tr>";
        }
    }
    strtblMemberDetail +=   "</tbody>"+
    $( "#tblMemberDetail" ).append( strtblMemberDetail);

    //console.log(GroupMemberList);

    $(document).ready(function () {

        $('#btnCloseMediaModal').click(function () {
            $("#openVideo").attr('src', '');
            $("#mediaDiv").html('');
        })//Stop Video On Close Event

        //setLoadMoreMessagesListener();
        ///Handle File Uploading start
        jQuery("input#file1").change(function () {
            ////1
            var totalSelectedFiles = $("input[type=file]")[0].files.length;
            var totalFiles = $("input[type=file]")[0].files;
            var totalFileType = "";

            if (totalFiles != null)
            {
                for (var l=0; l < totalSelectedFiles; l++)
                {

                    File = totalFiles[l];
                    //console.log(File);
                    //console.log(temptotalSelectedFiles+" + "+File.name);
                    totalFileType =File.type.split('/');
                    if(totalFileType[0] != 'image' && totalFileType[0] != 'video' && totalFileType[0] != 'audio')
                    {
                        totalFileType[0]  = 'doc';
                    }

                    var ext = File.name.split('.').pop();
                    var Filesize =(File.size / (1024*1024)).toFixed(2);

                    if(File){
                        if (Filesize < 95 ) {
                            if(   ext.toLowerCase() == "ppt"
                                ||ext.toLowerCase() == "pptx"
                                ||ext.toLowerCase() == "xls"
                                ||ext.toLowerCase() == "doc"
                                ||ext.toLowerCase() == "docx"
                                ||ext.toLowerCase() == "png"
                                ||ext.toLowerCase() == "jpg"
                                ||ext.toLowerCase() == "jpeg"
                                ||ext.toLowerCase() == "mp4"
                                ||ext.toLowerCase() == "pdf")
                            {
                                toastr.success("File Selected");
                                $("#fileCall").css({ 'color': "deepskyblue" });
                                $("#FileAlert").css({ 'display': "block" });
                                $("#FileAlertContent").html("<b>"+ (l+1) +" File Selected.</b>");
                                //Remove
                                $("#fileRemove").css({ 'display': "block" });
                                $("#fileCall").css({ 'display': "none" });
                                //
                                $("#txtSendMsg").attr('disabled','true')
                            }
                            else
                            {
                                toastr.info("You Choose Wrong format file... Please Select File having following extension .ppt, .pptx,  .xls, .doc, .docx, .png, .jpg, .jpeg, .mp4, .pdf");
                                $("#file1").val('');
                                $("#fileCall").css({ 'color': "" });
                                $("#FileAlert").css({ 'display': "none" });

                                $("#fileRemove").css({ 'display': "none" });
                                $("#fileCall").css({ 'display': "block" });
                                toastr.info("No File Selected... Please Open again for select a file.");
                                $("#txtSendMsg").removeAttr('disabled')
                            }

                        } else {
                            if(Filesize > 95)
                            {
                                toastr.info("Please Select a file having size less then 95MB.");
                                $("#file1").val('');
                                $("#fileCall").css({ 'color': "" });
                                $("#FileAlert").css({ 'display': "none" });

                                $("#fileRemove").css({ 'display': "none" });
                                $("#fileCall").css({ 'display': "block" });
                                toastr.info("No File Selected... Please Open again for select a file.");
                                $("#txtSendMsg").removeAttr('disabled')
                            }

                        }
                    }
                    else
                    {
                        toastr.info("No File Selected... Please Open again for select a file.");
                    }

                }//--For looop end
            }

        });
        ///Handle File Uploading end

        //Remove Attachment Start

        $("#fileRemove").click(function(){

            $("#fileRemove").css({ 'display': "none" });
            $("#fileCall").css({ 'display': "block" });
            $("#file1").val('');
            $("#fileCall").css({ 'color': "" });
            $("#FileAlert").css({ 'display': "none" });
            toastr.info("Attachment Removed");
            $("#txtSendMsg").removeAttr('disabled')
        });
        //Remove Attachment End
        //        $("#txtSendMsg").keyup(function (event) {
        //          if (event.keyCode == 13) {
        //            $("#btnSendMsg").click();
        //       }
        //    });



        $("#loading").show();
        //QB.init(QuickbloxApp_Id, QuickbloxAuth_Key, QuickbloxAuth_Secret, true);
        QB.init(@System.Web.Configuration.WebConfigurationManager.AppSettings["QuickbloxApp_Id"],
              "@System.Web.Configuration.WebConfigurationManager.AppSettings["QuickbloxAuth_Key"]",
             "@System.Web.Configuration.WebConfigurationManager.AppSettings["QuickbloxAuth_Secret"]",
              true);


        QB.createSession(function (err, result) {


            if (err) {
                alert(err.message);
            } else {

                sessionStorage.setItem("sToken", result.token);

                if (sFromQBId == '0') {

                    RegisterNewUser("@Session["FromUserEmail"]", "@Session["LoginUserUserId"]");
                }
                else {

                    startChat();

                }

            }//Else End Of createSession
        });

        function startChat() {
            var user = {
                id: sFromQBId,
                login: "@Session["FromUserEmail"]",
                password: "Welcome007!"
            };

            ////Check QBId start


            @*if (sToQBId == '0') {

                RegisterNewUser("@Session["ToUserEmail"]", "@Session["ToUserUserId"]");
            }*@


            QB.chat.connect({ userId: user.id, password: user.password }, function (err, roster) {

                if (err) {
                    //console.log('SERVER ERROR RESPONSE ');

                } else {
                    //console.log('SERVER SUCCESS RESPONSE ');


                    if (tmpDialogId == "0") {
                        CreateNewGroupDialod();
                    }
                    else {
                        //CreateSession();
                        loadChatMessages(100,0);
                        joinChatRoom();
                        toastr.success("Now You Can Start Chatting.");
                        $("#loading").hide();
                        //For Permission Start
                        @*@if (!@Session["Role"].ToString().Equals("SuperAdmin") || !@Session["Role"].ToString().Equals("Admin"))*@

                        if ('@ViewBag.role' != null){

                            if ('@Session["Role"]' != 'SuperAdmin' && '@Session["Role"]' != 'Admin' )
                            {
                                $('#lblPermissionInfo').css('display', 'block');
                                if ('@ViewBag.permission' == "1"){
                                    toastr.info("You Have Only Read Permission For This Group.");
                                    $('#lblPermissionInfo').html('You Have Only Read Permission For This Group.');
                                    $('#chatInput').css('display','none')

                                }
                                if ('@ViewBag.permission' == "2"){
                                    toastr.info("You Have Only Read / Write Permission For This Group.");
                                    $('#lblPermissionInfo').html('You Have Only Read / Write Permission For This Group.');
                                    $('#selectFileIcon').css('display','none');

                                }
                                if ('@ViewBag.permission' == "3" || '@ViewBag.permission' == "0"){

                                    toastr.info("You Have Read / Write / Attachment Permission For This Group.");
                                    $('#lblPermissionInfo').html('You Have Read / Write / Attachment Permission For This Group.');

                                }

                            }
                            else
                            {$('#lblPermissionInfo').css('display', 'none');}
                        }
                        //For Permission End
                    }

                }


            });
        }





        //Create New Group Chat Dialog Start

        function CreateNewGroupDialod() {

            var user = {
                id: sFromQBId,
                login: "@Session["FromUserEmail"]",
                password: "Welcome007!"
            };
            QB.createSession({ login: user.login, password: user.password }, function (err, result) {

                if (err) {
                    alert(err.message);
                } else {
                    //alert("Session Token- " + result.token);
                    sessionStorage.setItem("sToken", result.token);

                    //var occupants = new Array(sToQBId, sFromQBId);
                    var occupants = new Array();
                    for (var v1=0;v1 < GroupMemberList.length ; v1++)
                    {
                        occupants.push(GroupMemberList[v1].QuickBloxId);
                    }



                    var dialogOccupants = {
                        type: 2,
                        occupants_ids: occupants,//[sFromQBId, sToQBId],
                        name: "Chat_" + "@ViewBag.GroupName",
                        data: {
                            class_name: "ChatDialogType",
                            ChatCategory: "3"
                        }
                        //name: "Chat_" + sFromQBId + "_" + sToQBId
                    };



                    //Create New Group Chat Dialog
                    QB.chat.dialog.create(dialogOccupants, function (err, createdDialog) {
                        if (err) {
                            //console.log(err);
                            //console.log("DIALOG CREATED FAIL");
                        } else {
                            //Add new QuickBlox Id For Specific User

                            var url = INITURL + '/Chatting/SaveDialogId';


                            $.ajax({
                                url: url,
                                data: {
                                    @*NurseUserId: "@Session["ToUserUserId"]",
                                    SchedulerUserId: "@Session["LoginUserUserId"]",*@
                                    ChattingGroupId: @ViewBag.GroupDialogId,
                                    DialogId: createdDialog._id
                                },
                                cache: false,
                                type: 'POST',
                                async: false,
                                success: function (data) {
                                    if (data == "Success") {
                                        tmpDialogId = createdDialog._id;
                                    }
                                    loadChatMessages(100,0);
                                    joinChatRoom();
                                    toastr.success("Now You Can Start Chatting.");
                                    $("#loading").hide();
                                },
                                error: function (reponse) {
                                    alert("error : " + reponse);
                                    $("#loading").hide();
                                }
                            });
                        }
                    });
                }
            });

            //---
        }

        //Create New Group Chat Dialog End

        //Register New User Start
        function RegisterNewUser(Login, UserId1,Index) {
            var RegisterUser = { 'login': Login, 'password': "Welcome007!", 'tag': "differenzsystem", 'email': Login };

            QB.users.create(RegisterUser, function (err, user1) {
                if (user1) {
                    //Add new QuickBlox Id For Specific User

                    var url = INITURL + '/Chatting/SaveQBId';
                    var QBId = user1.id;
                    $.ajax({
                        url: url,
                        data: { UserId: UserId1, QuickBloxId: QBId },
                        cache: false,
                        type: 'POST',
                        async: false,
                        success: function (data) {
                            if (data == "Success") {

                                if (UserId1 == "@Session["LoginUserUserId"]") {
                                    sFromQBId = "" + QBId + "";
                                    GroupMemberList[Index].QuickBloxId = sFromQBId;

                                    sessionStorage.setItem("FromQBId", QBId);
                                    startChat();

                                }
                                if (UserId1 == GroupMemberList[Index].UserId) {

                                    //sToQBId = "" + QBId + "";
                                    //GroupMemberList[Index].QuickBloxId = sToQBId;
                                    sessionStorage.setItem("ToQBId", QBId);
                                }
                            }
                            //CreateNewGroupDialod();
                        },
                        error: function (reponse) {
                            alert("error : " + reponse);
                            $("#loading").hide();
                        }
                    });


                    // success
                } else {
                    return;
                    // error
                }
            });
        }
        //Register New User End

        //Load Chat Message Start
        function loadChatMessages(vLimit,vSkip) {

            var user = {
                id: sFromQBId,
                login: "@Session["FromUserEmail"]",
                password: "Welcome007!"
            };
            QB.createSession({ login: user.login, password: user.password }, function (err, result) {

                if (err) {
                    alert(err.message);
                } else {
                    //alert("Session Token- " + result.token);
                    sessionStorage.setItem("sToken", result.token);

                  var mlimit = 100;
                  var mskip = 0;

                  loadMessageV1(1,mlimit,mskip);

                }
            });

        }
        //Load Chat Message End


        //Join Group Chat Start
        function joinChatRoom() {
            dialogJid = QB.chat.helpers.getRoomJidFromDialogId(tmpDialogId);
            QB.chat.muc.join(dialogJid, function (resultStanza) {

                var joined = true;

                for (var i = 0; i < resultStanza.childNodes.length; i++) {
                    var elItem = resultStanza.childNodes.item(i);
                    if (elItem.tagName === 'error') {
                        joined = false;
                    }
                }
            });
        }
        //Join Group Chat End

        function onMessage(sFromQBId, sentMsg) {

            //  debugger;
            if(sentMsg.markable){
                //     debugger;
                var params = {
                    messageId: sentMsg.id,
                    userId: sFromQBId,
                    dialogId: sentMsg.dialog_id
                };
                QB.chat.sendReadStatus(params);
            }

            loadChatMessages(100,0);
            //$("#file1").val('');
            $("#fileCall").css({ 'color': "" });
            $("#loading").hide();
        }

        QB.chat.onMessageListener = onMessage;



        QB.chat.onReadStatusListener = function(messageId, dialogId, userId){
            //  debugger;

            if(parseInt(userId) != parseInt(sFromQBId))
            {
                loadMessageV1(0,limit,skip);
            }
        }




        //Start Send Message To CareGiver
        $("#btnSendMsg").click(function () {

            IsScrollDown = 1;

            var currentMessage = $('#txtSendMsg').val();
            $('#txtSendMsg').val("");
            //var opponentId = sToQBId;
            var sToken = sessionStorage.getItem("sToken");


            ////1
            var totalSelectedFiles = $("input[type=file]")[0].files.length;
            totalFiles = $("input[type=file]")[0].files;
            var totalFileType = "";

            if (totalSelectedFiles > 0)
            {
                $("#loading").show();
                toastr.info("File Uploading Stared");
                uploadFile(totalSelectedFiles-1,totalFiles[totalSelectedFiles-1]);
                //$("#loading").hide();

            }
            else {


                var msg = {
                    type: 'groupchat',
                    body: currentMessage,
                    extension: {
                        save_to_history: 1,
                        userName:sFromQBName,
                        chatType:"@ViewBag.GroupTypeId",//"2",//Custom Parameter pass to QuickBlox
                        MsgType:'text'
                    },
                    markable: 1
                };

                if (currentMessage.length != 0) {
                    QB.chat.send(dialogJid, msg);
                    $("#loading").show();
                    //Send PushNotification start
                    var url = INITURL + '/Chatting/NotifyUserForChatMessage';
                    $.ajax({
                        url: url,
                        data: {
                            UserId: "@Session["LoginUserUserId"]",
                            Msg: currentMessage,
                            QuickBloxId:sFromQBId,
                            DialogId : tmpDialogId,
                            Type:"@ViewBag.GroupTypeId",    @*Type : "2",*@
                            UserName : sFromQBName,
                            GroupName : "@ViewBag.GroupName"
                        },
                        cache: false,
                        type: 'POST',
                        async: false,
                        success: function (data) {
                        },
                        error: function (reponse) {
                            $("#loading").hide();
                        }
                    });
                    //Send PushNotification end
                }
                else
                {
                    toastr.info("Please Enter Message.");
                }
            }

			 $('#txtSendMsg').focus();
        });
        //End Send Message To CareGiver

        function setLoadMoreMessagesListener (){
            $("#chat1").on('scroll', function loadMoreMessages(e) {
                var elem = e.currentTarget;
                if (elem.scrollTop < 5) {
                    gSkip= gSkip+100;
                    //loadChatMessages(gSkip,gSkip);
                    $('#ScrollUp').css('display','block');
                    $('#ScrollDown').css('display','none');
                }
                if (elem.scrollTop == 1) {
                    $('#ScrollUp').css('display','none');
                    $('#ScrollDown').css('display','block');
                }
            });

        };
        $("#ScrollUp").click(function(){
            $('#chat1').animate({
                scrollTop: 6
            }, 'slow')
            $('#ScrollUp').css('display','none');
            $('#ScrollDown').css('display','block');
        });
        $("#ScrollDown").click(function(){
            $('#chat1').animate({
                scrollTop: $('#chat1')[0].scrollHeight
            }, 'slow')
            $('#ScrollDown').css('display','none');
        });

        function uploadFile(temptotalSelectedFiles,File){
            $("#loading").show();
            File = totalFiles[temptotalSelectedFiles];
            //console.log(temptotalSelectedFiles+" + "+File.name);
            totalFileType =File.type.split('/');
            if(totalFileType[0] != 'image' && totalFileType[0] != 'video' && totalFileType[0] != 'audio')
            {
                totalFileType[0]  = 'doc';
            }



            if (File != null) {

                var params = { name: File.name, file: File, type: File.type, size: File.size, 'public': false };
                $("#loading").show();
                QB.content.createAndUpload(params, function (err, response) {
                    if (err) {
                        console.log(err);
                    } else {
                        var uploadedFileId = response.id;


                        var msg = {
                            type: 'groupchat',
                            body: totalFileType[0]+". ",// + currentMessage,
                            extension: {
                                save_to_history: 1,
                                userName:sFromQBName,
                                chatType:"@ViewBag.GroupTypeId",//"2",//Custom Parameter pass to QuickBlox
                                MsgType:totalFileType[0],
                                file_name:File.name,
                                file_size:File.size

                            },
                            markable: 1
                        };
                        msg["extension"]["attachments"] = [{ id: uploadedFileId, type: File.type }];


                        QB.chat.send(dialogJid, msg);
                        toastr.success(File.name +" "+ File.type +  " uploaded");
                        $("#FileAlert").css({ 'display': "none" });
                        $("#fileRemove").css({ 'display': "none" });
                        $("#fileCall").css({ 'display': "block" });
                        $("#fileCall").css({ 'color': "" });

                        //Send PushNotification start

                        var url = INITURL + '/Chatting/NotifyUserForChatMessage';
                        $.ajax({
                            url: url,
                            data: {
                                UserId: "@Session["LoginUserUserId"]",
                                Msg:  totalFileType[0]+". ",//+ currentMessage,
                                QuickBloxId:sFromQBId,
                                DialogId : tmpDialogId,
                                Type:"@ViewBag.GroupTypeId",    @*Type : "2",*@
                                UserName : sFromQBName,
                                GroupName : "@ViewBag.GroupName"
                            },
                            cache: false,
                            type: 'POST',
                            async: false,
                            success: function (data) {
                                //console.log(temptotalSelectedFiles+" + "+File.name);
                                //console.log("temptotalSelectedFiles - " + temptotalSelectedFiles);
                                temptotalSelectedFiles -= 1;
                                if(temptotalSelectedFiles >= 0)
                                {
                                    uploadFile(temptotalSelectedFiles,totalFiles[temptotalSelectedFiles]);
                                }
                                else
                                {
                                    toastr.info("File Uploading Finished.");
                                    $("#file1").val('');
                                    $("#txtSendMsg").removeAttr('disabled');
                                    $("#loading").hide();
                                }
                            },
                            error: function (reponse) {
                                //alert("error : " + reponse);
                                $("#loading").hide();
                            }
                        });
                        //Send PushNotification end

                    }

                });

            }

        }
    });

    function openMedia(url,type)
    {

        var media = '';
        $("#mediaDiv").css("max-height", "320px");
        $("#mediaDiv").html(media);
        if(type==1)
        {
            media="<img src='"+url+"' style='vertical-align:middle' width='90%' height='90%' alt='image'/>";
            $("#mediaDiv").css("max-height", "320px");
            $("#mediaDiv").html(media);
        }
        else if(type==2)
        {
            media="<video id='openVideo'  controls>"+"<source  src='"+url+"' type='video/mp4'>"+  "<source src='"+url+"' type='video/ogg'>"+"</video>";
            $("#mediaDiv").css("height", "310px"); $("#mediaDiv").css("max-height", "400px");
            $("#mediaDiv").html(media);
        }
        else if(type==3)
        {
            PDFObject.embed(url, "#mediaDiv");
            $("#mediaDiv").css("height", "510px");
            $("#mediaDiv").css("max-height", "510px");

        }

    }

