    function convertTimeStampToTimeAgo(TimeStamp) {
        var date = new Date(TimeStamp * 1000);
        var seconds = Math.floor((new Date() - date) / 1000);
        if (Math.round(seconds / (60 * 60 * 24 * 365.25)) >= 2) return Math.round(seconds / (60 * 60 * 24 * 365.25)) + " years ago";
        else if (Math.round(seconds / (60 * 60 * 24 * 365.25)) >= 1) return "last year ago";
        else if (Math.round(seconds / (60 * 60 * 24 * 30.4)) >= 2) return Math.round(seconds / (60 * 60 * 24 * 30.4)) + " months ago";
        else if (Math.round(seconds / (60 * 60 * 24 * 30.4)) >= 1) return "last month ago";
        else if (Math.round(seconds / (60 * 60 * 24 * 7)) >= 2) return Math.round(seconds / (60 * 60 * 24 * 7)) + " weeks ago";
        else if (Math.round(seconds / (60 * 60 * 24 * 7)) >= 1) return "last week ago";
        else if (Math.round(seconds / (60 * 60 * 24)) >= 2) return Math.round(seconds / (60 * 60 *  24)) + " days ago";
        else if (Math.round(seconds / (60 * 60 * 24)) >= 1) return "yesterday";
        else if (Math.round(seconds / (60 * 60)) >= 2) return Math.round(seconds / (60 * 60)) + " hours ago";
        else if (Math.round(seconds / (60 * 60)) >= 1) return "an hour ago";
        else if (Math.round(seconds / 60) >= 2) return Math.round(seconds / 60) + " minutes ago";
        else if (Math.round(seconds / 60) >= 1) return "a minute ago";
        else if (seconds >= 2) return seconds + " seconds ago";
        else if (seconds == 1) return "just now";
        else return "just now";
    };
