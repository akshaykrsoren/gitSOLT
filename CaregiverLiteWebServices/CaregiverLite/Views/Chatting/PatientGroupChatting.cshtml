        var b = a.filter(function (el) {

            var x = OfficeNameText;
            var y = el.OfficeName;
         //   debugger;
            // str.includes("world");
            return el.OfficeName.includes(OfficeNameText);
            // return el.OfficeName == OfficeName;
        });

        if ($('#ddlOfficeDropDownList').val() != 0) {
            var datatable = ooTable;

            datatable.clear().draw();
            datatable.rows.add(b);
            // Add new data
            datatable.columns.adjust().draw();
        }
        else {
            var datatable = ooTable;

            datatable.clear().draw();
            datatable.rows.add(a);
            // Add new data
            datatable.columns.adjust().draw();
        }
 //********************************************************* old logic for unread count
        //for (var i1 = 0; i1 < GroupDialogIds.length ; i1++) {
        //    var res1 = JSON.parse(localStorage.getItem('res1'));
        //    //   debugger;
        //    if (res1[GroupDialogIds[i1].GroupDialogId]) {
        //        //   debugger;
        //        if (($("#myDataTable").find('tbody tr td span[id="notifyGroup' + GroupDialogIds[i1].GroupDialogId + '"]')).length > 0) {
        //            $("#notifyGroup" + GroupDialogIds[i1].GroupDialogId).text(res1[GroupDialogIds[i1].GroupDialogId]);
        //            $("#notifyGroup" + GroupDialogIds[i1].GroupDialogId).show();
        //        }
        //        else {

        //            if (GroupDialogIds[i1].GroupDialogId != "") {
        //                //console.log(DialogIds[i1].NurseId + " _ notify" + DialogIds[i1].QuickBloxDialogId);
        //                var tmpdid = "notifyGroup" + GroupDialogIds[i1].GroupDialogId
        //                $("#" + GroupDialogIds[i1].NurseId).show();
        //                $("#" + GroupDialogIds[i1].NurseId).attr('id', tmpdid);
        //                $("#notifyGroup" + GroupDialogIds[i1].GroupDialogId).text(res1[GroupDialogIds[i1].GroupDialogId]);

        //            }
        //        }
        //    }

        //}
//*********************************************************

    }

    //For Search Critaria Start

    $(document).ready(function () {

        localStorage.removeItem("local_group_chatting_data");
        localStorage.removeItem("group_chatting_data");

        var columns = [

                            {
                                'targets': 0,
                                "sName": "GroupName",
                                "mRender": function (data, type, row, meta) {
                                    //var notify = "";

                                    //if (row.DialogId != "") {
                                    //    notify = '<span class="label label-danger" style="float: right;height: 25px;width: auto;padding-top: 7px;font-size: 12px;border-radius: 15px;display:none" v1="' + row.GroupName + '"  id="notifyGroup' + row.DialogId + '"></span>';
                                    //}
                                    //else {
                                    //    notify = '<span class="label label-danger" style="float: right;height: 25px;width: auto;padding-top: 7px;font-size: 12px;border-radius: 15px;display:none" v1="' + row.GroupName + '"  id="' + row.GroupName + '"></span>';
                                    //}

                                    var v1 = '<span class="label label-danger" style="float: right;height: 25px;width: auto;padding-top: 7px;font-size: 12px;border-radius: 15px;">' + row.unreadMsgCount + '</span>'
                                    //GroupName
                                  //  return '<span style="margin-left: 0px;">' + row.GroupName + '</span>' + notify;

                                    if (row.unreadMsgCount) {
                                        return '<span style="margin-left: 0px;">' + row.GroupName + '</span>' + v1;
                                    }
                                    else {

                                        return '<span style="margin-left: 0px;">' + row.GroupName + '</span>' ;
                                    }
                                }
                            },
                           {
                               "sName": "OfficeName",
                               "bSortable": true,
                               "mRender": function (data, type, row, meta) {

                                   return row.OfficeName;
                               }
                           },
                            {
                                "sName": "ChattingGroupId",
                                "bSortable": false,
                                "mRender": function (data, type, row, meta) {
                                    var actionhtml = '';
                                    //actionhtml += '<a href="javascript:;" onclick="OpenChatWindow(\'' + oObj["NurseId"] + '\');" class="btn btn-xs btn-primary" style="margin-top:5px; width:100%;" >Chat</a>'
                                    actionhtml += '<a href="/Chatting/OpenGroupChatWindow?Id=' + row.ChattingGroupId + '" class="btn btn-xs btn-primary" style="width:100%;" >Chat</a>'
                                    //actionhtml += '<a href="javascript:;" class="btn btn-xs btn-primary" style="margin-top:5px; width:100%;" onclick="OpenChatWindow(\'' + oObj["NurseId"] + '\');">Chat</a>'
                                    return actionhtml;
                                }
                            },
                            {
                                "sName": "Time",
                                "bVisible": false,
                                "mRender": function (data, type, row, meta) {
                                    return row.Time;

                                    console.log(data);
                                    console.log(row.Time);
                                }
                            },
                            {

                                "sName": "NurseCoordinator",
                                "bSortable": false,
                                "bVisible": @Session["IsSuperAdmin"],
                                "mRender": function (data, type, row, meta) {
                                    //row.NurseCoordinatorId
                                    //row.NurseCoordinatorPermission
                                    //return '<Select id=NurseCo' + row.ChattingGroupId + ' class="form-control input-sm" value="' + row.NurseCoordinatorId + '"></Select>' +
                                    //    ' <Select id="permission' + row.ChattingGroupId + '" class="form-control input-sm" style="margin-left:10px;" value="' + row.NurseCoordinatorPermission + '"></Select>' +
                                    //    ' <input type="button" class="btn btn-xs btn-primary" style="margin-left:10px; width:auto;" onclick="SetNurseCoordinator(' + row.ChattingGroupId + ')" value="Assign">';

                                    return '<input type="button" class="btn btn-xs btn-primary" style="margin-left:10px; width:auto;" onclick="OpenAssignNew(' + row.ChattingGroupId + ',\'' + escape(row.GroupName) + '\')" value="Assign Office Staff">';
                                }
                            },
                            {

                                "sName": "Nurse",
                                "bSortable": false,
                                "bVisible": @Session["IsSuperAdmin"],
                                "mRender": function (data, type, row, meta) {
                                    return '<input type="button" class="btn btn-xs btn-primary" style="margin-left:10px; width:auto;" onclick="OpenAssignNewCaregiverModal(' + row.ChattingGroupId + ',\'' +  escape(row.GroupName)  + '\')" value="Assign Caregiver">';
                                }
                            },
                              {

                                  "sName": "Scheduler",
                                  "bSortable": false,
                                  "bVisible": @Session["IsSuperAdmin"],
                                  "mRender": function (data, type, row, meta) {
                                      return '<input type="button" class="btn btn-xs btn-primary" style="margin-left:10px; width:auto;" onclick="OpenAssignNewSchedulerModal(' + row.ChattingGroupId + ',\'' + row.GroupName + '\')" value="Assign Scheduler">';
                                  }
                              },
                            {

                                "sName": "Member",
                                "bSortable": false,
                                @*"bVisible":@Session["IsNurseCoordinator"],*@
                                "bVisible": '@Session["Role"]' == 'Nurse'?true : '@Session["Role"]' == 'NurseCoordinator'? true:false ,
                                "mRender": function (data, type, row, meta) {
                                    var actionHtml = '';
                                        actionHtml = '<input type="button" class="btn btn-xs btn-primary" style="margin-left:10px; width:auto;" onclick="OpenAssignNewMemberModal(' + row.ChattingGroupId + ',\'' + escape(row.GroupName) + '\',\'' + row.GroupTypeId + '\')" value="Assign Member">';
                                    return actionHtml;
                                }
                            }
        ]
        if (localStorage.getItem('local_group_chatting_data') == null) {
            localdata();
        }
        else {
            dataTable();
        }

        function localdata() {
            //  debugger;
            try {
                // $('#loading').show();
                $.ajax({
                    url: "@Url.Action("GetChattingListPatientGroupWise", "Chatting")",
                    type: 'POST',
                    data: jQuery.param({ sEcho: "1", iDisplayStart: "0", iDisplayLength: "5000", iSortCol_0: "2", sSortDir_0: "asc", sSearch: "", iColumns: "3" }),
                    success: function (response) {
                        localStorage.setItem('local_group_chatting_data', JSON.stringify(response));
                        dataTable();
                    },
                    error: function (error) {
                        //   debugger;
                        //throw error;
                    }
                });

            } catch (e) {
                //  $('#loading').hide();

            }
        }

        function dataTable() {

            //var testdata = JSON.parse(localStorage.getItem('local_group_chatting_data'));
            //var data = testdata.aaData;

            if (localStorage.getItem('group_chatting_data') != null) {
                //  var testdata = JSON.parse(localStorage.getItem('local_chatting_data'));
                var data = JSON.parse(localStorage.getItem('group_chatting_data'));

            }
            else {
                var testdata = JSON.parse(localStorage.getItem('local_group_chatting_data'));
                var data = testdata.aaData;

            }

            $("#loading").show();
            var jquey = jQuery.noConflict();

            ooTable = $('#myDataTable')
                     .DataTable({
                         "aaData": data,
                         "draw": 1,
                         "bDeferRender": true,
                         "sDom": '<"top"l>rt<"bottom"ip><"clear">',
                         "pageLength": 100,
                         "autoWidth": false,
                         "bPaginate": true,
                         "bSearchable": true,
                         columns: columns,
                         "order": [[3, 'desc']],
                     });

            $("#loading").hide();

            setTimeout(groupSortByTime, 2000);

        }

        $('#myDataTable_filter input').unbind(); //Unbind direct search on each keypress
        $('#myDataTable_filter input').bind('keyup', function (e) { //Bind Keyup event that filter data only on "Enter" key.
            if (e.keyCode == 13) {
                ooTable.fnFilter(this.value);
            }
        });

        $("#loading").hide();

        $('#table-filter').bind('keyup',function (e) {
            //Bind Keyup event that filter data only on "Enter" key.
            if (e.keyCode == 13) {
                ooTable.search(this.value).draw();
                //oTable.fnFilter(this.value, null, false);
            }
        });

        function groupSortByTime()
        {
            var dialogs = JSON.parse(localStorage.getItem('QBres'));
            var testdata = JSON.parse(localStorage.getItem('local_group_chatting_data'));
            var dataSource = testdata.aaData;
            //debugger;
            try{
                for (var d = 0; d < dialogs.length; d++) {
                    var dt;
                    dt = dialogs[d].last_message_date_sent;
                    count = dialogs[d].unread_messages_count;

                    for (var x = 0; x < dataSource.length; x++) {
                        if (dialogs[d]._id == dataSource[x].DialogId) {
                            dataSource[x]["Time"] = dt;
                            dataSource[x]["unreadMsgCount"] = count;
                        }
                    }
                }


                ////-----
            }catch(e){}

            var sortData1 = dataSource.sort(function (a, b) { return b.Time - a.Time });
            localStorage.setItem('group_chatting_data', JSON.stringify(sortData1));
        }
    });


    //NurseCoordinator
    //Add new
    function OpenAssignNew(ChattingGroupId, GroupName) {
        $("#loading").show();
      //  var url=INITURL+ 'Chatting/AssignNurseCoordinator?ChattingGroupId=' + ChattingGroupId + '&GroupName=\"' + unescape(GroupName) +'\"';

        var url = INITURL + 'Chatting/AssignNurseCoordinator?ChattingGroupId=' + ChattingGroupId + '&GroupName=' + unescape(GroupName );
        $('#AssignNurseCoordinator').load(encodeURI(url), function () {
            sessionStorage.setItem("PartialView", "1");
            $('#myModal').modal('show');
            $("#loading").hide();
        });
    }

    //Added by Pinki
    function OpenAssignNewCaregiverModal(ChattingGroupId, GroupName) {
        $("#loading").show();
      //  var url=INITURL+ 'Chatting/AssignCaregiver?ChattingGroupId=' + ChattingGroupId + '&GroupName=\"' + unescape(GroupName) +'\"';

        var url = INITURL + 'Chatting/AssignCaregiver?ChattingGroupId=' + ChattingGroupId + '&GroupName=' + unescape(GroupName );

        $('#AssignCaregiver').load(encodeURI(url), function () {
            sessionStorage.setItem("PartialView", "1");
            $('#modalCaregiverAssignment').modal('show');
            $("#loading").hide();
        });
    }

    function OpenAssignNewMemberModal(ChattingGroupId, GroupName, GroupTypeId) {
        $("#loading").show();
        //var url=INITURL+ 'Chatting/AssignMember?ChattingGroupId=' + ChattingGroupId + '&GroupName=\"' + GroupName+'\"';
        var url = INITURL + 'Chatting/AssignMember?ChattingGroupId=' + ChattingGroupId + '&GroupName=' + unescape(GroupName ) + '&GroupTypeId=' + GroupTypeId;
        $('#AssignMember').load(encodeURI(url), function () {
            sessionStorage.setItem("PartialView", "1");
            $('#modalMemberAssignment').modal('show');
            $("#loading").hide();
        });
    }

    function OpenAssignNewSchedulerModal(ChattingGroupId, GroupName) {
        $("#loading").show();
        var url=INITURL+ 'Chatting/AssignScheduler?ChattingGroupId=' + ChattingGroupId + '&GroupName=\"' + GroupName+'\"';
        $('#AssignScheduler').load(encodeURI(url), function () {
            sessionStorage.setItem("PartialView", "1");
            $('#modalSchedulerAssignment').modal('show');
            $("#loading").hide();
        });
    }

</script>
