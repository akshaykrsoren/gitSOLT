@{
    ViewBag.Title = "Patient Chat Room List";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<!-- ADD nurseCoordinator POPUP START -->
<div class="modal fade" id="myModal" tabindex="-1" role="dialog" aria-labelledby="myModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-md">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                <h4 class="modal-title" id="gridSystemModalLabel">Assign Office Staff</h4>
            </div>
            <div class="modal-body row" id="AssignNurseCoordinator">
            </div>
        </div>
    </div>
</div>

<!-- ADD Caregiver POPUP START -->
<div class="modal fade" id="modalCaregiverAssignment" tabindex="-1" role="dialog" aria-labelledby="myModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-md">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                <h4 class="modal-title" id="gridSystemModalLabel">Assign Caregiver(s)</h4>
            </div>
            <div class="modal-body row" id="AssignCaregiver">
            </div>
        </div>
    </div>
</div>

<!-- ADD member POPUP START -->
<div class="modal fade" id="modalMemberAssignment" tabindex="-1" role="dialog" aria-labelledby="myModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-md">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                <h4 class="modal-title" id="gridSystemModalLabel">Assign Member(s)</h4>
            </div>
            <div class="modal-body row" id="AssignMember">
            </div>
        </div>
    </div>
</div>

<!-- ADD Scheduler POPUP START -->
<div class="modal fade" id="modalSchedulerAssignment" tabindex="-1" role="dialog" aria-labelledby="myModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-md">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                <h4 class="modal-title" id="gridSystemModalLabel">Assign Scheduler(s)</h4>
            </div>
            <div class="modal-body row" id="AssignScheduler">
            </div>
        </div>
    </div>
</div>


<div class="wrapper wrapper-content animated fadeInRight">
    <div class="row">
        <div class="col-lg-12">
            <div class="ibox float-e-margins">
                <div class="ibox-title">
                    <h5>Patient Chat Room List</h5>
                    <div class="ibox-tools">
                        @*<input type="text" class="form-control input-sm" style="margin-top:-9px;" id="table-filter" placeholder="Search Here..">
                            <select id="ddlUnread" name="ddlUnread" onchange="GetUnread();" style="width: 148px;height:34px;border-color:#e5e6e7">
                                <option value="0">All</option>
                                <option value="1">Unread</option>
