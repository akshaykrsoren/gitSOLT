                    </div>
                </div>
                <div class="ibox-content">
                    <div class="form-group col-md-2 pull-right">
                        <label>Search:</label>
                        <input type="text" class="form-control" id="table-filter" placeholder="Search Here..">
                    </div>
                    <div class="form-group col-md-2 pull-right">

                        <label>@CaregiverLite.Views.Resources.PatientRequest.FilterLabelOffice</label>
                        </br>
                        <div class="form-group" style="margin-right: 10px;">
                            @Html.DropDownList("ddlOfficeDropDownList", (System.Web.Mvc.SelectList)ViewBag.OfficeDropDownList, new { @class = "form-control", style = "width:170px", @onchange = "FilterOffice(this.value)" })
                        </div>
                    </div>
                    <div class="clearfix"></div>
                    <table id="myDataTable" class="table table-striped table-bordered table-hover dataTables-example">
                        <thead>
                            <tr>
                                <th>Name</th>
                                <th>Office</th>
                                <th>Chat</th>
                                <th>Time</th>
                                <th>Office Staff</th>
                                <th>Caregiver</th>
                                <th>Scheduler</th>
                                <th>Member</th>
                            </tr>
                        </thead>
                        <tbody></tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="~/Scripts/js/jquery-2.1.1.js"></script>
<script src="~/Scripts/js/jquery.dataTables.js"></script>
<link rel="stylesheet" href="https://code.jquery.com/ui/1.12.1/themes/base/jquery-ui.css">
<script src="~/Scripts/js/oms.min.js"></script>
<script>
    var tempMsg = '@TempData["Message"]';
    if (tempMsg != "")
        toastr.success(tempMsg);


    $('#ddlOfficeDropDownList').val(0);
    var ooTable;
    //For Search Critaria Start
    function GetUnread() {

        //debugger;
        var a = JSON.parse(localStorage.getItem('group_chatting_data'));


        var b = a.filter(function (el) {
            return el.unreadMsgCount > 0;
        });


        if ($('#ddlUnread').val() == 1) {
            var datatable = ooTable;

            datatable.clear().draw();
            datatable.rows.add(b);
            // Add new data
            datatable.columns.adjust().draw();
        }
        else {
            var datatable = ooTable;

            datatable.clear().draw();
            datatable.rows.add(a);
            // Add new data
            datatable.columns.adjust().draw();
        }
        for (var i1 = 0; i1 < GroupDialogIds.length ; i1++) {
            var res1 = JSON.parse(localStorage.getItem('res1'));
            //   debugger;
            if (res1[GroupDialogIds[i1].GroupDialogId] != 0) {
                //   debugger;
                if (($("#myDataTable").find('tbody tr td span[id="notifyGroup' + GroupDialogIds[i1].GroupDialogId + '"]')).length > 0) {
                    $("#notifyGroup" + GroupDialogIds[i1].GroupDialogId).text(res1[GroupDialogIds[i1].GroupDialogId]);
                    $("#notifyGroup" + GroupDialogIds[i1].GroupDialogId).show();
                }
                else {

                    if (GroupDialogIds[i1].GroupDialogId != "") {
                        //console.log(DialogIds[i1].NurseId + " _ notify" + DialogIds[i1].QuickBloxDialogId);
                        var tmpdid = "notifyGroup" + GroupDialogIds[i1].GroupDialogId
                        $("#" + GroupDialogIds[i1].NurseId).show();
                        $("#" + GroupDialogIds[i1].NurseId).attr('id', tmpdid);
                        $("#notifyGroup" + GroupDialogIds[i1].GroupDialogId).text(res1[GroupDialogIds[i1].GroupDialogId]);

                    }
                }
            }

        }

    }
    function FilterOffice(OfficeId) {

