                        <div class="clearfix"></div>
                    </div>*@


                <!--<div class="form-group radio-group">
                <label>-->
                @*<input type="radio" name="group-type" value="office" id="office-group" checked>*@
                <!--@Html.RadioButtonFor(model => model.IsOfficeGroup, true)
                    Office Group Chat
                </label>

                <label>-->
                @*<input type="radio" name="group-type" value="custom" id="customgroup">*@
                <!--@Html.RadioButtonFor(model => model.IsCustomGroup, false)
                        Custom Group Chat
                    </label>
                </div>-->


                <div class="form-group radio-group">
                    <label>
                        Office Group Chat

                        @Html.RadioButtonFor(model => model.SelectedGroup, "Office", new { id = "IsOfficeGroup", style = "margin-left: 14px;" })

                    </label>
                    <br />
                    <br />
                    <label>
                        Custom Group Chat

                        @Html.RadioButtonFor(model => model.SelectedGroup, "Custom", new { id = "IsCustomGroup", style = "margin-left: 8px;" })

                    </label>
                </div>



                @if (Session["Role"].ToString() == "SuperAdmin" || Session["Role"].ToString() == "Scheduler" || Session["Role"].ToString() == "Admin" || Session["Role"].ToString() == "OrgSuperAdmin")
                {
                    <div class="form-group" id="OfficeGroup">
