@model CaregiverLite.Models.GroupChatModel

@*CreateGroupWithSingleAndMultipleOffices*@

@*CreateNewGroup*@

@using (Html.BeginForm("CreateGroupWithSingleAndMultipleOffices", "Chatting", FormMethod.Post, new { @id = "frmCreateGroup", @class = "horizontal-form", @enctype = "multipart/form-data" }))
{
    <div id="main_div">
        <div class="alert alert-danger alert-dismissable" style="display:none" id="dvError3">
            <button onclick="divClose();" class="close" type="button">×</button>
            <label id="lblError3"></label>
        </div>

        <div class="col-md-12">
            <div class="form-group">
                @Html.HiddenFor(model => model.QuickBloxIds)
                @Html.HiddenFor(model => model.GroupDialogId)
                @Html.HiddenFor(model => model.MembersUserId)
                @Html.HiddenFor(model => model.OfficeIds)
                @Html.HiddenFor(model=>model.IsCheckOfficeGroup)


                <div class="form-group">
                    <label>Group Name</label>
                    <span style="color:red;">*</span>
                    @Html.ValidationMessageFor(model => model.GroupName)
                    @Html.TextBoxFor(model => model.GroupName, new { @type = "text", @maxlength = "25", @placeholder = "Enter Group Name", @class = "form-control" })
                </div>
                <div class="form-group">
                    <label>Subject</label>
                    <span style="color:red;">*</span>
                    @Html.ValidationMessageFor(model => model.GroupSubject)
                    @Html.TextBoxFor(model => model.GroupSubject, new { @type = "text", @maxlength = "500", @placeholder = "Enter Subject", @class = "form-control", @onblur = "javascript:IsGroupNameAndSubjectExist();" })
                </div>


                @*<div class="col-md-12">
                        <label class="m-r-md">IsOfficeGroup</label>
