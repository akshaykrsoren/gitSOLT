                        <span style="color:red;">*</span>

                        @*@Html.ValidationMessageFor(model => Model.OfficeId)
                            @Html.DropDownList("OfficeId", (System.Web.Mvc.MultiSelectList)ViewBag.lstOffice, "Select Office", new { @multiple = "multiple", @class = "form-control" })*@

