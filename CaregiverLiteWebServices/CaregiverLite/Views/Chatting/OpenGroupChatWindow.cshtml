                                <h3 style="color:purple">DateTime:</h3>


                                <div><p id="p1"></p></div>

                                <script>

                                    var today = new Date();

                                    var date = today.getDate() + '-' + (today.getMonth() + 1) + '-' + today.getFullYear();

                                    var time = today.getHours() + ":" + today.getMinutes();

                                    var dateTime = date + ' ' + time;
                                    document.getElementById("p1").innerHTML = dateTime;



                                </script>

                            </div>
                        </div>


                        <form>


