<script>
    $(function () {
        var dateFormat = "mm/dd/yy",
            from = $("#ScheduledDate")
                .datepicker({
                    defaultDate: "+1w",
                    changeMonth: true,
                    numberOfMonths: 1,
                    maxDate: new Date()

                })
                .on("change", function () {

                    to.datepicker("option", "minDate", getDate(this));
                }),
            to = $("#ReScheduledDate").datepicker({
                defaultDate: "+1w",
                changeMonth: true,
                numberOfMonths: 1,
                maxDate: new Date(),
                minDate: $("#ScheduledDate").val()

            })
                .on("change", function () {

                    to.datepicker("option", "minDate", getDate(this));
                });



        var dateFormat1 = "mm/dd/yy",
            from1 = $("#ScheduledDate1")
                .datepicker({
                    defaultDate: "+1w",
                    changeMonth: true,
                    numberOfMonths: 1,
                    maxDate: new Date()

                })
                .on("change", function () {

                    to1.datepicker("option", "minDate", getDate(this));
                }),
            to1 = $("#ReScheduledDate1").datepicker({
                defaultDate: "+1w",
                changeMonth: true,
                numberOfMonths: 1,
                maxDate: new Date(),
                minDate: $("#ScheduledDate1").val()

            })
                .on("change", function () {

                    to1.datepicker("option", "minDate", getDate(this));
                });

        var dateFormat2 = "mm/dd/yy",
            from2 = $("#ScheduledDateTime2")
                .datepicker({
                    defaultDate: "+1w",
                    changeMonth: true,
                    numberOfMonths: 1,
                    maxDate: new Date()

                })
                .on("change", function () {

                    to2.datepicker("option", "minDate", getDate(this));
                }),
            to2 = $("#ReScheduledDateTime2").datepicker({
                defaultDate: "+1w",
                changeMonth: true,
                numberOfMonths: 1,
                maxDate: new Date(),
                minDate: $("#ScheduledDateTime2").val()

            })
                .on("change", function () {

                    to2.datepicker("option", "minDate", getDate(this));
                });



        function getDate(element) {
            var date;
            try {
                date = $.datepicker.parseDate(dateFormat, element.value);
            } catch (error) {
                date = null;
            }

            return date;
        }


    });

</script>













