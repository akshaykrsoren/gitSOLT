                                    <select name="Time" id="ScheduledTime" required>
                                        <option value="">SelectTime</option>

                                        <option value="Morning(6AM - 12 PM)">Morning(6AM - 12 PM)</option>
                                        <option value="Afternoon(12PM-6PM)"> Afternoon(12PM-6PM)</option>
                                        <option value="Evening (6PM-12AM)">Evening (6PM-12AM)</option>

