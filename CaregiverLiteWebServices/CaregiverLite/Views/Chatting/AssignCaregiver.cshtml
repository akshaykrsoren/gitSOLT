    function RemoveCaregiver(ChattingGroupId, UserId, QuickBloxId) {
        if (!confirm('Are you sure you want remove this caregiver ?'))
            return false;
        if (ChattingGroupId && UserId) {
            $('#loading').show();
            var url = INITURL + '/Chatting/RemoveMemberFromGroupChat';

            $.ajax({
                url: url,
                type: 'GET',
                data: {
                    ChattingGroupId: ChattingGroupId,
                    UserId: UserId,
                    QuickBloxId: QuickBloxId
                },
                async: true,
                success: function (data) {                    
                    if (data.result == "Success") {
                        $('#' + UserId).remove();                        
                        loadCaregiverSelectList(data.lstCaregiver);
                        $('#loading').hide();
                        toastr.success('Caregiver has been removed successfully.');
                    }
                    else {
                        toastr.error('Something went wrong!');
                        $('#loading').hide();
                    }
                },
                error: function (reponse) {
                    $('#loading').hide();
                }
            });
        }
    }

    function loadCaregiverSelectList(lstCaregiver) {
        //unassignedCaregivers = data.lstCaregiver;
        $('#ddlCaregiver').empty();
        if (lstCaregiver.length > 0) {
            $.each(lstCaregiver, function (key, value) {
                $('#ddlCaregiver').append("<option value=" + value.UserId + " nurseid=" + value.NurseId + " qbid=" + value.QuickBloxId + "email=" + value.Email + ">" + value.Name + "</option>");
                //$('#ddlCaregiver').append("<option value=" + value.UserId + ">" + value.Name + "</option>");
            });
        }
        $('#ddlCaregiver').trigger("chosen:updated");
        $('#loading').hide();
    }

