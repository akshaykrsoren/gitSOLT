
@{
    ViewBag.Title = "Organisation";
}

@*<h2>Organisation</h2>*@


<!-- ADD Organisation POPUP START -->
<div class="modal fade" id="myModal" tabindex="-1" role="dialog" aria-labelledby="myModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-sm">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                <h4 class="modal-title" id="gridSystemModalLabel">Add New Organisation</h4>
            </div>
            <div class="modal-body row" id="AddOrganisation">
            </div>
        </div>
    </div>
</div>

<!-- EDIT Organisation POPUP START -->
<div class="modal fade" id="myModal2" tabindex="-1" role="dialog" aria-labelledby="myModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-sm">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                <h4 class="modal-title" id="gridSystemModalLabel">Update Organisation</h4>
            </div>
            <div class="modal-body row" id="EditPanel">
            </div>
        </div>
    </div>
</div>

<!-- ASSIGN Organisation ZIPCODES POPUP START -->
<div class="modal fade" id="modalOrganisationZipcodes" tabindex="-1" role="dialog" aria-labelledby="myModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-md">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                <h4 class="modal-title" id="gridSystemModalLabel">Assign Zipcode(s)</h4>
            </div>
            <div class="modal-body row" id="AssignOrganisationZipcodes">
            </div>
        </div>
    </div>
</div>

<div class="wrapper wrapper-content animated fadeInRight containerstyle">
    <div class="row">
        <div class="col-lg-12">
            <div class="ibox float-e-margins">
                <div class="ibox-title" style="height: 88px ">
                    @*<h5 style="font-size: 14px;margin: 0 0 22px 7px;padding: 0;text-overflow: ellipsis;float: left;width: 100%;">Organisation List</h5>
                        <div class="ibox-tools" style="float:left">
                            <a class="btn btn-xs CutomButton" style="margin-top:-9px;" href="javascript:;" onclick="OpenAddNew()">Add New Organisation</a>
                            <div class="clearfix"></div>
                        </div>*@

                    <div style="margin-top: 17px;">
                        <span id="OrganisationHeader" style="font-size:15px;color:#1B1B1C;font-weight:800">Organisations</span>
                        <a class="btn btn-xs CutomButton" style="margin-top: -10px;float: right;background-color: #092C44;color: white;padding: 10px;width: 190px;height: 42px;font-size: 14px;" href="javascript:;" onclick="OpenAddNew()">
                            <img src="http://ec2-52-38-33-252.us-west-2.compute.amazonaws.com/Content/image/AddIcon.svg" alt="Add Patient">
                            <span style="margin-left: 3px;font-size: 14px;">Add New Organisation</span>

                        </a>
                        <div class="clearfix"></div>
                    </div>
                </div>
                <div class="ibox-content">
                    <table id="myDataTable" class="table table-striped table-bordered table-hover dataTables-example">
                        <thead>
                            <tr>
                                <th></th>
                                <th>Organisation Name</th>
                                <th>Organisation Manager</th>
                                <th>Street</th>
                                <th>City</th>
                                <th>State</th>
                                <th>Zipcode</th>
                                @* <th>Assigned Zipcodes</th> *@
                                <th style="width: 100px;">@CaregiverLite.Views.Resources.Schedulers.TableHeaderAction</th>
                                @*  <th style="width: 100px;">Assign ZipCodes</th> *@
                            </tr>
                        </thead>
                        <tbody></tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
<script src="~/Scripts/js/jquery-2.1.1.js"></script>
<script src="~/Scripts/js/jquery.dataTables.js"></script>
<link rel="stylesheet" href="https://code.jquery.com/ui/1.12.1/themes/base/jquery-ui.css">
<script src="~/Scripts/js/oms.min.js"></script>
<script type="text/javascript">
    var tempMsg = '@TempData["Message"]';
    if (tempMsg != "")
        toastr.success(tempMsg);

    var oTable;
    $(document).ready(function () {
        //GetUnAssignedNurseCoordinator();

        $("#loading").show();
        var jquey = jQuery.noConflict();
        oTable = $('#myDataTable').dataTable({
            responsive: true,
            "dom": 'lfrtip',
            "bPaginate": true,
            "bServerSide": true,
            "bSortable": true,
            "sPaginationType": "full_numbers",
            "oLanguage": {
                "sProcessing": "<div class=\"loading\" id=\"loading\" style=\"display: block;\"></div>"
            },
            "processing": true,
            "sAjaxSource": "GetAllOrganisationsList",
            "fnServerData": function (sSource, aoData, fnCallback) {
                $.getJSON(sSource, aoData, function (json) {
                    fnCallback(json);
                    $("#loading").hide();
                }).fail(function (jqxhr, textStatus, error) {
                    $("#loading").hide();
                   // window.location.reload();
                });
            },
            "fnDrawCallback": function (oSettings) {
                //Navigation validation
                var rowsPerPage = this.fnSettings()._iDisplayLength;
                var rowsToShow = this.fnSettings().fnRecordsDisplay();
                var table = $('#myDataTable').DataTable();
                var info = table.page.info();
                var currentPageNo = info.page + 1;
                $("#OrganisationHeader").text("");
                $("#OrganisationHeader").text("Organisations (" + rowsToShow + ")");

                $('#myDataTable tbody td').css('height', '40px');





                $('#myDataTable_filter input ').css({ 'border-radius': '5px', 'height': '36px' });


                $('#myDataTable_wrapper select ').css({ 'margin-top': '10px', 'border-radius': '5px', 'margin-bottom': '10px' });
                $('#myDataTable_filter label').contents().filter(function () {
                    return this.nodeType === 3; // This checks for text nodes
                }).remove();

                var searchInput = $('#myDataTable_filter input');
                searchInput.wrap('<div class="search-container" style="position: relative; display: inline-block; width: 100%;"></div>'); // Wrap the search input
                searchInput.css({
                    'padding-right': '30px' // Add padding to the right to make space for the icon
                });
                searchInput.after('<img src="http://ec2-52-38-33-252.us-west-2.compute.amazonaws.com/Content/image/SearchIcon.png" class="search-icon" id="SearchIcon" alt="Search Icon" style="position: absolute; right: 10px; top: 50%; transform: translateY(-50%); cursor: pointer;">');

                $("#loading").hide();
            },
            "responsive": {
                "details": {
                    "type": 'column'
                }
            },
            "aoColumns": [
                            {
                                className: 'control',
                                orderable: false,
                                targets: 0,
                                "mRender": function (oObj) {
                                    return '';
                                }
                            },
                            {
                                "sName": "OrganisationName",
                                "mRender": function (oObj) {
                                    return oObj["OrganisationName"];
                                }
                            },
                              {
                                  "sName": "AdminName",
                                  "mRender": function (oObj) {
                                      return oObj["OrganisationAdminName"];
                                  }
                              },
                            {
                                "sName": "Street",
                                "mRender": function (oObj) {
                                    return oObj["Street"];
                                }
                            },
                            {
                                "sName": "City",
                                "mRender": function (oObj) {
                                    return oObj["City"];
                                }
                            },
                            {
                                "sName": "State",
                                "mRender": function (oObj) {
                                    return oObj["State"];
                                }
                            },
                            {
                                "sName": "ZipCode",
                                "mRender": function (oObj) {
                                    return oObj["ZipCode"];
                                }
                            },
                           @* {
                                "sName": "AssignedZipcodes",
                                "mRender": function (oObj) {
                                    return '<span title="' + oObj["AssignedZipcodes"] + '">' + (oObj["AssignedZipcodes"].length >= 99 ? (oObj["AssignedZipcodes"].substring(0, 50) + "...") : oObj["AssignedZipcodes"]) + '</span>';

                                }
                            }, *@
                                 {
                                     "sName": "OrganisationId",
                                     "bSortable": false,
                                     "mRender": function (oObj) {
                                         var actionhtml = '';
                                       //  actionhtml += '<a href="javascript:;" class="btn btn-xs btn-danger" style="margin-top:5px; width:100%;" onclick="DeleteOrganisation(\'' + oObj["OrganisationId"] + '\');">@CaregiverLite.Views.Resources.CareGiver.ButtonDelete</a>'
                                         //actionhtml += '<a href="javascript:;" class="btn btn-xs btn-primary" style="margin-top:5px; width:100%;" onclick="EditOrganisation(\'' + oObj["OrganisationId"] + '\');">EDIT</a>'

                                         actionhtml += '<a href="javascript:;" title="Edit"   style="margin-top:5px;margin-left:35px; width:100%;height: 15px;width: 15px;" onclick="EditOrganisation(\'' + oObj["OrganisationId"] + '\');"><img src="http://ec2-52-38-33-252.us-west-2.compute.amazonaws.com/Content/image/EditIcon.png" alt="Delete Icon"></a>';

                                         return actionhtml;
                                     }
                                 },
                                @* {
                                     "sName": "OrganisationId",
                                     "bSortable": false,
                                     "mRender": function (oObj) {
                                         var actionhtml = '';
                                         actionhtml += '<a href="javascript:;" class="btn btn-xs btn-primary" style="margin-top:5px; width:100%;" onclick="AssignZipcodes(\'' + oObj["OrganisationId"] + '\');">ASSIGN ZIPCODES</a>'
                                         return actionhtml;
                                     }
                                 } *@


            ]
        });

        $('#myDataTable_filter input').unbind(); //Unbind direct search on each keypress
        $('#myDataTable_filter input').bind('keyup', function (e) { //Bind Keyup event that filter data only on "Enter" key.
            if (e.keyCode == 13) {
                oTable.fnFilter(this.value);
            }
        });
        /* Init DataTables */
        $('.carousel').carousel({
            interval: false
        });

        var config = {
            '.chosen-select': {},
            '.chosen-select-deselect': { allow_single_deselect: true },
            '.chosen-select-no-single': { disable_search_threshold: 10 },
            '.chosen-select-no-results': { no_results_text: 'Oops, nothing found!' },
            '.chosen-select-width': { width: "95%" }
        }
        for (var selector in config) {
            $(selector).chosen(config[selector]);
        }

        $("#loading").hide();
    });

    //Add new
    function OpenAddNew() {
        $("#loading").show();
        console.log(INITURL);

        $('#AddOrganisation').load(INITURL + 'Organisation/_AddOrganisation', function () {
            sessionStorage.setItem("PartialView", "1");
            $('#myModal').modal('show');
            $("#loading").hide();
        });
    }
    //Delete One
    function DeleteOrganisation(OrganisationId1) {
        if (confirm('Are you sure you want to delete Organisation?')) {
            $("#loading").show();
            var url = INITURL + '/Organisation/DeleteOrganisation';

            $.ajax({
                url: url,
                data: { OrganisationId: OrganisationId1 },
                cache: false,
                type: 'POST',
                async: false,
                success: function (data) {
                    if (data == "Success") {
                        toastr.success('Organisation is Deleted successfully.');
                        window.location = INITURL + '/Organisation/Organisation';
                    }
                    $("#loading").hide();
                },
                error: function (reponse) {
                    alert("error : " + reponse);
                    $("#loading").hide();
                }
            });
        }
    }

    //Edit One
    function EditOrganisation(OrganisationId) {
        // console.log(schedulerid);
        $("#loading").show();
        $('#EditPanel').load(INITURL + '/Organisation/_EditOrganisation/' + OrganisationId, function () {
            sessionStorage.setItem("PartialView", "1");
            $('#myModal2').modal('show');
            $("#loading").hide();
        });
    }
    //Assign Zipcodes
    function AssignZipcodes(OrganisationId) {
        //$('#AssignOrganisationZipcodes').remove();

        $("#loading").show();
        $('#AssignOrganisationZipcodes').load(INITURL + '/Organisation/_AssignZipcodes/' + OrganisationId, function () {
            sessionStorage.setItem("PartialView", "1");
            $('#modalOrganisationZipcodes').modal('show');
            $("#loading").hide();
        });
    }


    $(document).on('click', '#SearchIcon', function (event) {
        event.stopPropagation();  // Prevents the outer div's click event
        var query = $('#myDataTable_filter input').val(); // Get the value from the search input
        $('#myDataTable').DataTable().search(query).draw(); // Trigger the DataTable search

    });


</script>