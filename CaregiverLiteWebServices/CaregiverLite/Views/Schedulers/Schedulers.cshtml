
@{
    ViewBag.Title = "Scheduler";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .Schedularbtn {
        margin-top: 5px;
        width: 100%;
        border-radius: 4px;
        background-color: #FFFFFF !important;
        border: 1px solid #1B4066;
        color: #1B4066;
        text-transform: none;
        font-weight: bold;
        letter-spacing: 0px;
    }

    .items-badge {
        /*align-self: flex-start;
        border-radius: 6px;
        background-color: #fff;
        color: #1b4066;
        padding: 5px 7px;
        font: 600 12px Open Sans, sans-serif;
        border: 1px solid #1b4066;*/
        align-self: flex-start;
        border-radius: 18px;
        color: #239450;
        padding: 6px 10px;
        font: 600 12px Open Sans, sans-serif;
        background-color: #D4FFE8;
    }



    .items-badgeInActive {
        align-self: flex-start;
        border-radius: 18px;
        color: #E24B4B;
        padding: 6px 10px;
        font: 600 12px Open Sans, sans-serif;
        background-color: #FFDEDE;
    }



    .toggle-container {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-top: -27px;
    }

    /*.switch {
        position: relative;
        display: inline-block;
        width: 48px;
        height: 24px; =
        margin-left: 70%;
    }*/

    .switch {
        position: relative;
        display: inline-block;
        width: 48px; /* reduced width */
        height: 24px; /* reduced height */
        margin-top: -8px;
        margin-left: 5px;
    }

        .switch input {
            display: none;
        }

    .slider {
        position: absolute;
        cursor: pointer;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background-color: #ccc;
        transition: 0.4s;
        border-radius: 28px; /* adjusted to match new height */
    }

        .slider:before {
            position: absolute;
            content: "";
            height: 18px; /* adjusted height */
            width: 18px; /* adjusted width */
            left: 4px; /* adjusted position */
            bottom: 3px;
            background-color: white;
            transition: 0.4s;
            border-radius: 50%;
        }

    input:checked + .slider {
        background-color: #4CAF50;
    }

        input:checked + .slider:before {
            transform: translateX(22px); /* adjusted translation */
        }

    /*#toggleText {
        font-weight: bold;
        margin-top: -7px;
    }*/

    #toggleText {
        font-weight: bold;
        margin-top: -7px;
        margin-left: 6px;
    }

    #toggleText1 {
        font-weight: bold;
        margin-top: -7px;
        margin-left: 216px;
        ;
    }

    .confirmbtn {
        background-color: #e6f4ea;
        color: #1d9b6c;
        border: 1px solid;
        border-radius: 4px;
        height: 40px;
        font-weight: bold;
    }

        .confirmbtn:hover {
            background-color: #d1ecd9;
        }

    .cancelbtn {
        background-color: #f4e6e6;
        color: #d93025;
        border: 1px solid;
        border-radius: 4px;
        height: 40px;
        font-weight: bold;
    }

        .cancelbtn:hover {
            background-color: #ebd2d2;
        }



    .cancelbtnActive {
        background-color: #e6f4ea;
        color: #1d9b6c;
        border: 1px solid;
        border-radius: 4px;
        height: 40px;
        font-weight: bold;
    }

        .cancelbtnActive:hover {
            background-color: #d1ecd9;
        }

    .confirmbtnActive {
        background-color: #f4e6e6;
        color: #d93025;
        border: 1px solid;
        border-radius: 4px;
        height: 40px;
        font-weight: bold;
    }

        .confirmbtnActive:hover {
            background-color: #ebd2d2;
        }

    .Schedularbtn:hover {
        background-color: #092C44 !important;
        color: white !important;
    }
</style>
<!-- ADD Sheduler POPUP START -->
<div class="modal fade" id="myModal" tabindex="-1" role="dialog" aria-labelledby="myModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-sm" id="modalAddPopup">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
