<script>
    var tempMsg = '@TempData["Message"]';
    if (tempMsg != "")
        toastr.success(tempMsg);

    var SchedulerName = "";
    var role = '@Session["role"]';

    var oTable;
    $(document).ready(function () {

        $("#loading").show();
        var jquey = jQuery.noConflict();
        oTable = $('#myDataTable').dataTable({
            responsive: true,
            "dom": 'lfrtip',
            "bPaginate": true,
            "bServerSide": true,
            "bSortable": true,
            "sPaginationType": "full_numbers",
            "oLanguage": {
                "sProcessing": "<div class=\"loading\" id=\"loading\" style=\"display: block;\"></div>"
            },
            "processing": true,
            "sAjaxSource": "GetSchedulerList",
            "fnServerParams": function (aoData) {
                aoData.push({ "name": "ddFilterOffice", "value": $('#OfficeId').val() });
				aoData.push({ "name": "FilterOrganisationId", "value": $('#ddFilterOrganisation option:selected').val() });
				aoData.push({ "name": "FilterActiveStatus", "value": $('#ddFilterActiveInactive option:selected').val() });

            },
            "fnServerData": function (sSource, aoData, fnCallback) {
                $.getJSON(sSource, aoData, function (json) {
                    fnCallback(json);
                }).fail(function (jqxhr, textStatus, error) {
                    window.location.reload();
                });
            },
            "fnDrawCallback": function (oSettings) {
                //Navigation validation
                var rowsPerPage = this.fnSettings()._iDisplayLength;
                var rowsToShow = this.fnSettings().fnRecordsDisplay();
                var table = $('#myDataTable').DataTable();
                var info = table.page.info();
                var currentPageNo = info.page + 1;
                $("#loading").hide();
                $("#SchedularHeader").text("");
                $("#SchedularHeader").text("Scheduler  (" + rowsToShow + ")");
                $('#myDataTable tbody td').css('height', '40px');


                $('#myDataTable_filter input ').css({ 'border-radius': '5px', 'height': '36px' });
                $('#myDataTable_wrapper select ').css({ 'margin-top': '10px', 'border-radius': '5px', 'margin-bottom': '10px' });
                $('#myDataTable_filter label').contents().filter(function () {
                    return this.nodeType === 3; // This checks for text nodes
                }).remove();

                var searchInput = $('#myDataTable_filter input');
                searchInput.wrap('<div class="search-container" style="position: relative; display: inline-block; width: 100%;"></div>'); // Wrap the search input
                searchInput.css({
                    'padding-right': '30px' // Add padding to the right to make space for the icon
                });
                searchInput.after('<img src="http://ec2-52-38-33-252.us-west-2.compute.amazonaws.com/Content/image/SearchIcon.png" class="search-icon" id="SearchIcon" alt="Search Icon" style="position: absolute; right: 10px; top: 50%; transform: translateY(-50%); cursor: pointer;">');

                $("#loading").hide();
            },
            "responsive": {
                "details": {
                    "type": 'column'
                }
            },
            "aoColumns": [
                            {
                                className: 'control',
                                orderable: false,
                                targets: 0,
                                "mRender": function (oObj) {
                                    return '';
                                }
                            },
                            {
                                "sName": "FirstName",
                                "mRender": function (oObj) {
                                    return '<span>' + oObj["FirstName"] + '</span>';
                                }
                            },
                            {
                                "sName": "LastName",
                                "mRender": function (oObj) {
                                    return oObj["LastName"];
                                }
                            },
                            {
                                "sName": "UserName",
                                "mRender": function (oObj) {
                                    return oObj["UserName"];
                                }
                            },
                            {
                                "sName": "Email",
                                "mRender": function (oObj) {
                                    return oObj["Email"];
                                }
                            },
                               {
                                   "sName": "OfficeName",
                                   "mRender": function (oObj) {

                                       if (oObj["OfficeName"] == '')
                                       {
                                           return '-';
                                       }

                                       var OfficeNames = oObj["OfficeName"];
                                       OfficeNames = OfficeNames.replace(/,/g, '<br>');

                                       // return oObj["OfficeName"];
                                       return OfficeNames;
                                   }
                               },

                            {
                                "sName": "SchedulerId",
                                "bSortable": false,
                                "mRender": function (oObj) {
                                    var actionhtml = '';
                                    actionhtml += '<a href="javascript:;" class="btn btn-xs btn-primary Schedularbtn"  onclick="OpenAssignGroupModal(\'' + oObj["UserId"] + '\' , \'' + oObj["FirstName"] + '\',\'' + oObj["LastName"] + '\',\'' + oObj["QuickBloxId"] + '\',\'' + oObj["Email"] + '\');">Assign Patient Chat Room</a>'
                                    return actionhtml;
                                }
                            },
                              {
                                  "sName": "SchedulerId",
                                  "bSortable": false,
                                  "mRender": function (oObj)
                                  {

                                      if (oObj["FirstName"] == '') {
                                          return '-';
                                      }

                                      var actionhtml = '';
                                      SchedulerName = oObj["FirstName"];

                                      if (role != 'Scheduler') {

                                          if (oObj["FirstName"].includes("'")) {

                                              actionhtml += '<a href="javascript:;" class="btn btn-xs btn-primary Schedularbtn" onclick="OpenAssignOfficeModal(\'' + oObj["UserId"] + '\' , \'' + '_' + '\',\'' + oObj["LastName"] + '\',\'' + oObj["Email"] + '\');">Assign Office</a>'
                                          }
                                          else {
                                              actionhtml += '<a href="javascript:;" class="btn btn-xs btn-primary Schedularbtn"   onclick="OpenAssignOfficeModal(\'' + oObj["UserId"] + '\' , \'' + oObj["FirstName"] + '\',\'' + oObj["LastName"] + '\',\'' + oObj["Email"] + '\');">Assign Office</a>'

                                          }
                                      }
                                      else {
                                          actionhtml = '_';
                                      }

                                      return actionhtml;
                                  }
                              },
                                {
                                    "sName": "SchedulerId",
                                    "bSortable": false,
                                    "mRender": function (oObj)
                                    {
                                        var actionhtml = '';
                                        if (role != 'Scheduler')
                                        {
                                           @*actionhtml += '<a href="javascript:;" class="btn btn-xs btn-danger" style="margin-top:5px; width:100%;" onclick="DeleteScheduler(\'' + oObj["SchedulerId"] + '\',\'' + oObj["UserName"] + '\');">@CaregiverLite.Views.Resources.CareGiver.ButtonDelete</a>'
                                            actionhtml += '<a href="javascript:;" class="btn btn-xs btn-primary" style="margin-top:5px; width:100%;" onclick="EditScheduler(\'' + oObj["SchedulerId"] + '\');">@CaregiverLite.Views.Resources.CareGiver.ButtonEditProfile</a>'*@

                                            actionhtml += '<a href="javascript:;"  title="Edit"   style="margin-top:5px;margin-left:17px; width:100%;height: 15px;width: 15px;"  onclick="EditScheduler(\'' + oObj["SchedulerId"] + '\');"><img src="http://ec2-52-38-33-252.us-west-2.compute.amazonaws.com/Content/image/EditIcon.png" alt="Edir Icon"></a>';
                                            actionhtml += '<a href="javascript:;"  title="Delete"   style="margin-top:5px;margin-left:28px; width:100%;height: 15px;width: 15px;" onclick="DeleteScheduler(\'' + oObj["SchedulerId"] + '\',\'' + oObj["UserName"] + '\');"><img src="http://ec2-52-38-33-252.us-west-2.compute.amazonaws.com/Content/image/DeleteIcon.png" alt="Delete Icon"> </a>';

                                        }
                                        else {
                                            actionhtml = '_';
                                        }
                                        return actionhtml;
                                    }
                                },
                                {
                                    "sname": "IsActive",
                                    "bSortable": false,
                                    "mRender": function (oObj) {
                                        if (oObj["IsActive"] != "False") {

                                            return '<span class="items-badge">Active</span>'
                                        }
                                        else {
                                            return '<span class="items-badgeInActive">Inactive</span>'
                                        }
                                        //  return oObj["IsActive"];
                                    }
                                }

            ]
        });

        $('#myDataTable_filter input').unbind(); //Unbind direct search on each keypress
        $('#myDataTable_filter input').bind('keyup', function (e) { //Bind Keyup event that filter data only on "Enter" key.
            if (e.keyCode == 13) {
                oTable.fnFilter(this.value);
            }
        });
        /* Init DataTables */
        $('.carousel').carousel({
            interval: false
        });

        var config = {
            '.chosen-select': {},
            '.chosen-select-deselect': { allow_single_deselect: true },
            '.chosen-select-no-single': { disable_search_threshold: 10 },
            '.chosen-select-no-results': { no_results_text: 'Oops, nothing found!' },
            '.chosen-select-width': { width: "95%" }
        }
        for (var selector in config) {
            $(selector).chosen(config[selector]);
        }

        $("#loading").hide();
    });


    $('#OfficeId').bind('change', function (e) {

        //debugger;
        // $('#OfficeId').val();
        oTable.fnFilter('');
    });


$('#ddFilterOrganisation').bind('change', function (e) {

        //debugger;
        // $('#OfficeId').val();
        oTable.fnFilter('');
})
$('#ddFilterActiveInactive').bind('change', function (e) {

    //debugger;
    // $('#OfficeId').val();
    oTable.fnFilter('');
})

    function DeleteScheduler(schedulerid,username) {
        if (confirm('Are you sure you want to delete Scheduler?')) {
            $("#loading").show();
            var url = INITURL + '/Schedulers/DeleteScheduler';

            $.ajax({
                url: url,
                data: { SchedulerId: schedulerid, UserName: username },
                cache: false,
                type: 'POST',
                async: false,
                success: function (data) {
                    if (data == "Success") {
                        window.location = INITURL + '/Schedulers/Schedulers';
                    }
                    $("#loading").hide();
                },
                error: function (reponse) {
                    alert("error : " + reponse);
                    $("#loading").hide();
                }
            });
        }
    }

