
    




    <a href="" id="btnFilter2" class="btn btn-xs pull-right btn-primary">@CaregiverLite.Views.Resources.Dashboard.ButtonFilter</a>
    <div class="clearfix"></div>
    <div class="hr-line-dashed"></div>
    <div id="PaymentReceived">
        <div class="row">
            <div class="col-md-12">
                <table id="myDataTableLAstWeekPayment" class="table table-striped table-bordered table-hover dataTables-example">
                    <thead>
                        <tr>
                            <th>@CaregiverLite.Views.Resources.Dashboard.TableHeaderPatientName</th>
                            <th>@CaregiverLite.Views.Resources.Dashboard.TableHeaderDateTime</th>
                            <th>@CaregiverLite.Views.Resources.Dashboard.TableHeaderTotalPayment</th>
                        </tr>
                    </thead>
                    <tbody>
                       
                            @foreach (CaregiverLite.CaregiverLiteService.PatientRequests item in ViewBag.PaymentReceivePatientAll)
                            {
                                <tr>
                                    <td>@item.PatientName</td>
                                    <td>@item.Date @item.FromTime</td>
                                    <td style="text-align:right">@item.PaidAmount</td>
                                </tr>
                            }
                      
                    </tbody>
                </table>
            </div>
            <div class="clearfix"></div>
        </div>
    </div>

<script type="text/javascript">
    $(document).ready(function () {

        $("#loading").show();
        $('#myDataTableLAstWeekPayment').dataTable({
            responsive: true,
            "dom": 'lfrtip'
        });
        $("#loading").hide();
    });
    $("#btnFilter2").click(function () {
        $("#loading").show();
        var patient = $("#ddlPatient2dash").val();
        var fromdate = $("#FromTime2dash").val() == "" ? "1000-01-01" : $("#FromTime2dash").val();
        var todate = $("#ToTime2dash").val() == "" ? "1000-01-01" : $("#ToTime2dash").val();
        patient = patient.replace(/ /g, "$");

        if ($('#FromTime2dash').val() == "") {
            alert('@CaregiverLite.Views.Resources.Dashboard.RequiredMsgDate5');
            $("#loading").hide();
            return false;
            
        }
        if ($('#ToTime2dash').val() == "") {
            alert('@CaregiverLite.Views.Resources.Dashboard.RequiredMsgDate6');
            $("#loading").hide();
            return false;
        }
        else {
            $("#PaymentReceived").load('@(Url.Action("GetPaymentReceive", "Payment", null, Request.Url.Scheme))?FromDate=' + fromdate + "&ToDate=" + todate + "&PatientId=" + patient, function () {

                $("#FromTime2dash").val(fromdate == "1000-01-01" ? "" : fromdate);
                $("#ToTime2dash").val(todate == "1000-01-01" ? "" : todate);
                $("#ddlPatient2dash").val(patient.replace(/\$/g, " "));
          
            });
            return false;
        }

      

    });
    sessionStorage.setItem("PartialView", "1");
</script>
