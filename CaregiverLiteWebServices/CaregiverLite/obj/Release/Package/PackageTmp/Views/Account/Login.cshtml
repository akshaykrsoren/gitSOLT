<script>
    $(document).ready(function () {

        debugger;
        localStorage.clear();
        sessionStorage.clear();

        var tempMsg = '@TempData["message_login"]';
        if (tempMsg != "") {
            if ('@TempData["LoginError"]' == "true") {
                $("#LoginError").html(tempMsg);
            }
            else {
                $("#spError").html(tempMsg);
            }
        }
        else {
            $("#spError").html("");
        }
    });
</script>



<style>
    .form-outline {
        margin-top: 12px;
        padding-bottom: 9px;
    }

    .form-check {
        padding-bottom: 9px;
    }

    .leftdiv {
        text-align: center;
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%,-50%);
        width: 100%;
    }

    .rightdiv {
        padding: 50px 45px 0px 52px;
        /*margin-left: 30px;*/
    }

    .leftImage {
        height: 100vh;
        background-size: cover;
        background-repeat: no-repeat;
        background-image: url('http://ec2-52-38-33-252.us-west-2.compute.amazonaws.com/Content/image/Group427318954.png');
    }

    .regular-text {
        text-align: center;
        color: #757575;
        font-family: 'Open Sans', 'Roboto', sans-serif;
        font-size: 20px;
        font-style: normal;
        font-weight: 700;
        line-height: normal;
    }

    .bold-text {
        text-align: center;
        color: #5D9BD6;
        font-size: 20px;
        color: #1B1B1C;
        font-family: Roboto, sans-serif;
        font-size: 28px;
        font-style: normal;
        font-weight: 800;
        line-height: normal;
        margin-top: 0.6rem;
        margin-top: -10px;
        margin-left: 10px;
    }

    .password-container {
        position: relative;
    }

    .password-input {
        width: 100%;
        padding: 10px;
        padding-right: 40px; /* Space for the icon */
        box-sizing: border-box;
    }

    .toggle-password {
        position: absolute;
        right: 10px;
        top: 50%;
        transform: translateY(-50%);
        cursor: pointer;
        font-size: 18px;
        z-index: 1;
    }


        .toggle-password.hide {
            background-image: url('http://ec2-52-38-33-252.us-west-2.compute.amazonaws.com/Content/image/Password_openIcon.png');
        }

       img{
            max-width: 100%;           
            /*object-fit: cover;*/
        }

        @@media(max-width:768px) {
            img {
                width: 100%;
            }
        }
    
    
</style>

<div class="container-fluid" style="padding-left:0px">
    <div class="row">
        <div class="col-md-7  col-sm-7 col-xs-7" style="width: 55.333333%;background-color:#1F305B;height: 100%;">

            <img src="http://ec2-52-38-33-252.us-west-2.compute.amazonaws.com/Content/image/LoginIconPattern.png" style="width: 90%;height: 85vh;" />
            <div class="leftdiv">
                 <img id="pasevalogo" src="http://ec2-52-38-33-252.us-west-2.compute.amazonaws.com/Content/image/pasevalogowhite.png" style="height: 120px;" />
                
            </div>
            <div style="margin-top: 17px;margin-left:3%">
                <p style="color: white;font-size: 13px ;padding-top: 20px;text-align: center ">Simplifying Home Healthcare Operations</p>

            </div>
        </div>
        <div class="col-md-5  col-sm-5 col-xs-5" style="margin-left: 33px;color: #1B1B1C">
            
            <div class="rightdiv">
                @using (Html.BeginForm(new { ReturnUrl = ViewBag.ReturnUrl }))
                {

                    <div class="row" style="margin-top: 35px;   margin-left: -70px;">
                        
                        <h3 class="fw-normal mb-3 pb-3 regular-text" style="color: #757575">Login to</h3>

                        <p class="bold-text">Your Account</p>

                    </div>
                    @Html.AntiForgeryToken()
                    @Html.ValidationSummary(true)
                    <div class="row" style="margin: 10px 34px 0px 19px">
                        <div>
                            <div class="form-outline mb-4 ">
                                <label class="form-label" style="color: #1B1B1C; font-size: 13px;">User Name</label>
                                @Html.TextBoxFor(model => model.UserName, new { @type = "text", @required = "required", @class = "form-control",@style = "height: 44px; margin-top: 3px; " })
                            </div>
                            <div class="form-outline mb-4">
                                <div class="row">
                                    <div class="col-md-6 col-sm-6 col-xs-6 " style="font-size: 13px;">
                                        <label class="form-label" style="color: #1B1B1C;">Password </label>
                                    </div>
                                    
                                </div>

                              
                                <div class="password-container">
                                    @Html.TextBoxFor(model => model.Password, new { @type = "password", @required = "required", @class = "form-control", @style = "height: 44px; margin-top: 3px; " })
                                   
                                    <img id="togglePassword" class="toggle-password" src="" />
                                </div>



                               
                            </div>

                            <div class="form-outline mb-4" style="margin-bottom: 20px;">
                                <div class="row">
                                    <div class="col-md-6">
                                        <input class="form-check-input" type="checkbox" value="" id="form1Example3" />
                                        <span class="form-check-label" for="form1Example3" style="color:#777;font-size: 13px;padding-left: 6px;"> Remember password </span>

                                    </div>
                                    <div class="col-md-6" >
                                        <span class="form-check-label" style="margin-top: 3px;float: right;font-size: 13px;"><a class="text-muted" href="@Url.Action("ForgotPassword", "Account")">Forgot password?</a></span>
                                    </div>

                                </div>

                            </div>


                           
                            <button class="btn btn-primary btn-lg btn-block" type="submit" style="background-color: #1F305B;border: none;height: 44px; font-size: 15px;
    padding: 0px;">
                                Log In
                            </button>
                            <div class="form-group" style="text-align: center;">
                                <span id="spError" style="color:green"></span>
                                <span id="LoginError" style="color:red;font-weight: bold;"></span>
                            </div>
                        </div>
                    </div>

                }
            </div>
        </div>
    </div>
</div>

<script type="text/javascript">
    $(document).ready(function () {

        const passwordInput = document.getElementById('Password');
        const togglePassword = document.getElementById('togglePassword');
        togglePassword.src = "http://ec2-52-38-33-252.us-west-2.compute.amazonaws.com/Content/image/Password_ClosedIcon.png";
        togglePassword.addEventListener('click', () => {

            debugger;

            const type = passwordInput.getAttribute('type') === 'password' ? 'text' : 'password';
            passwordInput.setAttribute('type', type);


            if (type == 'text') {
                togglePassword.src = "http://ec2-52-38-33-252.us-west-2.compute.amazonaws.com/Content/image/Password_openIcon.png";
            } else {
                togglePassword.src = "http://ec2-52-38-33-252.us-west-2.compute.amazonaws.com/Content/image/Password_ClosedIcon.png";
            }

            //togglePassword.textContent = type === 'password' ?


            //     togglePassword.src = "http ://ec2-52-38-33-252.us-west-2.compute.amazonaws.com/Content/image/Password_openIcon.png";

            //  togglePassword.classList.toggle('hide');
        });
    });


</script>
