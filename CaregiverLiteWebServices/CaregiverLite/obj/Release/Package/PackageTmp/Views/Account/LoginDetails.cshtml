
@{
    Layout = null;
}

<head>
    <title>PaSeva</title>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/bootstrap/3.4.1/css/bootstrap.min.css">
    <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
    <script src="https://maxcdn.bootstrapcdn.com/bootstrap/3.4.1/js/bootstrap.min.js"></script>
    <link rel="icon" type="image/x-icon" href="http://ec2-52-38-33-252.us-west-2.compute.amazonaws.com/Content/image/Title_icon.png">
</head>
<style>
    .form-outline {
        margin-top: 12px;
        padding-bottom: 9px;
    }

    .form-check {
        padding-bottom: 9px;
    }

    .leftdiv {
        text-align: center;
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%,-50%);
        width: 100%;
    }

    .rightdiv {
        padding: 60px 98px 0px 98px;
        margin: 40px 0px 0px 66px;
    }

    .leftImage {
        height: 100vh;
        background-size: cover;
        background-repeat: no-repeat;
        background-image: url('http://ec2-52-38-33-252.us-west-2.compute.amazonaws.com/Content/image/Group427318954.png');
    }
</style>


<div class="container-fluid" style="padding-left:0px">
    <div class="row">
        @*<div class="col-md-7 ">
                <img src="http://ec2-52-38-33-252.us-west-2.compute.amazonaws.com/Content/image/Login_Left_IMG.png" style="width: 100%;height: 100vh;" />

                <div class="leftdiv">
                    <h2 class="block m-t-xs text-center nav-label" style="font-size: 18px;font-weight: 700">
                        <img src="http://ec2-52-38-33-252.us-west-2.compute.amazonaws.com/Content/image/Logo.png" style="height: 100px;" />
                        <span style="color: white;text-align: center; font-size: 50px;">paseva</span>
                        <p style="color: white;text-align: center;font-size: 22px ;padding-top: 20px ">Simplifying Home Healthcare Operations</p>
                    </h2>
                </div>

                <div style="position: absolute;  bottom: 25px;right: -36px;;transform: translate(-50%, 10px);">
