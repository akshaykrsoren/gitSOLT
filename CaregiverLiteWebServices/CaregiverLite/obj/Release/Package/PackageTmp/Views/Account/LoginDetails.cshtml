                </div>
            </div>*@
        <div class="col-md-7 " style="width: 55.333333%;background-color:#1F305B;height: 100%;">

            <img src="http://ec2-52-38-33-252.us-west-2.compute.amazonaws.com/Content/image/LoginIconPattern.png" style="width: 90%;height: 85vh;" />
            <div class="leftdiv">
                <img id="pasevalogo" src="http://ec2-52-38-33-252.us-west-2.compute.amazonaws.com/Content/image/pasevalogowhite.png" style="height: 120px;" />

            </div>
            <div style="margin-top: 17px;margin-left:3%">
                <p style="color: white;font-size: 13px ;padding-top: 20px;text-align: center ">Simplifying Home Healthcare Operations</p>

            </div>
        </div>



        <div class="col-md-5 text-black">
            <div class="rightdiv">
                @using (Html.BeginForm("LoginDetails", "Account", FormMethod.Post, new { @id = "fmMarketDetails", @class = "horizontal-form", @enctype = "multipart/form-data" }))
                {
                <div>


                    @if (Session["OrganisationId"].ToString() == "0")
                    {
                        <img style="text-align: left;height: 65px;" src="http://ec2-52-38-33-252.us-west-2.compute.amazonaws.com/Content/image/Paseva_CompleteLogo.png" />
                    }
                    else
                    {
                    if (Session["OrganisationId"].ToString() == "3")
                    {

                    }
                        <img style="text-align: left;height: 65px;" src="http://ec2-52-38-33-252.us-west-2.compute.amazonaws.com/Content/image/Harmony.jpg" />
                  }


                </div>
                <div style="padding-top: 15px">
                    <div class="form-outline mb-4">
                        <p class="form-label" style="color: #1F305B; margin: 0px 0 1px ">Organisation</p>
                        <label class="form-label" style="color: #1F305B;">@ViewBag.Organtisation</label>
                    </div>

                    @if (@ViewBag.RoleName == "Admin")
                    {
                        <div class="form-outline mb-4">
                            <p class="form-label" style="color: #1F305B;margin: 0px 0 1px ">Role</p>
                            <label class="form-label" style="color: #1F305B;">Office Manager</label>
                        </div>
                    }
                    else
                    {
                        <div class="form-outline mb-4">
                            <p class="form-label" style="color: #1F305B;margin: 0px 0 1px ">Role</p>
                            <label class="form-label" style="color: #1F305B;">@ViewBag.RoleName</label>
                        </div>
                    }
                    <div class="form-outline mb-4">
                        <p class="form-label" style="color: #1F305B;margin: 0px 0 1px ">Name</p>
                        <label class="form-label" style="color: #1F305B;">@ViewBag.Name</label>

                    </div>
                    <div class="form-outline mb-4">
                        <p class="form-label" style="color: #1F305B;margin: 0px 0 1px ">Email</p>
                        <label class="form-label" style="color: #1F305B;">@ViewBag.Email</label>

                    </div>
                    <div class="form-outline mb-4">
                        <button class="btn btn-primary btn-lg btn-block" type="submit" style="width: 100%;background-color: #1F305B;border: none;font-size: 15px;">Continue</button>

                    </div>

                </div>




                }
            </div>
        </div>




