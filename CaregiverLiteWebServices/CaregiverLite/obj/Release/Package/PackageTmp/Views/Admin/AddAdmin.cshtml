    function CheckUserName() {
        var url = INITURL + '/Schedulers/IsUserNameExists';
        var result;
        $.ajax({
            url: url,
            data: { Username: $("#Username").val(), UserId: $("#UserId").val() },
            cache: false,
            async: false,
            type: 'POST',
            success: function (data) {
                result = data;
            },
            error: function (reponse) {
                alert("error : " + reponse);
            }
        });
        return result;
    }

    function CheckEmail() {
        var url = INITURL + '/Schedulers/IsEmailExists';
        var result;
        $.ajax({
            url: url,
            data: { Email: $("#Email").val(), UserId: $("#UserId").val() },
            cache: false,
            async: false,
            type: 'POST',
            success: function (data) {
                result = data;
            },
            error: function (reponse) {
                alert("error : " + reponse);
            }
        });
        return result;
    }

    function divClose() {
        $("#dvError3").css("display", "none");
    }
    $("#showPasswordEdit").click(function () {
        $("#showPasswordEdit").css("display", "none"); $("#HidePasswordEdit").css("display", "block");
        $("#Password").get(0).type = 'text';
    });
    $("#HidePasswordEdit").click(function () {
        $("#showPasswordEdit").css("display", "block"); $("#HidePasswordEdit").css("display", "none");
        $("#Password").get(0).type = 'password';
    });
</script>
