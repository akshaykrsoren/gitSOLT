    function formatDate(date) {

        var d = new Date(date),
            month = '' + (d.getMonth() + 1),
            day = '' + d.getDate(),
            year = d.getFullYear();

        if (month.length < 2)
            month = '0' + month;
        if (day.length < 2)
            day = '0' + day;

        return [year, month, day].join('-');
    }
    function enableDisable(element, divId) {
        var header = document.getElementById(divId);
        var btns = header.getElementsByTagName("button");
        for (var i = 0; i < btns.length; i++) {
            if (btns[i].className.includes("active")) {
                btns[i].classList.remove("active");
            }
        }
        debugger;
        element.className += " active";

    }


    function Get_DashboardRecord_ChartData() {


        var url = INITURL + '/Chart/DashBoardRecords_ForChart';
        var result;
        $.ajax({
            url: url,
            type: 'GET',
            success: function (data) {
                debugger;
                result = data;
                nfObject = new Intl.NumberFormat('en-US');

                NurseCount = nfObject.format(result[0].Count);// result[0].Count;
                PatientCount = nfObject.format(result[1].Count); //result[1].Count;
                AppointmentCount = nfObject.format(result[2].Count);// result[2].Count;
                TotalDrivingCount = nfObject.format(result[3].Count);// result[2].Count;


                
                PatientAdded = result[4].Count;
                NurseAdded = result[5].Count;
                AppointmentAdded = result[6].Count;
                totaldrivingAddedd = result[7].Count;

                debugger;


                //  output = nfObject.format(AppointmentCount);



                document.getElementById("PatientRecordId").innerHTML = PatientCount;
                if (parseInt(PatientAdded) == 0) {
                    document.getElementById("TotalPatientRecordStatusId").innerHTML = "No Patient added today";
                } else {
                    document.getElementById("TotalPatientRecordStatusId").innerHTML = `+${PatientAdded} Patient added today`;
                }




                document.getElementById("NurseRecordId").innerHTML = NurseCount;
                if (parseInt(NurseAdded) == 0) {
                    document.getElementById("TotalCaregiverRecordStatusId").innerHTML = "No Caregiver added today";
                } else {
                    document.getElementById("TotalCaregiverRecordStatusId").innerHTML = `+${NurseAdded} Caregiver added`;
                }



                document.getElementById("TotalAppointmentId").innerHTML = AppointmentCount;

                if (parseInt(AppointmentAdded) == 0) {
                    document.getElementById("TotalAppointmenStatustId").innerHTML = "No Appointment today";
                } else {
                    document.getElementById("TotalAppointmenStatustId").innerHTML = `+${AppointmentAdded} Appointment added`;
                }

                document.getElementById("TotalDistanceId").innerHTML = TotalDrivingCount;

                debugger;
                var ssss = parseInt(totaldrivingAddedd);

                if (parseInt(totaldrivingAddedd) == 0 || totaldrivingAddedd == "") {
                    document.getElementById("TotalDistanceStatusId").innerHTML = "No Driving today added";
                } else {
                    let gg = TotalDrivingCount;

                    document.getElementById("TotalDistanceStatusId").innerHTML = `+${totaldrivingAddedd}  Miles driven added`;
                }






            },
            error: function (reponse) {
                alert("error : " + reponse);
            }
        });



    }
    function Get_PatientListOfficeWise_ChartData(element, Interval) {
        if (element != null) {
            enableDisable(element, "myDIV5");
        }
        let currentDate = new Date();
        localFromDate = "";
        localToDate = "";
        let FromDate = currentDate.setDate(currentDate.getDate() - parseInt(Interval));
        localFromDate = formatDate(FromDate);
        localToDate = currentLocalFormatedDate;
$("#loading").show();
        $('#PatientOfficeWiseChart').load('/Chart/PatientOfficewise_ChartData?FromDate=' + localFromDate + '&ToDate=' + localToDate);

    }
