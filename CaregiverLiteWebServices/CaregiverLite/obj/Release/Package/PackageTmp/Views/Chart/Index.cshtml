    function PatientListOfficeWise_timechange(startDate, endDate) {

         if ((new Date(startDate)) > (new Date(endDate))) {
            alert("start date should not be greater ");
            return;
        } else {

             if (getDayDifference(startDate, endDate) > 30) {
                 removeActiveClass("myDIV5");
             }

            $('#PatientOfficeWiseChart').load('/Chart/PatientOfficewise_ChartData?FromDate=' + startDate + '&ToDate=' + endDate);

        }

    }
    function TypeOfVisitPatinetWise_timechange(startDate, endDate) {
         if ((new Date(startDate)) > (new Date(endDate))) {
            alert("start date should not be greater  ");
        } else {
             if (getDayDifference(startDate, endDate) > 30) {
                 removeActiveClass("myDIV2");
             }
            $('#TypeOfVisitPatientChart').load('/Chart/TypeOfVisitByPatient_ChartData?FromDate=' + startDate + '&ToDate=' + endDate);
        }

    }
    function ManualAutoSchedule_timechange(startDate, endDate) {
       if ((new Date(startDate)) > (new Date(endDate))) {
            alert("start date should not be greater ");
            return;
       } else {

           DateDifference = getDayDifference(startDate, endDate);
           if (DateDifference > 30) {
               removeActiveClass("myDIV6");
           }
            $('#AutoSchedulingChart').load('/Chart/ManualAutoScheduling_ChartData?FromDate=' + startDate + '&ToDate=' + endDate);
        }

    }



    function setInitialValue() {

