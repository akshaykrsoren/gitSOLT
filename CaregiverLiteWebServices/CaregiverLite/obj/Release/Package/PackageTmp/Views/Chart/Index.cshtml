                let number = parseFloat(TotalDrivingCount.replace(/,/g, ''));

                // 2. Format the number with two decimal places and add commas
                TotalDrivingCount = number.toLocaleString('en-US', {
                    minimumFractionDigits: 2,
                    maximumFractionDigits: 2
                });
                PatientAdded = result[4].Count;
                NurseAdded = result[5].Count;
                AppointmentAdded = result[6].Count;
                totaldrivingAddedd = result[7].Count;


                document.getElementById("PatientRecordId").innerHTML = PatientCount;
                if (parseInt(PatientAdded) == 0) {
                    document.getElementById("TotalPatientRecordStatusId").innerHTML = "No Patients added today";
                } else {
                    document.getElementById("TotalPatientRecordStatusId").innerHTML = `+${PatientAdded} Patient added today`;
                }




                document.getElementById("NurseRecordId").innerHTML = NurseCount;
                if (parseInt(NurseAdded) == 0) {
                    document.getElementById("TotalCaregiverRecordStatusId").innerHTML = "No Caregivers added today";
                } else {
                    document.getElementById("TotalCaregiverRecordStatusId").innerHTML = `+${NurseAdded} Caregiver added today`;
                }



                document.getElementById("TotalAppointmentId").innerHTML = AppointmentCount;

                if (parseInt(AppointmentAdded) == 0) {
                    document.getElementById("TotalAppointmenStatustId").innerHTML = "No Appointments  added today";
                } else {
                    document.getElementById("TotalAppointmenStatustId").innerHTML = `+${AppointmentAdded} Appointments added today`;
                }

                document.getElementById("TotalDistanceId").innerHTML = (TotalDrivingCount != 0) ? TotalDrivingCount : 0;



                if (parseInt(totaldrivingAddedd) == 0 || totaldrivingAddedd == "") {
                    document.getElementById("TotalDistanceStatusId").innerHTML = "No Driving data added today";
                } else {
                    document.getElementById("TotalDistanceStatusId").innerHTML = `+${totaldrivingAddedd}  Miles driven added `;
                }

                debugger;
                var url = INITURL + '/Chart/TotalLicenseRelated_ForChart';
                var result;
                $.ajax({
                    url: url,
                    type: 'GET',
                    success: function (data) {
                        debugger;
                        var jsonresult = data;

                        //document.getElementById("TotalLicenseId").innerHTML = jsonresult[0].UsedActiveLicense;

                        if (jsonresult != null || jsonresult != "") {
                            document.getElementById("TotalLicenseStatusId").innerHTML = "Total License Limit :" + jsonresult[0].TotalActiveLicense;
                        } else {
