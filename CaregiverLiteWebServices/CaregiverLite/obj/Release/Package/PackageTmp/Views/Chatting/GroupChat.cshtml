
@{
    ViewBag.Title = "Group Chat";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .unReadCount {
        float: right;
        height: 25px;
        width: auto;
        padding-top: 7px;
        font-size: 12px;
        border-radius: 15px;
    }

    .table-fixed tbody {
        height: 230px;
        overflow-y: auto;
        width: 100%;
    }

    .table-fixed thead, .table-fixed tbody, .table-fixed tr, .table-fixed td, .table-fixed th {
        display: block;
    }
      .ChatRoombtn{
       text-align: center; margin-top: 5px;width: auto;border-radius: 4px;background-color:#FFFFFF !important;border: 1px solid #1B4066;color: #1B4066; text-transform: none;font-weight: bold;letter-spacing: 0px;
    }
    .ChatRoombtn:hover{
         background-color: #092C44 !important;
         color: white !important; 
    }
    

    .SearchImage{position: absolute; right: 23px; top: 52%; transform: translateY(-52%); cursor: pointer}

     @@media (min-width: 300px) and  (max-width: 780px) {
       .SearchImage{position: absolute; right: 23px; top: 55%; transform: translateY(-55%); cursor: pointer}
  }

 
</style>

<!-- Assign Permission POPUP START -->
<div class="modal fade" id="modalAssignPermission" tabindex="-1" role="dialog" aria-labelledby="myModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-md">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                <h4 class="modal-title" id="gridSystemModalLabel">Assign Permission(s)</h4>
            </div>
            <div class="modal-body row" id="AssignPermission">
            </div>
        </div>
    </div>
</div>

<!-- ADD New Group POPUP START -->
<div class="modal fade" id="addGroupModal" tabindex="-1" role="dialog" aria-labelledby="myModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-md" id="modalAddPopup">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                <h4 class="modal-title" id="gridSystemModalLabel">Add New Group</h4>
            </div>
            <div class="modal-body row" id="AddNewGroup">
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="modalMemberAssignment" tabindex="-1" role="dialog" aria-labelledby="myModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-md">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                <h4 class="modal-title" id="gridSystemModalLabel">Assign Member(s)</h4>
            </div>
            <div class="modal-body row" id="AssignMember">
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="modalGroupDetailEdit" tabindex="-1" role="dialog" aria-labelledby="myModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-md">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                <h4 class="modal-title" id="gridSystemModalLabel">Edit Group Detail(s)</h4>
            </div>
            <div class="modal-body row" id="GroupDetailEdit">
            </div>
        </div>
    </div>
</div>

<div class="wrapper wrapper-content animated fadeInRight containerstyle">
    <div class="row">
        <div class="col-lg-12">
            <div class="ibox float-e-margins">
                <div class="ibox-title" style="height: 88px ">

                    <div class="row" style="margin-top: 17px;text-align:start;">
                        <div class="col-md-6">
                            <span id="CaregiverHeader" style="font-size:15px;color:#1B1B1C;font-weight:800">                              
                               Company Chat
                            </span>
                        </div>
                        <div class="col-md-6" style="text-align:end;">
                            @if (ViewContext.Controller.HasRoles("Nurse"))
                            {
                                if (Session["IsApproved"].ToString() == "True" && Session["IsAllowToCreateGroupChat"].ToString() == "True")
                                {
                                    @*<a class="btn btn-xs CutomButton" style="margin-top:-9px;" href="javascript:;" onclick="OpenAddNew()">Add New Group</a>*@
                                    <a class="btn btn-xs CutomButton" style="margin-top: -10px;float: right;background-color: #092C44;color: white;padding: 10px;height: 42px;font-size: 14px;" href="javascript:;" onclick="OpenAddNew()">
                                        <img src="http://ec2-52-38-33-252.us-west-2.compute.amazonaws.com/Content/image/AddIcon.svg" alt="Create Group">
                                         <span style="margin-left: 3px;font-size:14px">Create Group</span>
                                    </a>

                                }
                            }
                            else
                            {
                                if (Session["IsAllowToCreateGroupChat"].ToString() == "True")
                                {
                                    @*<a class="btn btn-xs CutomButton" style="margin-top:-9px;" href="javascript:;" onclick="OpenAddNew()">Add New Group</a>*@
                                    <a class="btn btn-xs CutomButton" style="margin-top: -10px;float: right;background-color: #092C44;color: white;padding: 10px;height: 42px;font-size: 14px;" href="javascript:;" onclick="OpenAddNew()">
                                        <img src="http://ec2-52-38-33-252.us-west-2.compute.amazonaws.com/Content/image/AddIcon.svg" alt="Create Group">
                                        <span style="margin-left: 3px;font-size:14px">Create Group</span>
                                    </a>

                                }
                            }
                           

                        </div>
                    </div>


                    @*<h5>Group Chat List</h5>
                    <div class="ibox-tools" style="float:left">

                     
                        <div class="clearfix"></div>
                    </div>*@
                </div>
                <div class="ibox-content">
                   
                    <div class="row">
                        <div class="col-xs-7 col-md-9">
                            <div class="form-group col-md-2" id="divOfficeFilter">
                                <label>@CaregiverLite.Views.Resources.PatientRequest.FilterLabelOffice</label>
                                </br>
                                <div class="form-group" style="margin-right: 10px;">
                                    @Html.DropDownList("ddlOfficeDropDownList", (System.Web.Mvc.SelectList)ViewBag.OfficeDropDownList, new { @class = "form-control customdropDown", @onchange = "officeFilter(this.value)", @style = "width: 202px;    border: 1px solid #b6b2b2 !important;    border-radius: 4px !important;   " })
                                </div>
                            </div>

                        </div>
                        <div class="col-xs-5 col-md-3">
                            <div class="form-group">
                                <label></label>
                                <input type="text" class="form-control" id="table-filter" style="border-radius:4px" placeholder="Search by Name..">
                                <img src="http://ec2-52-38-33-252.us-west-2.compute.amazonaws.com/Content/image/SearchIcon.png" class="search-icon SearchImage" id="SearchIcon" alt="Search Icon" >
                            </div>
                        </div>

                    </div>

                 
                    <div class="clearfix"></div>
                    <table id="groupchatTable" class="table table-striped table-bordered table-hover dataTables-example">
                        <thead>
                            <tr>
                                <th>Name</th>
                                <th>Office</th>
                                <th>Chat</th>
                                <th>Member</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody></tbody>
                    </table>
                    <div id="loadMore" class="input-group pull-right margin-25" style="display:none;margin-right: 10px;margin-top: 10px;">
                        <img id="loadingMore" style="display:none" src="~/image/Spinner-1s-32px.gif" />
                        <a id="btnLoadMore" class="btn btn-sm btn-primary" onclick="loadMore();">Load More</a>
                        <span id="allmsg" class="text-primary"></span>
                    </div>
                    <div class="clearfix"></div>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="~/Scripts/js/jquery-2.1.1.js"></script>
<script src="~/Scripts/js/jquery.dataTables.js"></script>
<link rel="stylesheet" href="https://code.jquery.com/ui/1.12.1/themes/base/jquery-ui.css">
<script src="~/Scripts/js/oms.min.js"></script>

<script type="text/javascript">

    $('#ddlOfficeDropDownList').val(0);

    var IsSuperAdmin = '@Session["IsSuperAdmin"]'

    var sFromQBId = "@Session["FromQBId"]";

    var limit = 100;
    var skip = 0;
    var totalEntriesPatient = 0;
    // var officeIds = "1";
    var officeIds = [];
    // officeIds.push("1");

    var groupChat = [];

    var searchInput = "";

    var IsSearch = 0;

    if (IsSuperAdmin == "false") {

        $('#divOfficeFilter').hide();
    }

    // for officewise filter


    var ddlArray = new Array();
    var ddl = document.getElementById('ddlOfficeDropDownList');
    for (i = 0; i < ddl.options.length; i++) {
        ddlArray[i] = ddl.options[i].value;
        officeIds.push(ddlArray[i]);
    }

   if(sFromQBId!='')
   {
       officeIds.push('1');
     }


    $(document).ready(function () {

        $("#loading").show();

        $('#ddlOfficeDropDownList').val(0);

        localStorage.setItem("IsOffcFilterFlagGroup", 0);

        localStorage.setItem("OfficeIdGroup", 0);

        var jquey = jQuery.noConflict();

        CreateSession();
        //setTimeout(getPatientChatRoomDialogs, 10000);

        window.setInterval(function () {


            var sToken = sessionStorage.getItem("sToken");

            if (sToken == null) {
                CreateSession();
            }

            if (localStorage.getItem("IsOffcFilterFlagGroup") == 0) {
                if (searchInput != null && IsSearch == 1) {

                    //debugger;
                    getPatientChatRoomDialogs(limit, skip, 0, officeIds, 0, 1);
                }
                else {
                    getPatientChatRoomDialogs(limit, skip, 0, officeIds, 0, 0);
                }
            }
            //    getPatientChatRoomDialogs(100, 0, 0,officeIds,0,0);

        }, 1000 * 10);

    });



    function CreateSession() {
        //START CREATE SESSION
        QB.createSession(function (err, result) {

            if (err) {

            } else {
                sessionStorage.setItem("sToken", result.token);

                if (sFromQBId == '0') {
                    RegisterNewUser("@Session["FromUserEmail"]", "@Session["LoginUserUserId"]");
                }
                else {
                    var user = {
                        id: sFromQBId,
                        login: "@Session["FromUserEmail"]",
                        password: "Welcome007!"
                    };

                    QB.createSession({ login: user.login, password: user.password }, function (err, result) {
                        if (err) {

                            alert(err.message);
                        } else {
                            sessionStorage.setItem("sToken", result.token);
                            getPatientChatRoomDialogs(limit, skip, 1, officeIds, 0, 0);
                        }
                    });
                }
            }
        });
        //END CREATE SESSION
    }



    function getPatientChatRoomDialogs(limit, skip, flagIsload, officeIds, flagIsfilter, flagIsSearch) {

        var filterOfficeId = officeIds;

        if (flagIsload)
            $("#loading").show();

        if (flagIsSearch) {
            var filters = {
                count: 1,
                name: {
                    ctn: searchInput
                },
                data: {
                    class_name: "ChatDialogType",
                    ChatCategory: 3,
                    OfficeID: {
                        in: officeIds
                    },
                    // OfficeID: officeIds
                }
            }
        }
        else {
            var filters = {
                count: 1,
                data: {
                    class_name: "ChatDialogType",
                    ChatCategory: 3,
                    OfficeID: {
                        in: officeIds
                    },
                    // OfficeID: officeIds
                }
            }
        }

        QB.chat.dialog.list(filters, function (error, response) {
            if (error) {
                return false;
            }

            totalEntriesPatient = response.items.count
           // debugger;

            if (totalEntriesPatient > 100) {
                $("#loadMore").show();
            }
            else {
                $("#loadMore").hide();
            }

            if (flagIsSearch) {
                var filters = {
                    limit: limit,
                    skip: skip,
                    sort_desc: "last_message_date_sent",
                    name: {
                        ctn: searchInput
                    },
                    data: {
                        class_name: "ChatDialogType",
                        ChatCategory: 3,
                        //  OfficeID: officeIds
                        OfficeID: {
                            in: officeIds
                        },
                    }
                }
            }
            else {
                var filters = {
                    limit: limit,
                    skip: skip,
                    sort_desc: "last_message_date_sent",
                    //name: {
                    //    ctn: "Bles"
                    //},
                    data: {
                        class_name: "ChatDialogType",
                        ChatCategory: 3,
                        //  OfficeID: officeIds
                        OfficeID: {
                            in: officeIds
                        },
                    }
                }
            }

            if ((localStorage.getItem("IsOffcFilterFlagGroup") == 0 && flagIsfilter == 0) || (localStorage.getItem("IsOffcFilterFlagGroup") == 1 && flagIsfilter == 1)) {
            QB.chat.dialog.list(filters, function (error, response) {
                if (error) {
                    //   debugger;
                    return false;
                }

                var dialogs = response.items

                var patientgroupDialogIds = "";
                for (i = 0; i < dialogs.length ; i++) {

                    if (i != 99)
                        patientgroupDialogIds += dialogs[i]._id + ","
                    else
                        patientgroupDialogIds += dialogs[i]._id
                }

                if ((localStorage.getItem("IsOffcFilterFlagGroup") == 0 && flagIsfilter == 0) || (localStorage.getItem("IsOffcFilterFlagGroup") == 1 && flagIsfilter == 1)) {
                    var url = INITURL + '/Chatting/GetPatientRoomGroupList';
                    $.ajax({
                        url: url,
                        data: { QBGroupDialogIds: patientgroupDialogIds, GroupType: 2 },
                        cache: false,
                        type: 'POST',
                        async: false,
                        success: function (data) {

                            //  debugger;
                            if ((localStorage.getItem("IsOffcFilterFlagGroup") == 0 && flagIsfilter == 0) || (localStorage.getItem("IsOffcFilterFlagGroup") == 1 && flagIsfilter == 1)) {

                                //debugger;
                                if ((filterOfficeId.length > 0 && localStorage.getItem("OfficeIdGroup") == 0) || (filterOfficeId[0] == localStorage.getItem("OfficeIdGroup"))) {

                                    var dataSource = data;
                                    //debugger;
                                    for (var d = 0; d < dialogs.length; d++) {
                                        var dt;
                                        dt = dialogs[d].last_message_date_sent;
                                        count = dialogs[d].unread_messages_count;
                                        try {
                                            for (var x = 0; x < dataSource.length; x++) {
                                                if (dialogs[d]._id == dataSource[x].DialogId) {
                                                    dataSource[x]["Time"] = dt;
                                                    dataSource[x]["unreadMsgCount"] = count;
                                                }
                                            }
                                        } catch (e) { }
                                    }


                                    var sortData = dataSource.sort(function (a, b) { return b.Time - a.Time });
                                    //  debugger;

                                    var IsOffcFilterFlag = localStorage.getItem("IsOffcFilterFlagGroup");

                                    if (flagIsfilter == 1 || IsOffcFilterFlag == 1)
                                        groupChat = [];

                                    if ((IsOffcFilterFlag == 0 && flagIsfilter == 0) || (flagIsfilter == 1 && IsOffcFilterFlag == 1)) {

                                        if (groupChat.length > 0) {

                                            for (var i = 0; i < sortData.length; i++) {
                                                var groupchatIndex = 0;
                                                var currentData = sortData[i];
                                                var groupchatData = $.grep(groupChat, function (element, index) {
                                                    ///groupchatIndex = index;
                                                    return element.DialogId == currentData.DialogId;
                                                });
                                                if (groupchatData != null && groupchatData.length > 0) {
                                                    // debugger;
                                                    var chatData = groupchatData[0];
                                                    chatData.unreadMsgCount = currentData.unreadMsgCount;
                                                    chatData.Time = currentData.Time;
                                                }
                                                else {
                                                    groupChat.push(currentData);
                                                }
                                            }

                                        }
                                        else {
                                            groupChat = $.merge($.merge([], groupChat), sortData);

                                        }


                                        groupChat = groupChat.sort(function (a, b) { return b.Time - a.Time });

                                        groupChat = groupChat.sort(function (a, b) { return b.Time - a.Time });
                                        // mearge two array working

                                        var groupchatTable = "";


                                        $('#groupchatTable tbody').remove();

                                        for (var tb1 = 0; tb1 < groupChat.length ; tb1++) {

                                            var unReadHtml = "";
                                            var chatBtnhtml = '';
                                            var assignCaregiverBtnhtml = '';
                                            var assignOffStaffBtnhtml = '';
                                            var assignMemberBtnhtml = '';
                                            var actionhtml = '';
                                            var backgroundColorHtml = '';

                                            if (groupChat[tb1].unreadMsgCount > 0) {
											//debugger;
											var RestrictedGroupId = @Convert.ToInt16(System.Configuration.ConfigurationManager.AppSettings["RestrictedGroupId"].ToString());
                                                        var RestrictedGroupAccessIds = "@System.Configuration.ConfigurationManager.AppSettings["RestrictedLoginUserUserId"]";
                                                        var SessionUserId = "@Session["UserId"].ToString()";


                                                 //   if (groupChat[tb1].ChattingGroupId != RestrictedGroupId && !RestrictedGroupAccessIds.includes//(SessionUserId.Contains)) {
                                                        unReadHtml = "<span class='label label-danger unReadCount'>" + groupChat[tb1].unreadMsgCount + "</span>";
                                                  //  }

                                               // unReadHtml = "<span class='label label-danger unReadCount'>" + groupChat[tb1].unreadMsgCount + "</span>";
                                            }

                                            //    chatBtnhtml += '<a href="/Chatting/OpenGroupChatWindow?Id=' + groupChat[tb1].ChattingGroupId + '" class="btn btn-xs btn-primary" style="width:100%;" >Chat</a>';

                                            chatBtnhtml += '<a href="/Chatting/OpenGroupChatWindow?Id=' + groupChat[tb1].ChattingGroupId + '&GroupType=3" class="btn btn-xs btn-primary" style="width:100%;text-transform: none;border-radius:4px" >Chat</a>'

                                            if (groupChat[tb1].IsGroupAdmin == true && groupChat[tb1].IsOfficeGroup == false)
                                                assignMemberBtnhtml += '<input type="button" class="btn btn-xs btn-primary ChatRoombtn" style="margin-left:10px; width:auto;text-transform: none;" onclick="OpenAssignNewMemberModal(' + groupChat[tb1].ChattingGroupId + ',\'' + escape(groupChat[tb1].GroupName) + '\',\'' + groupChat[tb1].GroupTypeId + '\')" value="Assign Member">'
                                            else
                                                assignMemberBtnhtml += '-'


                                            if (groupChat[tb1].IsGroupAdmin == true && groupChat[tb1].IsOfficeGroup == false) {
                                                //actionhtml += '<input type="button" class="btn btn-xs btn-primary" style=";margin-left:10px; width:auto;text-transform: none;" onclick="EditGroupDetaiModal(' + groupChat[tb1].ChattingGroupId + ',\'' + groupChat[tb1].DialogId + '\',\'' + groupChat[tb1].GroupName + '\',\'' + groupChat[tb1].GroupSubject + '\')" value="Edit">'
                                                //actionhtml += '<input type="button" class="btn btn-xs btn-primary" style="background-color: #e00e0e;margin-left:10px; width:auto;text-transform: none;" onclick="DeleteGroupChat(' + groupChat[tb1].ChattingGroupId + ',\'' + groupChat[tb1].DialogId + '\')" value="Delete Group">'
                                          
                                                actionhtml += '<a href="javascript:;" title="Edit Group"  style="margin-top:5px;margin-left:17px; width:100%;height: 15px;width: 15px;"  onclick="EditGroupDetaiModal(' + groupChat[tb1].ChattingGroupId + ',\'' + groupChat[tb1].DialogId + '\',\'' + groupChat[tb1].GroupName + '\',\'' + groupChat[tb1].GroupSubject + '\')" ><img src="http://ec2-52-38-33-252.us-west-2.compute.amazonaws.com/Content/image/EditIcon.png" alt="Edit Group"></a>';
                                                actionhtml += '<a href="javascript:;"  title="Delete Group"  style="margin-top:5px;margin-left:28px; width:100%;height: 15px;width: 15px;" onclick="DeleteGroupChat(' + groupChat[tb1].ChattingGroupId + ',\'' + groupChat[tb1].DialogId + '\')"><img src="http://ec2-52-38-33-252.us-west-2.compute.amazonaws.com/Content/image/DeleteIcon.png" alt="Delete Group"> </a>';

                                            }

                                            if (groupChat[tb1].IsOfficeGroup == false) {
                                                if ("@Session["Role"]" != "SuperAdmin") {
                                                    actionhtml += '<input type="button" class="btn btn-xs btn-primary" style="background-color: #e00e0e;margin-left:10px; width:auto;text-transform: none;"  onclick="ExitGroupChat(' + groupChat[tb1].ChattingGroupId + ',\'' + groupChat[tb1].DialogId + '\',\'' + groupChat[tb1].GroupName + '\')" value="Exit Group">'
                                                }
                                            }
                                            if (groupChat[tb1].IsOfficeGroup == true) {
                                                if ("@Session["Role"]" == "SuperAdmin" || "@Session["Role"]" == "Admin") {
                                                    actionhtml += '<input type="button" class="btn btn-xs btn-primary ChatRoombtn" style="margin-left:10px; width:auto;text-transform: none;"  onclick="AssignPermission(' + groupChat[tb1].ChattingGroupId + ',\'' + groupChat[tb1].GroupName + '\',\'' + groupChat[tb1].GroupTypeId + '\')" value="Assign Permission ">'
                                                }

                                                backgroundColorHtml += 'background-color:#cdf0be'

                                            }

                                            //  assignMemberBtnhtml += '<input type="button" class="btn btn-xs btn-primary" style="margin-left:10px; width:auto;" onclick="OpenAssignNewMemberModal(' + groupChat[tb1].ChattingGroupId + ',\'' + escape(groupChat[tb1].GroupName) + '\',\'' + groupChat[tb1].GroupTypeId + '\')" value="Assign Member">';

                                            groupchatTable += "<tr>" +
                                                    "<td style=" + backgroundColorHtml + ">" + groupChat[tb1].GroupName + unReadHtml + "</td>" +
                                                    "<td style=" + backgroundColorHtml + ">" + groupChat[tb1].OfficeName + "</td>" +
                                                    "<td style=" + backgroundColorHtml + ">" + chatBtnhtml + "</td>" +
                                                    "<td style=" + backgroundColorHtml + ">" + assignMemberBtnhtml + "</td>" +
                                                    "<td style=" + backgroundColorHtml + ">" + actionhtml + "</td>" +
                                                    "</tr>";

                                        }



                                        if (groupChat.length == 0) {
                                            groupchatTable += "<tr><td>No group chat available</td><td></td><td></td><td></td><td></td><td></td></tr>";
                                        }

                                      //  $("#groupchatTable").append(groupchatTable);

                                        if ((localStorage.getItem("IsOffcFilterFlagGroup") == 0 && flagIsfilter == 0) || (localStorage.getItem("IsOffcFilterFlagGroup") == 1 && flagIsfilter == 1)) {

                                            if ((filterOfficeId.length > 0 && localStorage.getItem("OfficeIdGroup") == 0) || (filterOfficeId[0] == localStorage.getItem("OfficeIdGroup"))) {
                                                $('#groupchatTable').append(groupchatTable).promise().then(function () {
                                                    // run when the animation succeeds
                                                }).then(function () {
                                                    // also run when the animation succeeds

                                                    //  if (flagIsfilter == 1)
                                                    $("#loading").hide();
                                                });
                                            }
                                        }

                                        localStorage.setItem("IsOffcFilterFlagGroup", 0);

                                        $("#loadingMore").hide();
                                        if (skip > totalEntriesPatient) {
                                            $("#btnLoadMore").hide();
                                            $("#allmsg").show();
                                            $("#allmsg").text("No more group chat available");
                                        }
                                        else {
                                            $("#btnLoadMore").show();
                                            $("#allmsg").hide();
                                        }
                                    }
                                }
                            }
                            $('#table-filter').css({ 'border-radius': '5px', 'height': '36px' });
                        },
                        error: function (reponse) {
                            //alert("error : " + reponse);
                            $("#loading").hide();
                            $("#loadingMore").hide();
                            $("#btnLoadMore").hide();
                        }
                    });
                }
                // debugger;

            });
        }

        });



    }


    $('window').scroll(function () {

        //debugger;
    });
    function loadMore() {

        skip = limit + skip;

        $("#loadingMore").show();
        $("#btnLoadMore").hide();


        if (skip < totalEntriesPatient) {
            if (searchInput != null && IsSearch == 1) {
                getPatientChatRoomDialogs(limit, skip, 0, officeIds, 0, 1);
            }
            else {
                getPatientChatRoomDialogs(limit, skip, 0, officeIds, 0, 0);
            }
        }
        else {
            $("#loadMore").hide();
            $("#allmsg").show();
            $("#allmsg").text("No more group chat available");
        }


    }

    function officeFilter(OfficeId) {
        //debugger;


        $("#loading").show();

        $("#ddlOfficeDropDownList").blur();

        localStorage.setItem("IsOffcFilterFlagGroup", 1);

        localStorage.setItem("OfficeIdGroup", OfficeId);

        officeIds = [];

        if (OfficeId == 0) {
            for (i = 0; i < ddl.options.length; i++) {
                ddlArray[i] = ddl.options[i].value;
                officeIds.push(ddlArray[i]);
            }

        }
        else {
            officeIds.push(OfficeId);
        }

        limit = 100;
        skip = 0;

        $('#groupchatTable tbody').remove();

        setTimeout(function () {

            getPatientChatRoomDialogs(limit, skip, 1, officeIds, 1, 0);

        }, 1500);

        //getPatientChatRoomDialogs(limit, skip, 1, officeIds, 1, 0);
    }


    $("#table-filter").keyup(function (event) {
