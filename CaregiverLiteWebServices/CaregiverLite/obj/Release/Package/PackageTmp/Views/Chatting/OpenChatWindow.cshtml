								 // RefreshLoadChatMessages();
                                    joinChatRoom();
                                    toastr.success("Now You Can Start Chatting.");
                                    $("#loading").hide();
                                },
                                error: function (reponse) {
                                    //alert("error : " + reponse);
                                    $("#loading").hide();
                                }
                            });
                        }
                    });
                }
            });

            //---
        }

