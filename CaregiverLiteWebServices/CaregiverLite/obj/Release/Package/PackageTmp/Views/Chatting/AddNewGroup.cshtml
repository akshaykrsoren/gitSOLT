                $('#ddlMember').append("<option value=" + value.UserId + " qbid=" + value.QuickBloxId + "email=" + value.Email + ">" + value.MemberName + "</option>");
            });
        }
        $('#ddlMember').trigger("chosen:updated");
        $('#loading').hide();
    }

