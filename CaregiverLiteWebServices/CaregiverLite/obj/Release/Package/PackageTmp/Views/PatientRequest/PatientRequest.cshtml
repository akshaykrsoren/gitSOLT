    function OpenAddRating(PatientRequestId1) {
        $("#loading").show();

        $("#star1").prop('checked', false);
        $("#star2").prop('checked', false);
        $("#star3").prop('checked', false);
        $("#star4").prop('checked', false);
        $("#star5").prop('checked', false);

        $('#myModalRating').modal('show');
        var url = INITURL + '/PatientRequest/GetRatingByPatientRequestId';
        //var Comment1 = document.getElementById("Comment" + NurseId1).value;
        $.ajax({
            url: url,
            data: { PatientRequestId: PatientRequestId1 },
            cache: false,
            type: 'POST',
            async: false,
            success: function (data) {
                //if (data["Result"] == "0") {
                //    $("#star1").prop('checked', true);
                //}
                if (data["Result"] > "0") {
                    $("#star1").prop('checked', true);
                }
                if (data["Result"] > "1") {
