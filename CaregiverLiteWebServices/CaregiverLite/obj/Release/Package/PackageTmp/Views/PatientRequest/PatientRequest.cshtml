    //View Checkin-checkout caregiver Start
    $('#ViewOnMapCheckInOutAddress').click(function () {
        $('#myModalCheckInCheckOutLocation').modal('show');
        setTimeout(function () {

            var gm = google.maps;
            var infowindow;
            var iw = new gm.InfoWindow();

            var CheckInLatLong1 = $("#checkInLatLongSpan").text();
            var checkOutLatLong1 = $("#checkOutLatLongSpan").text();
            var CheckInLatLongArray = CheckInLatLong1.split(',', 2);
            var CheckOutLatLongArray = checkOutLatLong1.split(',', 2);


            var img = new Image();
            img.bluepin = "https://scheduler.paseva.com/CaregiverLiteMobileService/Images/CareGiverProfileImages/blue-dot.png";
            img.greenpin = "https://scheduler.paseva.com/CaregiverLiteMobileService/Images/CareGiverProfileImages/green-dot.png"
            img.redpin = "https://scheduler.paseva.com/CaregiverLiteMobileService/Images/CareGiverProfileImages/red-dot.png"
            var bounds = new google.maps.LatLngBounds();


            if (CheckInLatLongArray != null && CheckInLatLongArray.length > 0) {

                var mapCenter = {
                    lat: parseFloat(CheckInLatLongArray[0]),
                    lng: parseFloat(CheckInLatLongArray[1])
                }

                var map = new google.maps.Map(document.getElementById('mapLocation'),
                 {
                     center: mapCenter,
                     zoom: 16,
                     mapTypeId: google.maps.MapTypeId.ROADMAP
                 });


                var centerinfowindow = new google.maps.InfoWindow();
                var centermarker = new google.maps.Marker({
                    position: mapCenter,
                    map: map
                });

                centermarker.setIcon(img.bluepin);


                var centercontent =
                        '<div><strong>Latitude: </strong>' +
                        //CheckInLatLongArray[0] +
                        CheckInLatLongArray[0].substr(0, CheckInLatLongArray[0].indexOf(".") + 7) +
                        '</div>' +
                        '<div><strong>Longitude: </strong>' +
                        CheckInLatLongArray[1].substr(0, CheckInLatLongArray[1].indexOf(".") + 7) +
                        '</div>' +
                        '<div>' +
                                '<a class="btn btn-xs btn-primary" style="margin-top:5px;" href="javascript:;" onclick="seeAddress(this,' + CheckInLatLongArray[0] + ',' + CheckInLatLongArray[1] + ')">See Address</a>'
                '</div>';
                google.maps.event.addListener(centermarker,
                    'click',
                    (function (centermarker, centercontent, centerinfowindow) {
                        return function () {
                            centerinfowindow.setContent(centercontent);
                            centerinfowindow.open(map, centermarker);

                        };
                    })(centermarker, centercontent, centerinfowindow));
            }

            if (CheckOutLatLongArray != null && CheckOutLatLongArray.length > 0) {
                var mapC = {
                    lat: parseFloat(CheckOutLatLongArray[0]),
                    lng: parseFloat(CheckOutLatLongArray[1])
                }
                var centerinfowindow = new google.maps.InfoWindow();
                var cmarker = new google.maps.Marker({
                    position: mapC,
                    map: map
                });
                cmarker.setIcon(img.greenpin)
                var centercontent1 =

                        '<div><strong>Latitude: </strong>' +
                        CheckOutLatLongArray[0].substr(0, CheckOutLatLongArray[0].indexOf(".") + 7) +
                        '</div>' +
                        '<div><strong>Longitude: </strong>' +
                        CheckOutLatLongArray[1].substr(0, CheckOutLatLongArray[1].indexOf(".") + 7) +
                        '</div>' +
                        '<div>' +
                                '<a class="btn btn-xs btn-primary" style="margin-top:5px;" href="javascript:;" onclick="seeAddress(this,' + CheckOutLatLongArray[0] + ',' + CheckOutLatLongArray[1] + ')">See Address</a>'
                '</div>';
                google.maps.event.addListener(cmarker,
                    'click',
                    (function (cmarker, centercontent1, centerinfowindow) {
                        return function () {
                            centerinfowindow.setContent(centercontent1);
                            centerinfowindow.open(map, cmarker);
                            google.maps.event.trigger(map, 'resize');

                        };
                    })(cmarker, centercontent1, centerinfowindow));
            }

            var legend = document.createElement('dvMapLegend');
            legend.className = "dvMapLegendb";
            if (legend != null) {
                var startpoint = document.createElement('div');
                startpoint.className = "map-notdriving";
                startpoint.innerHTML = '<img src="' + img.bluepin + '" />' + '     Check-In Point';
                legend.appendChild(startpoint);

                var endpoint = document.createElement('div');
                endpoint.className = "map-notdriving";
                endpoint.innerHTML = '<img src="' + img.greenpin + '" />' + '     Check-Out Point';
                legend.appendChild(endpoint);

                map.controls[google.maps.ControlPosition.RIGHT_TOP].push(legend);

                $("#divMapLegend").show();
            }

        }, 500);
        google.maps.event.trigger(map, 'resize');

    });


