<script src="~/Scripts/js/jquery-2.1.1.js"></script>
<script src="~/Scripts/js/jquery.dataTables.js"></script>
<link rel="stylesheet" href="https://code.jquery.com/ui/1.12.1/themes/base/jquery-ui.css">
<script src="~/Scripts/js/oms.min.js"></script>

<script type="text/javascript">

    var oTable;

    $(document).ready(function () {


        $("#loading").show();
        var jquey = jQuery.noConflict();
        oTable = $('#myDataTable').DataTable({

            responsive: true,
            "dom": 'lfrtip',

            "bPaginate": true,
            "bServerSide": true,

            "bSortable": true,
            "sPaginationType": "full_numbers",
			"aaSorting": [[ 6, "desc" ]] ,
            "oLanguage": {
                "sProcessing": "<div class=\"loading\" id=\"loading\" style=\"display: block;\"></div>"
            },
            "processing": true,

            "sAjaxSource": "GetMarketingAttendanceList",
            "fnServerData": function (sSource, aoData, fnCallback) {
                $.getJSON(sSource, aoData, function (json) {
				debugger;
                    fnCallback(json);
                }).fail(function (jqxhr, textStatus, error) {
                    window.location.reload();
                });
            },
            "fnServerParams": function (aoData) {
                aoData.push({ "name": "FilterOfficeId", "value": $('#ddFilterOffice option:selected').val() });
            },
            "fnDrawCallback": function (oSettings) {

                var rowsPerPage = this.fnSettings()._iDisplayLength;
                var rowsToShow = this.fnSettings().fnRecordsDisplay();
                var table = $('#myDataTable').DataTable();
                $('#myDataTable thead th').css({
                    "background-color": "white" // Your desired color
                    // Text color
                });
                var info = table.page.info();
                var currentPageNo = info.page + 1;
                $("#AttandanceHeader").text("");
                $("#AttandanceHeader").text("Marketer Attendance List (" + rowsToShow + ")");

                $('#myDataTable tbody td').css('height', '40px');



                $('#myDataTable_filter input ').css({ 'border-radius': '5px', 'height': '36px' });


                $('#myDataTable_wrapper select ').css({ 'margin-top': '10px', 'border-radius': '5px', 'margin-bottom': '10px' });
                $('#myDataTable_filter label').contents().filter(function () {
                    return this.nodeType === 3; // This checks for text nodes
                }).remove();

                var searchInput = $('#myDataTable_filter input');
                searchInput.wrap('<div class="search-container" style="position: relative; display: inline-block; width: 100%;"></div>'); // Wrap the search input
                searchInput.css({
                    'padding-right': '30px' // Add padding to the right to make space for the icon
                });
                searchInput.after('<img src="http://ec2-52-38-33-252.us-west-2.compute.amazonaws.com/Content/image/SearchIcon.png" class="search-icon" id="SearchIcon" alt="Search Icon" style="position: absolute; right: 10px; top: 50%; transform: translateY(-50%); cursor: pointer;">');

                $("#loading").hide();
            },
            "responsive": {
                "details": {
                    "type": 'column'
                }
            },
            "aoColumns": [

                            {
                                "sName": "MarketersName",
                                "mRender": function (oObj) {
                                    return '<span>' + oObj["MarketersName"] + '</span>';
                                }
                            },
                            //{
                            //    "sName": "ClientRequestId",
                            //    "mRender": function (oObj) {
                            //        return oObj["ClientRequestId"];
                            //    }
                            //   },
                                {
                                    "sName": "ClientName",
                                    "mRender": function (oObj) {
                                        return oObj["ClientName"];
                                    }
                                },
                              {
                                  "sName": "Dateofvisit",
                                  "mRender": function (oObj) {
                                      return oObj["Dateofvisit"];
                                  }
                              },
                              {
                                  "sName": "CheckInTotalTime",
                                //  "bSortable": false,
                               "mRender": function (oObj) {
                                   return oObj["CheckInTotalTime"];
                                }
                              },


                                {
                                    "sName": "Review",
                                    "bSortable": false,
                                    "mRender": function (oObj) {
                                        return oObj["Review"];
                                    }
                                }
                              ,
                            {
                                "sName": "ClientRequestId",
                                "bSortable": false,
                                "mRender": function (oObj) {
                                    var actionhtml = '';
                                    //actionhtml += '<a href="javascript:;" class="btn btn-xs btn-primary noExl" style="margin-top:5px; width:100%;" onclick="AttendanceDetails(\'' + oObj["ClientRequestId"] + '\');">Details</a>'
                                    actionhtml += '<a href="javascript:;" class="btn btn-xs btn-primary" style="margin-top:5px; width:100%;border-radius: 4px;text-transform: none;font-weight: bold;" onclick="AttendanceDetails(\'' + oObj["ClientRequestId"] + '\');">Details</a>'
                                    return actionhtml;
                                }
                            },
							{
                                 "sName": "Referral",
                                 "bSortable": false,
                                 "mRender": function (oObj) {

                                     var actionhtml = '';
                                     if (oObj["ReferralId"] > 0) {
                                         actionhtml += '<a href="javascript:;" noExl" style="margin-top:5px; width:100%;" onclick="ReferralDetails(\'' + oObj["ClientRequestId"] + '\');"><i class="fa fa-eye" style="font-size:24px" aria-hidden="true"></i></a>'
                                         return actionhtml;
                                     }
                                     else {
                                         actionhtml = 'Not available';
                                             return actionhtml;

                                     }
                                 }
                             }


            ]
        });

        $('#myDataTable_filter input').unbind(); //Unbind direct search on each keypress
        $('#myDataTable_filter input').bind('keyup', function (e) { //Bind Keyup event that filter data only on "Enter" key.
            if (e.keyCode == 13) {
                oTable.search(this.value).draw();
            }
        });
        /* Init DataTables */
        $('.carousel').carousel({
            interval: false
        });

        var config = {
            '.chosen-select': {},
            '.chosen-select-deselect': { allow_single_deselect: true },
            '.chosen-select-no-single': { disable_search_threshold: 10 },
            '.chosen-select-no-results': { no_results_text: 'Oops, nothing found!' },
            '.chosen-select-width': { width: "95%" }
        }
        for (var selector in config) {
            $(selector).chosen(config[selector]);
        }

        $("#loading").hide();

        ///Handle File Uploading start
        jQuery("input#file").change(function () {
          //  alert('JJj');
            var input = this.files[0];
            var ext = jQuery(this).val().split('.').pop();
            var Filesize = (input.size / (1024 * 1024)).toFixed(2);
            //alert(Filesize);//ppt ,pptx ,xls ,doc,docx,png,jpg,jpeg,mp4,pdf
            if (input) {
                if (Filesize < 95) {
                    if (ext.toLowerCase() == "xls" || ext.toLowerCase() == "xlsx") {
                        toastr.success("File Selected");

                        $("#btnUpload").css({ 'display': "block" });
                        $("#FileAlertContent").html("<b>1 File Selected.</b>");
                        $("#btnResetFile").css({ 'display': "block" });
                        $("#fileDiv").css({ 'display': "none" });
                        $("#btnIMPORT").css({ 'display': "none" });
                        $("#btnReset").css({ 'display': "block" });
                        //Remove
                        //$("#fileRemove").css({ 'display': "block" });
                        //$("#selectFileIcon").css({ 'display': "none" });
                        //

                    }
                    else {
                        toastr.info("You Choose Wrong format file... Please Select File having following extension .xls, .xlsx");
                        $("#file").val('');
                        $("#fileCall").css({ 'color': "" });
                        $("#FileAlert").css({ 'display': "none" });
                    }

                } else {
                    if (Filesize > 95) {
                        toastr.info("Please Select a file having size less then 95MB.");
                        $("#file").val('');
                        $("#fileCall").css({ 'color': "" });
                        $("#FileAlert").css({ 'display': "none" });
                    }

                }
            }
            else {
                toastr.info("No File Selected... Please Open again for select a file.");
            }

        });
        $("#btnUpload").click(function () {
            $("#loading").show();
        });

    });
    //function ResetUpload()
    //{
    //    $("#btnUpload").css({ 'display': "none" });

    //    $("#file").val('');
    //    //$("#fileDiv").css({ 'display': "none" });
    //    $("#btnIMPORT").css({ 'display': "block" });
    //    $("#btnReset").css({ 'display': "none" });
    //}
    //function UploadData() {
    //    if ($("#fmUploadDataFromExcel").valid()) {
    //        $("#fmUploadDataFromExcel").submit();
    //    }
    //    else {
    //        toastr.error("Please Select File From Import");
    //        return;
    //    }
    //}

    function AttendanceDetails(pClientRequestId) {
        //debugger;
        $("#loading").show();

        $('#EditPanel').load(INITURL + '/MarketingClientAttendance/ClientAttendanceDetail/?ClientRequestId=' + pClientRequestId, function () {
            sessionStorage.setItem("PartialView", "1");
            $('#myModal2').modal('show');
            $("#loading").hide();
        });
    }


    function OpenAddNew() {
        debugger;
        $("#loading").show();
        //alert(INITURL);
        $('#EditPanel1').load(INITURL + 'MarketingClientAttendance/MarketersExcelReport', function () {
            sessionStorage.setItem("PartialView", "1");
            $('#myModal3').modal('show');
            $("#loading").hide();
        });
    }

	 function OpenAddReferrals() {
        debugger;
        $("#loading").show();
        //alert(INITURL);
        $('#EditPanel1').load(INITURL + 'MarketingClientAttendance/MarketersReferralsReport', function () {
            sessionStorage.setItem("PartialView", "1");
            $('#myModal3').modal('show');
            $("#loading").hide();
        });
    }


	 function ReferralDetails(pClientRequestId) {
        //debugger;

        //alert('fdfd');

        $("#loading").show();

        $('#EditREferralPanel').load(INITURL + '/MarketingClientAttendance/ReferrralDetail/?ClientRequestId=' + pClientRequestId, function () {
            sessionStorage.setItem("PartialView", "1");
            $('#REferreralModel').modal('show');
            $("#loading").hide();
        });
    }


    function Filtration() {

        oTable.search($('#myDataTable').val()).draw();
    }

    $(document).on('click', '#SearchIcon', function (event) {
        event.stopPropagation();  // Prevents the outer div's click event
        var query = $('#myDataTable_filter input').val(); // Get the value from the search input
        $('#myDataTable').DataTable().search(query).draw(); // Trigger the DataTable search

    });

</script>


