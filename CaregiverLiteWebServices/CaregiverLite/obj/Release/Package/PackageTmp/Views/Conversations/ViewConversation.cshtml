<link href="~/Content/css/bootstrap.min.css" rel="stylesheet">
<link href="~/Content/font-awesome/css/font-awesome.css" rel="stylesheet">

<link href="~/Content/css/dataTables.responsive.css" rel="stylesheet">
<link href="~/Content/css/dataTables.tableTools.min.css" rel="stylesheet">

<script src="https://ajax.googleapis.com/ajax/libs/jquery/3.2.1/jquery.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/quickblox/2.5.4/quickblox.min.js"></script>


<body style="background-color:none">
    <div class="col-md-16" style="z-index: 1001;overflow-y: scroll;">

        <table id="myDataTable" class="table table-striped table-bordered table-hover dataTables-example" border="1">
            <thead>

            </thead>
            <tbody id="chatMsg"></tbody>
        </table>

    </div>
</body>
<script type="text/javascript">
    var ID = "@ViewBag.ids";
    ///---Old Credentioals For Testting
    var QuickbloxApp_Id = "59080";
    var QuickbloxAuth_Key = "YkCbtUVQAQkzfVC";
    var QuickbloxAuth_Secret = "fgHFRP3Rrqe-EOr";
    //QB.init(QuickbloxApp_Id, QuickbloxAuth_Key, QuickbloxAuth_Secret, true);
    QB.init(@System.Configuration.ConfigurationManager.AppSettings["QuickbloxApp_Id"],
          @System.Configuration.ConfigurationManager.AppSettings["QuickbloxAuth_Key"],
          @System.Configuration.ConfigurationManager.AppSettings["QuickbloxAuth_Secret"],
          true);
    //alert(ID);
    var QBId = ID.split("_");
    var user = {
        login: QBId[0],
        password: "Welcome007!"
    };
    QB.createSession({ login: user.login, password: user.password }, function (err, result) {
        debugger;
        if (err) {
            alert(err.message);
        } else {
            //alert("Session Token- " + result.token);
            sessionStorage.setItem("sToken", result.token);
            var CaregiverId = QBId[1];
            var Dialod = QBId[2];

            var params1 = { chat_dialog_id: Dialod, sort_desc: 'date_sent', limit: 100, skip: 0 };
            QB.chat.message.list(params1, function (err, messages1) {
                debugger;
                if (messages1) {
                    var latestMessages1 = "";

                    var len1 = messages1.items.length;
                    if (len1 > 0) {
                        for (var i = len1 - 1; i >= 0; i--) {
                            var date1 = new Date(messages1.items[i].date_sent * 1000).toLocaleTimeString() + " " + new Date(messages1.items[i].date_sent * 1000).toLocaleDateString();
                            if (messages1.items[i].sender_id == CaregiverId) {
                                //console.log("Sender Id " + messages.items[i].sender_id + " - " + messages.items[i].message + " Sent By You");
                                latestMessages1 += "<tr ><td><strong>Caregiver </strong> Said : <strong>" + messages1.items[i].message + "</strong><span style='float:right'>" + date1 + "</span> </td></tr>";
                            } else {
                                //console.log("Reveiver Id " + messages.items[i].sender_id + " - " + messages.items[i].message + " Sent By  @Session["ToQBUserName"] ");
                                latestMessages1 += "<tr><td><strong>Scheduler </strong> Said : <strong>" + messages1.items[i].message + "</strong><span style='float:right'>" + date1 + "</span>  </td></tr>";
                            }
                        }
                        debugger;
                    }
                    else {

                        latestMessages1 += "<tr><td><strong>Conversation Not Started.</strong> </td></tr>";
                        debugger;
                    }
                    $("#chatMsg").empty();
                    document.getElementById("chatMsg").innerHTML = latestMessages1;
                    $('#chat1').scrollTop($('#chat1')[0].scrollHeight);
                    debugger;
                } else {
                    console.log(err);
                }

            });
        }

    });
    ////createSession End
    QB.chat.disconnect();



</script>
