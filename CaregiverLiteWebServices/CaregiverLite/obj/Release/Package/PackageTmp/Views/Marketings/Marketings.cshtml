    var tempMsg = '@TempData["Message"]';
    var tempFlag = '@TempData["error"]';

    if (tempFlag != "True") {
        if (tempMsg != "")
            toastr.success(tempMsg);
    }
    else {
        if (tempMsg != "")
            toastr.error(tempMsg);
    }

    var oTable;

	//  $(window).resize(function(){

//location.reload();})
    $(document).ready(function () {






        $("#loading").show();
        var jquey = jQuery.noConflict();
        oTable = $('#myDataTable').DataTable({

            responsive: true,
			columnDefs: [
          { responsivePriority: 1 },
          { responsivePriority: 2 },
          { responsivePriority: 3 },
          { responsivePriority: 4 },
          { responsivePriority: 5 },
          { responsivePriority: 6 },
          { responsivePriority: 7 },
          { responsivePriority: 8 },
          { responsivePriority: 9 },
            ],
            "dom": 'lfrtip',

            "bPaginate": true,
            "bServerSide": true,

            "bSortable": true,
            "sPaginationType": "full_numbers",
            "oLanguage": {
                "sProcessing": "<div class=\"loading\" id=\"loading\" style=\"display: block;\"></div>"
            },
            "processing": true,

            "sAjaxSource": "GetMarketingsDetailsList",
            "fnServerData": function (sSource, aoData, fnCallback) {
                $.getJSON(sSource, aoData, function (json) {
                    fnCallback(json);
                }).fail(function (jqxhr, textStatus, error) {
                    window.location.reload();
                });
            },
            "fnServerParams": function (aoData) {
                aoData.push({ "name": "FilterOfficeId", "value": $('#ddFilterOffice option:selected').val() });
            },
            "fnDrawCallback": function (oSettings) {
                //Navigation validation
                var rowsPerPage = this.fnSettings()._iDisplayLength;
                var rowsToShow = this.fnSettings().fnRecordsDisplay();
                var table = $('#myDataTable').DataTable();
                $('#myDataTable thead th').css({
                    "background-color": "white" // Your desired color
                    // Text color
                });
                var info = table.page.info();
                var currentPageNo = info.page + 1;
                $("#MarketersHeader").text("");
                $("#MarketersHeader").text("Marketer Attendance (" + rowsToShow + ")");

                $('#myDataTable tbody td').css('height', '40px');



                $('#myDataTable_filter input ').css({ 'border-radius': '5px', 'height': '36px' });


                $('#myDataTable_wrapper select ').css({ 'margin-top': '10px', 'border-radius': '5px', 'margin-bottom': '10px' });
                $('#myDataTable_filter label').contents().filter(function () {
                    return this.nodeType === 3; // This checks for text nodes
                }).remove();

                var searchInput = $('#myDataTable_filter input');
                searchInput.wrap('<div class="search-container" style="position: relative; display: inline-block; width: 100%;"></div>'); // Wrap the search input
                searchInput.css({
                    'padding-right': '30px' // Add padding to the right to make space for the icon
                });
                searchInput.after('<img src="http://ec2-52-38-33-252.us-west-2.compute.amazonaws.com/Content/image/SearchIcon.png" class="search-icon" id="SearchIcon" alt="Search Icon" style="position: absolute; right: 10px; top: 50%; transform: translateY(-50%); cursor: pointer;">');

                $("#loading").hide();
            },
            "responsive": {
                "details": {
                    "type": 'column'
                }
            },
            "aoColumns": [
			              {
                                className: 'control',
                                "bSortable": false,
                                targets: 0,
                                "mRender": function (oObj) {
                                    return '';
                                }
                            },

                            {
                                "sName": "Patient",
                                "mRender": function (oObj) {
                                    return '<span>' + oObj["MarketersName"] + '</span>';
                                }
                            },
                            {
                                "sName": "MedicalId",
                                "mRender": function (oObj) {
                                    return oObj["MarketersId"];
                                }
                            },
                            {
                                "sName": "Street",
                                "mRender": function (oObj) {
                                    return oObj["Street"];
                                }
                            },
                            {
                                "sName": "City",
                                "mRender": function (oObj) {
                                    return oObj["City"];
                                }
                            },
                            {
                                "sName": "State",
                                "mRender": function (oObj) {
                                    return oObj["State"];
                                }
                            },
                             {
                                 "sName": "ZipCode",
                              //   "bSortable": false,
                                 "mRender": function (oObj) {
                                     return oObj["ZipCode"];
                                 }
                             }, {
                                 "sName": "PhoneNo",
                               //  "bSortable": false,
                                "mRender": function (oObj) {
                                    return oObj["PhoneNo"];
                                }
                            },
                              //{
                              //    "sName": "PrimaryMD",
                              //    "bSortable": false,
                              //  "mRender": function (oObj) {
                              //      return oObj["PrimaryMD"];
                              //  }
                              //},
                              {
                                  "sName": "OfficeName",
                                  "mRender": function (oObj) {
                                      return oObj["OfficeName"];
                                  }
                              },
                            {
                                "sName": "PatientId",
                                "bSortable": false,
                                "mRender": function (oObj) {
                                    var actionhtml = '';
                                    @*actionhtml += '<a href="javascript:;" class="btn btn-xs btn-danger noExl" style="margin-top:5px; width:100%;" onclick="DeleteMarketerDetail(\'' + oObj["MarketersId"] + '\');">@CaregiverLite.Views.Resources.CareGiver.ButtonDelete</a>'
                                    actionhtml += '<a href="javascript:;" class="btn btn-xs btn-primary noExl" style="margin-top:5px; width:100%;" onclick="EditmarketingDetail(\'' + oObj["MarketersId"] + '\');">EDIT</a>'*@
                                    actionhtml += '<a href="javascript:;" title="Edit "   style="margin-top:5px;margin-left:17px; width:100%;height: 15px;width: 15px;" onclick="EditmarketingDetail(\'' + oObj["MarketersId"] + '\');"><img src="http://ec2-52-38-33-252.us-west-2.compute.amazonaws.com/Content/image/EditIcon.png" alt="Delete Icon"></a>';
                                    actionhtml += '<a href="javascript:;"  title="Delete " style="margin-top:5px;margin-left:28px; width:100%;height: 15px;width: 15px;"onclick="DeleteMarketerDetail(\'' + oObj["MarketersId"] + '\');"><img src="http://ec2-52-38-33-252.us-west-2.compute.amazonaws.com/Content/image/DeleteIcon.png" alt="Delete Icon"> </a>';

                                    return actionhtml;
                                }
                            },


            ]
        });

        $('#myDataTable_filter input').unbind(); //Unbind direct search on each keypress
        $('#myDataTable_filter input').bind('keyup', function (e) { //Bind Keyup event that filter data only on "Enter" key.
            if (e.keyCode == 13) {
                oTable.search(this.value).draw();
            }
        });
        /* Init DataTables */
        $('.carousel').carousel({
            interval: false
        });

        var config = {
            '.chosen-select': {},
            '.chosen-select-deselect': { allow_single_deselect: true },
            '.chosen-select-no-single': { disable_search_threshold: 10 },
            '.chosen-select-no-results': { no_results_text: 'Oops, nothing found!' },
            '.chosen-select-width': { width: "95%" }
        }
        for (var selector in config) {
            $(selector).chosen(config[selector]);
        }

        $("#loading").hide();

        ///Handle File Uploading start
        jQuery("input#file").change(function () {
          //  alert('JJj');
            var input = this.files[0];
            var ext = jQuery(this).val().split('.').pop();
            var Filesize = (input.size / (1024 * 1024)).toFixed(2);
            //alert(Filesize);//ppt ,pptx ,xls ,doc,docx,png,jpg,jpeg,mp4,pdf
            if (input) {
                if (Filesize < 95) {
                    if (ext.toLowerCase() == "xls" || ext.toLowerCase() == "xlsx") {
                        toastr.success("File Selected");

                        $("#btnUpload").css({ 'display': "block" });
                        $("#FileAlertContent").html("<b>1 File Selected.</b>");
                        $("#btnResetFile").css({ 'display': "block" });
                        $("#fileDiv").css({ 'display': "none" });
                        $("#btnIMPORT").css({ 'display': "none" });
                        $("#btnReset").css({ 'display': "block" });
                        //Remove
                        //$("#fileRemove").css({ 'display': "block" });
                        //$("#selectFileIcon").css({ 'display': "none" });
                        //

                    }
                    else {
                        toastr.info("You Choose Wrong format file... Please Select File having following extension .xls, .xlsx");
                        $("#file").val('');
                        $("#fileCall").css({ 'color': "" });
                        $("#FileAlert").css({ 'display': "none" });
                    }

                } else {
                    if (Filesize > 95) {
                        toastr.info("Please Select a file having size less then 95MB.");
                        $("#file").val('');
                        $("#fileCall").css({ 'color': "" });
                        $("#FileAlert").css({ 'display': "none" });
                    }

                }
            }
            else {
                toastr.info("No File Selected... Please Open again for select a file.");
            }

        });
        $("#btnUpload").click(function () {
            $("#loading").show();
        });

    });
    function ResetUpload()
    {
        $("#btnUpload").css({ 'display': "none" });

        $("#file").val('');
        //$("#fileDiv").css({ 'display': "none" });
        $("#btnIMPORT").css({ 'display': "block" });
        $("#btnReset").css({ 'display': "none" });
    }
    function UploadData() {
        if ($("#fmUploadDataFromExcel").valid()) {
            $("#fmUploadDataFromExcel").submit();
        }
        else {
            toastr.error("Please Select File From Import");
            return;
        }
    }

    function ExportTable() {
            $(".loading").show();
            var url = '@Url.Action("ExportDataSetToExcel", "Patients")';

            $.ajax({
                url: url,
                type: "POST",
                data: { strOfficeId: $("#ddFilterOffice").val() },
                success: function (res) {
                    $(".loading").hide();
                    if (res) {
                        var filename = res;
                        var iframe = document.createElement("iframe");
                        iframe.src = filename;
                        iframe.style.display = 'none';
                        document.body.appendChild(iframe);
                        toastr.success("successfully export.");

                    }
                    else {
                        toastr.warning("Not Exported Try again");
                    }
                },
                error: function (reponse) {
                    //alert("error : " + JSON.stringify(reponse));
                    $(".loading").hide();
                }
            });
    }



    function OpenAddNew() {
        $("#loading").show();
        $('#AddNewMarketers').load(INITURL + 'Marketings/AddMarketers', function () {
            sessionStorage.setItem("PartialView", "1");
            $('#myMarketModal').modal({ backdrop: 'static', keyboard: false })
            $('#myMarketModal').modal('show');
        });
    }

    function OpenAddNewAppointment() {

        $("#loading").show();
        //alert(INITURL);
        $('#EditPanel1').load(INITURL + 'Marketings/GetReadExcelScheduledList', function () {
            sessionStorage.setItem("PartialView", "1");
            $('#myModal3').modal('show');
            $("#loading").hide();
        });

    }


    function EditmarketingDetail(objmarketerid) {

        $("#loading").show();
        $('#EditMarketersdiv').load(INITURL + '/Marketings/EditmarketingDetail/' + objmarketerid, function () {
            sessionStorage.setItem("PartialView", "1");
            $('#myMarketEdit').modal({ backdrop: 'static', keyboard: false })
            $('#myMarketEdit').modal('show');
            $("#loading").hide();
        });
    }
    //Delete One
    function DeleteMarketerDetail(pMarketingId) {
        if (confirm('Are you sure you want to delete Marketer Details permanently ?')) {
            $("#loading").show();
            var url = INITURL + '/Marketings/DeleteMarketingDetail';

            $.ajax({
                url: url,
                data: { MarketerId: pMarketingId },
                cache: false,
                type: 'POST',
                async: false,
                success: function (data) {
                    if (data == "Success") {
                        toastr.success("Marketer deleted successfully");
                        window.location = INITURL + '/Marketings/Marketings';
                    }
                    $("#loading").hide();
                },
                error: function (reponse) {
                    //alert("error : " + reponse);
                    $("#loading").hide();
                }
            });
        }
    }

    function Filtration() {

        oTable.search($('#myDataTable').val()).draw();
    }

    $(document).on('click', '#SearchIcon', function (event) {
        event.stopPropagation();  // Prevents the outer div's click event
        var query = $('#myDataTable_filter input').val(); // Get the value from the search input
        $('#myDataTable').DataTable().search(query).draw(); // Trigger the DataTable search

    });
</script>
