            {
                toastr.error("Description will not allow greater then 150 characters.");
                $('.Edit_div #Street').focus()
                return false;
            }
        });
        // $("#dvweek-select").hide();
        $('.Edit_div #ZipCode').blur(function (event) {

            if ($('.Edit_div #ZipCode').val().length > 3 && ($(".Edit_div #Street").val() + $(".Edit_div #City").val() + $(".Edit_div #State").val()).length > 3) {

                $("#loading").show();
                GetLanLat()
                $("#loading").hide();
                return false;
            }
        });



        $("#loading").show();


        var form = $("#fmEditMarketingDetails").closest("form");
        form.removeData('validator');
        form.removeData('unobtrusiveValidation');
        $.validator.unobtrusive.parse(form);

        $('#myModal').on('shown.bs.modal', function () {

            $("#Date").datepicker(
            {
                minDate: 0,
                onSelect: function () {
                    $(this).change();
                }

                //,dateFormat: 'dd-mm-yy'
            });


            $("#RepeatDate").datepicker(
            {
                minDate: 0,
                onSelect: function () {
                    $(this).change();
                }

                //,dateFormat: 'dd-mm-yy'
            });

        });

        var config = {
            '.chosen-select': {},
            '.chosen-select-deselect': { allow_single_deselect: true },
            '.chosen-select-no-single': { disable_search_threshold: 10 },
            '.chosen-select-no-results': { no_results_text: 'Oops, nothing found!' },
            '.chosen-select-width': { width: "95%" }
        }
        for (var selector in config) {
            $(selector).chosen(config[selector]);

        }
        $("#loading").hide();
    });




    function UpdateClientDetail() {
        $('#loading').show();
        debugger;
        $('#modalAddPopup').remove();//for remove form control of Add popup
        var MarketersName = $(".Edit_div #MarketersName").val();
      //  var CRNumber = $(".Edit_div #CRNumber").val();
        var ZipCode = $(".Edit_div #ZipCode").val();
        var MarketersId = $("#hdnMarketersId").val();
        //var Date = $("#Date").val();
        var Street = $(".Edit_div #Street").val();
        var City = $(".Edit_div #City").val();
        var State = $(".Edit_div #State").val();
        var Phone = $(".Edit_div #PhoneNo").val();
        var OfficeId = $(".Edit_div #OfficeId").val();

        if (MarketersName == "" &&  ZipCode == "" && MarketersId == "" && Street == "" && City == "" && State == "" && Phone == "" && OfficeId == "") {
            toastr.error('Please fill all required fields');
            $('#loading').hide();
            return false;
        }
        //else if (MarketersId == "") {
        //    toastr.error('Please Enter Medical Id');
        //    $('#loading').hide();
        //    return false;
        //}
        //if (CRNumber == "" || CRNumber == "undefined") {
        //    toastr.error('Please Enter CRNumber');
        //    $('#loading').hide();
        //    return false;
        //}
        else if (MarketersName == "") {
            toastr.error('Please Enter Client Name');
            $('#loading').hide();
            return false;
        }
        else if (Phone == "") {
            toastr.error('Please Enter Phone');
            $('#loading').hide();
            return false;
        }
        else if (OfficeId == "") {
            toastr.error('Please Select OfficeId');
            $('#loading').hide();
            return false;
        }

        else if (Street == "") {
            toastr.error('Please Enter Street Information');
            $('#loading').hide();
            return false;
        } else if (State == "") {
            toastr.error('Please Enter State Id');
            $('#loading').hide();
            return false;
        }
        else if (City == "") {
            toastr.error('Please Enter City Information');
            $('#loading').hide();
            return false;
        }
        else if (ZipCode == "") {
            toastr.error('Please Enter ZipCode');
            $('#loading').hide();
            return false;
        }
        $("#dvError3").hide();
        var selectedValues = "";



        if (!GetLanLat()) {
            $('#loading').hide();
            return false;
        }
        var lat = $("#Latitude").val();
        var long = $("#Longitude").val();
        var TimezoneOffset = $("#hdnTimezoneOffset").val();
        var timeZoneId = $("#hdntimeZoneId").val();
        var TimezonePostfix = $("#hdnTimezonePostfix").val();

        if (lat === null || lat === '' || lat === 'undefined' || lat === 'undefined' || long === null || long === '') {
            toastr.error('Please enter valid address');
            $('#loading').hide();
            return false;
        }
        debugger;
        if ($("#fmEditMarketingDetails").valid())
        {

            $("#fmEditMarketingDetails").submit();

