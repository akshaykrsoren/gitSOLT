@model CaregiverLite.Models.MarketerDetailsModel



@using (Html.BeginForm("EditmarketingDetail", "Marketings", FormMethod.Post, new { @id = "fmEditMarketingDetails", @class = "horizontal-form", @enctype = "multipart/form-data" }))
{

    <div id="main_div" class="Edit_div">

        <div class="alert alert-danger alert-dismissable" style="display:none" id="dvError3">
            <button onclick="divClose();" class="close" type="button">×</button>
            <label id="lblError3"></label>
        </div>

        <div class="col-md-6">
            @*CRNumber Name*@
            <div class="form-group">
                <label>Marketer Name</label>
                <span style="color:red;">*</span>
                @Html.TextBoxFor(model => model.MarketersName, new { @type = "text", @maxlength = "100", @placeholder = "Marketer Name", @class = "form-control", @tabindex = "1" })
                @Html.ValidationMessageFor(model => model.MarketersName, "", new { @class = "text-danger" })

            </div>
            @*MarketersName*@

            @*Phone Number*@
            <div class="form-group">
                <label>Phone No</label>
                <span style="color:red;">*</span>
                @Html.ValidationMessageFor(model => model.PhoneNo)
                @Html.TextBoxFor(model => model.PhoneNo, new { @type = "text", @maxlength = "25", @placeholder = "PhoneNo", @class = "form-control", @tabindex = "1" })
            </div>
            @*Email*@
            <div class="form-group">
                <label>Email</label>
                <span style="color:red;">*</span>
                @Html.ValidationMessageFor(model => model.Email)
                @Html.TextBoxFor(model => model.Email, new { @type = "text", @maxlength = "100", @placeholder = "Email", @class = "form-control", @tabindex = "1" })
            </div>

            <div class="form-group">
                <label>Office</label>
                <span style="color:red;">*</span>
                @Html.ValidationMessageFor(model => model.OfficeId)
                @Html.DropDownListFor(model => model.OfficeId, Model.OfficeSelectList, "Select...", new { @class = "form-control", @tabindex = "5" })

            </div>
			
			 <div class="form-group">
                <label>UserName</label>
                @Html.TextBoxFor(model => model.UserName, new { @type = "text", @maxlength = "100", @placeholder = "UserName", @class = "form-control", @tabindex = "1" , @readonly = "readonly"   })
                @Html.ValidationMessageFor(model => model.UserName, "", new { @class = "text-danger" })

            </div>


        </div>
        <div class="col-md-6">
            <div class="form-group">
                <label>Street</label>
                <span style="color:red;">*</span>
                @Html.ValidationMessageFor(model => model.Street)
                @Html.TextBoxFor(model => model.Street, new { @type = "text", @maxlength = "100", @placeholder = "Street", @class = "form-control", @tabindex = "1" })

            </div>


            @*State*@
            <div class="form-group">
                <label>State</label>
                <span style="color:red;">*</span>
                @Html.ValidationMessageFor(model => model.State)
                @Html.TextBoxFor(model => model.State, new { @type = "text", @maxlength = "100", @placeholder = "State", @class = "form-control", @tabindex = "1" })
            </div>

            @*City*@
            <div class="form-group">
                <label>City</label>
                <span style="color:red;">*</span>
                @Html.ValidationMessageFor(model => model.City)
                @Html.TextBoxFor(model => model.City, new { @type = "text", @maxlength = "100", @placeholder = "City", @class = "form-control", @tabindex = "1" })

            </div>

            @*ZipCode*@
            <div class="form-group">
                <label>ZipCode</label>
                @Html.TextBoxFor(model => model.ZipCode, new { @type = "text", @maxlength = "25", @placeholder = "ZipCode", @class = "form-control", @tabindex = "1" })
                @Html.ValidationMessageFor(model => model.ZipCode, "", new { @class = "text-danger" })

            </div>

              <div class="form-group">
                <label>Password</label>
                @Html.TextBoxFor(model => model.Password, new { @type = "password", @maxlength = "100", @placeholder = "Password", @class = "form-control", @tabindex = "1",  @attr = "txtpassword" })
                @Html.ValidationMessageFor(model => model.Password, "", new { @class = "text-danger" })
                  <span style="position: absolute; right: 16px;height: 40px;">
                    <i class="fa fa-eye btn btn-link" id="HidePasswordEdit" style="position: relative; top: -30px;display:none" aria-hidden="true"></i>
                    <i class="fa fa-eye-slash btn btn-link" id="showPasswordEdit" style="position: relative; top: -30px;" aria-hidden="true"></i>
                </span>
            </div>

            <div>
                @Html.HiddenFor(model => model.MarketersId, new { @id = "hdnMarketersId" })
                @Html.HiddenFor(model => model.TimezoneOffset, new { @id = "hdnTimezoneOffset" })
                @Html.HiddenFor(model => model.TimezoneId, new { @id = "hdntimeZoneId" })
                @Html.HiddenFor(model => model.TimezonePostfix, new { @id = "hdnTimezonePostfix" })
                @Html.HiddenFor(model => model.Latitude)
                @Html.HiddenFor(model => model.Longitude)
            </div>
        </div>

        <div class="col-md-12">
            <button type="button" onclick="UpdateClientDetail()" class="btn btn-sm btn-primary pull-right" tabindex="10">Update</button>
            <div class="clearfix"></div>
        </div>





    </div>


}


<link rel="stylesheet" href="https://code.jquery.com/ui/1.12.1/themes/base/jquery-ui.css">
<script type="text/javascript">
    //$("#Date").datepicker();
    var latitude;
    var longitude;
    var MaxCaregiver = 0;
    var MaxDistance = 0;
    var add = "";
    $("#loading").hide();

    $.validator.setDefaults({
        ignore: [],
    });
    $(document).ready(function () {

        $('.Edit_div #Street').keypress(function (event) {
