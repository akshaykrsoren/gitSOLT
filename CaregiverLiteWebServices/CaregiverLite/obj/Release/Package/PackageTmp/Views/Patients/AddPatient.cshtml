

@model CaregiverLite.Models.PatientDetailsModel


<style>
    .clsDatePicker {
        z-index: 100000;
    }

    #ui-datepicker-div {
        z-index: 1003;
    }

    .field-validation-error {
        color: red;
        float: right;
    }

    .table td {
        text-align: center;
    }

    .form-control {
        margin-top: 4px;
        border-radius: 5px;
    }

    .customdropDown {
        background-position-x: 95% !important;
    }
</style>




@using (Html.BeginForm("AddPatientDetails", "Patients", FormMethod.Post, new { @id = "fmAddPatientDetails", @class = "horizontal-form", @enctype = "multipart/form-data" }))
{
    <div id="main_div">

        @Html.HiddenFor(model => model.OrganisationId, new { @id = "OrganisationId" })

        <div class="alert alert-danger alert-dismissable" style="display:none" id="dvError3">
            <button onclick="divClose();" class="close" type="button">×</button>
            <label id="lblError3"></label>
        </div>
        <div class="col-md-6">
            @*Medical Id*@
            <div class="form-group">
                <label>Patient ID</label>
                <span style="color:red;">*</span>
                @Html.ValidationMessageFor(model => model.MedicalId)
                @Html.TextBoxFor(model => model.MedicalId, new { @type = "text", @maxlength = "25", @placeholder = @CaregiverLite.Views.Resources.PatientRequest.PlaceHolderMedicalId, @class = "form-control", @tabindex = "1", @onblur = "javascript:IsMedicalIdExist();" })
            </div>
            @*Patient Name*@
            <div class="form-group">
                <label>First Name</label>
                <span style="color:red;">*</span>
                @Html.ValidationMessageFor(model => model.PatientName)
                @Html.TextBoxFor(model => model.PatientName, new { @id = "FirstName", @type = "text", @maxlength = "100", @placeholder = @CaregiverLite.Views.Resources.PatientRequest.PlaceHolderPatientName, @class = "form-control", @tabindex = "2" })
            </div>

            <div class="form-group">
                <label>Last Name</label>
                <span style="color:red;">*</span>
                @Html.ValidationMessageFor(model => model.PatientName)
                @Html.TextBoxFor(model => model.PatientName, new { @id = "LastName", @type = "text", @maxlength = "100", @placeholder = @CaregiverLite.Views.Resources.PatientRequest.PlaceHolderPatientName, @class = "form-control", @tabindex = "2" })
            </div>

            @*PrimaryMD*@
            <div class="form-group">
                <label>Primary MD</label>
                <span style="color:red;">*</span>
                @Html.ValidationMessageFor(model => model.PrimaryMD)
                @Html.TextBoxFor(model => model.PrimaryMD, new { @type = "text", @placeholder = "Enter PrimaryMD", @class = "form-control", @tabindex = "3" })
            </div>
            @*PhoneNo*@
            <div class="form-group">
                <label>Phone No</label>
                <span style="color:red;">*</span>
                @Html.ValidationMessageFor(model => model.PhoneNo)
                @Html.TextBoxFor(model => model.PhoneNo, new
                {
                    @type = "text",
                    @maxlength = "20",
                    @placeholder = "Enter Phone Number",
                    @class = "form-control",
                    @tabindex = "4"@*, @onkeypress = "return isNumber(event);"*@})
            </div>

            @*Office*@
            <div class="form-group">
                <label>Office</label>
                <span style="color:red;">*</span>
                @Html.ValidationMessageFor(model => model.OfficeId)
                @Html.DropDownListFor(model => model.OfficeId, Model.OfficeSelectList, "Select...", new { @class = "form-control customdropDown", @tabindex = "5" })
            </div>

            <div class="form-group">
                <label>Payer Id</label>
                @*<span style="color:red;">*</span>*@
                @Html.ValidationMessageFor(model => model.PayerId)


                @Html.DropDownListFor(model => model.PayerId, Model.PayerIDSelectList, "Select...", new { @class = "form-control customdropDown", @tabindex = "7" })




            </div>

            @if (Model.OrganisationId != 3)
            {
                <div class="form-group">
                    <label>Jurisdiction Code</label>
                    @*<span style="color:red;">*</span>*@
                    @Html.ValidationMessageFor(model => model.JurisdictionCode)

                    @Html.DropDownListFor(model => model.JurisdictionCode, new SelectList(Model.JurisdictionEntitiesSelectList, "Value", "Text"), htmlAttributes: new { @class = "form-control customdropDown", @id = "JurisdictionCode", @disabled = "true" })


                </div>
            }

        </div>
        <div class="col-md-6">
            @*Street*@
            <div class="form-group">
                <label>@CaregiverLite.Views.Resources.Patients.TableHeaderStreet</label>
                <span style="color:red;">*</span>
                @Html.ValidationMessageFor(model => model.Street)
                @Html.TextBoxFor(model => model.Street, new { @type = "text", @placeholder = "Enter Street", @class = "form-control", @tabindex = "6", @onblur = "" })
            </div>
            @*City*@
            <div class="form-group">
                <label>@CaregiverLite.Views.Resources.Patients.TableHeaderCity</label>
                <span style="color:red;">*</span>
                @Html.ValidationMessageFor(model => model.City)
                @Html.TextBoxFor(model => model.City, new { @type = "text", @maxlength = "20", @placeholder = "Enter City", @class = "form-control", @tabindex = "7", @onblur = "" })
            </div>
            @*State*@
            <div class="form-group">
                <label>@CaregiverLite.Views.Resources.Patients.TableHeaderState</label>
                <span style="color:red;">*</span>
                @Html.ValidationMessageFor(model => model.State)
                @Html.TextBoxFor(model => model.State, new { @type = "text", @maxlength = "20", @placeholder = "Enter State", @class = "form-control", @tabindex = "8", @onblur = "" })
            </div>

            @*Zipcode*@
            <div class="form-group">
                <label>@CaregiverLite.Views.Resources.PatientRequest.TableHeaderZipCode</label>
                <span style="color:red;">*</span>
                @Html.ValidationMessageFor(model => model.ZipCode)
                @Html.TextBoxFor(model => model.ZipCode, new
                {
                    @type = "text",
                    @maxlength = "10",
                    @placeholder = @CaregiverLite.Views.Resources.PatientRequest.PlaceHolderZipCode,
                    @class = "form-control",@*@onchange = "javascript:GetTime(this.value);",*@ @tabindex = "9"
                })
            </div>

            <div>
                @Html.HiddenFor(model => model.TimezoneOffset, new { @id = "hdnTimezoneOffset" })
                @Html.HiddenFor(model => model.TimezoneId, new { @id = "hdntimeZoneId" })
                @Html.HiddenFor(model => model.TimezonePostfix, new { @id = "hdnTimezonePostfix" })
                @Html.HiddenFor(model => model.Latitude)
                @Html.HiddenFor(model => model.Longitude)
            </div>


            <div class="form-group">
                <label>Date Of Birth</label>
                <div class="input-group date" id="datetimepicker1">
                    <input type="text" id="DateOfBirth" class="form-control" style="margin-top: 0px;border-radius: 5px 0 0 5px;">
                    <span class="input-group-addon">
                        <i class="glyphicon glyphicon-calendar"></i>
                    </span>
                </div>
            </div>

            <div class="form-group">
                <label>Payer Program</label>
                @*<span style="color:red;">*</span>*@
                @Html.ValidationMessageFor(model => model.PayerProgram)

                @Html.DropDownListFor(model => model.PayerProgram, new SelectList(Model.PayerProgramSelectList, "Value", "Text"), htmlAttributes: new { @class = "form-control customdropDown", @id = "PayerProgram", @disabled = "true" })

            </div>

            <div class="form-group">
                <label>Procedure Code</label>
                @*<span style="color:red;">*</span>*@
                <br />
                <input type="text" id="procId" class="form-control " />
                @Html.ValidationMessageFor(model => model.ProcedureCode)


                @Html.DropDownListFor(model => model.ProcedureCode, new MultiSelectList(Model.ProcedureCodeSelectList, "Value", "Text"), htmlAttributes: new { @class = "form-control customdropDown", @id = "ProcedureCode", @disabled = "true" })


            </div>

        </div>



        <div class="col-md-12">
            <button type="button" onclick="Addnew()" class="btn btn-sm btn-primary pull-right" tabindex="10">Save</button>
            <div class="clearfix"></div>
        </div>

        <input type="hidden" id="hdndstOffset" />
        <input type="hidden" id="hdnrawOffset" />
        <input type="hidden" id="hdntimeZoneFullName" />
    </div>
}


