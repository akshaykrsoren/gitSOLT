<style>
     select.form-group-sm .form-control, select.input-sm {
        height: 30px;
        line-height: 20px;
        text-align: center;
    }
    .btn-round {
        border-radius: 50%; /* Make the button round */
        padding: 10px;
        background-color: #f1f1f1; /* Button background */
        border: none;
        width: 37px;
        height: 37px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .items-badge {
        /*align-self: flex-start;
        border-radius: 6px;
        background-color: #fff;
        color: #1b4066;
        padding: 5px 7px;
        font: 600 12px Open Sans, sans-serif;
        border: 1px solid #1b4066;*/

        align-self: flex-start;
        border-radius: 18px;
        color: #239450;
        padding: 6px 10px;
        font: 600 12px Open Sans, sans-serif;
        background-color: #D4FFE8;
    }



    .items-badgeInActive {
        align-self: flex-start;
        border-radius: 18px;
        color: #E24B4B;
        padding: 6px 10px;
        font: 600 12px Open Sans, sans-serif;
        background-color: #FFDEDE;
    }

    .toggle-container {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-top: -27px;
    }

    .switch {
        position: relative;
        display: inline-block;
        width: 48px; /* reduced width */
        height: 24px; /* reduced height */
        margin-left: 70%;
    }

        .switch input {
            display: none;
        }

    .slider {
        position: absolute;
        cursor: pointer;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background-color: #ccc;
        transition: 0.4s;
        border-radius: 28px; /* adjusted to match new height */
    }

        .slider:before {
            position: absolute;
            content: "";
            height: 18px; /* adjusted height */
            width: 18px; /* adjusted width */
            left: 4px; /* adjusted position */
            bottom: 3px;
            background-color: white;
            transition: 0.4s;
            border-radius: 50%;
        }

    input:checked + .slider {
        background-color: #4CAF50;
    }

        input:checked + .slider:before {
            transform: translateX(22px); /* adjusted translation */
        }

    #toggleText {
        font-weight: bold;
        margin-top: -7px;
    }

    .cancelbtn {
        background-color: #e6f4ea;
        color: #1d9b6c;
        border: 1px solid;
        border-radius: 4px;
        height: 40px;
        font-weight: bold;
    }

        .cancelbtn:hover {
            background-color: #d1ecd9;
        }

    .confirmbtn {
        background-color: #f4e6e6;
        color: #d93025;
        border: 1px solid;
        border-radius: 4px;
        height: 40px;
        font-weight: bold;
    }

        .confirmbtn:hover {
            background-color: #ebd2d2;
        }


    .cancelbtnActive {
        background-color: #e6f4ea;
        color: #1d9b6c;
        border: 1px solid;
        border-radius: 4px;
        height: 40px;
