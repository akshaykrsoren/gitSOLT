                            <img src="@roleImagePath" alt="User Avatar" class="user-avatar" />
                        }
                        else
                        {
                            <img src="/Content/image/DefaultProfile.png" alt="User Avatar" class="user-avatar" />
                        }
                      
                        <span>
                            Welcome @if (Session["Name"] != null)
                            {
                                @Session["Name"].ToString();
                            }
                        </span>
                    </div>
                </div>
            </header>
