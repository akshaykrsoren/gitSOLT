        debugger;
        function getHeaderCountGroup()
        {
            //return;
            debugger;
            if(chatCountSession==false){

                // Display one to one dialog counts
                DisplayUnreadCount(1);

                // Display patient chat room dialog counts
                DisplayUnreadCount(2);

                // Display group chat dialog counts
                DisplayUnreadCount(3);

             chatCountSession=true;

            }
            else
            {
                if(chatCountSession==true){

