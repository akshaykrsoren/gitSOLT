    //Time Out Functionality Function Start
    function timerIncrement() {
        idleTime = idleTime + 1;
        if (idleTime > 30) { // 30 minutes
            toastr.info("Session Timeout...");
            window.location.href = "@Url.Action("SessionTimeout", "account")";
        }
    }
    //Time Out Functionality Function End

    function ChatPermission() {
        try {
            var url = window.location;
            // $('#loading').show();
            $.ajax({
                url: "@Url.Action("IsAllowForChat", "Account")",
                type: 'POST',
                async: false,
                success: function (data) {
                    result = data;

                    var paramstt = window.location.href.toString().split(window.location.host)[1];
                    paramstt = paramstt.substring(10);

                    if("@Session["IsAllowOneToOneChat"]" != null && "@Session["IsAllowOneToOneChat"].ToString()" != "True" && paramstt == "OneToOneChat")
                    {
                        window.location.href = "@Url.Action("NoAuthorize", "Chatting")";
                    }
                    else if("@Session["IsAllowForPatientChatRoom"]" != null && "@Session["IsAllowForPatientChatRoom"].ToString()" != "True" && paramstt == "PatientChatRoom")
                    {
                        window.location.href = "@Url.Action("NoAuthorize", "Chatting")";
                    }
                    else if("@Session["IsAllowGroupChat"]" != null&& "@Session["IsAllowGroupChat"].ToString()" != "True" && paramstt == "GroupChat")
                    {
                        window.location.href = "@Url.Action("NoAuthorize", "Chatting")";
                    }
                },
                error: function (error) {
                    throw error;
                }
            });

        } catch (e) {
            //  $('#loading').hide();
            console.log(e);
        }
    }
</script>

<body>
    <div class="loading" id="loading">
    </div>
    <div id="wrapper">
        <!--NAVIGATION START -->
        @Html.Partial("_LeftMenu")
        <!-- NAVIGATION END -->
        <!-- CONTENT START -->
        <div id="page-wrapper" class="gray-bg">
            <div class="row wrapper border-bottom bg-success page-heading">
                <div class="col-md-6 col-sm-6 col-xs-6">
                    <h2 style="font-weight:400;">
                        @if (@ViewBag.GroupTypeId == 3)
                        {
                            <span>Group Chat Room</span>
                        }
                        else
                        {
                            @ViewBag.Title
                        }
                    </h2>
                </div>

                <ul class="nav navbar-top-links navbar-right ">
                    @*@if (!ViewContext.Controller.HasRoles("NurseCoordinator"))
                        { }*@

                    <div class="row">
                        <div class="col-md-8">
                            @*<label id=".mylabel" style="font-weight:400; padding-top:15px" height="40"><b  >Notification Sound</b></label>*@
                            <b>Notification Sound</b>
                            <input id="Toggle" type="image" src="" alt="" width="25" height="40" style="padding-top: 20px ;cursor:grab" outline="none">

                        </div>
                    </div>

                    @if (Session["IsOfficePermission"].ToString() == "True" && Session["IsAllowOneToOneChat"].ToString() == "True")
                    {
                        <li id="lblMsgNotification" class="dropdown" style="padding: 0 0 0 0" !important title="Chatting">
                            <a class="count-info" href="~/Chatting/OneToOneChat">
                                <i class="fa fa-comments"></i>
                                <span id="lblMessageCount1" class="label label-success">
                                    <strong id="cntNotification1">0</strong>
                                </span>
                            </a>
                        </li>
                    }

                    @if (Session["IsOfficePermission"].ToString() == "True" && Session["IsAllowForPatientChatRoom"].ToString() == "True")
                    {
                        <li id="lblGroupMsgNotification" class="dropdown" title="Patient chat room">
                            <a class="count-info" href="~/Chatting/PatientChatRoom">
                                <i class="fa fa-group"></i>
                                <span id="lblMessageCount2" class="label label-success">
                                    <strong id="cntNotification2">0</strong>
                                </span>
                            </a>
                        </li>
                    }
                    @if (Session["IsOfficePermission"].ToString() == "True" && Session["IsAllowGroupChat"].ToString() == "True")
                    {
                        <li id="lblCommonGroupMsg" class="dropdown" style="padding: 0 60px 0 0" !important title="Group chat">
                            <a class="count-info" href="~/Chatting/GroupChat">
                                <strong><i class="fa fa-weixin"></i></strong>
                                <span id="lblMessageCount3" class="label label-success">
                                    <strong id="cntNotification3">0</strong>
                                </span>
                            </a>
                        </li>
                    }
                    <li>
                        <h4 style="font-weight:400; padding-top:20px;">
                            <span class="m-r-sm text-muted welcome-message">
                                <b>
                                    Welcome @if (Session["Name"] != null)
                                    { @Session["Name"].ToString();
                                    }
                                </b>
                            </span>
                        </h4>
                    </li>
                </ul>

                <div class="clearfix"></div>
            </div>
            @RenderBody()
            <div class="footer">
                <div class="pull-right">@CaregiverLite.Views.Resources.Layout.FooterCopyright</div>
            </div>
        </div>
    </div>
</body>
</html>