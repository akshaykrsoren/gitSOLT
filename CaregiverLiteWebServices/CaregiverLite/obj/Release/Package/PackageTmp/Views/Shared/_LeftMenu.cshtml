@functions {


    public string GetActiveClass(string controller, string action)
    {
        string currentController = ViewContext.RouteData.Values["controller"].ToString();
        string currentAction = ViewContext.RouteData.Values["action"].ToString();

        return currentController.Equals(controller, StringComparison.OrdinalIgnoreCase) &&
               currentAction.Equals(action, StringComparison.OrdinalIgnoreCase) ? "active" : string.Empty;


    }
}

