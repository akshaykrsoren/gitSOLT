        // Bind hover event for list items
        $('.sidebar-content .nav-list > li').hover(
            function () {
                // On hover in: Change the src to the one in the alt attribute if not active
                if (!$(this).hasClass('active')) {
                    var imgElement = $(this).find('img'); // Find the child img element
                    var newSrc = INITURL + imgElement.attr('alt'); // Get new src from alt

                    // Store the original src in a data attribute for future use
                    $(this).data('original-src', imgElement.attr('src')); // Save original src

                    // Change the img src to the new src
                    imgElement.attr('src', newSrc);
                }
            },
            function () {
                // On hover out: Revert back to the original src if not active
                if (!$(this).hasClass('active')) {
                    var imgElement = $(this).find('img'); // Find the child img element
                    var originalSrc = $(this).data('original-src'); // Retrieve original src from data attribute

                    // Change the img src back to the original
                    imgElement.attr('src', originalSrc);
                }
            }
        );

        $('.sign-out-btn').hover(
            function () {
                // On hover in: Change the src to the one in the alt attribute if not active
