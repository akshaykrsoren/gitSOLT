        $('.sidebar-content .nav-list > li').click(function () {
            debugger;
            var originalSrc = $(this).data('original-src');
            var imgElement = $(this).find('img');

            //$('.sidebar-content .nav-list > li').removeClass();

            //$('.sidebar-content .nav-list > li').addClass('active');


            var newSrc = INITURL + imgElement.attr('alt');
            //$(this).attr('alt');

            // Toggle active class
            if ($(this).hasClass('active')) {
                $(this).attr('src', originalSrc).removeClass('active'); // Revert to original
            } else {
                $(this).attr('src', newSrc).addClass('active'); // Keep the alt image
            }
        });


