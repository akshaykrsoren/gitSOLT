            url: "/GenerateReports/ListOffices",
            data: '{}',
            contentType: "application/json; charset=utf-8",
            dataType: "json",
            success: function (response) {
                ddlCustomers.empty().append('<option selected="selected" value="0">Select Office</option>');
                $.each(response, function () {
