    });


</script>

@using (Html.BeginForm("GenerateReportActionForPauseAndResume", "GenerateReports", FormMethod.Post, new { @id = "fmGenerateReportExcel1", @class = "horizontal-form", @enctype = "multipart/form-data" }))
{
    <div id="main_div" class="Edit_div">
        <div class="alert alert-danger alert-dismissable" style="display:none" id="dvError3">
            <button onclick="divClose();" class="close" type="button">×</button>
            <label id="lblError3"></label>
        </div>
        <div class="row form-calender">
            <div class="col-md-6">
                @*Date*@
                <div class="form-group">
                    <label>From Date</label>
                    <span style="color:red;">*</span>
                    @*@Html.ValidationMessageFor(model => model.Date)*@
                    @Html.TextBoxFor(model => model.FromDate1, new { @class = "form-control clsDatePicker", @data_toggle = "dropdown", @placeholder = "MM-DD-YYYY", onkeydown = "return false", autocomplete = "off", @tabindex = "9" })
