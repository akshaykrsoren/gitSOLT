<script type="text/javascript">
    $(".loading").show();


    debugger;
    function AddnewExcelReport() {
       $('#loading').show();
        var FromDate = $("#FromDate1").val();
        var ToDate = $("#ToDate1").val();
        var OfficeId = $("#ddlOffices1").val();
        var NurseId = $("#Caregivers1").val();
        //var PatientId = $("#PatientList1").val();

        if (FromDate == "" && ToDate == "") {
            toastr.error("Please select required field.");
            $("#loading").hide();
            return false;
        }
        else if (FromDate == "") {
            toastr.error("Please select from date.");
            $("#loading").hide();
            return false;
        }
        else if (ToDate=="") {
            toastr.error("Please select to date.");
            $("#loading").hide();
            return false;
        }
        else if (OfficeId == "0") {
            toastr.error("Please select Offices.");
            $("#loading").hide();
            return false;
        }
        else if (NurseId == "null") {
            toastr.error("Please select Nurse From list.");
            $("#loading").hide();
            return false;
        }


        //$(".loading").show();
        debugger;
       var url = '@Url.Action("GenerateReportActionForPauseAndResume", "GenerateReports")';

        //var url = "http://localhost:15177/AttendanceManagement/GenerateReportActionForPauseAndResume";
        $.ajax({
            url: url,
            type: "POST",
            data: { FromDate: FromDate, ToDate: ToDate, OfficeId: OfficeId, NurseId: NurseId},
            success: function (res) {
                
                $(".loading").hide();
                if (res) {
                    var filename = res;
                    var iframe = document.createElement("iframe");
                    iframe.src = filename;
                    iframe.style.display = 'none';
                    document.body.appendChild(iframe);
                    toastr.success("successfully export.");

                }
                else {
                    toastr.warning("No File Exported!");
                }

            },
            error: function (reponse) {
                alert("error : " + JSON.stringify(reponse));
                $(".loading").hide();
            }
        });

        //if($("#fmGenerateReport").valid())
        //{
        //    $("#fmGenerateReport").submit();
        //}


    }


