            </div>
            <div class="col-md-6">
                <label>To Date</label>
                <span style="color:red;">*</span>
                @Html.TextBoxFor(model => model.ToDate1, new { @class = "form-control clsDatePicker", @data_toggle = "dropdown", @placeholder = "MM-DD-YYYY", onkeydown = "return false", autocomplete = "off", @tabindex = "9" })
                <label id="lblToDate"></label>
            </div>
        </div>
        <div class="col-md-12">
            <div class="col-md-4">

                <div>
                    <label>Offices :</label>
                    <select id="ddlOffices1"></select>
                </div>
                @*<div>
