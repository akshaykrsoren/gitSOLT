                           // alert('Nir');
                        }

                       

                        var polyLine = new google.maps.Polyline({
                            path: [src, des],
                            strokeColor: colorCode,
							strokeOpacity: opacityCode,
                            strokeWeight: 5,
                            map: map
                        });

                        var content =
                            '<div><strong>Date: </strong>' +
                                trackedLocations[i].LocationDateTime +
