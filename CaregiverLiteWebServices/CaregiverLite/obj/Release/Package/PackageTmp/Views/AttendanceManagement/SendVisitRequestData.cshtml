            }
        });
    //});





    });


</script>

@using (Html.BeginForm("GetAndPostEmployeeVisitData", "AttendanceManagement", FormMethod.Get, new { @class = "horizontal-form", @enctype = "multipart/form-data" }))
{
    <div id="main_div" class="Edit_div">
        <div class="alert alert-danger alert-dismissable" style="display:none" id="dvError3">
            <button onclick="divClose();" class="close" type="button">×</button>
            <label id="lblError3"></label>
        </div>
        <div class="row form-calender">
            <div class="col-md-6">
                @*Date*@
                <div class="form-group">
                    <label>From Date</label>
                    <span style="color:red;">*</span>
                    @*@Html.ValidationMessageFor(model => model.Date)*@
                    @Html.TextBoxFor(model => model.FromDate, new { @class = "form-control clsDatePicker", @data_toggle = "dropdown", @placeholder = "DD-MM-YYYY", onkeydown = "return false", autocomplete = "off", @tabindex = "8" })
                    <label id="lblFromDate"></label>
                </div>
            </div>
            <div class="col-md-6">
                <label>To Date</label>
                <span style="color:red;">*</span>
                @Html.TextBoxFor(model => model.ToDate, new { @class = "form-control clsDatePicker", @data_toggle = "dropdown", @placeholder = "DD-MM-YYYY", onkeydown = "return false", autocomplete = "off", @tabindex = "8" })
                <label id="lblToDate"></label>
            </div>
        </div>
        <div class="col-md-2">

            <div>
                <label>Offices :</label>
                <select id="ddlOffices"></select>
            </div>
        </div>
        <div class="col-md-12">
            <button type="button" onclick="SendData();" class="btn btn-sm btn-primary pull-right" tabindex="10">Export Data</button>
            <div class="clearfix"></div>
        </div>
    </div>



    <div class="col-md-12">
        <div class="clearfix"></div>
    </div>
}

<script type="text/javascript">

    function SendData() {


        var tempFromDate = $("#FromDate").val();
        var FromDate1 = new Date(tempFromDate);
        var tempToDate = $("#ToDate").val();
        var ToDate1 = new Date(tempToDate);

        if (tempFromDate == "") {
            toastr.error("Please select from date.");
            $("#loading").hide();
            return false;
        }
        else if (tempToDate == "") {
            toastr.error("Please select to date.");
            $("#loading").hide();
            return false;
        }

        if (FromDate1 > ToDate1) {
            toastr.error("From Date can not be greater than To date.");
            $("#loading").hide();
            return false;
        }
        ToDate1.setHours(23);
        ToDate1.setMinutes(59);

        //var FromDate = FromDate1.getFullYear() + "-" + (FromDate1.getMonth() + 1) + "-" + FromDate1.getDate() + " " + FromDate1.getHours() + ":" + FromDate1.getMinutes() + ":" + FromDate1.getSeconds();
        //var ToDate = ToDate1.getFullYear() + "-" + (ToDate1.getMonth() + 1) + "-" + ToDate1.getDate() + " " + ToDate1.getHours() + ":" + ToDate1.getMinutes() + ":" + ToDate1.getSeconds();

        var FromDate = FromDate1.getFullYear() + "-" + (FromDate1.getMonth() + 1) + "-" + FromDate1.getDate();
        var ToDate = ToDate1.getFullYear() + "-" + (ToDate1.getMonth() + 1) + "-" + ToDate1.getDate();

        var OfficeId=$("#ddlOffices").val();
        if (OfficeId == 0 || OfficeId == "" || OfficeId == "undefined") {
            toastr.error("Please select Office");
            $("#loading").hide();
            return false;
        }
        

        $('#loading').show();
        var url = '@Url.Action("GetAndPostEmployeeVisitData", "AttendanceManagement")';

        // var url = "http://localhost:15177/AttendanceManagement/GetAndPostEmployeeVisitData";
        $.ajax({
            url: url,
            type: "POST",
            data: { FromDate: FromDate, ToDate: ToDate, OfficeId: OfficeId},
            success: function (res) {
                $(".loading").hide();
                debugger;
                if (res.Success) {
                    toastr.success("Data sent successfully.");
                }
                else {
                    toastr.error(res.Result);
                }
                $(".loading").hide();

            },
            error: function (reponse) {
                alert("error : " + JSON.stringify(reponse));
                $(".loading").hide();
            }
        });
    }
</script>