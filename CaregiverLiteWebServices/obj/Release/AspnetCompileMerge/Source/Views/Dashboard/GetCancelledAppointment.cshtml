<style>
    .css-digits {
        float: right;
    }
    .nosort1:after {
    display : none;
    
    }
</style>

<div class="ibox-title">
    <h5>@CaregiverLite.Views.Resources.Dashboard.TableHeaderCancelledAppoinment</h5>
    <div class="ibox-tools">
        <a class="collapse-link">
            <i class="fa fa-chevron-up"></i>
        </a>
        <a class="close-link">
            <i class="fa fa-times"></i>
        </a>
    </div>
</div>
<div class="ibox-content">
    <table id="myDataTable6" class="table table-striped table-hover">
        <thead>
            <tr>
                <th style="width: 70px;">@CaregiverLite.Views.Resources.Dashboard.TableHeaderPatientName</th>
                <th>@CaregiverLite.Views.Resources.Dashboard.TableHeaderPatientAddress</th>
                <th>@CaregiverLite.Views.Resources.Dashboard.TableHeaderFromDateTime</th>
                <th>@CaregiverLite.Views.Resources.Dashboard.TableHeaderTotalHours</th>
                <th>@CaregiverLite.Views.Resources.Dashboard.TableHeaderTotalPayment</th>
                <th class="nosort1">@CaregiverLite.Views.Resources.Dashboard.TableHeaderAction</th>
            </tr>
        </thead>
        <tbody>
            @foreach (@CaregiverLite.CaregiverLiteService.PatientRequests item in ViewBag.CancelledAppointment)
            {
                <tr>
                    <td>@item.PatientName</td>
                    <td>@item.PatientAddress</td>
                    <td>@item.Date @item.FromTime</td>
                    <td style="text-align:right">@item.TotalHours</td>
                    <td style="text-align:right">@item.TotalAmount </td>
                    <td>Cancelled</td> 
                </tr>
            }
        </tbody>
    </table>
</div>
<script type="text/javascript">
    $(document).ready(function () {
        $('#myDataTable6').dataTable({
            responsive: true,
            "dom": 'lfrtip'
        });
    });

    sessionStorage.setItem("PartialView", "1");
</script>