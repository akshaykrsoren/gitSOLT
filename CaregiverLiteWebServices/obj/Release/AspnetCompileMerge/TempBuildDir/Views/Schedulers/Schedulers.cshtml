
@{
    ViewBag.Title = "Scheduler";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!-- ADD Sheduler POPUP START -->
<div class="modal fade" id="myModal" tabindex="-1" role="dialog" aria-labelledby="myModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-sm" id="modalAddPopup">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                <h4 class="modal-title" id="gridSystemModalLabel">@CaregiverLite.Views.Resources.Schedulers.ButtonAddScheduler</h4>
            </div>
            <div class="modal-body row" id="AddScheduler">
            </div>
        </div>
    </div>
</div>

<!-- EDIT Sheduler POPUP START -->
<div class="modal fade" id="myModal2" tabindex="-1" role="dialog" aria-labelledby="myModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-sm" id="modalEditPopup">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                <h4 class="modal-title" id="gridSystemModalLabel">@CaregiverLite.Views.Resources.Schedulers.ButtonEditScheduler</h4>
            </div>
            <div class="modal-body row" id="EditPanel">
            </div>
        </div>
</div>
    </div>

<!-- ADD Group(s) POPUP START -->
<div class="modal fade" id="modalGroupAssignment" tabindex="-1" role="dialog" aria-labelledby="myModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-md">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                <h4 class="modal-title" id="gridSystemModalLabel">Assign Patient Chat Room(s)</h4>
            </div>
            <div class="modal-body row" id="AssignGroupToScheduler">
            </div>
        </div>
    </div>
</div>

<!-- ADD Office(s) POPUP START -->
<div class="modal fade" id="modalOfficeAssignment" tabindex="-1" role="dialog" aria-labelledby="myModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-md">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                <h4 class="modal-title" id="gridSystemModalLabel">Assign Office(s)</h4>
            </div>
            <div class="modal-body row" id="AssignOfficeToScheduler">
            </div>
        </div>
    </div>
</div>

<div class="wrapper wrapper-content animated fadeInRight">
    <div class="row">
        <div class="col-lg-12">
            <div class="ibox float-e-margins">
                <div class="ibox-title">
                    <h5>@CaregiverLite.Views.Resources.Schedulers.HeaderSchedulerList</h5>
                    <div class="ibox-tools">
                        <a class="btn btn-xs btn-primary" style="margin-top:-9px;" href="javascript:;" onclick="OpenAddNew()">Add Scheduler</a>
                        <div class="clearfix"></div>
                    </div>
                </div>
                <div class="ibox-content">
                    <div class="row">
                        <div class="form-group col-md-3 pull-right">
                            <div class="form-group filter-option" style="margin-left:35px">
                                <label>Office: </label>
                                <div class="form-group">

                                    @Html.DropDownList("OfficeId", (SelectList)ViewBag.OfficeDropDownList, "All", new { @class = "form-control" })
                                    
                                    @*@Html.DropDownList("OfficeId", (SelectList)ViewBag.OfficeDropDownList, "All", new { @class = "form-control" })*@

                                    @*@Html.DropDownList("TruckID", (SelectList)ViewBag.lstTrucks, "All", new { @class = "form-control" })*@
                                </div>
                                @*<select id="ddFilterStatus" class="m-l-sm" name="ddFilterStatus" style="width: 148px;height:34px;border-color:#e5e6e7">
                                    <option value="2">All</option>
                                    <option value="1">Approved</option>
                                    <option value="0">Not Approved</option>
                                </select>*@
                            </div>
                        </div>

                    </div>
                    <table id="myDataTable" class="table table-striped table-bordered table-hover dataTables-example">
                        <thead>
                            <tr>
                                <th></th>
                                <th>@CaregiverLite.Views.Resources.Schedulers.TableHeaderFirstName</th>
                                <th>@CaregiverLite.Views.Resources.Schedulers.TableHeaderLastName</th>
                                <th>@CaregiverLite.Views.Resources.Schedulers.TableHeaderUserName</th>
                                <th>@CaregiverLite.Views.Resources.Schedulers.TableHeaderEmail</th>
                                <th>Office(s)</th>
                                <th style="width: 100px;">@CaregiverLite.Views.Resources.Schedulers.TableHeaderAction</th>
                                <th>Assign Patient Chat Room</th>
                                <th>Assign Office</th>
                            </tr>
                        </thead>
                        <tbody></tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
<script src="~/Scripts/js/jquery-2.1.1.js"></script>
<script src="~/Scripts/js/jquery.dataTables.js"></script>
<link rel="stylesheet" href="https://code.jquery.com/ui/1.12.1/themes/base/jquery-ui.css">
<script src="~/Scripts/js/oms.min.js"></script>
<script>
    var tempMsg = '@TempData["Message"]';
    if (tempMsg != "")
        toastr.success(tempMsg);

    var oTable;
    $(document).ready(function () {

        $("#loading").show();
        var jquey = jQuery.noConflict();
        oTable = $('#myDataTable').dataTable({
            responsive: true,
            "dom": 'lfrtip',
            "bPaginate": true,
            "bServerSide": true,
            "bSortable": true,
            "sPaginationType": "full_numbers",
            "oLanguage": {
                "sProcessing": "<div class=\"loading\" id=\"loading\" style=\"display: block;\"></div>"
            },
            "processing": true,
            "sAjaxSource": "GetSchedulerList",
            "fnServerParams": function (aoData) {
                aoData.push({ "name": "ddFilterOffice", "value": $('#OfficeId').val() });
            },
            "fnServerData": function (sSource, aoData, fnCallback) {
                $.getJSON(sSource, aoData, function (json) {
                    fnCallback(json);
                }).fail(function (jqxhr, textStatus, error) {
                    window.location.reload();
                });
            },
            "fnDrawCallback": function (oSettings) {
                //Navigation validation
                var rowsPerPage = this.fnSettings()._iDisplayLength;
                var rowsToShow = this.fnSettings().fnRecordsDisplay();
                var table = $('#myDataTable').DataTable();
                var info = table.page.info();
                var currentPageNo = info.page + 1;
                $("#loading").hide();
            },
            "responsive": {
                "details": {
                    "type": 'column'
                }
            },
            "aoColumns": [
                            {
                                className: 'control',
                                orderable: false,
                                targets: 0,
                                "mRender": function (oObj) {
                                    return '';
                                }
                            },
                            {
                                "sName": "FirstName",
                                "mRender": function (oObj) {
                                    return '<span>' + oObj["FirstName"] + '</span>';
                                }
                            },
                            {
                                "sName": "LastName",
                                "mRender": function (oObj) {
                                    return oObj["LastName"];
                                }
                            },
                            {
                                "sName": "UserName",
                                "mRender": function (oObj) {
                                    return oObj["UserName"];
                                }
                            },
                            {
                                "sName": "Email",
                                "mRender": function (oObj) {
                                    return oObj["Email"];
                                }
                            },
                               {
                                   "sName": "OfficeName",
                                   "mRender": function (oObj) {

                                       if (oObj["OfficeName"] == '')
                                       {
                                           return '-';
                                       }

                                       var OfficeNames = oObj["OfficeName"];
                                       OfficeNames = OfficeNames.replace(/,/g, '<br>');

                                       // return oObj["OfficeName"];
                                       return OfficeNames;
                                   }
                               },
                            {
                                "sName": "SchedulerId",
                                "bSortable": false,
                                "mRender": function (oObj) {
                                                var actionhtml = '';
                                                actionhtml += '<a href="javascript:;" class="btn btn-xs btn-danger" style="margin-top:5px; width:100%;" onclick="DeleteScheduler(\'' + oObj["SchedulerId"] + '\',\'' + oObj["UserName"] + '\');">@CaregiverLite.Views.Resources.CareGiver.ButtonDelete</a>'
                                                actionhtml += '<a href="javascript:;" class="btn btn-xs btn-primary" style="margin-top:5px; width:100%;" onclick="EditScheduler(\'' + oObj["SchedulerId"] + '\');">@CaregiverLite.Views.Resources.CareGiver.ButtonEditProfile</a>'
                                            return actionhtml;
                                }
                            },
                            {
                                "sName": "SchedulerId",
                                "bSortable": false,
                                "mRender": function (oObj) {
                                    var actionhtml = '';
                                    actionhtml += '<a href="javascript:;" class="btn btn-xs btn-primary" style="margin-top:5px; width:100%;" onclick="OpenAssignGroupModal(\'' + oObj["UserId"] + '\' , \'' + oObj["FirstName"] + '\',\'' + oObj["LastName"] + '\',\'' + oObj["QuickBloxId"] + '\',\'' + oObj["Email"] + '\');">Assign Patient Chat Room</a>'
                                    return actionhtml;
                                }
                            },
                              {
                                  "sName": "SchedulerId",
                                  "bSortable": false,
                                  "mRender": function (oObj) {
                                      var actionhtml = '';
                                      actionhtml += '<a href="javascript:;" class="btn btn-xs btn-primary" style="margin-top:5px; width:100%;" onclick="OpenAssignOfficeModal(\'' + oObj["UserId"] + '\' , \'' + oObj["FirstName"] + '\',\'' + oObj["LastName"] + '\',\'' + oObj["Email"] + '\');">Assign Office</a>'
                                      return actionhtml;
                                  }
                              }

            ]
        });

        $('#myDataTable_filter input').unbind(); //Unbind direct search on each keypress
        $('#myDataTable_filter input').bind('keyup', function (e) { //Bind Keyup event that filter data only on "Enter" key.
            if (e.keyCode == 13) {
                oTable.fnFilter(this.value);
            }
        });
        /* Init DataTables */
        $('.carousel').carousel({
            interval: false
        });

        var config = {
            '.chosen-select': {},
            '.chosen-select-deselect': { allow_single_deselect: true },
            '.chosen-select-no-single': { disable_search_threshold: 10 },
            '.chosen-select-no-results': { no_results_text: 'Oops, nothing found!' },
            '.chosen-select-width': { width: "95%" }
        }
        for (var selector in config) {
            $(selector).chosen(config[selector]);
        }

        $("#loading").hide();
    });


    $('#OfficeId').bind('change', function (e) {

        //debugger;
        // $('#OfficeId').val();
        oTable.fnFilter('');
    });

    function DeleteScheduler(schedulerid,username) {
        if (confirm('Are you sure you want to delete Scheduler?')) {
            $("#loading").show();
            var url = INITURL + '/Schedulers/DeleteScheduler';

            $.ajax({
                url: url,
                data: { SchedulerId: schedulerid, UserName: username },
                cache: false,
                type: 'POST',
                async: false,
                success: function (data) {
                    if (data == "Success") {
                        window.location = INITURL + '/Schedulers/Schedulers';
                    }
                    $("#loading").hide();
                },
                error: function (reponse) {
                    alert("error : " + reponse);
                    $("#loading").hide();
                }
            });
        }
    }

    //function EditScheduler(schedulerid) {
    //        $("#loading").show();
    //        var url = INITURL + '/Schedulers/EditScheduler';

    //        $.ajax({
    //            url: url,
    //            data: { SchedulerId: schedulerid },
    //            cache: false,
    //            type: 'POST',
    //            async: false,
    //            success: function (data) {
    //                if (data == "Success") {
    //                    window.location = INITURL + '/Schedulers/Schedulers';
    //                }
    //                $("#loading").hide();
    //            },
    //            error: function (reponse) {
    //                alert("error : " + reponse);
    //                $("#loading").hide();
    //            }
    //        });

    //}


    function EditScheduler(schedulerid) {
      
        $("#loading").show();
        $('#EditPanel').load(INITURL + '/Schedulers/EditScheduler/' + schedulerid, function () {
            sessionStorage.setItem("PartialView", "1");
            $('#myModal2').modal('show');
            $("#loading").hide();
        });
    }

    function OpenAddNew() {
        $("#loading").show();
       
        console.log(INITURL);
        // $('#AddScheduler').load(INITURL + 'Schedulers/AddScheduler', function () {
        $('#AddScheduler').load(INITURL + 'Schedulers/AddScheduler', function () {
            sessionStorage.setItem("PartialView", "1");
            $('#myModal').modal('show');
         
            $("#loading").hide();
        });
    }

    function OpenAssignGroupModal(userid, FirstName, LastName, quickbloxid, email) {
        $("#loading").show();
        var name = FirstName + ' ' + LastName;
        var url = INITURL + 'Schedulers/AssignGroup?UserId=' + userid + '&Name=' + name + '&QuickBloxId=' + quickbloxid + '&Email=' + email;
        $('#AssignGroupToScheduler').load(encodeURI(url), function () {
            sessionStorage.setItem("PartialView", "1");
            $('#modalGroupAssignment').modal('show');
            $("#loading").hide();
        });
    }

    function OpenAssignOfficeModal(userid, FirstName, LastName, email) {
        $("#loading").show();
        var name = FirstName + ' ' + LastName;
        var url = INITURL + 'Schedulers/AssignOfficeToScheduler?UserId=' + userid + '&Name=' + name + '&Email=' + email;

        $('#AssignOfficeToScheduler').load(encodeURI(url), function () {
            sessionStorage.setItem("PartialView", "1");
            $('#modalOfficeAssignment').modal('show');
            $("#loading").hide();
        });
    }
</script>