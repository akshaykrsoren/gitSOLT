
@{
    ViewBag.Title = "Director";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<!-- ADD nurseCoordinator POPUP START -->
<div class="modal fade" id="myModal" tabindex="-1" role="dialog" aria-labelledby="myModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-sm">
        <div class="modal-content">
            <div class="modal-header">

                <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                <h4 class="modal-title" id="gridSystemModalLabel">@CaregiverLite.Views.Resources.NurseCoordinator.ButtonAddNurseCoordinator</h4>
            </div>
            <div class="modal-body row" id="AddNurseCoordinator">
            </div>
        </div>
    </div>
</div>

<!-- EDIT nurseCoordinator POPUP START -->
<div class="modal fade" id="myModal2" tabindex="-1" role="dialog" aria-labelledby="myModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-sm" id="modalEditPopup">
            <div class="modal-content">
                <div class="modal-header">
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                    <h4 class="modal-title" id="gridSystemModalLabel">@CaregiverLite.Views.Resources.NurseCoordinator.ButtonEditNurseCoordinator</h4>
                </div>
                <div class="modal-body row" id="EditNurseCoordinator">
                </div>
            </div>
        </div>
</div>



<div class="wrapper wrapper-content animated fadeInRight">
    <div class="row">
        <div class="col-lg-12">
            <div class="ibox float-e-margins">
                <div class="ibox-title">
                    <h5>@CaregiverLite.Views.Resources.NurseCoordinator.HeaderNurseCoordinatorList</h5>
                    <div class="ibox-tools">
                        <a class="btn btn-xs btn-primary" style="margin-top:-9px;" href="javascript:;" onclick="OpenAddNew()">Add Director</a>
                        <div class="clearfix"></div>
                    </div>
                </div>
                <div class="ibox-content">
                    <div class="row">
                        <div class="form-group col-md-2 pull-right">
                            <label>Office:</label>
                            </br>

                            @Html.DropDownList("ddFilterOffice", (System.Web.Mvc.SelectList)ViewBag.lstOffice, "All", new { @class = "form-control" })
                        </div>
                    </div>
                    <div class="form-group">
                        <label></label>
                        <div class="input-group pull-right margin-25">
                            <a href="javascript:;" class="btn btn-sm btn-primary" onclick="RemoveFiltration();">Remove Filter</a>
                        </div>
                        <div class="input-group pull-right margin-25" style="margin-right: 10px;">
                            <a href="javascript:;" class="btn btn-sm btn-primary" onclick="Filtration();">Filter</a>
                        </div>

                        <div class="clearfix"></div>
                    </div>

                    <table id="myDataTable" class="table table-striped table-bordered table-hover dataTables-example">
                        <thead>
                            <tr>
                                <th></th>
                                <th>@CaregiverLite.Views.Resources.Schedulers.TableHeaderFirstName</th>
                                <th>@CaregiverLite.Views.Resources.Schedulers.TableHeaderLastName</th>
                                <th>@CaregiverLite.Views.Resources.Schedulers.TableHeaderUserName</th>
                                <th>@CaregiverLite.Views.Resources.Schedulers.TableHeaderEmail</th>
                                <th>Allow For Patient Chat Room</th>
                                <th>Office</th>
                                <th>Job Title</th>
                                <th style="width: 100px;">@CaregiverLite.Views.Resources.Schedulers.TableHeaderAction</th>
                            </tr>
                        </thead>
                        <tbody></tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
<script src="~/Scripts/js/jquery-2.1.1.js"></script>
<script src="~/Scripts/js/jquery.dataTables.js"></script>
<link rel="stylesheet" href="https://code.jquery.com/ui/1.12.1/themes/base/jquery-ui.css">
<script src="~/Scripts/js/oms.min.js"></script>


<script type="text/javascript">
    var tempMsg = '@TempData["Message"]';
    if (tempMsg != "")
        toastr.success(tempMsg);

    var oTable;
    $(document).ready(function () {
        //GetUnAssignedNurseCoordinator();

        $("#loading").show();
        var jquey = jQuery.noConflict();
        oTable = $('#myDataTable').DataTable({
            responsive: true,
            "dom": 'lfrtip',
            "bPaginate": true,
            "bServerSide": true,
            "bSortable": true,
            "sPaginationType": "full_numbers",
            "oLanguage": {
                "sProcessing": "<div class=\"loading\" id=\"loading\" style=\"display: block;\"></div>"
            },
            "processing": true,
            "sAjaxSource": "GetNurseCoordinatorList",
            "fnServerData": function (sSource, aoData, fnCallback) {
                $.getJSON(sSource, aoData, function (json) {
                    fnCallback(json);
                }).fail(function (jqxhr, textStatus, error) {
                    window.location.reload();
                });
            },
            "fnServerParams": function (aoData) {
                aoData.push({ "name": "FilterOfficeId", "value": $('#ddFilterOffice option:selected').val() });
            },
            "fnDrawCallback": function (oSettings) {
                //Navigation validation
                var rowsPerPage = this.fnSettings()._iDisplayLength;
                var rowsToShow = this.fnSettings().fnRecordsDisplay();
                var table = $('#myDataTable').DataTable();
                var info = table.page.info();
                var currentPageNo = info.page + 1;
                $("#loading").hide();
            },
            "responsive": {
                "details": {
                    "type": 'column'
                }
            },
            "aoColumns": [
                            {
                                className: 'control',
                                orderable: false,
                                targets: 0,
                                "mRender": function (oObj) {
                                    return '';
                                }
                            },
                            {
                                "sName": "FirstName",
                                "mRender": function (oObj) {
                                    return '<span>' + oObj["FirstName"] + '</span>';
                                }
                            },
                            {
                                "sName": "LastName",
                                "mRender": function (oObj) {
                                    return oObj["LastName"];
                                }
                            },
                            {
                                "sName": "UserName",
                                "mRender": function (oObj) {
                                    return oObj["UserName"];
                                }
                            },
                            {
                                "sName": "Email",
                                "mRender": function (oObj) {
                                    return oObj["Email"];
                                }
                            },
                             {
                                 "sName": "AllowForPatientChatRoom",
                                 "mRender": function (oObj) {
                                     var actionhtml = '';
                                     if (oObj["IsAllowForPatientChatRoom"])
                                     {
                                         actionhtml = "<span style='display: block; text-align: center'><i class='fa fa-check'></i></span>"
                                         return actionhtml;
                                     }
                                     else
                                     {
                                         actionhtml = "<span style='display: block; text-align: center'><i class='fa fa-times'></i></span>"
                                         return actionhtml;
                                     }
                                 }
                             },
                            {
                                "sName": "OfficeName",
                                "mRender": function (oObj) {
                                    return oObj["OfficeName"];
                                }
                            },
                               {
                                   "sName": "JobTitle",
                                   "mRender": function (oObj) {
                                       return oObj["JobTitle"];
                                   }
                               },
                                 {
                                     "sName": "NurseCoordinatorId",
                                     "bSortable": false,
                                     "mRender": function (oObj) {
                                         var actionhtml = '';
                                         actionhtml += '<a href="javascript:;" class="btn btn-xs btn-danger" style="margin-top:5px; width:100%;" onclick="DeleteNurseCoordinator(\'' + oObj["NurseCoordinatorId"] + '\',\'' + oObj["UserName"] + '\');">@CaregiverLite.Views.Resources.CareGiver.ButtonDelete</a>'
                                         actionhtml += '<a href="javascript:;" class="btn btn-xs btn-primary" style="margin-top:5px; width:100%;" onclick="EditNurseCoordinator(\'' + oObj["NurseCoordinatorId"] + '\');">EDIT</a>'
                                         return actionhtml;
                                     }
                                 }
                               

            ]
        });

        $('#myDataTable_filter input').unbind(); //Unbind direct search on each keypress
        $('#myDataTable_filter input').bind('keyup', function (e) { //Bind Keyup event that filter data only on "Enter" key.
            if (e.keyCode == 13) {
                oTable.search(this.value).draw();
            }
        });
        /* Init DataTables */
        $('.carousel').carousel({
            interval: false
        });

        var config = {
            '.chosen-select': {},
            '.chosen-select-deselect': { allow_single_deselect: true },
            '.chosen-select-no-single': { disable_search_threshold: 10 },
            '.chosen-select-no-results': { no_results_text: 'Oops, nothing found!' },
            '.chosen-select-width': { width: "95%" }
        }
        for (var selector in config) {
            $(selector).chosen(config[selector]);
        }

        $("#loading").hide();
    });


    //Delete One
    function DeleteNurseCoordinator(NurseCoordinatorId1, username) {
        if (confirm('Are you sure you want to delete Director?')) {
            $("#loading").show();
            var url = INITURL + '/NurseCoordinator/DeleteNurseCoordinator';

            $.ajax({
                url: url,
                data: { NurseCoordinatorId: NurseCoordinatorId1, UserName: username },
                cache: false,
                type: 'POST',
                async: false,
                success: function (data) {
                    if (data == "Success") {
                        window.location = INITURL + '/NurseCoordinator/NurseCoordinator';
                    }
                    $("#loading").hide();
                },
                error: function (reponse) {
                    alert("error : " + reponse);
                    $("#loading").hide();
                }
            });
        }
    }

    //Add new
    function OpenAddNew() {
        $("#loading").show();
        console.log(INITURL);
        // $('#AddScheduler').load(INITURL + 'Schedulers/AddScheduler', function () {
        $('#AddNurseCoordinator').load(INITURL + 'NurseCoordinator/AddNurseCoordinator', function () {
            sessionStorage.setItem("PartialView", "1");
            $('#myModal').modal('show');
            $("#loading").hide();
        });
    }

    //Edit One
    function EditNurseCoordinator(NurseCoordinatorId) {
        $("#loading").show();
        $('#EditNurseCoordinator').load(INITURL + '/NurseCoordinator/EditNurseCoordinator/' + NurseCoordinatorId, function () {
            sessionStorage.setItem("PartialView", "1");
            $('#myModal2').modal('show');
            $("#loading").hide();
        });
    }

    //function GetUnAssignedNurseCoordinator()
    //{
    //    debugger;
    //    var url = INITURL + '/Chatting/GetUnAssignedNurseCoordinatorList';
    //    $.ajax({
    //        url: url,
    //        cache: false,
    //        type: 'POST',
    //        async: false,
    //        success: function (data) {
    //            debugger;
              
    //        },
    //        error: function (reponse) {
    //            alert("error : " + reponse);
              
    //        }
    //    });
    //}

    function RemoveFiltration() {
        $('#ddFilterOffice').val("");
        oTable.search($('#myDataTable').val()).draw();
    }

    function Filtration() {

        oTable.search($('#myDataTable').val()).draw();
    }
</script>
