<script>

    $("#btnClose").click(function () {
        $("#modalAddPopup").css('width', '600px');
    });

    function Filtration() {
        if ($('#ToDate').val() == "" && $('#FromDate').val() != "") {
            toastr.error('Please fill To Date');
        }
        else if ($('#FromDate').val() == "" && $('#ToDate').val() != "")
        {
            toastr.error('Please fill From Date');
        }
        else {
            oTable.search($('#myDataTable').val()).draw();
        }
    }
    function RemoveFiltration() {
        $('#FromDate').val('');
        $('#ToDate').val('');
        $('#ddFilterStatus').val(0);
        $('#ddFilterOffice').val(0);
        oTable.search($('#myDataTable').val()).draw();
    }

    function clearMap()
    { document.getElementById("divmap").innerHTML = ""; }

    
    var oTable;
    //$(document).ready(function () {
    //    setInterval(function () {
    //        //var RequestPatientId = localStorage.getItem("PatientRequestId");
    //        LoadTrackLocationMap(localStorage.getItem("PatientRequestId"));

    //    }, 30000);

    //})
    function ViewCareGiverProfile(id) {
        
        
        $("#loading").show();
        $('#ViewPanel').load(INITURL + '/CareGiver/ViewCareGiver/' + id, function () {
            $('#care-giver-details').modal('show');
            sessionStorage.setItem("PartialView", "1");
        });
    }

    function LoadNotifiedNurseList(PatientRequestId, TotalCaregiversNotified) {
        localStorage.setItem("PatientRequestId", PatientRequestId);
        $("#GetNurseList").load('@(Url.Action("GetNurseList", "PatientRequest", null, Request.Url.Scheme))?PatientRequestId=' + PatientRequestId, function (data, response, status, xhr) {
            //console.log(JSON.stringify(data, response, status));
        });

        if (TotalCaregiversNotified > 0) {
            $('#myModal1').modal('show');
        }
        else {
            alert("No caregivers found for this request.");
        }
    }

    function LoadTrackLocationMap(PatientRequestId) {

        @*$("#GetNurseList").load('@(Url.Action("GetNurseList", "PatientRequest", null, Request.Url.Scheme))?PatientRequestId=' + PatientRequestId, function (data, response, status, xhr) {
            //console.log(JSON.stringify(data, response, status));
        });*@
        $("#loading").show();

        $('#myModalTrackLocation').modal({ backdrop: 'static', keyboard: false })
        $('#myModalTrackLocation').modal('show');
        $.ajax({
            url: "@Url.Action("TrackLocationByPatientRequestId", "PatientRequest")",
            data: { PatientRequestId: PatientRequestId },
            cache: false,
