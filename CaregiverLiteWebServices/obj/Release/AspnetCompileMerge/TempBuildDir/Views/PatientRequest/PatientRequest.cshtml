<style>
    /*Rating CSS Start*/
    fieldset, label {
        margin: 0;
        padding: 0;
    }

    body {
    }

    h1 {
        font-size: 1.5em;
        margin: 10px;
    }

    /****** Style Star Rating Widget *****/

    .rating {
        border: none;
        float: left;
    }

        .rating > input {
            display: none;
        }

        .rating > label:before {
            margin: 5px;
            font-size: 1.25em;
            font-family: FontAwesome;
            display: inline-block;
            content: "\f005";
        }

        .rating > .half:before {
            content: "\f089";
            position: absolute;
        }

        .rating > label {
            color: #ddd;
            float: right;
        }

        /***** CSS Magic to Highlight Stars on Hover *****/

        .rating > input:checked ~ label, /* show gold star when clicked */
        .rating:not(:checked) > label:hover, /* hover current star */
        .rating:not(:checked) > label:hover ~ label {
            color: #43AADB;
        }
            /* hover previous stars in list */

            .rating > input:checked + label:hover, /* hover current star when changing rating */
            .rating > input:checked ~ label:hover,
            .rating > label:hover ~ input:checked ~ label, /* lighten current selection */
            .rating > input:checked ~ label:hover ~ label {
                color: #43AADB;
            }
    /*Rating CSS End*/
    #dvMapLegend {
        background: #fff;
        padding: 10px;
        margin: 10px;
        border: 1px solid #000;
    }

    .dvMapLegendb {
        background: #fff;
        padding: 10px;
        margin: 10px;
        border: 1px solid #000;
    }

    .map-driving {
        color: #4986E7;
        /*color: #0000ff;*/
        font-size: 16px;
    }

    .map-notdriving {
        color: #000000;
        font-size: 16px;
    }

    .map-pic {
        position: absolute;
        top: 6.4px;
        left: 15px;
        border-radius: 50%;
        height: 40px;
        width: 40px;
    }

    .bluemarkerimage {
        position: relative;
        width: 70px;
    }

    .gm-style-iw > div > div {
        overflow: hidden !important;
    }
</style>

