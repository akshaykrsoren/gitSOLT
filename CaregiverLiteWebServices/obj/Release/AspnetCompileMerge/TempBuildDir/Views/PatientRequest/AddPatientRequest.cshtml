<script type="text/javascript">
    //$("#Date").datepicker();
    $("#FromTime").prepend("<option value='' selected='selected'>-- Select FromTime --</option>");
    $("#ToTime").prepend("<option value='' selected='selected'>-- Select ToTime --</option>");
    var latitude;
    var longitude;
    var MaxCaregiver = 0;
    var MaxDistance = 0;

    $("#loading").hide();

    $.validator.setDefaults({
        ignore: [],
    });
    $(document).ready(function () {


        // $("#dvweek-select").hide();
        $('#dvdatepicker').hide();

        $('#IsRepeat').change(function () {
            if (this.checked)
            {
                $('#dvdatepicker').show();
                $('#RepeatDate').prop('required',true);
            }
            else
            {
                $('#dvdatepicker').hide();
                $('#RepeatDate').prop('required',false);
            }
            $("#dvweek").hide();
        });

        $('#RepeatTypeID').on('change', function () {
            //
            if (this.value == '2')
                //.....................^.......
            {
                $('#dvweek').empty();
                var strtable = "";
                strtable += "<table class='table table-bordered'>";
                strtable += "<tr class='success'>";
                strtable += "<td>MON</td>";
                strtable += "<td>TUE</td>";
                strtable += "<td>WED</td>";
                strtable += "<td>THU</td>";
                strtable += "<td>FRI</td>";
                strtable += "<td>SAT</td>";
                strtable += "<td>SUN</td>";
                strtable += "</tr>";
                strtable += "<tr class='success'>";
                for (var i = 0; i < 7; i++) {
                    strtable += "<td> <input class='chkweek' type='checkbox' value=" + i + " id=week_" + i + "/>";
                    strtable += "</td>";
                }
                strtable += "</tr>";
                strtable += "</table>"
                $("#dvweek").append(strtable);
                $("#dvweek").show();




            }
            else if (this.value == '3') {


                $('#dvweek').empty();

                var now = new Date();
                var DayInMounth = new Date(now.getFullYear(), now.getMonth() + 1, 0).getDate();

                var strtable = "";
                strtable += "<table class='table table-bordered'>";
                strtable += "<tr class='success'>";
                for (var i = 1; i <= 31; i++) {
                    strtable += "<td>" + i + "<br><input class='chkmonth' type='checkbox' value=" + i + " id=month_" + i + "/>";
                    strtable += "</td>";
                    //if (i == 31) {
                    //    strtable += "<td>" + i + "<br><input class='chkmonth' type='checkbox' value="+ 0 + " id=month_" + i + "/>";
                    //    strtable += "</td>";
                    //}
                    if (i == 7)
