    function getCaregiverBasedOnInput(patientLatlong, CaregiverLatLong) {

        setTimeout(function () {

            var gm = google.maps;
            var infowindow;
            var iw = new gm.InfoWindow();

            var patientLatlongArray = patientLatlong.split(',', 2);

            var img = new Image();
            img.bluepin = "https://scheduler.paseva.com/CaregiverLiteMobileService/Images/CareGiverProfileImages/blue-dot.png";
            img.greenpin = "https://scheduler.paseva.com/CaregiverLiteMobileService/Images/CareGiverProfileImages/green-dot.png"
            img.redpin = "https://scheduler.paseva.com/CaregiverLiteMobileService/Images/CareGiverProfileImages/red-dot.png"
            var bounds = new google.maps.LatLngBounds();

            //Patient Location
            if (patientLatlongArray != null && patientLatlongArray.length > 0) {

                var mapCenter = {
                    lat: parseFloat(patientLatlongArray[0]),
                    lng: parseFloat(patientLatlongArray[1])
                }

                var map = new google.maps.Map(document.getElementById('mapCaregiverLocationList'),
                 {
                     center: mapCenter,
                     zoom: 14,
                     mapTypeId: google.maps.MapTypeId.ROADMAP
                 });


                var centerinfowindow = new google.maps.InfoWindow();
                var centermarker = new google.maps.Marker({
                    position: mapCenter,
                    map: map
                });

                centermarker.setIcon(img.bluepin);
                var centercontent =
                        '<div><strong>Latitude: </strong>' +
                        patientLatlongArray[0] +
                        '</div>' +
                        '<div><strong>Longitude: </strong>' +
                        patientLatlongArray[1] +
                        '</div>' ;
                google.maps.event.addListener(centermarker,
                    'click',
                    (function (centermarker, centercontent, centerinfowindow) {
                        return function () {
                            centerinfowindow.setContent(centercontent);
                            centerinfowindow.open(map, centermarker);

                        };
                    })(centermarker, centercontent, centerinfowindow));
            }

            var circle = new google.maps.Circle({
                map: map,
                radius: getMeters(MaxDistance),    // metres
                fillColor: '#f4b7b7',
                strokeColor: '#ff6666',
                strokeOpacity: 0.8,
                strokeWeight: 1
            });
            circle.bindTo('center', centermarker, 'position');

            //Caregiver Location
            for (var i = 0; i < CaregiverLatLong.length; i++) {

                if ( i < CaregiverLatLong.length) {

                    var service = new google.maps.DirectionsService();
                    var directionsDisplay = new google.maps.DirectionsRenderer();

                    //   var bounds = new google.maps.LatLngBounds();

                    var src = new google.maps.LatLng(
                        parseFloat(CaregiverLatLong[i].Latitude),
                        parseFloat(CaregiverLatLong[i].Longitude)
                    );



                    var content =
                        '<div><strong>Caregiver Name: </strong>' +
                           CaregiverLatLong[i].Name +
                            '</div>';

                    var infowindow = new google.maps.InfoWindow();

                    var marker = new google.maps.Marker({
                        position: src,
                        map: map
                    });
                    bounds.extend(marker.position);

                    google.maps.event.addListener(marker,
                        'click',
                        (function (marker, content, infowindow) {
                            return function () {
                                infowindow.setContent(content);
                                infowindow.open(map, marker);

                            };
                        })(marker, content, infowindow));

                    marker.setIcon(img.redpin)
                    //map.fitBounds(bounds);
                }
            }
            //set fit bound start
            var pt1 = new google.maps.LatLng(
                        parseFloat(patientLatlongArray[0]),
                        parseFloat(patientLatlongArray[1])
                    );
            var marker1 = new google.maps.Marker({
                position: pt1,
                map: map
            });
            bounds.extend(marker1.position);
            marker1.setIcon(img.bluepin);
            map.fitBounds(bounds);
            //set fit bound end

            var legend = document.createElement('dvMapLegend');
            legend.className = "dvMapLegendb";
            if (legend != null) {
                var startpoint = document.createElement('div');
                startpoint.className = "map-notdriving";
                startpoint.innerHTML = '<img src="' + img.bluepin + '" />' + '     Patient Location';
                legend.appendChild(startpoint);

                var endpoint = document.createElement('div');
                endpoint.className = "map-notdriving";
                endpoint.innerHTML = '<img src="' + img.redpin + '" />' + '     Caregiver Location';
                legend.appendChild(endpoint);

                map.controls[google.maps.ControlPosition.RIGHT_TOP].push(legend);

                $("#divMapLegend").show();
            }

        }, 500);
        google.maps.event.trigger(map, 'resize');
    };


