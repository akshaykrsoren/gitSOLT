                        //$("#drpToTime").find('option[value="' + data.ToTime + '"]').attr('selected', 'selected');
                        //debugger;
                        $("#Description").val(data.Description);
                        $("#OfficeName").val(data.OfficeName);
                        $("#Office").val(data.Office);
                        if (data.ServiceNames) {
                            var selectedValues = new Array();
                            selectedValues = data.ServiceNames.trim().split(',')
                            $("#ddlService").val(selectedValues);
                        }

                        //for (var i = 0 ; i < selectedValues.length ; i++)
                        //{
                        //    //$("#ddlService").find('option[value="' + selectedValues[i] + '"]').attr('selected', 'selected');
                        //}
                        //$("#ddlService").val(selectedValues);
                    }
                    else {
                        $("#PatientName").val('');
                        $("#Street").val('');
                        $("#City").val('');
                        $("#State").val('');
                        $("#ZipCode").val('');
                        $("#Description").val('');
                        $("#OfficeName").val('');
                        $("#Office").val('');
                        $("#Date").val('');

                        toastr.error('This MedicalId is not exist. Please insert patient detail with this MedicalId and try again. ');
                    }
                    $("#loading").hide();
                },
                error: function (response) {
                    alert("error : " + response);
                    $("#loading").hide();
                }
            });
        }
    }
