@model CaregiverLite.Models.PatientDetailsModel

<style>
    .clsDatePicker {
        z-index: 100000;
    }

    #ui-datepicker-div {
        z-index: 1003;
    }

    .field-validation-error {
        color: red;
        float: right;
    }

    .table td {
        text-align: center;
    }
</style>


@using (Html.BeginForm("EditPatientDetail", "Patients", FormMethod.Post, new { @id = "fmEditPatientDetails", @class = "horizontal-form", @enctype = "multipart/form-data" }))
{
    <div id="main_div">



        <div class="alert alert-danger alert-dismissable" style="display:none" id="dvError3">
            <button onclick="divClose();" class="close" type="button">×</button>
            <label id="lblError3"></label>
        </div>
        <div class="col-md-6">
           @*Medical Id*@
        <div class="form-group">
            <label>@CaregiverLite.Views.Resources.PatientRequest.TableHeaderMedicalId</label>
            <span style="color:red;">*</span>
            @Html.ValidationMessageFor(model => model.MedicalId)
            @Html.TextBoxFor(model => model.MedicalId, new { @type = "text", @maxlength = "10", @placeholder = @CaregiverLite.Views.Resources.PatientRequest.PlaceHolderMedicalId, @class = "form-control", @tabindex = "1", @onblur = "",@readonly = true })
        </div>
        @*Patient Name*@
        <div class="form-group">
            <label>@CaregiverLite.Views.Resources.PatientRequest.TableHeaderPatientName</label>
            <span style="color:red;">*</span>
            @Html.ValidationMessageFor(model => model.PatientName)
            @Html.TextBoxFor(model => model.PatientName, new { @type = "text", @maxlength = "100", @placeholder = @CaregiverLite.Views.Resources.PatientRequest.PlaceHolderPatientName, @class = "form-control", @tabindex = "2" })
        </div>
        @*PrimaryMD*@
        <div class="form-group">
            <label>PrimaryMD</label>
            <span style="color:red;">*</span>
            @Html.ValidationMessageFor(model => model.PrimaryMD)
            @Html.TextBoxFor(model => model.PrimaryMD, new { @type = "text", @placeholder = "Enter PrimaryMD", @class = "form-control", @tabindex = "3" })
        </div>
        @*PhoneNo*@
        <div class="form-group">
            <label>@CaregiverLite.Views.Resources.Patients.TableHeaderPhoneNo</label>
            <span style="color:red;">*</span>
            @Html.ValidationMessageFor(model => model.PhoneNo)
            @Html.TextBoxFor(model => model.PhoneNo, new { @type = "text", @maxlength = "20", @placeholder = "Enter Phone Number", @class = "form-control", @tabindex = "4" })
        </div>
        @*Office*@
        <div class="form-group">
            <label>Office</label>
            <span style="color:red;">*</span>
            @Html.ValidationMessageFor(model => model.OfficeId)
            @Html.DropDownListFor(model => model.OfficeId, Model.OfficeSelectList, "Select...", new { @class = "form-control", @tabindex = "5" })
        </div>

        </div>
        <div class="col-md-6">
            @*Street*@
            <div class="form-group">
                <label>@CaregiverLite.Views.Resources.Patients.TableHeaderStreet</label>
                <span style="color:red;">*</span>
                @Html.ValidationMessageFor(model => model.Street)
                @Html.TextBoxFor(model => model.Street, new { @type = "text", @placeholder = "Enter Street", @class = "form-control", @tabindex = "6", @onblur = "" })
            </div>
            @*City*@
            <div class="form-group">
                <label>@CaregiverLite.Views.Resources.Patients.TableHeaderCity</label>
                <span style="color:red;">*</span>
                @Html.ValidationMessageFor(model => model.City)
                @Html.TextBoxFor(model => model.City, new { @type = "text", @maxlength = "20", @placeholder = "Enter City", @class = "form-control", @tabindex = "7", @onblur = "" })
            </div>
            @*State*@
            <div class="form-group">
                <label>@CaregiverLite.Views.Resources.Patients.TableHeaderState</label>
                <span style="color:red;">*</span>
                @Html.ValidationMessageFor(model => model.State)
                @Html.TextBoxFor(model => model.State, new { @type = "text", @maxlength = "20", @placeholder = "Enter State", @class = "form-control", @tabindex = "8", @onblur = "" })
            </div>

            @*Zipcode*@
            <div class="form-group">
                <label>@CaregiverLite.Views.Resources.PatientRequest.TableHeaderZipCode</label>
                <span style="color:red;">*</span>
                @Html.ValidationMessageFor(model => model.ZipCode)
                @Html.TextBoxFor(model => model.ZipCode, new { @type = "text", @maxlength = "10", @placeholder = @CaregiverLite.Views.Resources.PatientRequest.PlaceHolderZipCode, @class = "form-control", @*@onchange = "javascript:GetTime(this.value);",*@ @tabindex = "9" })
            </div>

            <div>
                @Html.HiddenFor(model => model.TimezoneOffset, new { @id = "hdnTimezoneOffset" })
                @Html.HiddenFor(model => model.TimezoneId, new { @id = "hdntimeZoneId" })
                @Html.HiddenFor(model => model.TimezonePostfix, new { @id = "hdnTimezonePostfix" })
                @Html.HiddenFor(model => model.Latitude)
                @Html.HiddenFor(model => model.Longitude)
                @Html.HiddenFor(model => model.PatientId)
            </div>
        </div>

        <div class="col-md-12">
            <button type="button" onclick="Save()" class="btn btn-sm btn-primary pull-right" tabindex="10">Save</button>
            <div class="clearfix"></div>
        </div>

        <input type="hidden" id="hdndstOffset" />
        <input type="hidden" id="hdnrawOffset" />
        <input type="hidden" id="hdntimeZoneFullName" />
    </div>
}


<link rel="stylesheet" href="https://code.jquery.com/ui/1.12.1/themes/base/jquery-ui.css">
<script type="text/javascript">
    //$("#Date").datepicker();
    var latitude;
    var longitude;
    var MaxCaregiver = 0;
    var MaxDistance = 0;
    var add = "";
    $("#loading").hide();

    $.validator.setDefaults({
        ignore: [],
    });
    $(document).ready(function () {

        $('#Street').keypress(function (event) {
            if ($('#Street').val().length > 99)
            {
                toastr.error("Description will not allow greater then 150 characters.");
                $('#Street').focus()
                return false;
            }
        });
        // $("#dvweek-select").hide();
        $('#ZipCode').blur(function (event) {

            if ($('#ZipCode').val().length > 3 && ($("#Street").val() + $("#City").val() + $("#State").val()).length > 3) {

                $("#loading").show();
                GetLanLat()
                $("#loading").hide();
                return false;
            }
        });



        $("#loading").show();


        var form = $("#fmAddPatientDetails").closest("form");
        form.removeData('validator');
        form.removeData('unobtrusiveValidation');
        $.validator.unobtrusive.parse(form);

        $('#myModal').on('shown.bs.modal', function () {

            $("#Date").datepicker(
            {
                minDate: 0,
                onSelect: function () {
                    $(this).change();
                }

                //,dateFormat: 'dd-mm-yy'
            });


            $("#RepeatDate").datepicker(
            {
                minDate: 0,
                onSelect: function () {
                    $(this).change();
                }

                //,dateFormat: 'dd-mm-yy'
            });

        });

        var config = {
            '.chosen-select': {},
            '.chosen-select-deselect': { allow_single_deselect: true },
            '.chosen-select-no-single': { disable_search_threshold: 10 },
            '.chosen-select-no-results': { no_results_text: 'Oops, nothing found!' },
            '.chosen-select-width': { width: "95%" }
        }
        for (var selector in config) {
            $(selector).chosen(config[selector]);

        }
        $("#loading").hide();
    });

    //Fetch Filtered Caregiver End


    function Save() {
        $('#loading').show();
        $('#modalAddPopup').remove();//for remove form control of Add popup
        var PatientName = $("#PatientName").val();
        var PrimaryMD = $("#PrimaryMD").val();
        var ZipCode = $("#ZipCode").val();
        var MedicalId = $("#MedicalId").val();
        //var Date = $("#Date").val();
        var Street = $("#Street").val();
        var City = $("#City").val();
        var State = $("#State").val();
        var PhoneNo = $("#PhoneNo").val();
        var OfficeId = $("#OfficeId").val();

        if (PatientName == "" && PrimaryMD == "" && ZipCode == "" && MedicalId == "" && Street == "" && City == "" && State == "" && PhoneNo == "" && OfficeId == "") {
            toastr.error('Please fill all required fields');
            $('#loading').hide();
            return false;
        }
        else if (MedicalId == "") {
            toastr.error('Please Enter Medical Id');
            $('#loading').hide();
            return false;
        }
        else if (PatientName == "") {
            toastr.error('Please Enter Patient Name');
            $('#loading').hide();
            return false;
        }
        else if (PrimaryMD == "") {
            toastr.error('Please Enter PrimaryMD');
            $('#loading').hide();
            return false;
        }
        else if (PhoneNo == "") {
            toastr.error('Please Enter PhoneNo');
            $('#loading').hide();
            return false;
        }
        else if (OfficeId == "") {
            toastr.error('Please Select OfficeId');
            $('#loading').hide();
            return false;
        }
        else if (Street == "") {
            toastr.error('Please Enter Street Information');
            $('#loading').hide();
            return false;
        }
        else if (City == "") {
            toastr.error('Please Enter City Information');
            $('#loading').hide();
            return false;
        }
        else if (State == "") {
            toastr.error('Please Enter State Id');
            $('#loading').hide();
            return false;
        }
        else if (ZipCode == "") {
            toastr.error('Please Enter ZipCode');
            $('#loading').hide();
            return false;
        }
        $("#dvError3").hide();
        var selectedValues = "";




        if (!GetLanLat()) {
            $('#loading').hide();
            return false;
        }
        var lat = $("#Latitude").val();
        var long = $("#Longitude").val();

        //var dstOffset = $("#hdndstOffset").val();
        //var rawOffset = $("#hdnrawOffset").val();
        //var timeZoneFullName = $("#hdntimeZoneFullName").val();
        var TimezoneOffset = $("#hdnTimezoneOffset").val();
        var timeZoneId = $("#hdntimeZoneId").val();
        var TimezonePostfix = $("#hdnTimezonePostfix").val();

        if (lat === null || lat === '' || lat === 'undefined' || lat === 'undefined' || long === null || long === '') {
            toastr.error('Please enter valid address');
            $('#loading').hide();
            return false;
        }
        //debugger;
        //console.log($("#PatientName").val());
        //console.log($("#Address").val());
        //console.log($("#ZipCode").val());
        //console.log($("#MedicalId").val());
        //console.log($("#Latitude").val());
        //console.log($("#Longitude").val());
        //console.log($("#hdnTimezoneOffset").val());
        //console.log($("#hdntimeZoneId").val());
        //console.log($("#hdnTimezonePostfix").val());
        //debugger;
        if ($("#fmEditPatientDetails").valid()) {
            $("#fmEditPatientDetails").submit();
            
        }
        else {

            $('#loading').hide();
        }
    }

    function isNumber(evt) {
        evt = (evt) ? evt : window.event;
        var charCode = (evt.which) ? evt.which : evt.keyCode;
        if (charCode > 31 && (charCode < 48 || charCode > 57)) {
            return false;
        }
        return true;
    }

    function GetLanLat() {
        var Address = $("#Street").val() + $("#City").val() + $("#State").val();//$("#Address").val();
        var Pincode = $("#ZipCode").val();
        var flag = true;
        
        $.ajax({
            type: "GET",
            url: "https://maps.google.com/maps/api/geocode/json",
            data: "address=" + Address + ",  zip code=" + Pincode + "&key=AIzaSyDCQgMe2fLgmaF9GDvxF61wsIXnktEBKhg",
            async: false,
            contentType: "text/plain; charset=utf-8",
            dataType: "json",
            success: function (result) {
                
                if (result["status"] == "OK") {
                    //add = result;
                    $("#Latitude").val(result["results"][0]["geometry"]["location"]["lat"]);
                    $("#Longitude").val(result["results"][0]["geometry"]["location"]["lng"]);
                    var Latitude = result["results"][0]["geometry"]["location"]["lat"];
                    var Longitude = result["results"][0]["geometry"]["location"]["lng"];

                    //$("#City").val(result.results[0].address_components[2].long_name);
                    //$("#State").val(result.results[0].address_components[3].long_name);

                    var today = new Date();
                    //var UTCDate = today.toUTCString();
                    //var UtcNow = Math.floor(today.getTime() / 1000);
                    
                    var timestamp = today.getTime() / 1000 + today.getTimezoneOffset() * 60;
                    $.ajax({
                        type: "GET",
                        url: "https://maps.googleapis.com/maps/api/timezone/json?location=" + Latitude + "," + Longitude + "&timestamp=" + timestamp + "&sensor=false",
                        async: false,
                        contentType: "text/plain; charset=utf-8",
                        dataType: "json",
                        success: function (data, result) {

                            
                            if (data["status"] == "OK" && result == "success") {
                                $("#hdndstOffset").val(data.dstOffset);
                                $("#hdnrawOffset").val(data.rawOffset);
                                $("#hdntimeZoneFullName").val(data.timeZoneName);
                                $("#hdntimeZoneId").val(data.timeZoneId);

                                var str = data.timeZoneName;
                                var splitString = str.split(" ");
                                var abbr = "";
                                for (i = 0; i < splitString.length; i++) {
                                    abbr += splitString[i].charAt(0);
                                }
                                $("#hdnTimezonePostfix").val(abbr);
                                //var TimeZoneOffset = data.rawOffset;
                                var TimeZoneOffset = data.dstOffset + data.rawOffset
                                // console.log(TimeZoneOffset);
                                //debugger
                                TimeZoneOffset = TimeZoneOffset < 0 ? "-" + Math.abs(TimeZoneOffset) / 60 : "+" + Math.abs(TimeZoneOffset) / 60;
                                $("#hdnTimezoneOffset").val(parseInt(TimeZoneOffset));
                                return true;
                            }
                        }
                    });
                }
                else if (result.status === "ZERO_RESULTS") {
                    toastr.error('Please enter valid address');
                    flag = false;
                }
            }
        });
        //----------End Pincode+Address----------------
        return flag;
    }

    function divClose() {
        $("#dvError3").css("display", "none");
    }

    function isNumberAndDot(evt) {
        evt = (evt) ? evt : window.event;
        var charCode = (evt.which) ? evt.which : evt.keyCode;
        if (charCode > 31 && (charCode < 48 || charCode > 57) && charCode != 46) {
            return false;
        }
        return true;
    }

    function GetTime(val) {
        
        if (val !== '') {
            var Address = $("#Street").val() + $("#City").val() + $("#State").val();//$("#Address").val();
            var Pincode = $("#ZipCode").val();
            $('#drpFromTime option[value!="0"]').remove();
            $('#drpToTime option[value!="0"]').remove();

            if (Address !== '') {
                if (Pincode !== '') {
                    $('#loading').show();
                    var flag = true;
                    $.ajax({
                        type: "GET",
                        url: "https://maps.google.com/maps/api/geocode/json",
                        data: "address=" + Address + ", zip code=" + Pincode + "&key=AIzaSyDCQgMe2fLgmaF9GDvxF61wsIXnktEBKhg",
                        async: false,
                        contentType: "text/plain; charset=utf-8",
                        dataType: "json",
                        success: function (result) {
                            if (result["status"] == "OK") {
                                var Latitude = result["results"][0]["geometry"]["location"]["lat"];
                                var Longitude = result["results"][0]["geometry"]["location"]["lng"];
                                var today = new Date();
                                var timestamp = today.getTime() / 1000 + today.getTimezoneOffset() * 60;
                                $.ajax({
                                    type: "GET",
                                    url: "https://maps.googleapis.com/maps/api/timezone/json?location=" + Latitude + "," + Longitude + "&timestamp=" + timestamp + "&sensor=false",
                                    async: false,
                                    contentType: "text/plain; charset=utf-8",
                                    dataType: "json",
                                    success: function (data, result) {
                                        if (data["status"] == "OK" && result == "success") {
                                            var str = data.timeZoneName;
                                            var splitString = str.split(" ");
                                            var abbr = "";
                                            for (i = 0; i < splitString.length; i++) {
                                                abbr += splitString[i].charAt(0);
                                            }
                                            var TimeZoneOffset = data.dstOffset * 1000 + data.rawOffset * 1000;
                                           
                                            var localDate = new Date(timestamp * 1000 + TimeZoneOffset)
                                           

                                            var selectedDate = $('#Date').val();
                                            var Sdate = new Date(selectedDate);

                                           
                                            var CurrentHours = new Date(localDate).getHours();
                                           
                                            if (Sdate.setHours(0, 0, 0, 0) != localDate.setHours(0, 0, 0, 0)) {
                                                CurrentHours = 0;
                                            }

                                           

                                            for (var i = CurrentHours + 1; i <= 24; i++) {
                                                var hours = i;
                                                var minutes = 0;
                                                var seconds = 0;
                                                var ampm = hours >= 12 ? 'PM' : 'AM';
                                                hours = hours % 12;
                                                hours = hours ? (hours < 10) ? ("0" + hours) : hours : 12;
                                                minutes = minutes < 10 ? '0' + minutes : minutes;
                                                var strTime = hours + ':' + minutes + ' ' + ampm;
                                                var id = i === 0 ? i + 1 : i + 1;
                                                if (i < 24) {
                                                    var temphour = i < 10 ? '0' + i : i;
                                                    $("#drpFromTime").append($("<option>").attr("value", temphour + ":00:00").text(strTime + " (" + abbr + ") ").attr("id", id));
                                                    $("#drpToTime").append($("<option>").attr("value", temphour + ":00:00").text(strTime + " (" + abbr + ") ").attr("id", id));
                                                } else {
                                                    $("#drpToTime").append($("<option>").attr("value", "23:59:59").text("11:59 PM" + " (" + abbr + ") ").attr("id", id));
                                                }
                                            }
                                            $("#loading").hide();
                                            return true;
                                        }
                                    }
                                });
                            }
                            else if (result.status === "ZERO_RESULTS") {
                                $("#loading").hide();
                                toastr.error('Please enter valid address with valid zip code');
                                $('#drpFromTime option[value!="0"]').remove();
                                $('#drpToTime option[value!="0"]').remove();
                                flag = false;
                            }
                        }
                    });
                }
                else {
                    toastr.error('Please Enter ZipCode');
                    $('#drpFromTime option[value!="0"]').remove();
                    $('#drpToTime option[value!="0"]').remove();
                }
            } else {
                toastr.error('Please Enter Address');
                $('#drpFromTime option[value!="0"]').remove();
                $('#drpToTime option[value!="0"]').remove();
            }
        } else {
            $('#drpFromTime option[value!="0"]').remove();
            $('#drpToTime option[value!="0"]').remove();
        }
    }


</script>


