@model CaregiverLite.Models.NurseCoordinatorModel


<div id="main_div">
    @*@using (Html.BeginForm("AssignNurseCoordinator", "NurseCoordinator", FormMethod.Post, new { @id = "fmAssignNurseCoordinator", @class = "horizontal-form", @enctype = "multipart/form-data" }))
    {*@

        <div class="alert alert-danger alert-dismissable" style="display:none" id="dvError3">
            <button onclick="divClose();" class="close" type="button">×</button>
            <label id="lblError3"></label>
        </div>
        <div class="col-md-12">
            <div class="form-group">
                <label>Group : @ViewBag.GroupName </label>
            </div>
            <div class="form-group">
                <label> Director</label>
                <Select id="NurseCo" class="form-control input-sm" style="height:35px">
                    <option value="0">Select Director</option>
                    @if (ViewBag.NurseCoordinatorList != null)
                    {
                        foreach (var item in ViewBag.NurseCoordinatorList)
                        {
                            <option value="@item.UserId" nursecoordinatorid="@item.NurseCoordinatorId" qbid="@item.QBID"> @item.FirstName  @item.LastName </option>
                        }
                    }
                    else
                    {
                        <option value="0"> Director Not Found</option>
                    }
                </Select>
            </div>
            <div class="form-group">
                <label>Assign Permission</label>
                <Select id="permission" class="form-control input-sm" style="height:35px">
                    @*<option value="0">Assign Permission</option>*@
                    <option value="1">Read</option>
                    <option value="2">Read / Write</option>
                    <option value="3" , Selected = "true" >Read / Write / Attachment</option>
                </Select>
            </div>
        </div>
        <div class="col-md-12">
            @*<input type="button" class="btn btn-xs btn-primary" style="margin-left:10px; width:auto;" onclick="SetNurseCoordinator(' + row.ChattingGroupId + ')" value="Assign">*@
            <button type="button" onclick="SetNurseCoordinator(@ViewBag.ChattingGroupId)" class="btn btn-sm btn-primary pull-right">ASSIGN PERMISSION</button>
            <div class="clearfix"></div>
        </div>
        <div class="col-md-12">
            <div class="form-group">
                <label>Director List</label>

                <div class="col-md-06" style="overflow-y:auto;scroll:auto;max-height:300px">
                    <table class="table table-striped table-bordered table-hover dataTables-example">
                        <thead>
                            <tr>
                            <td><b>Director</b> </td>
                            <td><b>Office</b></td>
                            <td><b>Permission</b></td>
                                <td style="width:10%;">
                                    <b>Action</b>
                                </td>
                            </tr>
                        </thead>
                        <tbody>
                            @if (ViewBag.NurseCoDetail != null)
                            {
                                foreach (var item in ViewBag.NurseCoDetail)
                                {
                                    
                                        <tr id="@item.UserId"> 
                                        <td>@item.MemberName</td>
                                        <td>@item.OfficeName</td> 
                                        <td>@item.Type</td>
                                            <td>
                                                <center>
                                                    <button class="btn btn-xs btn-danger" style="margin:5px; width:auto;" onclick="RemoveNurseCordinatorFromGroup('@ViewBag.ChattingGroupId','@item.UserId','@item.QuickBloxId')"><span class="fa fa-remove"></span></button>
                                                </center>
                                            </td>
                                        </tr>
                                   
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        @*//}*@
</div>

<link rel="stylesheet" href="https://code.jquery.com/ui/1.12.1/themes/base/jquery-ui.css">
<script type="text/javascript">


    function SetNurseCoordinator(ChattingGroupId) {
       
        
        var selectedId = $('#NurseCo option:selected').val();
        var selectedPermission = $('#permission option:selected').val();
        var qbid = $('#NurseCo option:selected').attr("qbid");

        var selectedNurseCoIds = '';

        $('#NurseCo :selected').each(function () {
            selectedNurseCoIds += $(this).attr("nursecoordinatorid") + ',';
            //if ($(this).attr("qbid"))
            //    selectedQBIds += parseInt($(this).attr("qbid")) + ',';
        });

        selectedNurseCoIds = selectedNurseCoIds.replace(/,\s*$/, "");


        if (selectedId == 0) {
            toastr.info("Please Select Director");
            $('#NurseCo').focus();
            return;
        }

        if (selectedPermission == 0) {
            toastr.info("Please Select Permission");
            $('#permission').focus();
            return;
        }
        $('#loading').show();
        //alert(ChattingGroupId + ' ' + selectedId + ' ' + selectedPermission);
        var url = INITURL + '/Chatting/SetNurseCoordinator';

        $.ajax({
            url: url,
            cache: false,
            type: 'POST',
            data: {
                ChattingGroupId: ChattingGroupId,
                NurseCoordinatorId: selectedNurseCoIds,
                Permission: selectedPermission,
                QuickBloxId: qbid
            },
            async: true,
            success: function (data) {
                $('#myModal').modal('hide');
                $('#loading').hide();
                toastr.success('Director Assigned.');
            },
            error: function (reponse) {

                $('#loading').hide();
            }
        });
    }


    function RemoveNurseCordinatorFromGroup(ChattingGroupId, UserId, QuickBloxId) {
        //debugger;
        if (!confirm('Are you sure you want remove this Director ?'))
            return false;
        if (ChattingGroupId && UserId) {
            $('#loading').show();
            var url = INITURL + '/Chatting/RemoveNurseCordinatorFromGroupChat';

            $.ajax({
                url: url,
                type: 'GET',
                data: {
                    ChattingGroupId: ChattingGroupId,
                    UserId: UserId,
                    QuickBloxId: QuickBloxId
                },
                async: true,
                success: function (data) {
                    //debugger;
                    if (data.result == "Success") {
                        $('#' + UserId).remove();
                        loadNurseCordinatorSelectList(data.lstNurseCoordinator);
                        $('#loading').hide();
                        toastr.success('Director has been removed successfully.');
                    }
                    else {
                        toastr.error('Something went wrong!');
                        $('#loading').hide();
                    }
                },
                error: function (reponse) {
                    $('#loading').hide();
                }
            });
        }
    }


    function loadNurseCordinatorSelectList(lstNurseCoordinator) {
        //unassignedCaregivers = data.lstCaregiver;
        $('#NurseCo').empty();
        if (lstNurseCoordinator.length > 0) {
            $.each(lstNurseCoordinator, function (key, value) {

                $('#NurseCo').append("<option value=" + value.UserId + " nursecoordinatorid=" + value.NurseCoordinatorId + " qbid=" + value.QuickBloxId + ">" + value.FirstName + ' ' + value.LastName + "</option>");
               // $('#NurseCo').append("<option value=" + value.NurseCoordinatorId + " qbid=" + value.QuickBloxId + ">" + value.Name + "</option>");
                //$('#ddlCaregiver').append("<option value=" + value.UserId + ">" + value.Name + "</option>");
            });
        }
        $('#NurseCo').trigger("chosen:updated");
        $('#loading').hide();
    }

</script>

