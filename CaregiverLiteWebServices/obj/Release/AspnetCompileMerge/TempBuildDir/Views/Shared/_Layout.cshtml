        function FetchAllDialogIds() {

            var user = {
                id: sFromQBId,
                login: "@Session["FromUserEmail"]",
                password: "Welcome007!"
            };
            var url = INITURL + '/Chatting/GetAllDialogId';

            $.ajax({
                url: url,
                cache: false,
                type: 'POST',
                async: false,
                success: function (data) {

                    try{
                        // debugger;
                        var len = data.objChattingsList.length;
                        if (len > 0) {
                            DialogIds = [];
                        }
                        for (i = 0; i < len ; i++) {
                            DialogIds.push({ UserId: data.objChattingsList[i].UserId, QuickBloxDialogId: data.objChattingsList[i].QuickBloxDialogId });

                        }

                        //    debugger;
                    }catch(e){}

                },
                error: function (reponse) {
                    //alert("error : " + reponse);
                    $("#loading").hide();
                }
            });
        }

