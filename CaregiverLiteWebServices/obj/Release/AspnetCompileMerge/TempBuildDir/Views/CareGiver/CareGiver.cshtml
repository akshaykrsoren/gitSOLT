<script src="//maps.googleapis.com/maps/api/js?v=3.exp&key=AIzaSyCySi2MFE1G-NwmKnJL0GCc-OVlnWGmzEc&amp;" type="text/javascript"></script>
<script src="~/Scripts/js/jquery-2.1.1.js"></script>
<script src="~/Scripts/js/jquery.dataTables.js"></script>
<link rel="stylesheet" href="https://code.jquery.com/ui/1.12.1/themes/base/jquery-ui.css">
<script>

    function Filtration() {
        oTable.search($('#myDataTable').val()).draw();
    }
    function RemoveFiltration() {
        $('#ddFilterStatus').val(2);
        $('#ddFilterOffice').val(0);
        oTable.search($('#myDataTable').val()).draw();
    }

    var oTable;
    $(document).ready(function () {
        localStorage.clear();

        var tempMsg = '@TempData["Message"]';
        if (tempMsg != "")
            toastr.success(tempMsg);

        var value = '@Request.QueryString["IsAdded"]';
        if (value != '') {
            if (value == 'True') {
                toastr.success('CareGiver is Added SuccessFully');
                var originalURL = window.location.href;
                window.history.pushState("string", '@ViewBag.Title', originalURL.substring(0, originalURL.indexOf('?')));
            } else {
                toastr.error('Internal server error');
            }
        }

        $("#loading").show();
        var jquey = jQuery.noConflict();
        oTable = $('#myDataTable').DataTable({
            responsive: true,
            "dom": 'lfrtip',
            "bPaginate": true,
            "bServerSide": true,
            "bSortable": true,
            "sPaginationType": "full_numbers",
            "oLanguage": {
                "sProcessing": "<div class=\"loading\" id=\"loading\" style=\"display: block;\"></div>"
            },
            "processing": true,
            "sAjaxSource": "GetCareGiverList",
            "fnServerParams": function (aoData) {
                aoData.push({ "name": "FilterOffice", "value": $('#ddFilterOffice option:selected').val() });
                aoData.push({ "name": "ddFilterStatus", "value": $('#ddFilterStatus').val() });
            },
            "fnServerData": function (sSource, aoData, fnCallback) {
                $.getJSON(sSource, aoData, function (json) {
                    fnCallback(json);
                }).fail(function (jqxhr, textStatus, error) {
                    window.location.reload();
                });
            },
            "fnDrawCallback": function (oSettings) {
                //Navigation validation
                var rowsPerPage = this.fnSettings()._iDisplayLength;
                var rowsToShow = this.fnSettings().fnRecordsDisplay();
                var table = $('#myDataTable').DataTable();
                var info = table.page.info();
                var currentPageNo = info.page + 1;
                $("#loading").hide();
            },
            "responsive": {
                "details": {
                    "type": 'column'
                }
            },
            "aoColumns": [
                            {
                                className: 'control',
                                orderable: false,
                                targets: 0,
                                "mRender": function (oObj) {
                                    return '';
                                }
                            },
                            {
                                "sName": "Name",
                                "mRender": function (oObj) {
                                    return '<span>' + oObj["Name"] + '</span>';
                                }
                            },
                            {
                                "sName": "ProfileImage",
                                "bSortable": false,
                                "mRender": function (oObj) {
                                    if (oObj["ProfileVideo"] != "")
                                        return '<img height="70" width="80" src=\"' + oObj["ProfileImage"] + '\" style=\"margin-left: 60px;\"/><br><a href="javascript:void(0)" style=\"margin-left: 30px;\" onclick="OpenVideoPopup(\'' + oObj["ProfileVideo"] + '\');">Click here to see video</a>'
                                    else
                                        return '<img height="70" width="80" src=\"' + oObj["ProfileImage"] + '\" style=\"margin-left: 60px;\" />';
                                }
                            },
                            {
                                "sName": "UserName",
                                "mRender": function (oObj) {
                                    return oObj["UserName"];
                                }
                            },
                            {
                                "sName": "Email",
                                "mRender": function (oObj) {
                                    return oObj["Email"];
                                }
                            },
                            {
                                "sName": "Phone",
                                "mRender": function (oObj) {
                                    return oObj["Phone"];
                                }
                            },
                            {
                                "sName": "ZipCode",
                                "mRender": function (oObj) {
                                    return oObj["ZipCode"];
                                }
                            },
                            {
                                "sName": "Office",
                                "mRender": function (oObj) {
                                    return oObj["Office"];
                                }
                            },
                            {
                              "sName": "InsertedOn",
                           //   "sWidth":"110",
                              "mRender": function (oObj) {
                                  return oObj["InsertedOn"];
                              }
                          },
                            {
                                "sName": "NurseId",
                                "bSortable": false,
                                "mRender": function (oObj) {
                                    var actionhtml = '';
                                    if (oObj["IsApprove"] == false) {
                                        @if (ViewContext.Controller.HasRoles("SuperAdmin") || ViewContext.Controller.IsSysAdmin() || ViewContext.Controller.HasRoles("Admin"))
                                        {
                                            @: actionhtml = '<a href="javascript:;" style="width:100%; margin-top:5px;" class="btn btn-xs btn-success" onclick="OpenApprovedPopup(\'' + oObj["UserName"] + '\', \'' + oObj["Email"] + '\', \'' + oObj["Password"] + '\', \'' + oObj["NurseId"] + '\', \'' + oObj["UserId"] + '\', \'' + oObj["OfficeId"] + '\', \'' + oObj["QuickBloxId"] + '\', \'' + parseFloat(oObj["HourlyRate"]).toFixed(2) + '\')">@CaregiverLite.Views.Resources.CareGiver.ButtonApprove</a>'
                                                                                }
                                    }
                                    else {
                                        @if (ViewContext.Controller.HasRoles("SuperAdmin") || ViewContext.Controller.HasRoles("Admin") || ViewContext.Controller.IsSysAdmin())
                                        {
                                            @: actionhtml = '<a href="javascript:;" style="width:100%; margin-top:5px;" class="btn btn-xs btn-warning" onclick="RejectApprovedNurse(\'' + oObj["NurseId"] + '\', \'' + oObj["OfficeId"] + '\', \'' + oObj["UserId"] + '\', \'' + oObj["QuickBloxId"] + '\',0)">@CaregiverLite.Views.Resources.CareGiver.ButtonReject</a>'
                                        }
                                    }

                                    @if (ViewContext.Controller.HasRoles("SuperAdmin") || ViewContext.Controller.HasRoles("Admin") || ViewContext.Controller.IsSysAdmin())
                                    {
                                        @:  actionhtml += '<a href="javascript:;" class="btn btn-xs btn-danger" style="margin-top:5px; width:100%;" onclick="DeleteNurse(\'' + oObj["NurseId"] + '\');">@CaregiverLite.Views.Resources.CareGiver.ButtonDelete</a>'
                                    }
                                    actionhtml += '<a href="javascript:;" class="btn btn-xs btn-primary" onclick="ViewCareGiverProfile(\'' + oObj["NurseId"] + '\');" style="margin-top:5px; width:100%;">@CaregiverLite.Views.Resources.CareGiver.ButtonProfile</a>'
                                    return actionhtml;
                                }
                            },
                            {
                                "sName": "NurseId",
                                "bSortable": false,
                                "mRender": function (oObj) {
                                    var actionhtml = '';
                                    actionhtml += '<a href="javascript:;" class="btn btn-xs btn-primary" style="margin-top:5px; width:100%;" onclick="NurseTrackLocation(\'' + oObj["NurseId"] + '\');">Track Location</a>'
                                    return actionhtml;
                                }
                            },
                            {
                                "sName": "AssignGroup",
                                "bSortable": false,
                                "mRender": function (oObj) {
                                    var actionhtml = '';
									if (oObj["IsApprove"] == true) {
                                    actionhtml += '<a href="javascript:;" class="btn btn-xs btn-primary" style="margin-top:5px; width:100%;" onclick="OpenAssignGroupModal(\'' + oObj["UserId"] + '\' , \'' + oObj["Name"] + '\',\'' + oObj["QuickBloxId"] + '\',\'' + oObj["Email"] + '\');">Assign Patient Chat Room</a>'
									}
                                    return actionhtml;
                                }
                            }
            ]
        });

        $('#myDataTable_filter input').unbind(); //Unbind direct search on each keypress
        $('#myDataTable_filter input').bind('keyup', function (e) { //Bind Keyup event that filter data only on "Enter" key.
            if (e.keyCode == 13) {
                //oTable.fnFilter(this.value);
                oTable.search(this.value).draw();
            }
        });

        //$('#ddFilterStatus').bind('change', function (e) {
        //    oTable.fnFilter('');
        //});
        //$('#ddFilterOffice').bind('change', function (e) {
        //    oTable.fnFilter('');
        //});
        /* Init DataTables */
        $('.carousel').carousel({
            interval: false
        });

        var config = {
            '.chosen-select': {},
            '.chosen-select-deselect': { allow_single_deselect: true },
            '.chosen-select-no-single': { disable_search_threshold: 10 },
            '.chosen-select-no-results': { no_results_text: 'Oops, nothing found!' },
            '.chosen-select-width': { width: "95%" }
        }
        for (var selector in config) {
            $(selector).chosen(config[selector]);
        }

        $("#loading").hide();
    });

    function OpenVideoPopup(URL) {
        $('.loading').show();
        $("#popupvideoid").attr("src", URL);
        $("#myModalVideo").modal('show');
        $('.loading').hide();
    }

    function DeleteNurse(nurseid) {
        if (confirm('@CaregiverLite.Views.Resources.CareGiver.MsgDeleteConfirmation')) {
            $("#loading").show();
            var url = INITURL + '/CareGiver/DeleteNurse';

            $.ajax({
                url: url,
                data: { NurseId: nurseid },
                cache: false,
                type: 'POST',
                async: false,
                success: function (data) {
                    if (data == "Success") {
                        window.location = INITURL + '/CareGiver/CareGiver';
                    }
                    $("#loading").hide();
                },
                error: function (reponse) {
                    alert("error : " + reponse);
                    $("#loading").hide();
                }
            });
        }
    }

    function ViewCareGiverProfile(id) {
        $("#loading").show();
        $('#ViewPanel').load(INITURL + '/CareGiver/ViewCareGiver/' + id, function () {
            $('#myModal1').modal('show');
            sessionStorage.setItem("PartialView", "1");
        });
    }

    function OpenAddNew() {
        $("#loading").show();
        $('#AddCareGiver').load(INITURL + 'CareGiver/AddCareGiver', function () {
            sessionStorage.setItem("PartialView", "1");
            $('#modalAddCareGiver').modal('show');
        });
    }

    function RejectApprovedNurse(nurseid, OfficeId, UserId, QuickBloxId) {

        if (confirm("Are you sure you wants to reject.?")) {
            $("#loading").show();
            var url = INITURL + '/CareGiver/SendApproval';
            var objCareGiver = { NurseId: nurseid, IsApproved: 0, UserId: UserId,OfficeId:OfficeId, QuickBloxId: QuickBloxId }

            $.ajax({
                url: url,
                data: JSON.stringify({ 'CareGiver': objCareGiver }),
                cache: false,
                contentType: 'application/json; charset=utf-8',
                dataType: 'json',
                type: 'POST',
                success: function (data) {
                    if (data.Result == "Success") {
                        window.location = INITURL + "/CareGiver/CareGiver";
                    }
                    else {
                        alert('@CaregiverLite.Views.Resources.CareGiver.MsgError');
                        $("#loading").hide();
                    }
                },
                error: function (reponse) {
                    alert("error : " + reponse);
                    $("#loading").hide();
                }
            });
        }
    }

    function OpenApprovedPopup(username, email, password, nurseid, userid,officeId,quckbloxid, hourrate) {
        $("#loading").show();
        $('#SendApprovePanel').load(INITURL + '/CareGiver/SendApproval', function () {
            sessionStorage.setItem("PartialView", "1");
            $("#apEmail").val(email);
            $("#hdnapNurseId").val(nurseid);
            $("#IsApproved").val(1);
            $("#hdnapUserid").val(userid);
            $("#apHourRate").val(hourrate)
            $("#apHourRate").val(hourrate)
            $("#apHourRate").val(hourrate)

            $("#hdnOfficeId").val(officeId);
            $("#hdnQuickbloxId").val(quckbloxid);
            if (email != username) {
                $("#apUsername").val(username);
                $("#apUsername").attr('readonly', true);
                $("#apPassword").val(password);
                $("#apPassword").attr('readonly', true);
                $("#btnApprove").text('Approve');
            }
            else {
                $("#apUsername").val("");
                $("#apUsername").attr('readonly', false);
                $("#apPassword").attr('readonly', false);
                $("#apPassword").val("");
            }
            $('#modelApproveCareGiver').modal('show');
            $("#loading").hide();
        });
    }


    
    function NurseTrackLocation(nurseid) {
       
        $("#loading").show();
        $('#myModalTrackLocationNurse').modal('show');
        localStorage.setItem("NurseId", nurseid);
        $("#Date").datepicker({
            // minDate: 0,
            dateFormat: 'mm-dd-yy',
            onSelect: function () {
                $(this).change();
            }
        });
        $("#Date").val('');
        $("#dvmap").hide();
        $("#loading").hide();
    }

  
    $('#ViewOnMap').click(function () {
        $("#loading").show();
        var Date = $("#Date").val();
        var NurseID = localStorage.getItem("NurseId");
 
        //   var d = new Date();
        //    var n = d.getTimezoneOffset();
        //     console.log(n);

        //var offset = new Date().getTimezoneOffset();
        //console.log(offset);


        if (Date == "") {
            toastr.error('Please Select Date');
            $('#loading').hide();
            return false;
        }
        console.log(Date);
        console.log(NurseID);

        $.ajax({
            url: "@Url.Action("TrackLocationByNurseId", "CareGiver")",
            data: { NurseId: NurseID, date: Date },
            cache: false,
            dataType: 'json',
            type: 'POST',
            success: function (data, response) {
                console.log(JSON.stringify(data));
                if (data.Result.length > 0) {
                    var trackedLocations = data.Result;
                    TrackLocationMap(trackedLocations)
                }
                else {
                    toastr.warning('No Location Available on this Date');
                    // $('#msg').html('No Location Available on this Date').show();
                }
                //  BindMap(NurseList)

        },
        error: function (xhr, response) {
            console.log(xhr, response);

            $('#loading').hide();
        }
    });
    $("#loading").hide();
    });

    function TrackLocationMap(trackedLocations) {
        setTimeout(function () {
            $("#dvmap").show();
            var gm = google.maps;
            var infowindow;

            var mapCenter = {
                lat: parseFloat(trackedLocations[0].LocationLatitude),
                lng: parseFloat(trackedLocations[0].LocationLongitude)
            }

            var myOptions =
            {
                zoom: 16,
                center: mapCenter,
                mapTypeId: google.maps.MapTypeId.ROADMAP
            };
            var map = new google.maps.Map(document.getElementById("dvmap"), myOptions);
            var iw = new gm.InfoWindow();

            //var  map = new google.maps.Map(document.getElementById('dvMap'),
            // {
            //     center: mapCenter,
            //     zoom: 18,
            //     mapTypeId: google.maps.MapTypeId.HYBRID
            // });

            // var bounds = new google.maps.LatLngBounds();
            if (trackedLocations != null && trackedLocations.length > 0) {


                // when only one marker
