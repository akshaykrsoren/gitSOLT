                                        infowindowDes.open(map, markerDes);

                                    };
                                })(markerDes, contentDes, infowindowDes));

                            map.fitBounds(bounds);
                        }

                    }
                }



            }
        }, 500);
    }

    function OpenAssignGroupModal(userid,name,quickbloxid,email) {        
        $("#loading").show();
        var url = INITURL + 'CareGiver/AssignGroup?UserId=' + userid + '&CaregiverName=' + name + '&QuickBloxId=' + quickbloxid + '&Email='+email;
        $('#AssignGroupToCaregiver').load(encodeURI(url), function () {
            sessionStorage.setItem("PartialView", "1");
            $('#modalGroupAssignment').modal('show');
            $("#loading").hide();
        });
    }

