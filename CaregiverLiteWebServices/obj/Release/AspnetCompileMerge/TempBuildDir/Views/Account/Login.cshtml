@model CaregiverLite.Models.LoginModel
@{
    ViewBag.Title = @CaregiverLite.Views.Resources.Account.TitleLogin;
    Layout = "~/Views/shared/_LoginLayout.cshtml";
}
<style>
    span.field-validation-error {
    color: red;
    display: block;
    text-align: right;
     float: none;
}
    </style>

<div style="background:rgba(0,0,0,0.5); height:100vh;">
    <div>
        <div class="middle-box text-center loginscreen  animated fadeInDown">
            <div style="background:#f5f5f5;padding:0 10px;border-radius:10px;">
                <h1 class="logo-name">@CaregiverLite.Views.Resources.Account.TitleLogin</h1>
                @using (Html.BeginForm(new { ReturnUrl = ViewBag.ReturnUrl }))
                {
                    @Html.AntiForgeryToken()
                    @Html.ValidationSummary(true)
                    <div class="form-group">
                        <span id="spError" style="color:green"></span>
                        <span id="LoginError" style="color:red"></span>
                    </div>
                    <div class="form-group">
                        @Html.ValidationMessageFor(model => model.UserName)
                        @Html.TextBoxFor(model => model.UserName, new { @type = "text", @required = "required", @class = "form-control", @placeholder = @CaregiverLite.Views.Resources.Account.PlaceHolderUserID })
                    </div>
                    <div class="form-group">
                        @Html.ValidationMessageFor(model => model.Password)
                        @Html.TextBoxFor(model => model.Password, new { @type = "password", @required = "required", @class = "form-control", @placeholder = @CaregiverLite.Views.Resources.Account.PlaceHolderPassword })
                    </div>
                    <button type="submit" class="btn btn-primary block full-width m-b">
                        @CaregiverLite.Views.Resources.Account.ButtonLogIn
                    </button>
                    @*<a href="~/Account/Register">@CaregiverLite.Views.Resources.Account.ButtonRegister</a> <span>|</span> *@<a href="~/Account/ForgotPassword">@CaregiverLite.Views.Resources.Account.ButtonForgotPassword</a>
                }
                <p class="m-t" style="padding-bottom:10px;">@CaregiverLite.Views.Resources.Layout.FooterCopyright</p>
            </div>
            <div class="clearfix"></div>
        </div>
    </div>
</div>
<script>
    $(document).ready(function () {
        localStorage.clear();
       
        var tempMsg = '@TempData["message_login"]';
        if (tempMsg != "") {
            if ('@TempData["LoginError"]' == "true") {
                $("#LoginError").html(tempMsg);
            }
            else {
                $("#spError").html(tempMsg);
            }            
        }
        else {
            $("#spError").html("");
        }
    });
</script>