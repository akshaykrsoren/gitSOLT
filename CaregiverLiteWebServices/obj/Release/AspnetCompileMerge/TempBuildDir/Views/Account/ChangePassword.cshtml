@model CaregiverLite.Models.CareGiverModel
@{
    ViewBag.Title = "ChangePassword";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<style>
    span.field-validation-error {
  color: red;
  float: right;
}
</style>
@using (Html.BeginForm("ChangePassword", "Account", FormMethod.Post, new { @id = "fmChangePassword", @class = "horizontal-form", @enctype = "multipart/form-data", @autocomplete = "off" }))
    {
<div class="wrapper wrapper-content animated fadeInRight">
    <div class="row">
        <div class="col-lg-4 col-lg-offset-4">
            <div class="ibox float-e-margins">
                <div class="ibox-content">
                    
                    <div class="form-group">
                        <label>@CaregiverLite.Views.Resources.Account.TitleOldPassword</label>
                        @Html.ValidationMessageFor(model => model.OldPassword)
                        <input type="password" style="display:none" />
                        @Html.TextBoxFor(model => model.OldPassword, new { @type = "password", @maxlength = "256", @placeholder = @CaregiverLite.Views.Resources.Account.PlaceHolderOldPassword, @class = "form-control" })
                    </div>

                    <div class="form-group">
                        <label>@CaregiverLite.Views.Resources.Account.NewPassword</label>
                        @Html.ValidationMessageFor(model => model.NewPassword)
                        <input type="password" style="display:none" />
                        @Html.TextBoxFor(model => model.NewPassword, new { @type = "password", @maxlength = "256", @placeholder = @CaregiverLite.Views.Resources.Account.PlaceHolderNewPassword, @class = "form-control" })
                    </div>
                    <div class="form-group">
                        <label>@CaregiverLite.Views.Resources.Account.ReTypePassword</label>                      
                        @Html.ValidationMessageFor(model => model.RetypeNewPassword)
                        <input type="password" style="display:none" />
                        @Html.TextBoxFor(model => model.RetypeNewPassword, new { @type = "password", @maxlength = "256", @placeholder = @CaregiverLite.Views.Resources.Account.PlaceHolderReTypePassword, @class = "form-control" })
                    </div>
                    <div>
                        <span id="errormsg">@ViewBag.Message</span>
                       
                        <button type="button" onclick="ChangePassword()" class="btn btn-sm btn-primary pull-right">@CaregiverLite.Views.Resources.Account.ButtonUpdate</button>
                    </div>
                    <div class="clearfix"></div>
                </div>
            </div>
        </div>
    </div>
</div>
}
<script src="~/Scripts/js/jquery-2.1.1.js"></script>

<script src="~/Scripts/js/jquery.validate.min.js"></script>
<script src="~/Scripts/js/jquery.validate.unobtrusive.min.js"></script>

<script>
    var tempMsg = '@TempData["message"]';
    if (tempMsg != "")
        toastr.success(tempMsg);
    $jq = jQuery.noConflict();
    function ChangePassword() {
        var selectedValues = "";

        $jq("#ddlEditService :selected").each(function () {
            selectedValues += $(this).val() + ",";
        });

        $jq("#hdnEditServices").val(selectedValues);

        $jq("#fmChangePassword").submit();

        //if ($jq('#OldPassword').val() !='' && $jq('#NewPassword').val()!= '') {
        //    if ($jq('#OldPassword').val() == $jq('#NewPassword').val()) {

        //        $jq('#errormsg').html("New and old password must be different");

        //    }
        //    else {
               
        //    }

           
        //}
       
        // $jq("#fmChangePassword").submit();

       
        
    }
</script>