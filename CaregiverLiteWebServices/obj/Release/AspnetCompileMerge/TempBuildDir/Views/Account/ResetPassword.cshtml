@model CaregiverLite.Models.ForgotPassword
@{
    ViewBag.Title = @CaregiverLite.Views.Resources.Account.TitleResetPassword;
    Layout = "~/Views/shared/_LoginLayout.cshtml";
}
<style>
    .logo-name {
        color: #088BCA;
        font-weight: 100;
        letter-spacing: 0px;
        font-family: 'Open Sans', sans-serif;
        margin-bottom: 40px;
        margin-top: 150px;
        text-align: center;
        padding-top: 20px;
    }
</style>
<div style="background:rgba(0,0,0,0.5); height:100vh;">
    <div class="middle-box text-center loginscreen  animated fadeInDown">
        <div style="background:#f5f5f5;padding:0 10px;border-radius:10px;">
            <h1 class="logo-name">@CaregiverLite.Views.Resources.Account.TitleLogin</h1>
            @using (Html.BeginForm("ResetPassword", "Account", FormMethod.Post, new { @id = "fmResetPassword", @class = "horizontal-form", @enctype = "multipart/form-data" }))
            {
                <div class="form-group">
                    <span id="spError" style="color:red"></span>
                </div>
                @Html.HiddenFor(model => model.Email)
                <div class="form-group">
                    @Html.ValidationMessageFor(model => model.NewPassword)
                    @Html.TextBoxFor(model => model.NewPassword, new { @type = "password", @class = "form-control", @placeholder = @CaregiverLite.Views.Resources.Account.PlaceHolderNewPassword })
                </div>
                <div class="form-group">
                    @Html.ValidationMessageFor(model => model.ConfirmPassword)
                    @Html.TextBoxFor(model => model.ConfirmPassword, new { @type = "password", @class = "form-control", @placeholder = @CaregiverLite.Views.Resources.Account.PlaceHolderReTypePassword })
                </div>
                <button type="button" onclick="submitform();" class="btn btn-primary block full-width m-b">@CaregiverLite.Views.Resources.Account.ButtonSubmit</button>
                <a href="~/Account/Login">@CaregiverLite.Views.Resources.Account.ButtonLogIn</a>
            }
            <p class="m-t" style="padding-bottom:10px;">@CaregiverLite.Views.Resources.Layout.FooterCopyright</p>
        </div>
        <div class="clearfix"></div>
    </div>
</div>
<script>
    $(document).ready(function () {
        var tempMsg = '@TempData["message"]';
        if (tempMsg != "") {
            $("#spError").html(tempMsg);
        }
        else {
            $("#spError").html("");
        }
    });

    function submitform() {
        $("#fmResetPassword").submit();
    }
</script>