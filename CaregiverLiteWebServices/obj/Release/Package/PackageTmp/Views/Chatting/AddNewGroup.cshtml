        if (IsGroupNameSubjectExist == true) {
            debugger;
     
            toastr.error("Group already exists with same name and subject line, please use different name or subject line.");
            $('#loading').hide();
        }

        if (GroupName == "") {
            toastr.error('Please Enter Group Name');
            $('#GroupName').focus();
            $('#loading').hide();
            return false;
        }
        else if (GroupSubject == "") {
            toastr.error('Please Enter Subject Name');
            $('#GroupSubject').focus();
            $('#loading').hide();
            return false;
        }
        else if (OfficeId == "") {
            toastr.error('Please Select Office');
            $('#OfficeId').focus();
            $('#loading').hide();
            return false;
        }


        var url = INITURL + '/Chatting/GetAllMemberByOffice';
        $.ajax({
            url: url,
            cache: false,
            type: 'POST',
            data: {
                OfficeId: OfficeId,
            },
            async: true,
            success: function (data) {
                //debugger;
                $('#loading').hide();
                if (data.result == "Success") {

                    loadMemberList(data.objGroupMemberDetailListing);

                    $("#main_div").css('display', 'none');
                    $("#main_div2").css('display', 'block');
                }
            },
            error: function (reponse) {
                $('#loading').hide();
            }
        });



        //$("#main_div").css('display', 'none');
        //$("#main_div2").css('display', 'block');


        $('#loading').hide();
    }

    function gotoAddScreen1() {
        $("#main_div2").css('display', 'none');
        $("#main_div").css('display', 'block');

    }


    function loadMemberList(lstMember) {

        //debugger;
        $('#ddlMember').empty();
        if (lstMember.length > 0) {
            $.each(lstMember, function (key, value) {
                $('#ddlMember').append("<option value=" + value.UserId + " qbid=" + value.QuickBloxId + "email=" + value.Email + ">" + value.MemberName + "</option>");
            });
        }
        $('#ddlMember').trigger("chosen:updated");
        $('#loading').hide();
    }

    function CreateNewGroup() {
