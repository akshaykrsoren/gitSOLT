    function Next() {
        //debugger;
        $('#loading').show();

        var GroupName = $("#GroupName").val().trim();

        var GroupSubject = $("#GroupSubject").val().trim();

        var OfficeId = $("#OfficeId").val();

       // var t = IsGroupNameAndSubjectExist();

        debugger;
