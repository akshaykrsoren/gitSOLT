@model CaregiverLite.Models.NurseCoordinatorModel


<div id="main_div">
    @using (Html.BeginForm("AddNurseCoordinator", "NurseCoordinator", FormMethod.Post, new { @id = "fmAddNurseCoordinator", @class = "horizontal-form", @enctype = "multipart/form-data" }))
    {

        <div class="alert alert-danger alert-dismissable" style="display:none" id="dvError3">
            <button onclick="divClose();" class="close" type="button">×</button>
            <label id="lblError3"></label>
        </div>

        <div class="col-md-12">

            <div class="form-group">
                <label>First Name</label>
                <span style="color:red;">*</span>
                @Html.ValidationMessageFor(model => model.FirstName)
                @Html.TextBoxFor(model => model.FirstName, new { @type = "text", @maxlength = "100", @placeholder = "", @class = "form-control" })
            </div>

            <div class="form-group">
                <label>Last Name</label>
                <span style="color:red;">*</span>
                @Html.ValidationMessageFor(model => model.LastName)
                @Html.TextBoxFor(model => model.LastName, new { @type = "text", @maxlength = "100", @placeholder = "", @class = "form-control" })
            </div>

            <div class="form-group">
                <label>Email</label>
                <span style="color:red;">*</span>
                @Html.ValidationMessageFor(model => model.Email)
                @Html.TextBoxFor(model => model.Email, new { @type = "email", @maxlength = "100", @placeholder = "Example@Paseva.com", @class = "form-control" })
            </div>


            <div class="form-group">
                <label>UserName</label>
                <span style="color:red;">*</span>
                @Html.ValidationMessageFor(model => model.Username)
                @Html.TextBoxFor(model => model.Username, new { @type = "text", @maxlength = "256", @placeholder = "", @class = "form-control" })
            </div>

            <div class="form-group">
                <label>Password</label>
                <span style="color:red;">*</span>
                @Html.ValidationMessageFor(model => model.Password)
                @Html.PasswordFor(model => model.Password, new { @autocomplete = "new-password", @type = "password", @maxlength = "256", @placeholder = "", @class = "form-control" })
                <span style="position: absolute; right: 16px;height: 40px;">
                    <i class="fa fa-eye btn btn-link" id="HidePassword" style="position: relative; top: -30px;display:none" aria-hidden="true"></i>
                    <i class="fa fa-eye-slash btn btn-link" id="showPassword" style="position: relative; top: -30px;" aria-hidden="true"></i>
                </span>
            </div>
           
            @*Office*@
            <div class="form-group">
                <label>Office</label>
                <span style="color:red;">*</span>
                @*@Html.ValidationMessageFor(model => Model.OfficeId)
                @Html.DropDownList("OfficeId", (System.Web.Mvc.SelectList)ViewBag.lstOffice, "Select Office", new { @class = "form-control" })*@
             
                @Html.ValidationMessageFor(model => model.OfficeId)
                @Html.DropDownListFor(model => model.OfficeId, Model.OfficeSelectList, "Select...", new { @class = "form-control"})
            </div>
            @*IsAllowForPatientChatRoom*@
            <div class="form-group">
                <label>Allow For Patient Chat Room</label>
                <br>
                @Html.CheckBoxFor(model => model.IsAllowForPatientChatRoom, new
           {  @*@maxlength = "100", @placeholder = "Example@Paseva.com", @class = "form-control"*@ @style = "transform: scale(1.5); margin-left: 10px;"
                })
            </div>

            <div class="form-group">
                <label>Job Title</label>
                @Html.ValidationMessageFor(model => model.JobTitle)
                @Html.TextBoxFor(model => model.JobTitle, new { @type = "text", @maxlength = "100", @placeholder = "", @class = "form-control" })
            </div>
        </div>



        <div class="col-md-12">
            <button type="button" onclick="Addnew()" class="btn btn-sm btn-primary pull-right">@CaregiverLite.Views.Resources.PatientRequest.ButtonAddNew</button>
            <div class="clearfix"></div>
        </div>
    }
</div>

<link rel="stylesheet" href="https://code.jquery.com/ui/1.12.1/themes/base/jquery-ui.css">
<script type="text/javascript">

    //$(document).ready(function () {
     

