    function Addnew() {
        //debugger;

       // var Name = $("#Name").val();
        var FirstName = $("#FirstName").val();
        var LastName = $("#LastName").val();
        var Email = $("#Email").val();
        var UserName = $("#Username").val();
        var Password = $("#Password").val();
        var OfficeId = $("#OfficeId").val();

       
        if (FirstName == "" && LastName == "" && Email == "" && UserName == "" && Password == "") {
            toastr.error('Please fill all required fields');
            $('#FirstName').focus();
            $('#loading').hide();
            return false;
        }
        else if (FirstName == "") {
            toastr.error('Please Enter Director First Name');
            $('#FirstName').focus();
            $('#loading').hide();
            return false;
        }
        else if (LastName == "") {
            toastr.error('Please Enter Director Last Name');
            $('#LastName').focus();
            $('#loading').hide();
            return false;
        }
        else if (Email == "") {
            toastr.error('Please Enter Email');
            $('#Email').focus();
            $('#loading').hide();
            return false;
        }
        else if (UserName == "") {
            toastr.error('Please Enter UserName');
            $('#Username').focus();
            $('#loading').hide();
            return false;
        }
        else if (Password == "") {
            toastr.error('Please Enter Password');
            $('#Password').focus();
            $('#loading').hide();
            return false;
        }
        else if (OfficeId == "") {
            toastr.error('Please Select Office');
            $('#OfficeId').focus();
            $('#loading').hide();
            return false;
        }



        var result = CheckUserName();
        if (result == false) {
            $("#dvError3").css("display", "");
            $("#lblError3").html("User Name already exists");
            $('#loading').hide();
            return false;
        }

        var result1 = CheckEmail();
        if (result1 == false) {
            $("#dvError3").css("display", "");
            $("#lblError3").html("Email already exists");
            $('#loading').hide();
            return false;
        }


        $("#dvError3").hide();

        if ($("#fmAddNurseCoordinator").valid()) {
            $('#loading').show();
          //  RegisterNurseCoordinator(Email);
            $("#fmAddNurseCoordinator").submit();



        }
        else {
            $('#loading').hide();
        }
    }


    function CheckUserName() {
        var url = INITURL + '/NurseCoordinator/IsUserNameExists';
        var result;
        $.ajax({
            url: url,
            data: { Username: $("#Username").val(), UserId: $("#UserId").val() },
            cache: false,
            async: false,
            type: 'POST',
            success: function (data) {
                result = data;
            },
            error: function (reponse) {
                alert("error : " + reponse);
            }
        });
        return result;
    }

    function CheckEmail() {
        var url = INITURL + '/NurseCoordinator/IsEmailExists';
        var result;
        $.ajax({
            url: url,
            data: { Email: $("#Email").val(), UserId: $("#UserId").val() },
            cache: false,
            async: false,
            type: 'POST',
            success: function (data) {
                result = data;
            },
            error: function (reponse) {
                alert("error : " + reponse);
            }
        });
        return result;
    }

