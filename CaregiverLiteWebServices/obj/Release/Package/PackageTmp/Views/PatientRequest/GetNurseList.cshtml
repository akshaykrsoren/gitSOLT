
<div class="row">
    <div class="col-md-12">
        <table id="myDataTable" class="table table-striped table-hover">
            <thead>
                <tr>                   
                    <th>@CaregiverLite.Views.Resources.CareGiver.TableHeaderName</th>
                    <th>@CaregiverLite.Views.Resources.CareGiver.TableHeaderPhoto</th>                                      
                    <th>@CaregiverLite.Views.Resources.CareGiver.TableHeaderEmail</th>
                    <th>@CaregiverLite.Views.Resources.CareGiver.TableHeaderAddress</th>
                    <th>@CaregiverLite.Views.Resources.CareGiver.TableHeaderZipCode</th>
                    <th>@CaregiverLite.Views.Resources.CareGiver.TableHeaderPhone</th>                                  
                </tr>
            </thead>
            <tbody>
                @foreach (CaregiverLiteWCF.CareGivers item in @ViewBag.CareGiverList)
                {
                    <tr>
                        <td>@item.Name</td>
                        <td><img height="80" width="80" src="@item.ProfileImage" /></td>                      
                        <td>@item.Email</td>
                        <td>@item.Address</td>
                        <td>@item.ZipCode</td>
                        <td>@item.Phone</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    <div class="clearfix"></div>
</div>
