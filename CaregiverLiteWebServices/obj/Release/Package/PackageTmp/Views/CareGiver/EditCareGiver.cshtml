@model CaregiverLite.Models.CareGiverModel

<div id="main_div">
    @using (Html.BeginForm("EditCareGiver", "CareGiver", FormMethod.Post, new { @id = "fmEditCareGiver", @class = "horizontal-form", @enctype = "multipart/form-data" }))
    {
        <div class="alert alert-danger alert-dismissable" style="display:none" id="dvError2">
            <button onclick="divClose();" class="close" type="button">×</button>
            <label id="lblError2"></label>
        </div>
        <div class="col-md-6">
            @Html.HiddenFor(model => model.NurseId)
            @Html.HiddenFor(model => model.UserId)
            @Html.HiddenFor(model => model.OldOfficeId)
            @Html.HiddenFor(model => model.QuickBloxId)
            @Html.HiddenFor(model => model.ChargeToPatient, new { @id = "hdnChargeToPatient" })
            @Html.HiddenFor(model => model.ServiceNames, new { @id = "hdnServices" })
            <div class="form-group">
                <label>@CaregiverLite.Views.Resources.CareGiver.TableHeaderName</label>
                @Html.ValidationMessageFor(model => model.Name)
                @Html.TextBoxFor(model => model.Name, new { @type = "text", @maxlength = "100", @placeholder = @CaregiverLite.Views.Resources.CareGiver.PlaceHolderName, @class = "form-control" })
            </div>
            <div class="form-group">
                <label>@CaregiverLite.Views.Resources.CareGiver.LabelHeaderServices</label>
                @Html.ValidationMessageFor(model => model.ServiceNames)
                <div class="form-group">
                    @Html.DropDownList("ddlEditService", new MultiSelectList(@ViewBag.ServiceList, "ServiceId", "ServiceName"), new { @multiple = "multiple", @class = "chosen-select" })
                    @Html.HiddenFor(model => model.ServiceNames, new { @id = "hdnEditServices" })
                </div>
            </div>
            <div class="form-group">
                <label>@CaregiverLite.Views.Resources.CareGiver.TableHeaderEmail</label>
                @Html.ValidationMessageFor(model => model.Email)
                @Html.TextBoxFor(model => model.Email, new { @type = "email", @maxlength = "100", @placeholder = @CaregiverLite.Views.Resources.CareGiver.PlaceHolderEmail, @class = "form-control", @readonly = "readonly" })
            </div>
            <div class="form-group">
                <label>@CaregiverLite.Views.Resources.CareGiver.TableHeaderUserName</label>
                @Html.ValidationMessageFor(model => model.Username)
                @Html.TextBoxFor(model => model.Username, new { @id = "txtUsername", @maxlength = "256", @placeholder = @CaregiverLite.Views.Resources.CareGiver.PlaceHolderUserName, @class = "form-control", @readonly = "readonly" })
            </div>
            <div class="form-group">
                <label>@CaregiverLite.Views.Resources.CareGiver.TableHeaderStreet</label>
                @Html.ValidationMessageFor(model => model.Street)
                @Html.TextBoxFor(model => model.Street, new { @id = "txtStreet",  @type = "text", @placeholder = @CaregiverLite.Views.Resources.CareGiver.PlaceHolderStreet, @class = "form-control" })
            </div>
            <div class="form-group">
                <label>@CaregiverLite.Views.Resources.CareGiver.TableHeaderCity</label>
                @Html.ValidationMessageFor(model => model.City)
                @Html.TextBoxFor(model => model.City, new {  @id = "txtCity", @type = "text", @placeholder = @CaregiverLite.Views.Resources.CareGiver.PlaceHolderCity, @class = "form-control" })
            </div>
            <div class="form-group">
                <label>@CaregiverLite.Views.Resources.CareGiver.TableHeaderState</label>
                @Html.ValidationMessageFor(model => model.State)
                @Html.TextBoxFor(model => model.State, new { @id = "txtState", @type = "text", @placeholder = @CaregiverLite.Views.Resources.CareGiver.PlaceHolderState, @class = "form-control" })
            </div>
            <div class="form-group">
                <label>@CaregiverLite.Views.Resources.CareGiver.TableHeaderZipCode</label>
                @Html.ValidationMessageFor(model => model.ZipCode)
                @Html.TextBoxFor(model => model.ZipCode, new { @id = "txtZipCode", @type = "text", @maxlength = "10", @placeholder = @CaregiverLite.Views.Resources.CareGiver.PlaceHolderZipCode, @class = "form-control" })
            </div>
            <div class="form-group">
                <label>@CaregiverLite.Views.Resources.CareGiver.TableHeaderEducation</label>
                @Html.ValidationMessageFor(model => model.Education)
                @Html.TextBoxFor(model => model.Education, new { @type = "text", @placeholder = @CaregiverLite.Views.Resources.CareGiver.PlaceHolderEducation, @class = "form-control" })
            </div>
            <div class="form-group">
                <label class="control-label">@CaregiverLite.Views.Resources.CareGiver.LabelHeaderServiceRadius</label>
                @Html.ValidationMessageFor(model => model.ServiceRadius)
                <div style="padding:7px 0;" id="radiobutton">
                    @Html.DropDownList("ServiceRadius", ViewData["Radious"] as List<SelectListItem>, "Select service radius", new { @class = "form-control" })
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="form-group">
                <label for="exampleInputFile">@CaregiverLite.Views.Resources.CareGiver.LabelPhotoUpload</label>
                @Html.ValidationMessageFor(model => model.ProfileImage)
                @Html.HiddenFor(model => model.ProfileImage)
                <img src="@Model.ProfileImage" id="ImgProfileImage" width="270" style="margin-bottom:10px" />
                @Html.TextBoxFor(model => model.ProfileImageFile, new { @type = "file", @onchange = "readURL5(this);", @class = "form-control", @accept = "image/*", @id = "EditProfileImageFile", @name = "EditProfileImageFile" })

                @*<input type="file" name="ProfileImageFile" id="ProfileImageFile" /><br><br>*@
            </div>
            <div class="form-group">
                <label for="exampleInputFile">Video Upload</label>
                @Html.ValidationMessageFor(model => model.ProfileVideo)
                @Html.HiddenFor(model => model.ProfileVideo)
                @Html.TextBoxFor(model => model.ProfileVideoFile, new { @type = "file", @class = "form-control file_div", @accept = "video/*", @id = "EditProfileImageFile" })
            </div>
            @*<div class="form-group">
                <label>@CaregiverLite.Views.Resources.CareGiver.TableHeaderHourRate</label>
                @Html.ValidationMessageFor(model => model.HoursRate)
                <div class="input-group">
                    <span class="input-group-addon">$</span>
                    @Html.TextBoxFor(model => model.HoursRate, new { @type = "text", @maxlength = "6", @onkeypress = "return isNumberAndDot(event)", @placeholder = @CaregiverLite.Views.Resources.CareGiver.PlaceHolderHourRate, @class = "form-control" })
                </div>
            </div>
            <div class="form-group">
                <label>To be charged to patient</label>
                @Html.ValidationMessageFor(model => model.ChargeToPatient)
                <div class="input-group" style="width: 100%; ">
                    <span class="input-group-addon">$</span>
                    @Html.TextBoxFor(model => model.ChargeToPatient, new { @type = "text", @maxlength = "6", @onkeypress = "return isNumberAndDot(event)", @placeholder = "Enter To be charged to patient", @class = "form-control" })
                </div>
            </div>*@
            <div class="form-group">
                <label>@CaregiverLite.Views.Resources.CareGiver.TableHeaderPhone</label>
                @Html.ValidationMessageFor(model => model.Phone)
                @Html.TextBoxFor(model => model.Phone, new { @type = "text", @maxlength = "100", @onkeypress = "return isNumber(event)", @placeholder = @CaregiverLite.Views.Resources.CareGiver.PlaceHolderPhone, @class = "form-control" })
            </div>
            <div class="form-group">
                <label>@CaregiverLite.Views.Resources.CareGiver.TableHeaderPassword</label>
                @Html.ValidationMessageFor(model => model.Password)
                @Html.HiddenFor(model => model.Latitude, new { @id = "hdnLatitude" })
                @Html.HiddenFor(model => model.Longitude, new { @id = "hdnLongitude" })
                @Html.HiddenFor(model => model.Address, new { @id = "hdnAddress" })
                @Html.TextBoxFor(model => model.Password, new { @type = "password", @maxlength = "256", @placeholder = @CaregiverLite.Views.Resources.CareGiver.PlaceHolderPassword, @class = "form-control" })
            </div>

            <div class="form-group">
                <label class="control-label">Office</label>
                <span style="color:red;">*</span>
                @Html.ValidationMessageFor(model => Model.OfficeId)
                @*@Html.DropDownList("OfficeId", (SelectList)ViewBag.OfficeDropDownList, "Select Office", new { @class = "form-control" })*@
                @Html.DropDownList("OfficeId", (System.Web.Mvc.SelectList)ViewBag.lstOffice, "Select Office",new { @class = "form-control" })
            </div>

        </div>
        <div class="col-md-12">
            @*@if (Model.CanAdminEdit == true)
            {
                <span>Permission granted by Caregiver to edit schedule.</span>
            }
            else
            {
                <span>Permission not granted by Caregiver to edit schedule.</span>
            }*@
            <button type="button" onclick="EditNurse()" class="btn btn-sm btn-primary pull-right">@CaregiverLite.Views.Resources.CareGiver.ButtonSaveChanges</button>
            <div class="clearfix"></div>
        </div>


    }
</div>
<script src="~/Scripts/jquery.unobtrusive-ajax.js"></script>
<script type="text/javascript">


    $(document).ready(function () {        
        $("#loading").show();
        var form = $("#fmEditCareGiver").closest("form");
        form.removeData('validator');
        form.removeData('unobtrusiveValidation');
        $.validator.unobtrusive.parse(form);

        var selectedValues = new Array();
        selectedValues = '@Model.Services'.trim().split(',')
        $("#ddlEditService").val(selectedValues);


        var config = {
            '.chosen-select': {},
            '.chosen-select-deselect': { allow_single_deselect: true },
            '.chosen-select-no-single': { disable_search_threshold: 10 },
            '.chosen-select-no-results': { no_results_text: 'Oops, nothing found!' },
            '.chosen-select-width': { width: "95%" }
        }
        for (var selector in config) {
            $(selector).chosen(config[selector]);

        }
        $("#loading").hide();
    });

    $(":radio").click(function (event) {
        $("#radiobutton").css("padding", "7px 0px");
    });

    $.validator.setDefaults({
        ignore: [],
    });

    $("#ddlEditService").change(function () {
        var selectedValues = "";

        $("#ddlEditService :selected").each(function () {
            selectedValues += $(this).val() + ",";
        });

        $("#hdnEditServices").val(selectedValues);
    });

    function EditNurse() {
        $('#loading').show();
        var selectedValues = "";

        $("#ddlEditService :selected").each(function () {
            selectedValues += $(this).val() + ",";
        });

        $("#hdnEditServices").val(selectedValues);
        if (!GetLanLat()) {
            $('#loading').hide();
            return false
        }

        var result = CheckUserName();
        if (result == false) {
            $("#dvError2").css("display", "");
            $("#lblError2").html("User Name is already exists");
            $('#loading').hide();
            return false;
        }

        var result1 = CheckEmail();
        if (result1 == false) {
            $("#dvError2").css("display", "");
            $("#lblError2").html("Email is already exists");
            $('#loading').hide();
            return false;
        }
        if ($(".radio-inline").find(":checked").val() == undefined) {
            $("#radiobutton").css("padding", "20px 0px");
        }
        else {
            $("#radiobutton").css("padding", "7px 0px");
        }        

        var Address = $("#hdnAddress").val();
        var Pincode = $("#txtZipCode").val();

        var Street = $("#txtStreet").val();
        Street = Street.replace(/,\s*$/, "");

        var City = $("#txtCity").val();
        City = City.replace(/,\s*$/, "");

        var State = $("#txtState").val();
        State = State.replace(/,\s*$/, "");

        if ($('#fmEditCareGiver').valid()) {

            var data = new FormData();

            var files = $("#EditProfileImageFile").get(0).files;

            // Add the uploaded image content to the form data collection
            if (files.length > 0) {
                data.append("UploadedImage", files[0]);
            }            
            var objCareGiverModel = {
                UserId: $("#UserId").val(),
                NurseId: $("#NurseId").val(),
                Username: $("#txtUsername").val(),
                Name: $("#Name").val(),
                Email: $("#Email").val(),
                ServiceNames: $("#hdnEditServices").val(),
                HoursRate: $("#HoursRate").val(),
                ServiceRadius: $("#ServiceRadius").val(),
                Phone: $("#Phone").val(),
                Address: Address,
                Street: Street,
                City: City,
                State: State,
                ZipCode: Pincode,
                ProfileImage: $("#ProfileImage").val(),
                Latitude: $("#hdnLatitude").val(),
                Longitude: $("#hdnLongitude").val(),
                Password: $("#Password").val(),
                ChargeToPatient: $("#ChargeToPatient").val(),
                Education: $("#Education").val(),
                OfficeId: $("#OfficeId").val(),
                OldOfficeId: $("#OldOfficeId").val(),
                QuickBloxId: $("#QuickBloxId").val()
            }
            data.append("ObjCareGiver", JSON.stringify({ 'CareGiverModelDetail': objCareGiverModel }));
            var url = INITURL + '/CareGiver/EditCareGiver';

            $.ajax({
                url: url,
                type: "POST",
                processData: false,
                contentType: false,
                data: data,
                //data: JSON.stringify({ 'objCareGiverModel': objCareGiverModel }),
                //cache: false,
                //contentType: 'application/json; charset=utf-8; multipart/form-data;',
                //dataType: 'json',
                //type: 'POST',
                success: function (data) {
                    if (data.Result == "Success") {
                        window.location = INITURL + "/CareGiver/CareGiver";
                    }
                    else {
                        $("#dvError2").css("display", "");
                        $("#lblError2").html(data.Result);
                    }
                    $('#loading').hide();
                },
                error: function (reponse) {
                    $('#loading').hide();
                    alert("error : " + JSON.stringify(reponse));
                }
            });

        }
        else {
            $('#loading').hide();
        }

    }

    function isNumber(evt) {
        evt = (evt) ? evt : window.event;
        var charCode = (evt.which) ? evt.which : evt.keyCode;
        if (charCode > 31 && (charCode < 48 || charCode > 57)) {
            return false;
        }
        return true;
    }

    function isNumberAndDot(evt) {
        evt = (evt) ? evt : window.event;
        var charCode = (evt.which) ? evt.which : evt.keyCode;
        if (charCode > 31 && (charCode < 48 || charCode > 57) && charCode != 46) {
            return false;
        }
        return true;
    }


