    function divClose() {
        $("#dvError2").css("display", "none");
    }

    function CheckUserName() {
        var url = INITURL + '/CareGiver/IsUserNameExists';
        var result;
        $.ajax({
            url: url,
            data: { Username: $("#Username").val(), UserId: $("#UserId").val() },
            cache: false,
            async: false,
            type: 'POST',
            success: function (data) {
                result = data;
            },
            error: function (reponse) {
                alert("error : " + reponse);
            }
        });
        return result;
    }

    function CheckEmail() {
        var url = INITURL + '/CareGiver/IsEmailExists';
        var result;
        $.ajax({
            url: url,
            data: { Email: $("#Email").val(), UserId: $("#UserId").val() },
            cache: false,
            async: false,
            type: 'POST',
            success: function (data) {
                result = data;
            },
            error: function (reponse) {
                alert("error : " + reponse);
            }
        });
        return result;
    }

    function readURL5(input) {

        if (input.files && input.files[0]) {
            var reader = new FileReader();

            reader.onload = function (e) {
                $('#divImg').html("<img id='editImg' src='" + e.target.result + "'>");

                $("#ImgProfileImage").attr("src", e.target.result);
            };

            reader.readAsDataURL(input.files[0]);
        }
    }

    function dataURItoBlob(dataURI) {
        // convert base64/URLEncoded data component to raw binary data held in a string
        var byteString;
        if (dataURI.split(',')[0].indexOf('base64') >= 0)
            byteString = atob(dataURI.split(',')[1]);
        else
            byteString = unescape(dataURI.split(',')[1]);

        // separate out the mime component
        var mimeString = dataURI.split(',')[0].split(':')[1].split(';')[0];

        // write the bytes of the string to a typed array
        var ia = new Uint8Array(byteString.length);
        for (var i = 0; i < byteString.length; i++) {
            ia[i] = byteString.charCodeAt(i);
        }

        return new Blob([ia], { type: mimeString });
    }


</script>
