@model CaregiverLite.Models.CareGiverModel
<style>
    .clsDatePicker {
        z-index: 100000;
    }

    #ui-datepicker-div {
        z-index: 1003;
    }

    .field-validation-error {
        color: red;
        float: right;
    }
</style>
<div id="main_div">
    @using (Html.BeginForm("AddCareGiver", "CareGiver", FormMethod.Post, new { @id = "fmAddCareGiver", @class = "horizontal-form", @enctype = "multipart/form-data", @autocomplete = "off" }))
    {
        <div class="alert alert-danger alert-dismissable" style="display:none" id="dvError3">
            <button onclick="divClose();" class="close" type="button">×</button>
            <label id="lblError3"></label>
        </div>
        <div class="col-md-6">
            @Html.HiddenFor(model => model.HoursRate, new { @id = "hdnHoursRate" })
            @Html.HiddenFor(model => model.ChargeToPatient, new { @id = "hdnChargeToPatient" })
            @Html.HiddenFor(model => model.ServiceNames, new { @id = "hdnServices" })


            @Html.HiddenFor(model => model.Address, new { @id = "hdnAddress" })

            @Html.HiddenFor(model => model.QuickBloxId)

            <div class="form-group">
                <label>@CaregiverLite.Views.Resources.CareGiver.TableHeaderName</label>
                @Html.ValidationMessageFor(model => model.Name)
                @Html.TextBoxFor(model => model.Name, new { @type = "text", @maxlength = "100", @placeholder = @CaregiverLite.Views.Resources.CareGiver.PlaceHolderName, @class = "form-control",
               @onkeypress = "javascript:return isCharacter(event)"
           })
            </div>
            <div class="form-group">
                <label>@CaregiverLite.Views.Resources.CareGiver.LabelHeaderServices</label>
                @Html.ValidationMessageFor(model => model.ServiceNames)
                <div class="form-group">
                    @Html.DropDownList("ddlService", new MultiSelectList(@ViewBag.ServiceList, "ServiceId", "ServiceName"), new { @multiple = "multiple", @class = "chosen-select" })
                    @Html.HiddenFor(model => model.ServiceNames, new { @id = "hdnServices" })
                </div>
            </div>
            <div class="form-group">
                <label>@CaregiverLite.Views.Resources.CareGiver.TableHeaderEmail</label>
                @Html.ValidationMessageFor(model => model.Email)
                @Html.TextBoxFor(model => model.Email, new { @type = "email", @maxlength = "100", @placeholder = @CaregiverLite.Views.Resources.CareGiver.PlaceHolderEmail, @class = "form-control" })
            </div>
            <div class="form-group">
                <label>@CaregiverLite.Views.Resources.CareGiver.TableHeaderUserName</label>
                @Html.ValidationMessageFor(model => model.Username)
                @Html.TextBoxFor(model => model.Username, new { @type = "text", @maxlength = "256", @placeholder = @CaregiverLite.Views.Resources.CareGiver.PlaceHolderUserName, @class = "form-control" })
            </div>
            <div class="form-group">
                <label>@CaregiverLite.Views.Resources.CareGiver.TableHeaderStreet</label>
                @Html.ValidationMessageFor(model => model.Street)
                @Html.TextBoxFor(model => model.Street, new { @type = "text", @placeholder = @CaregiverLite.Views.Resources.CareGiver.PlaceHolderStreet, @class = "form-control", @onchange = "GetLanLat()" })
            </div>
            <div class="form-group">
                <label>@CaregiverLite.Views.Resources.CareGiver.TableHeaderCity</label>
                @Html.ValidationMessageFor(model => model.City)
                @Html.TextBoxFor(model => model.City, new { @type = "text", @placeholder = @CaregiverLite.Views.Resources.CareGiver.PlaceHolderCity, @class = "form-control" ,@onchange = "GetLanLat()" })
            </div>
            <div class="form-group">
                <label>@CaregiverLite.Views.Resources.CareGiver.TableHeaderState</label>
                @Html.ValidationMessageFor(model => model.State)
                @Html.TextBoxFor(model => model.State, new { @type = "text", @placeholder = @CaregiverLite.Views.Resources.CareGiver.PlaceHolderState, @class = "form-control", @onchange = "GetLanLat()" })
            </div>
            <div class="form-group">
                <label>@CaregiverLite.Views.Resources.CareGiver.TableHeaderZipCode</label>
                @Html.ValidationMessageFor(model => model.ZipCode)
                @Html.TextBoxFor(model => model.ZipCode, new { @type = "text", @maxlength = "10", @placeholder = @CaregiverLite.Views.Resources.CareGiver.PlaceHolderZipCode, @class = "form-control", @onchange = "GetLanLat()" })
            </div>
        </div>
        <div class="col-md-6">
            <div class="form-group">
                <label>@CaregiverLite.Views.Resources.CareGiver.TableHeaderEducation</label>
                @Html.ValidationMessageFor(model => model.Education)
                @Html.TextBoxFor(model => model.Education, new { @type = "text", @placeholder = @CaregiverLite.Views.Resources.CareGiver.PlaceHolderEducation, @class = "form-control" })
            </div>
            <div class="form-group">
                <label for="exampleInputFile">@CaregiverLite.Views.Resources.CareGiver.LabelPhotoUpload</label>
                @Html.ValidationMessageFor(model => model.ProfileImage)
                @Html.HiddenFor(model => model.ProfileImage, new { @id = "hdnProfileImage" })
                @Html.TextBoxFor(model => model.ProfileImageFile, new { @type = "file", @class = "form-control", @accept = "image/*" })
                @*<input type="file" name="ProfileImageFile" id="ProfileImageFile" /><br><br>*@
            </div>
            <div class="form-group">
                <label for="exampleInputFile">Video Upload</label>
                @Html.ValidationMessageFor(model => model.ProfileVideo)
                @Html.HiddenFor(model => model.ProfileVideo)
                @Html.TextBoxFor(model => model.ProfileVideoFile, new { @type = "file", @class = "form-control file_div", @accept = "video/*", @id = "EditProfileImageFile" })
            </div>
            @*<div class="form-group">
                <label>@CaregiverLite.Views.Resources.CareGiver.TableHeaderHourRate</label>
                @Html.ValidationMessageFor(model => model.HoursRate)
                <div class="input-group" style="width:100%">
                    <span class="input-group-addon">$</span>
                    @Html.TextBoxFor(model => model.HoursRate, new { @type = "text", @maxlength = "6", @onkeypress = "return isNumberAndDot(event)", @placeholder = @CaregiverLite.Views.Resources.CareGiver.PlaceHolderHourRate, @class = "form-control" })
                </div>
            </div>
            <div class="form-group">
                <label>To be charged to patient</label>
                @Html.ValidationMessageFor(model => model.ChargeToPatient)
                <div class="input-group" style="width:100%">
                    <span class="input-group-addon">$</span>
                    @Html.TextBoxFor(model => model.ChargeToPatient, new { @type = "text", @maxlength = "6", @onkeypress = "return isNumberAndDot(event)", @placeholder = "Enter To be charged to patient", @class = "form-control" })
                </div>
            </div>*@
            <div class="form-group">
                <label>@CaregiverLite.Views.Resources.CareGiver.TableHeaderPhone</label>
                @Html.ValidationMessageFor(model => model.Phone)
                <input type="text" style="display:none" />
                @Html.TextBoxFor(model => model.Phone, new { @type = "text", @class = "form-control" , autocomplete = "off", @maxlength = "100", @onkeypress = "return isNumber(event)", @placeholder = @CaregiverLite.Views.Resources.CareGiver.PlaceHolderPhone})
               
            </div>
            <div class="form-group">
                <label>@CaregiverLite.Views.Resources.CareGiver.TableHeaderPassword</label>
                @Html.ValidationMessageFor(model => model.Password)
                <input type="password" style="display:none" />
                @Html.TextBoxFor(model => model.Password, new { @type = "password", @class = "form-control", autocomplete = "off", @maxlength = "256", @placeholder = @CaregiverLite.Views.Resources.CareGiver.PlaceHolderPassword })
            </div>
            <div class="form-group">
                <label class="control-label">@CaregiverLite.Views.Resources.CareGiver.LabelHeaderServiceRadius</label>
                @Html.ValidationMessageFor(model => model.ServiceRadius)
                @Html.HiddenFor(model => model.Latitude)
                @Html.HiddenFor(model => model.Longitude)
                <div style="padding:7px 0;" id="radiobutton">
                    @*<label class="radio-inline">
                            @Html.RadioButtonFor(model => model.ServiceRadius, "15", new { @value = "15", @type = "radio", @class = "radio-inline", @name = "inlineCheckbox" }) 15 Miles
                        </label>
                        <label class="radio-inline">
                            @Html.RadioButtonFor(model => model.ServiceRadius, "30", new { @value = "30", @type = "radio", @class = "radio-inline", @name = "inlineCheckbox" }) 30 Miles
                        </label>
                        <label class="radio-inline">
                            @Html.RadioButtonFor(model => model.ServiceRadius, "70", new { @value = "70", @type = "radio", @class = "radio-inline", @name = "inlineCheckbox" }) 70 Miles
                        </label>*@

                    @Html.DropDownListFor(model => model.ServiceRadius, ViewData["Radious"] as List<SelectListItem>, "Select service radius", new { @class = "form-control" })
                </div>
            </div>

            <div class="form-group">
                <label class="control-label">Office</label>
                <span style="color:red;">*</span>
                @Html.ValidationMessageFor(model => Model.OfficeId)
                @*@Html.DropDownList("OfficeId", (SelectList)ViewBag.OfficeDropDownList, "Select Office", new { @class = "form-control" })*@
                @Html.DropDownList("OfficeId", (System.Web.Mvc.SelectList)ViewBag.lstOffice,"Select Office", new { @class = "form-control" })
            </div>

            <div>
                @Html.HiddenFor(model => model.TimezoneOffset, new { @id = "hdnTimezoneOffset" })
                @Html.HiddenFor(model => model.TimezoneId, new { @id = "hdntimeZoneId" })
                @Html.HiddenFor(model => model.TimezonePostfix, new { @id = "hdnTimezonePostfix" })
            </div>
        </div>
        <div class="col-md-12">
            <button type="button" onclick="Addnew()" class="btn btn-sm btn-primary pull-right">@CaregiverLite.Views.Resources.CareGiver.ButtonAddNew</button>
            <div class="clearfix"></div>
        </div>
    }
    <input type="hidden" id="hdndstOffset" />
    <input type="hidden" id="hdnrawOffset" />
    <input type="hidden" id="hdntimeZoneFullName" />
</div>
<script src="~/Scripts/jquery.unobtrusive-ajax.js"></script>
<script type="text/javascript">
    var latitude;
    var longitude;
    
    $("#Phone").on("paste change", function () {

        if ($('#Phone').val() != $('#Phone').val().replace(/[^\d]/g, "")) {
            var number = $('#Phone').val().replace(/[^\d]/g, "");
            $('#Phone').val(number);
        }
    });
    
    $.validator.setDefaults({
        ignore: [],
    });
    $(document).ready(function () {
        $("#loading").show();

     //   $("#hdnAddress").val('dumy');
       
        var form = $("#fmAddCareGiver").closest("form");
        form.removeData('validator');
        form.removeData('unobtrusiveValidation');
        $.validator.unobtrusive.parse(form);

        var config = {
            '.chosen-select': {},
            '.chosen-select-deselect': { allow_single_deselect: true },
            '.chosen-select-no-single': { disable_search_threshold: 10 },
            '.chosen-select-no-results': { no_results_text: 'Oops, nothing found!' },
            '.chosen-select-width': { width: "95%" }
        }
        for (var selector in config) {
            $(selector).chosen(config[selector]);

        }
        $("#loading").hide();
    });

    function Addnew() {

        var Email = $("#Email").val();

        //debugger; 
        $('#loading').show();

        $("#dvError3").hide();
        var selectedValues = "";

        $("#ddlService :selected").each(function () {
            selectedValues += $(this).val() + ",";
        });

        $("#hdnServices").val(selectedValues);

        $("#hdnHoursRate").val(20);
        $("#hdnChargeToPatient").val(20);
  

        if ($("#ProfileImageFile").val() != null && $("#ProfileImageFile").val() != "") {
            $("#hdnProfileImage").val("Value");

        }
        //if (!GetLanLat())
        //{
        //    $('#loading').hide();
        //    return false;
        //}

        var result = CheckUserName();
        if (result == false) {
            $("#dvError3").css("display", "");
            $("#lblError3").html("User Name is already exists");
            $('#loading').hide();
            return false;
        }

        var result1 = CheckEmail();
        if (result1 == false) {
            $("#dvError3").css("display", "");
            $("#lblError3").html("Email is already exists");
            $('#loading').hide();
            return false;
        }
        if ($(".radio-inline").find(":checked").val() == undefined) {
            $("#radiobutton").css("padding", "20px 0px");
        }
        else {
            $("#radiobutton").css("padding", "7px 0px");
        }


            if (!GetLanLat()) {
                $('#loading').hide();
                return false;
            }
     
        if ($("#fmAddCareGiver").valid()) {

          //  RegisterCareGiverQB(Email);
        $("#fmAddCareGiver").submit();
        }
        else {
            $('#loading').hide();
        }
    }

    $(":radio").click(function (event) {
        $("#radiobutton").css("padding", "7px 0px");
    });

    function isNumber(evt) {
        evt = (evt) ? evt : window.event;
        var charCode = (evt.which) ? evt.which : evt.keyCode;
        if (charCode > 31 && (charCode < 48 || charCode > 57)) {
            toastr.error("Please Enter Only Character.")
            return false;
            
        }
        return true;
    }

    function isCharacter(evt) {
        evt = (evt) ? evt : window.event;
        var charCode = (evt.which) ? evt.which : evt.keyCode;
        if (charCode > 48 && charCode < 57) {
            toastr.error("Please Enter Only Character.")
            return false;
        }
        return true;
    }

    function GetFullAddress()
    {

        var Street = $("#Street").val();

        var City = $("#City").val();

        var State = $("#State").val();

        var FullAddress = Street + ',' + City + ',' + State;

        $("#hdnAddress").val(FullAddress);
    }

    function GetLanLat() {

        debugger;
        //    var Address = $("#Address").val();
        var Street = $("#Street").val().replace('&', '-');
        Street = Street.replace(/,\s*$/, "");
        //  var Address =$("#Address").val().replace('&','-');

        var City = $("#City").val();
        City = City.replace(/,\s*$/, "");

        var State = $("#State").val();
        State = State.replace(/,\s*$/, "");

        var FullAddress = Street + ', ' + City + ', ' + State;

        $("#hdnAddress").val(FullAddress);

        FullAddress = FullAddress.replace('&', '-');

        var Pincode = $("#ZipCode").val();
        if (Street !== '') {
            if (City !== '') {
                if (State !== '') {
        var flag = true;
        $.ajax({
            type: "GET",
            url: "https://maps.google.com/maps/api/geocode/json",
            data: "address=" + FullAddress + ",  zip code=" + Pincode + "&key=AIzaSyDCQgMe2fLgmaF9GDvxF61wsIXnktEBKhg",
            async: false,
            contentType: "text/plain; charset=utf-8",
            dataType: "json",
            success: function (result) {
                if (result["status"] == "OK") {
                    $("#Latitude").val(result["results"][0]["geometry"]["location"]["lat"]);
                    $("#Longitude").val(result["results"][0]["geometry"]["location"]["lng"]);
                    var Latitude = result["results"][0]["geometry"]["location"]["lat"];
                    var Longitude = result["results"][0]["geometry"]["location"]["lng"];
                    var today = new Date();
                    //var UTCDate = today.toUTCString();
                    //var UtcNow = Math.floor(today.getTime() / 1000);
                    var timestamp = today.getTime() / 1000 + today.getTimezoneOffset() * 60;
                    $.ajax({
                        type: "GET",
                        url: "https://maps.googleapis.com/maps/api/timezone/json?location=" + Latitude + "," + Longitude + "&timestamp=" + timestamp + "&sensor=false",
                        async: false,
                        contentType: "text/plain; charset=utf-8",
                        dataType: "json",
                        success: function (data, result) {
                            if (data["status"] == "OK" && result == "success") {
                                $("#hdndstOffset").val(data.dstOffset);
                                $("#hdnrawOffset").val(data.rawOffset);
                                $("#hdntimeZoneFullName").val(data.timeZoneName);
                                $("#hdntimeZoneId").val(data.timeZoneId);

                                var str = data.timeZoneName;
                                var splitString = str.split(" ");
                                var abbr = "";
                                for (i = 0; i < splitString.length; i++) {
                                    abbr += splitString[i].charAt(0);
                                }
                                $("#hdnTimezonePostfix").val(abbr);
                                var TimeZoneOffset = data.dstOffset + data.rawOffset;
                                TimeZoneOffset = TimeZoneOffset < 0 ? "-" + Math.abs(TimeZoneOffset) / 60 : "+" + Math.abs(TimeZoneOffset) / 60;
                                $("#hdnTimezoneOffset").val(parseInt(TimeZoneOffset));
                                return true;
                            }
                        }
                    });
                }
                else if (result.status === "ZERO_RESULTS") {
                    toastr.error('Please enter valid street/city/state with valid zip code');
                    flag = false;
                }
            }
        });
                } else {
                    toastr.error('Please Enter State');
                }
            }
            else {
                toastr.error('Please Enter City');
            }
        } else {
            toastr.error('Please Enter Street');
        }
        //----------End Pincode+Address----------------
        return flag;
    }

    $('#ddlService').val(2);
    $('#ddlService').trigger("chosen:updated");

    function CheckUserName() {
        var url = INITURL + '/CareGiver/IsUserNameExists';
        var result;
        $.ajax({
            url: url,
            data: { Username: $("#Username").val(), UserId: $("#UserId").val() },
            cache: false,
            async: false,
            type: 'POST',
            success: function (data) {
                result = data;
            },
            error: function (reponse) {
                alert("error : " + reponse);
            }
        });
        return result;
    }

    function CheckEmail() {
        var url = INITURL + '/CareGiver/IsEmailExists';
        var result;
        $.ajax({
            url: url,
            data: { Email: $("#Email").val(), UserId: $("#UserId").val() },
            cache: false,
            async: false,
            type: 'POST',
            success: function (data) {
                result = data;
            },
            error: function (reponse) {
                alert("error : " + reponse);
            }
        });
        return result;
    }

    function divClose() {
        $("#dvError3").css("display", "none");
    }

    function isNumberAndDot(evt) {
        evt = (evt) ? evt : window.event;
        var charCode = (evt.which) ? evt.which : evt.keyCode;
        if (charCode > 31 && (charCode < 48 || charCode > 57) && charCode != 46) {
            return false;
        }
        return true;
    }


